#Title Stan's Previously Owned Vessels
#Composer M. Land / P. McConnell / C. Bajakian
#Author SMI pipeline
#Timer 118
#ZenLen 192

; Echo â€” tame defaults. Per-song MML can override if needed.
#EchoLength 32
#EchoFeedback -86
#EchoVolume 36
#FirFilter 64 63 0 0 0 0 0 0

; Melodic instruments â€” one entry per SPC voice role.
@0 mt32_p8
@1 mt32_p88
@2 mt32_p71
@3 mt32_p74
@4 mt32_organ
@5 mt32_p88
@6 mt32_p88_low
@7 mt32_p74_low

; Drum instruments â€” one @name per unique drum referenced by
; the arrangement. Override names via plan["instruments"]["drums"].
