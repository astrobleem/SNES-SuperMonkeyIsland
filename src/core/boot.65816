	.include "src/core/boot.h"


.Section "Main Code"
core.boot.init:
	sep #$20

	lda #RAM
	pha
	plb
	rep #$31
	lda.w #ZP
	tcd

	lda.w #$1fff
	tcs

	jsr ClearRegisters

	sep #$20

	;clear OopObjRam + stack (SNES DRAM can power-on to $55, causing wild jumps)
	lda.b #0
	ldy.w #$1FC0
	ldx.w #$0000
	jsr ClearWRAM

	lda.b #0		;clear zero page
	ldy.w #kernelEnd-kernelStart
	ldx.w #ZP
	jsr ClearWRAM

	lda.b #0		;clear variable buffer
	ldy.w #VARS_end-VARS
	ldx.w #VARS
	jsr ClearWRAM

	rep #$31
	lda.w #STACK
	tcs

	jsr core.wram.init
	jsr core.vram.init
	jsr core.cgram.init
	jsr core.random.init
	jsr core.dma_channel.init
	jsr core.input.init
    jsr core.nmi.init
    jsr core.irq.init
	jsr core.dma.init
	jsr core.oam.init
	jsr core.screen.init
	jsr core.object.init
    jsr core.persistency.init

	;initialize Terrific Audio Driver (requires interrupts disabled, S-SMP at IPL)
	sep #$20
	jsl Tad_Init
	rep #$31

	jsl scummvm.zeroExtraWram

	rep #$31
	NEW Script.CLS.PTR oopCreateNoPtr main

;tier 0 main loop starts here:
core.boot.mainLoop:
    jsr core.nmi.waitFrame
	jsr core.oam.play
	jsr core.object.play

	;process Terrific Audio Driver (once per frame, after game logic)
	sep #$20
	jsl Tad_Process
	rep #$20

	bra core.boot.mainLoop
.ends

;null guard: OOP dispatcher uses $0000 as "no method" sentinel.
;Prevent any real code from landing at address $0000.
.bank 0 slot 0
.org 0
.section "null_guard" force
  brk
  brk
.ends

.bank 0 slot 0
.org BANK0_LOROM
.section "IRQ Bootstrap" force

NmiHandler:
	jml core.nmi.play

EmptyHandler:
	rti

Stop:
	jml StopJmp
StopJmp:
	rep #$30
	;save crash-site registers FIRST (jml preserves A/X/Y/D from crash site)
	sta.l GLOBAL.crashA
	txa
	sta.l GLOBAL.crashX
	tya
	sta.l GLOBAL.crashY
	tdc
	sta.l GLOBAL.crashDP
	;read kernel ZP tmp (OopHandlerExecute's cached method address)
	lda.w #ZP
	tcd
	lda tmp
	sta.l GLOBAL.crashTmp
	;BRK native mode stack: [SP+1]=P, [SP+2..3]=PC+2, [SP+4]=PB
	;save crash-site info before error handler clobbers the stack
	tsc
	sta.l GLOBAL.crashSP
	lda 2,s
	sta.l GLOBAL.crashPC
	sep #$20
	lda 4,s
	sta.l GLOBAL.crashPB
	lda 1,s
	sta.l GLOBAL.crashP
	rep #$31
    TRIGGER_ERROR E_Brk

StopCop:
	jml StopCopJmp

StopCopJmp:
	rep #$31
    TRIGGER_ERROR E_Cop


Boot:
	sei
	clc
	xce
	phk
	plb
	sep #$20
	stz NMITIMEN		;disable timers, NMI,and auto-joyread
	stz MEMSEL		;SA-1 mode: no FastROM
	jsl sa1.init		;initialize SA-1 co-processor
	jml core.boot.init

IrqHookUp:
	jml core.irq.play

.ends

.bank 0 slot 0
.section "SA-1 init" superfree
sa1.init:
  php
  sep #$20
  .ACCU 8

  ; Disable I-RAM write protection for both CPUs
  ; SIWP/CIWP: bit=1 PROTECTS that block. $00 = no protection = both can write.
  lda #$00
  sta.l SIWP              ; $2229 — allow SA-1 to write I-RAM
  sta.l CIWP              ; $222A — allow SNES CPU to write I-RAM

  ; Enable BW-RAM writes for both CPUs
  lda #SBWE_SNES_BWRAM_WRITE_ENABLE
  sta.l SBWE              ; $2226
  lda #CBWE_SA1_BWRAM_WRITE_ENABLE
  sta.l CBWE              ; $2227

  ; Set SA-1 reset vector to LoROM trampoline
  ; SA-1 starts at PBR=$00, so CRV must be a LoROM-accessible address.
  ; $FF9C = LoROM addr of Sa1CpuTrampoline (file offset $7F9C).
  rep #$20
  .ACCU 16
  lda #$FF9C
  sta.l CRV               ; $2203-$2204

  ; Set SA-1 IRQ vector
  lda #sa1.irqHandler
  sta.l CIV               ; $2207-$2208

  ; Un-reset SA-1 (clear bit 5 of CCNT)
  sep #$20
  .ACCU 8
  lda #0
  sta.l CCNT              ; $2200 — bit 5 = 0 means run

  plp
  rtl
.ends

;wla dx is too fucking stupid to properly allocate the memory it later needs for its own header creation feature, so we have to create it manually:

;--- LoROM header + vectors at $7FB0-$7FFF (one contiguous forced section) ---
;This area must be a single forced section to prevent WLA-DX from filling
;$7FB0-$7FFF with free/superfree sections (which corrupts data tables).
;Some flashcarts read the header at file offset $7FB0 for cart detection.
;
;IMPORTANT: This MUST be a single contiguous forced section covering the
;entire $7FB0-$7FFF range. Three separate forced sections left gaps that
;WLA-DX's linker would fill with free/superfree sections, silently
;overwriting data tables (OopClassLut, ClearWramBytePatterns, etc.) and
;causing palette corruption + black bars on screen.
.bank 0 slot 0
.org $7f9c
.section "lorom header and vectors" force
  ;--- SA-1 CPU reset trampoline at $7F9C (LoROM addr $FF9C) ---
  ;SA-1 CPU also starts at PBR=$00 via CRV. Needs LoROM trampoline.
Sa1CpuTrampoline:
  jml sa1.entry
  ;--- SNES CPU LoROM reset trampoline at $7FA0 (LoROM addr $FFA0) ---
  ;In SA-1 mode, SNES CPU reads RESET vector via LoROM mapping.
  ;LoROM address $FFA0 = file offset $7FA0. This trampoline immediately
  ;long-jumps to Boot in HiROM space ($C0:xxxx) where the real code lives.
Sa1ResetTrampoline:
  sei
  clc
  xce
  jml Boot
  ;--- NMI/IRQ trampolines at $7FA7/$7FAB (LoROM $FFA7/$FFAB) ---
Sa1NmiTrampoline:
  jml NmiHandler
Sa1IrqTrampoline:
  jml IrqHookUp
  ;--- 1 byte padding to $7FB0 ---
  .db 0
  ;--- header at $7FB0-$7FDF (48 bytes) ---
  .db "CD"		;maker code
  .db "AMIE"		;game code
  .dsb 7 0		;reserved
  .db 0		;expansion RAM size
  .db 0		;special version
  .db 0		;sub-cartridge type
  .db "SUPER MONKEY ISLAND  "
  .db $23	;mapping (SA-1)
  .db $35	;cartridgetype (SA-1+RAM+Battery)
  .db 10	;romsize
  .db 3	;sramsize
  .db 1	;country
  .db $33	;licenseecode
  .db 2	;version
  .dw $F9D8
  .dw $0627
  ;--- padding $7FE0-$7FE3 (4 bytes) ---
  .dsb 4 0
  ;--- native vectors at $7FE4-$7FEF (12 bytes) ---
  ;In SA-1 mode, NMI/IRQ set PBR=$00 and read vectors via LoROM.
  ;Trampolines at LoROM $FFA7/$FFAB jml to real handlers in HiROM.
  .dw StopCop
  .dw Stop
  .dw EmptyHandler
  .dw $FFA7		;NMI → Sa1NmiTrampoline (jml NmiHandler)
  .dw EmptyHandler
  .dw $FFAB		;IRQ → Sa1IrqTrampoline (jml IrqHookUp)
  ;--- padding $7FF0-$7FF3 (4 bytes) ---
  .dsb 4 0
  ;--- emu vectors at $7FF4-$7FFF (12 bytes) ---
  .dw StopCop
  .dw EmptyHandler
  .dw EmptyHandler
  .dw EmptyHandler
  .dw $FFA0		;RESET → SA-1 LoROM trampoline (file offset $7FA0)
  .dw EmptyHandler
.ends

;--- HiROM header at $FFB0 (primary, used by SNES CPU) ---
;extended header ($FFB0-$FFBF) — active when licensee code = $33
.org $ffb0
.section "extended header hack" force
  .db "CD"		;maker code ($FFB0-$FFB1)
  .db "AMIE"		;game code ($FFB2-$FFB5) — serial SHVC-AMIE
  .dsb 7 0		;reserved ($FFB6-$FFBC)
  .db 0		;expansion RAM size ($FFBD)
  .db 0		;special version ($FFBE)
  .db 0		;sub-cartridge type ($FFBF)
.ends

.org $ffc0
.section "header hack" force
  .db "SUPER MONKEY ISLAND  "
  .db $23	;mapping (SA-1)
  .db $35	;cartridgetype (SA-1+RAM+Battery)
  .db 10	;romsize
  .db 3	;sramsize (8KB — max that works with FXPak MSU-1)
  .db 1	;country (1=USA/NTSC)
  .db $33	;licenseecode ($33=extended header active)
  .db 2	;version
  .dw $F9D8
  .dw $0627
.ends


.bank 0 slot 0
.org $ffe4
.section "native vector hack" force
	.dw StopCop
	.dw Stop
	.dw EmptyHandler
	.dw NmiHandler
	.dw EmptyHandler
	.dw IrqHookUp
.ends

.org $fff4
.section "emu vector hack" force
	.dw StopCop
	.dw EmptyHandler
	.dw EmptyHandler
	.dw EmptyHandler
	.dw Boot
	.dw EmptyHandler
.ends
