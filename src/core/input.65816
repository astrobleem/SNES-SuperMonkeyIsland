.include "src/core/input.h"
.section "core.input"

core.input.init:
  php
  rep #$31
  sep #$20
  stz.w CheckJoypadMode

  ldx #INPUT.DEVICE.ID.0
  jsr core.input.reset
  plp
  rts

/**
* @param a<int,16bit> button mask
* @param x<int,8bit> input device id
*/
core.input.setMask:
  php
  rep #$31
  jsr _getInputDevicePointer
  sta.w inputDevice.mask,x
  plp
  rts

/**
* @param x<int,8bit> input device id
*/
core.input.get.press:
  php
  rep #$31
  jsr _getInputDevicePointer
  lda.w inputDevice.press,x
  and.w inputDevice.mask,x
  plp
  rts

/**
* @param x<int,8bit> input device id
*/
core.input.get.trigger:
  php
  rep #$31
  jsr _getInputDevicePointer
  lda.w inputDevice.trigger,x
  and.w inputDevice.mask,x
  plp
  rts

/**
* @param x<int,8bit> input device id
* @return x<int,16bit> input device pointer
*/
_getInputDevicePointer:
  php
  rep #$31
  pha
  txa
  and.w #$ff
  cmp #INPUT.DEVICE.ID.MAX
  bcc +
	pha
	TRIGGER_ERROR E_BadInputDevice

+
  .ACCU 16
  .INDEX 16
  asl a
  asl a
  asl a
  tax
  pla
  plp
  rts

/**
* @param x<int,8bit> input device id
*/
core.input.reset:
  php
  rep #$31
  jsr core.input.resetMask
  stz.w inputDevice.trigger,x
  stz.w inputDevice.old,x
  stz.w inputDevice.press,x
  plp
  rts

/**
* @param x<int,8bit> input device id
*/
core.input.resetMask:
  php
  rep #$31
  lda #$ffff
  jsr core.input.setMask
  plp
  rts

core.input.refresh:
	php
	rep #$31
	lda.w CheckJoypadMode
	and #%11
	asl a
	tax
	sep #$20
	jsr (CheckJoypadModeLUT,x)
	plp
	rts


CheckJoypadModeLUT:
	.dw	CheckJoypadSinglePlayer
	.dw CheckJoypadVoid
	.dw CheckJoypadVoid
	.dw CheckJoypadVoid
	
CheckJoypadVoid:
	rts

;fast joy1 checker. check this late in nmi so we don't have to wait for auto joypad read to finish:
CheckJoypadSinglePlayer:
	.ACCU 8
	.INDEX 16
	  lda.l HVBJOY
	  bit #HVBJOY_AUTO_JOY_STATUS
	  bne CheckJoypadSinglePlayer

	ldx #INPUT.DEVICE.ID.0
	jsr _checkInputDevice
	jsr _checkMouse
	rts

_checkInputDevice:
	rep #$30
	jsr _getInputDevicePointer
	lda.w inputDevice.old,x	;get last button state
	eor #$ffff			;xor
	sta.w inputDevice.trigger,x
	lda.l JOY1L
	sta.w inputDevice.press,x
	sta.w inputDevice.old,x
	and.w inputDevice.trigger,x	;and and only get buttons that werent pressed last frame
	sta.w inputDevice.trigger,x	;store in joypad buffer
	rts

;----------------------------------------------------------------------
; Mouse read routine — detect SNES Mouse on port 1, read displacement,
; remap buttons into joypad format, manage sensitivity.
; Entry: A=16bit, X/Y=16bit (from _checkInputDevice)
;----------------------------------------------------------------------
_checkMouse:
  .ACCU 16
  .INDEX 16
  ; Check mouse ID nibble from auto-read (bits 3-0 of JOY1L)
  lda.l JOY1L
  and #$000F
  cmp #$0001
  beq _cm.isMouse

  ; No mouse — clear state
  stz.w mouseDetected
  stz.w mouseDeltaX
  stz.w mouseDeltaY
  stz.w mouseButtons
  stz.w mouseOldButtons
  rts

_cm.isMouse:
  .ACCU 16
  .INDEX 16
  ;--- Read displacement (bits 17-32 via $4016) ---
  ; MUST happen before any $4016 writes (sensitivity strobe)
  rep #$20
  .ACCU 16
  stz.w mouseDeltaY             ; zero high bytes for later 16-bit read
  stz.w mouseDeltaX
  sep #$20
  .ACCU 8

  ; Read Y displacement (8 serial bits: direction + 7-bit magnitude)
  ldy #8
  lda #0
_cm.readY:
  .ACCU 8
  .INDEX 16
  pha
  lda.l JOYSER0
  lsr a                         ; serial bit 0 -> carry
  pla
  rol a                         ; carry -> result
  dey
  bne _cm.readY
  sta.w mouseDeltaY             ; 8-bit store (high byte already zeroed)

  ; Read X displacement (8 serial bits)
  ldy #8
  lda #0
_cm.readX:
  .ACCU 8
  .INDEX 16
  pha
  lda.l JOYSER0
  lsr a
  pla
  rol a
  dey
  bne _cm.readX
  sta.w mouseDeltaX             ; 8-bit store

  ;--- Convert sign+magnitude to signed 16-bit ---
  rep #$20
  .ACCU 16

  ; Y delta: direction 1=up(negative), 0=down(positive)
  lda.w mouseDeltaY
  bit #$0080
  beq _cm.yPos
  and #$007F
  beq _cm.yDone                 ; zero magnitude, skip negation
  eor #$FFFF
  inc a                         ; two's complement negate
  bra _cm.yDone
_cm.yPos:
  .ACCU 16
  and #$007F
_cm.yDone:
  .ACCU 16
  sta.w mouseDeltaY

  ; X delta: direction 1=left(negative), 0=right(positive)
  lda.w mouseDeltaX
  bit #$0080
  beq _cm.xPos
  and #$007F
  beq _cm.xDone
  eor #$FFFF
  inc a
  bra _cm.xDone
_cm.xPos:
  .ACCU 16
  and #$007F
_cm.xDone:
  .ACCU 16
  sta.w mouseDeltaX

  ;--- Extract and remap buttons ---
  ; JOY1L bit 7 = right button, bit 6 = left button
  lda.l JOY1L
  and #$00C0
  sta.w mouseButtons

  ; Remap: left($0040) -> JOY_BUTTON_A($0080), right($0080) -> JOY_BUTTON_B($8000)
  ldx #0
  bit #$0040                    ; left button? (bit doesn't modify A)
  beq _cm.noLeft
  ldx #JOY_BUTTON_A
_cm.noLeft:
  .ACCU 16
  .INDEX 16
  lda.w mouseButtons
  bit #$0080                    ; right button?
  beq _cm.noRight
  txa
  ora #JOY_BUTTON_B
  tax
_cm.noRight:
  .ACCU 16
  .INDEX 16
  ; Store remapped buttons and compute trigger
  stx.w inputDevice.press
  txa
  pha                           ; save current remapped buttons
  lda.w mouseOldButtons
  eor #$FFFF
  and 1,s                       ; ~old & current = newly pressed
  sta.w inputDevice.trigger
  pla
  sta.w mouseOldButtons         ; save for next frame
  sta.w inputDevice.old         ; sync

  ;--- Sensitivity handling ---
  lda.w mouseDetected
  bne _cm.wasDetected

  ; First detection — mark active, cycle sensitivity once (required by Nintendo)
  lda #$0001
  sta.w mouseDetected
  bra _cm.cycleSens

_cm.wasDetected:
  .ACCU 16
  ; Check if sensitivity is already 1 (normal)
  lda.l JOY1L
  and #$0030                    ; bits 5-4 = sensitivity
  cmp #$0010                    ; sensitivity == 1?
  beq _cm.done

_cm.cycleSens:
  .ACCU 16
  ; Cycle sensitivity: STB=1, CLK, STB=0
  sep #$20
  .ACCU 8
  lda #$01
  sta.l JOYSER0                 ; STB=1
  lda.l JOYSER0                 ; CLK while STB=1 -> increments sensitivity
  lda #$00
  sta.l JOYSER0                 ; STB=0
  rep #$20
  .ACCU 16

_cm.done:
  .ACCU 16
  rts

.ends

;----------------------------------------------------------------------
; Mouse BIOS ID string (required by emulators and BIOS detection)
;----------------------------------------------------------------------
.section "MouseBiosString" superfree
  .db "START OF MOUSE BIOS"
.ends

