;nmi handler — processes VRAM DMA queue, scroll updates, OAM transfer
.include "src/core/nmi.h"

;tile cache staging defines (must match room_scroll.h)
.define SCROLL_TILE_STAGE_WRAM   $7F4800
.define SCROLL_NMI_SLOTS_WRAM   $7F4C00

.section "nmi"

core.nmi.play:
	rep #$39
	pha
	phb
	phd
	phx
	phy
	lda.w #ZP
	tcd

	sep #$20
	lda #RAM
	pha
	plb

    lda.l RDNMI         ;reset nmi flag
	lda #0
	sta.l WRIO			;clear iobit

	; Lock CGRAM[$00] (backdrop) to $0000 every VBlank. The old cgramHdmaTable
	; scheme forced this at scanlines 137-143; without HDMA the backdrop shows
	; red during mountain fade frames if a script writes pal0 c0. Enforcing
	; black here matches the verb-area behavior baseline had.
	lda #$00
	sta.l CGADD
	lda #$00
	sta.l CGDATA
	sta.l CGDATA

	; Flush color-cycling updates to CGRAM (no-op when SCUMM.numCycles == 0)
	jsl scummvm.cycle.writeToCgram

	; Flush full CGRAM shadow if setPalColor dirtied it. DMA during VBlank
	; avoids the PPU race that caused cloud flicker on room 10.
	lda.w SCUMM.cgramDirty
	beq _nmi.noCgramFlush
	stz.w SCUMM.cgramDirty
	lda.b #$00
	sta.l CGADD                        ; start at CGRAM index 0
	lda.b #$00                         ; DMA mode: 1-reg, auto-inc
	sta.l DMAP7
	lda.b #$22                         ; B-bus: CGDATA ($2122)
	sta.l DMADEST7
	lda.b #$40                         ; BWRAM bank ($408000)
	sta.l DMASRC7B
	rep #$20
	lda.w #$8000                       ; BWRAM offset ($408000)
	sta.l DMASRC7L
	lda.w #256                         ; 128 colors x 2B
	sta.l DMALEN7L
	sep #$20
	lda.b #$80                         ; trigger DMA ch7
	sta.l MDMAEN
_nmi.noCgramFlush:

    lda.w GLOBAL.HDMA.CHANNEL.ENABLE        ;check which hdma channels need to be activated
    sta.l HDMAEN        ;set hdma channels and disable dma channel

	rep #$31
	inc.w FrameCounter
	lda.w window12Sel
	sta.l W12SEL
	lda.w window1Left
	sta.l W1L
	lda.w window2Left
	sta.l W2L
	lda.w windowBGLogic
	sta.l WBGLOG
	lda.w windowMainscreen
	sta.l TMW

    lda.w xScrollBG1
    sta.w GLOBALS.BUFFER.scroll.bg1.x
    lda.w yScrollBG1
    sta.w GLOBALS.BUFFER.scroll.bg1.y


	sep #$20
	lda.w windowObjSel
	sta.l WOBJSEL
	lda.w mosaicSetting
	sta.l MOSAIC

	lda.w ScreenMode		;set screenmode and bg sizes
	sta.l BGMODE
    sta.w GLOBAL.BUFFER.screenMode
	lda.w MainScreen		;setup main and subscreen
	sta.l TMAIN
    sta.w GLOBAL.BUFFER.mainScreen
	lda.w SubScreen		;setup main and subscreen
	sta.l TSUB
    sta.w GLOBAL.BUFFER.subScreen
	lda.w BGTilesVram12		;set offsets in vram for tiles
	sta.l BG12NBA			;of bg1 and bg2
    sta.w GLOBALS.BUFFER.bg12Tiles
	lda.w BGTilesVram34		;set offsets in vram for tiles
	sta.l BG34NBA			;of bg1 and bg2
	lda.w BG1TilemapVram	;set offset of bg1 tilemap in  vram
	sta.l BG1SC
    sta.w GLOBALS.BUFFER.bg1Tilemap
	lda.w BG2TilemapVram	;set offset of bg2 tilemap in  vram
	sta.l BG2SC
	lda.w BG3TilemapVram	;set offset of bg3 tilemap in  vram
	sta.l BG3SC
	lda.w BG4TilemapVram	;set offset of bg4 tilemap in  vram
	sta.l BG4SC

	lda.w colorAdditionSelect		;colour add/sub config
	sta.l CGWSEL

	lda.w CgadsubConfig
	sta.l CGADSUB
	lda.w FixedColourB
	and #COLDATA_INTENSITY
	ora #COLDATA_BLUE
	sta.l COLDATA
	lda.w FixedColourG
	and #COLDATA_INTENSITY
	ora #COLDATA_GREEN
	sta.l COLDATA
	lda.w FixedColourR
	and #COLDATA_INTENSITY
	ora #COLDATA_RED
	sta.l COLDATA

	lda.w xScrollBG1		;set bg1 h-offset
	sta.l BG1HOFS
	lda.w xScrollBG1&$ffff+1
	sta.l BG1HOFS
	lda.w yScrollBG1		;set bg1 v-offset
	sta.l BG1VOFS
	lda.w yScrollBG1&$ffff+1
	sta.l BG1VOFS
	lda.w xScrollBG2		;set bg2 h-offset
	sta.l BG2HOFS
	lda.w xScrollBG2&$ffff+1
	sta.l BG2HOFS
	lda.w yScrollBG2		;set bg2 v-offset
	sta.l BG2VOFS
	lda.w yScrollBG2&$ffff+1
	sta.l BG2VOFS
    lda.w xScrollBG3        ;set bg3 h-offset
    sta.l BG3HOFS
    lda.w xScrollBG3&$ffff+1
    sta.l BG3HOFS
    lda.w yScrollBG3        ;set bg3 v-offset
    sta.l BG3VOFS
    lda.w yScrollBG3&$ffff+1
    sta.l BG3VOFS

	;--- room scroll: write staged tile data to VRAM via DMA ch7 ---
	lda.w GLOBAL.room.nmiTileFlag
	beq _nmi.noTileWrite

	stz.w GLOBAL.room.nmiTileFlag

	lda.b #VMAIN_INCREMENT_MODE
	sta.l VMAIN

	rep #$20
	lda.w GLOBAL.room.nmiTileCount
	beq _nmi.noTileWrite2

	;--- DMA channel 7 static setup for tile data ---
	sep #$20
	.ACCU 8
	lda.b #$01                    ;A->B, increment A, 2-register write ($2118/$2119)
	sta.l DMAP7
	lda.b #$18                    ;B-bus target: VMDATAL
	sta.l DMADEST7
	lda.b #$7F                    ;source bank: $7F (SCROLL_TILE_STAGE_WRAM)
	sta.l DMASRC7B
	rep #$20
	.ACCU 16

	;X = VRAM address array offset, Y = staging buffer offset
	ldx #0
	ldy #0

_nmi.tileDmaLoop:
	.ACCU 16
	.INDEX 16
	;set VRAM destination address for this tile
	phx                           ;save addr offset (need X for long,x)
	lda.l SCROLL_NMI_SLOTS_WRAM,x
	sta.l VMADDL
	plx

	;set DMA source: low 16 bits of staging buffer + offset
	tya
	clc
	adc #SCROLL_TILE_STAGE_WRAM & $ffff
	sta.l DMASRC7L

	;set transfer length: 32 bytes (one 4bpp tile)
	lda #32
	sta.l DMALEN7L

	;trigger DMA channel 7
	sep #$20
	.ACCU 8
	lda.b #$80
	sta.l MDMAEN
	rep #$20
	.ACCU 16

	;advance offsets
	tya
	clc
	adc #32
	tay                           ;staging offset += 32
	inx
	inx                           ;VRAM addr array offset += 2

	;decrement tile count
	dec.w GLOBAL.room.nmiTileCount
	bne _nmi.tileDmaLoop

_nmi.noTileWrite2:
	.ACCU 16
	.INDEX 16
	sep #$20
_nmi.noTileWrite:
	.ACCU 8
	.INDEX 16

	;--- One-shot dialog font DMA (ExcFontTiles -> VRAM $A000) ---
	;Gated by SCUMM.dialogFontNmiPending flag; clears flag after DMA.
	;Uses DMA channel 7 — tile staging loop above is already finished.
	lda.w SCUMM.dialogFontNmiPending
	beq _nmi.noFontDma
	lda.w GLOBAL.room.nmiTileFlag
	bne _nmi.noFontDma

	stz.w SCUMM.dialogFontNmiPending

	lda.b #VMAIN_INCREMENT_MODE
	sta.l VMAIN
	rep #$20
	lda #$5000                        ;DIALOG_TILES_VRAM / 2 = word addr
	sta.l VMADDL
	sep #$20
	lda #DMAP_2_REG_WRITE_ONCE
	sta.l DMAP7
	lda #VMDATAL & $ff
	sta.l DMADEST7
	; ExcFontTiles lives at physical ROM $200638 (2-3MB range).
	; SA-1 EXB=4 maps $E0-$EF → 4-5MB, so `:ExcFontTiles` ($E0)
	; reads zeros. Temporarily remap EXB to 2 for the DMA.
	lda #2
	sta.l $2222                       ;EXB = 2 → $E0 = 2-3MB
	lda.b #:ExcFontTiles
	sta.l DMASRC7B
	rep #$20
	lda.w #ExcFontTiles
	sta.l DMASRC7L
	lda #ExcFontTiles.LEN
	sta.l DMALEN7L
	sep #$20
	lda #$80                          ;trigger DMA channel 7
	sta.l MDMAEN
	lda #4
	sta.l $2222                       ;EXB = 4 (restore)

_nmi.noFontDma:
	.ACCU 8
	.INDEX 16

	;--- One-shot verb font DMA (VerbFontTiles → VRAM word $4000 = byte $8000) ---
	;Gated by SCUMM.verbFontNmiPending flag; fires once after first processRoomChange.
	lda.w SCUMM.verbFontNmiPending
	beq _nmi.noVerbFontDma
	lda.w GLOBAL.room.nmiTileFlag
	bne _nmi.noVerbFontDma

	stz.w SCUMM.verbFontNmiPending

	lda.b #VMAIN_INCREMENT_MODE
	sta.l VMAIN
	rep #$20
	lda #$4000                        ;BG2 CHR base: word $4000 = byte $8000
	sta.l VMADDL
	sep #$20
	lda #DMAP_2_REG_WRITE_ONCE
	sta.l DMAP7
	lda #VMDATAL & $ff
	sta.l DMADEST7
	lda.b #:VerbFontTiles
	sta.l DMASRC7B
	rep #$20
	lda.w #VerbFontTiles
	sta.l DMASRC7L
	lda #VerbFontTiles.LEN
	sta.l DMALEN7L
	sep #$20
	lda #$80                          ;trigger DMA channel 7
	sta.l MDMAEN

_nmi.noVerbFontDma:
	.ACCU 8
	.INDEX 16

	;--- room scroll: write staged tilemap column to VRAM via DMA ch7 ---
	lda.w GLOBAL.room.nmiColFlag
	beq _nmi.noColWrite

	stz.w GLOBAL.room.nmiColFlag

	lda.b #VMAIN_INCREMENT_MODE | VMAIN_INCREMENT_32
	sta.l VMAIN

	rep #$20
	.ACCU 16
	lda.w GLOBAL.room.nmiColVramAddr
	sta.l VMADDL

	;--- DMA channel 7 setup for column tilemap ---
	sep #$20
	.ACCU 8
	lda.b #$01                    ;A->B, increment A, 2-register write ($2118/$2119)
	sta.l DMAP7
	lda.b #$18                    ;B-bus target: VMDATAL
	sta.l DMADEST7
	lda.b #$7E                      ;source bank (WRAM)
	sta.l DMASRC7B
	rep #$20
	.ACCU 16

	;source address: low 16 bits of colStaging
	lda #GLOBAL.room.colStaging & $ffff
	sta.l DMASRC7L

	;transfer length: nmiColRows * 2 bytes
	lda.w GLOBAL.room.nmiColRows
	asl a
	sta.l DMALEN7L

	;trigger DMA channel 7
	sep #$20
	.ACCU 8
	lda.b #$80
	sta.l MDMAEN

	lda.b #VMAIN_INCREMENT_MODE
	sta.l VMAIN

_nmi.noColWrite:
	.ACCU 8
	.INDEX 16
	sep #$20

	;--- OAM DMA: upload WRAM oamBuffer → hardware OAM during VBlank ---
	; Priority rotation: cycle OAMADDR base each frame so sprite dropout
	; distributes evenly instead of the same sprites always vanishing.
	lda.w GLOBAL.oamUploadFlag
	beq _nmi.noOamDma

	  stz.w OAMADDL              ; DMA writes from OAM address 0
	  stz.w OAMADDH
	  lda.b #$00                 ; DMA type: 1-register, auto-increment source
	  sta.l DMAP7
	  lda.b #OAMDATA & $ff       ; B-bus target: OAMDATA ($2104)
	  sta.l DMADEST7
	  lda.b #$7E                 ; source bank: WRAM
	  sta.l DMASRC7B
	  rep #$20
	  .ACCU 16
	  lda.w #GLOBAL.oamBuffer & $ffff
	  sta.l DMASRC7L
	  lda.w #$0220               ; OAM table 0 ($200) + table 1 ($20) = 544 bytes
	  sta.l DMALEN7L
	  sep #$20
	  .ACCU 8
	  lda.b #$80                 ; trigger DMA channel 7
	  sta.l MDMAEN

	  ; Set priority rotation: sprite at oamRotation becomes highest priority.
	  ; Distributes scanline overflow dropout across all sprites each frame.
	  lda.w GLOBAL.oamRotation
	  asl a                      ; sprite index × 2 = word address
	  sta.w OAMADDL
	  lda #$80                   ; bit 7 = enable priority rotation
	  sta.w OAMADDH
	  lda.w GLOBAL.oamRotation
	  clc
	  adc #4                     ; rotate by 4 sprites per frame
	  and #$7F                   ; wrap at 128
	  sta.w GLOBAL.oamRotation

	  stz.w GLOBAL.oamUploadFlag

_nmi.noOamDma:
	.ACCU 8
	.INDEX 16

	;--- Dialog tilemap NMI DMA: WRAM dialogTilemap → VRAM $9800 ---
	;Gated by SCUMM.dialogTilemapNmiPending; cleared after DMA.
	lda.w SCUMM.dialogTilemapNmiPending
	beq _nmi.noDialogTilemap

	stz.w SCUMM.dialogTilemapNmiPending

	lda.b #VMAIN_INCREMENT_MODE
	sta.l VMAIN
	rep #$20
	lda #$4C00
	sta.l VMADDL
	sep #$20
	lda #$01                          ;2-reg write ($2118/$2119)
	sta.l DMAP7
	lda #$18                          ;VMDATAL
	sta.l DMADEST7
	lda #$7E                          ;source bank: WRAM
	sta.l DMASRC7B
	rep #$20
	lda #SCUMM.dialogTilemap & $ffff
	sta.l DMASRC7L
	lda #2048                         ;DIALOG_TILEMAP_SIZE
	sta.l DMALEN7L
	sep #$20
	lda #$80                          ;trigger DMA channel 7
	sta.l MDMAEN

_nmi.noDialogTilemap:

	;--- Verb tilemap NMI DMA: WRAM verbTilemap → VRAM $4800 ---
	;Gated by SCUMM.verbTilemapNmiPending; set each time verb bar changes.
	lda.w SCUMM.verbTilemapNmiPending
	beq _nmi.noVerbTilemap

	stz.w SCUMM.verbTilemapNmiPending

	lda.b #VMAIN_INCREMENT_MODE
	sta.l VMAIN
	rep #$20
	lda #$4800                        ;BG2 tilemap word address (byte $9000)
	sta.l VMADDL
	sep #$20
	lda #$01                          ;2-reg write ($2118/$2119)
	sta.l DMAP7
	lda #$18                          ;VMDATAL
	sta.l DMADEST7
	lda #$7E                          ;source bank: WRAM
	sta.l DMASRC7B
	rep #$20
	lda #SCUMM.verbTilemap & $ffff
	sta.l DMASRC7L
	lda #2048                         ;VERB_TILEMAP_SIZE
	sta.l DMALEN7L
	sep #$20
	lda #$80                          ;trigger DMA channel 7
	sta.l MDMAEN

_nmi.noVerbTilemap:

	lda.w ObjSel
	sta.l OBJSEL

	jsr core.input.refresh

    ;update irq flags
    lda.w GLOBAL.interruptFlags
    sta.l NMITIMEN

	;--- guarded brightness restore ---
	;Write ScreenBrightness to INIDSP every frame so the display recovers
	;even when the main loop stalls (heavy cutscene scripts).
	;Guard: skip when ScreenBrightness==0 to preserve force blank during
	;boot and room loading (writing 0 would EXIT force blank, not enter it).
	;Must run BEFORE plb restores interrupted DBR (which could be $C0 ROM).
	lda.w ScreenBrightness
	beq +
	  sta.l INIDSP
+
	;--- end guarded brightness restore ---

	rep #$39

	ply
	plx
	pld
	plb
	pla
	;--- PBR guard: fix corrupted Program Bank Register before rti ---
	;On 65816, interrupts set PBR=$00. rti restores PBR from stack.
	;If the stacked PBR is corrupted, jsr(0,x) dispatch reads wrong bank.
	;Accept any ROM bank ($C0+) as valid — code lives in banks 0-5.
	sep #$20
	pha
	lda 5,s
	cmp #ROM
	bcs +
	  lda #ROM
	  sta 5,s
+
	.ACCU 8
	.INDEX 16
	pla
	;--- end PBR guard ---
	rti				;return from nmi

core.nmi.init:
	php

	sep #$20
	lda #INIDSP_FORCE_BLANK			;enter forced blank
	sta.l INIDSP
	lda #0		;clear zero page
	ldy #NmiGlobalVarsEnd-NmiGlobalVarsStrt
	ldx #NmiGlobalVarsStrt

	jsr ClearWRAM
	jsr ClearVRAM

	;zero scroll+SCUMM NMI-gated flags before enabling NMI.
	;DBR=$00 during boot, so stz.w misses bank $7E. Use sta.l (24-bit).
	lda #0
	sta.l GLOBAL.room.nmiColFlag
	sta.l GLOBAL.room.nmiTileFlag
	sta.l SCUMM.dialogFontNmiPending
	sta.l SCUMM.verbFontNmiPending
	sta.l SCUMM.dialogTilemapNmiPending
	sta.l SCUMM.verbTilemapNmiPending
	sta.l GLOBAL.oamUploadFlag
	;Zero cycle-engine count at $7F:4D00 (ClearWRAM only hits bank $7E;
	;leaving this garbage makes NMI's writeToCgram iterate bogus state
	;and blow the stack within a few hundred frames).
	sta.l $7F4D00

    lda.w GLOBAL.interruptFlags
	ora #NMITIMEN_NMI_ENABLE |	NMITIMEN_AUTO_JOY_READ	;enable screen and nmi, auto joypad
	sta.w GLOBAL.interruptFlags

	sta.l NMITIMEN
    lda #0
	sta.l SETINI			;dont set this during nmi cause if the overscan flag is changed mid-nmi, it might result in screw ups with the nmi timing

	lda.l RDNMI	;pull up nmi line
	lda.l TIMEUP	;pull up irq line

	stz.w ScreenBrightness

	plp
	cli
	rts

NmiPlay:
	rep #$31
	lda.w #$beef
	rts

NmiKill:
	sep #$20
	sei
	lda.w GLOBAL.interruptFlags
	and #NMITIMEN_NMI_ENABLE ~$ff
	sta.l NMITIMEN
	rts

/**
* temporally prevent nmis from happening.
* useful if working on transaction that could be corrupted by asynchronous writes.
* reenable with core.nmi.start
*
* MUST clear BOTH hardware AND GLOBAL.interruptFlags to prevent the IRQ handler
* (which calls core.nmi.start) from accidentally re-enabling NMI mid-transaction.
*/
core.nmi.stop:
  pha
  php
  sep #$20
  lda.w GLOBAL.interruptFlags
  and #NMITIMEN_NMI_ENABLE ~$ff
  sta.w GLOBAL.interruptFlags
  sta.l NMITIMEN

  plp
  pla
  rts

/**
* reenable temporally stopped nmis
*/
core.nmi.start:
  pha
  php
  sep #$20
  lda.w GLOBAL.interruptFlags
  ora #NMITIMEN_NMI_ENABLE
  sta.w GLOBAL.interruptFlags
  sta.l NMITIMEN

  plp
  pla
  rts

/**
* this is a hack and super dangerous! causes system to hang if nmis don't happen!!
*/
core.nmi.waitFrame:
  php
  rep #$31
  lda.l FrameCounter
-
    .ACCU 16
    .INDEX 16
    cmp.l FrameCounter
    beq -

  plp
  rts

.ends

