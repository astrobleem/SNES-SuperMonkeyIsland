/**
* oam manager.
*

sprite format, oamram
  byte OBJ*4+0: xxxxxxxx
  byte OBJ*4+1: yyyyyyyy
  byte OBJ*4+2: cccccccc
  byte OBJ*4+3: vhoopppN
*/


.include "src/core/oam.h"
.section "oamManager"


/**
*
*/
core.oam.init:
  php
  rep #$31
  stz.w GLOBAL.currentOamSlot
  sep #$20
  stz.w GLOBAL.oamUploadFlag
  stz.w GLOBAL.oamClearFlag

  jsr core.oam.clearTable

  stz.w GLOBAL.oam.vram.id
  lda.w MainScreen
  ora.b #T_OBJ_ENABLE
  sta.w MainScreen

  plp
  rts

oamClearWord:
  .dw 0

core.oam.clearAll:
  ;clear oam table buffer in ram
  php
  sep #$20
  lda #WRAM.CLEAR_PATTERN.OAM
  ldy.w #OAM.GLOBAL.END - OAM.GLOBAL.START
  ldx.w #OAM.GLOBAL.START
  jsr ClearWRAM
  plp
  rts


/**
* clear oam table buffer in ram & initate upload
*/
core.oam.play:
  ; Clear WRAM oam buffer and reset slot counter each frame.
  ; OAM upload to hardware is handled by NMI (core.nmi.play) via direct DMA ch7,
  ; gated on GLOBAL.oamUploadFlag (cleared by NMI after upload).
  php
  rep #$31
  lda.w #WRAM.CLEAR_PATTERN.OAM
  ldy.w #GLOBAL.oamBuffer.end - GLOBAL.oamBuffer
  ldx.w #GLOBAL.oamBuffer
  jsr ClearWRAM
  rep #$31
  stz.w GLOBAL.currentOamSlot
  sep #$20
  lda #1
  sta.w GLOBAL.oamUploadFlag
  plp
  rts

core.oam.clearTable:
  php
  sep #$20
  jsr core.oam.clearAll          ; fill WRAM oamBuffer+oamTable1 with $F8

  ; Write $F8 to all 544 hardware OAM bytes via CPU (no DMA — OAMDATA
  ; accepts CPU writes unconditionally; DMA requires force-blank to be active)
  stz.w OAMADDL                  ; reset OAM address to table 0 start
  stz.w OAMADDH
  lda #$F8                       ; Y=$F8 hides sprites (>= 224 = off-screen)
  ldy #OAM.TABLE.0.LENGTH + OAM.TABLE.1.LENGTH  ; = $220 = 544 iterations
- sta.w OAMDATA
  dey
  bne -

  plp
  rts  


/**
* get allocated memory adress for nametable. If none present yet, allocate some
*/
core.oam.getNametableBase:
  php
  rep #$31
  lda.w GLOBAL.oam.vram.id
  and.w #$ff
  bne _allocatedOk

	lda.w #SPRITE.TILE.GRANULARITY
	ldy.w #SPRITE.NAMETABLE.PRIMER
	ldx.w #SPRITE.TILE.GRANULARITY
	
	jsr core.vram.allocate
	bcs +
	  pea SPRITE.TILE.GRANULARITY
      TRIGGER_ERROR E_OutOfVram


+
	.ACCU 16
	.INDEX 16
	stx.w GLOBAL.oam.vram.start
	sep #$20
	sta.w GLOBAL.oam.vram.id
	rep #$31
	txa
	and.w #$C000
	sta.w GLOBAL.oam.vram.start
	rol a
	rol a
	rol a

	;second name table is +$2000 bytes
	;@fixme, select correct upper nametable
	sep #$20
	ora.b #OBJSEL_NAME_1
	sta.w ObjSel

_allocatedOk:
  .ACCU 8
  .INDEX 16
  ldy.w GLOBAL.oam.vram.start
  plp

  rts

.ends
