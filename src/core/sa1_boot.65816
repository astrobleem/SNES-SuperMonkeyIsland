.include "src/core/sa1_boot.h"

; SA-1 I-RAM layout — two address views of the same physical 2KB:
;   SA-1 CPU sees I-RAM at $0000-$07FF
;   SNES CPU sees I-RAM at $3000-$37FF
; Code running on SA-1 uses the SA1_ prefix ($0xxx).
; Code running on SNES uses the SNES_IRAM_ prefix ($3xxx).

; I-RAM addresses — both CPUs use $3000-$37FF (shared view)
; SA-1 also sees I-RAM at $0000-$07FF but $3000 range works for both.
.define SA1_MAILBOX_CMD    $3000   ; command byte: 0=idle, 1=scale, $FF=ack
.define SA1_MAILBOX_SCALE  $3001   ; scale factor (1-255)
.define SA1_MAILBOX_SRC    $3002   ; source ROM addr (3 bytes)
.define SA1_MAILBOX_TILES  $3005   ; tile count (word)
.define SA1_MAILBOX_WIDTH  $3007   ; sprite width in tiles (word)
.define SA1_MAILBOX_HEIGHT $3009   ; sprite height in tiles (word)
.define SA1_MAILBOX_OUT    $300B   ; output I-RAM offset (word)
.define SA1_MAILBOX_OUTTILES $300D ; output tile count (byte)
.define SA1_MAILBOX_STATUS $300E   ; status: 0=busy, 1=done, $42=alive, $FF=error
.define SA1_SCRATCH        $3010   ; 112 bytes scratch
.define SA1_STACK_TOP      $30FF   ; stack grows down from here
.define SA1_TILE_BUFFER    $3100   ; 1792 bytes tile output

; SNES CPU addresses ($3000-$37FF) — same physical bytes
.define SNES_IRAM_CMD      $3000
.define SNES_IRAM_STATUS   $300E

.bank 0 slot 0
.section "SA-1 boot" free

sa1.entry:
  sei
  clc
  xce                     ; native mode
  rep #$31
  .ACCU 16
  .INDEX 16

  ; Set direct page to I-RAM base
  lda #SA1_SCRATCH
  tcd

  ; Set stack to I-RAM
  lda #SA1_STACK_TOP
  tcs

  ; Enable IRQ from SNES (CIE bit 7)
  sep #$20
  .ACCU 8
  lda #CIE_IRQ_SNES2SA1_ENABLE
  sta.l CIE               ; $220A

  ; Write handshake: "I'm alive"
  lda #$42
  sta.l SA1_MAILBOX_STATUS

  ; Clear command byte
  lda #0
  sta.l SA1_MAILBOX_CMD

  ; Enter idle loop
sa1.idleLoop:
  wai                     ; wait for interrupt
  ; After IRQ handler returns, check command byte
  lda.l SA1_MAILBOX_CMD
  beq sa1.idleLoop        ; 0 = no command, keep waiting
  ; Future: dispatch commands here
  ; For now, just clear and loop
  lda #0
  sta.l SA1_MAILBOX_CMD
  bra sa1.idleLoop

; SA-1 IRQ handler (minimal for now)
sa1.irqHandler:
  ; Acknowledge IRQ from SNES
  sep #$20
  .ACCU 8
  lda #CIC_IRQ_SNES2SA1_CLEAR
  sta.l CIC               ; $220B — clear the IRQ flag
  rti

.ends
