/**
* Room loader subroutines for MSU-1 room data pack.
*
* Not an OOP class — just jsr-callable functions.
* Reads room data from .msu file: index lookup, header parse,
* palette/tileset DMA, column-major tilemap write.
*/

.include "src/object/room/room.h"
.section "room loader"


/**
* Seek to 32-bit address in MSU-1 data file and wait for ready.
* Drains any pending seek first, then issues new seek.
*
* @param a<16bit>  low 16 bits of address
* @param x<16bit>  high 16 bits of address
*/
;===================================================================
; room.setRomDataPtr -- set 24-bit pointer for ROM data access
;
; Converts a linear offset within rom_data.bin to a CPU address
; using the SA-1 MMC bank mapping:
;   EXB=4 → $E0-$EF = physical 64-79  (offset 0x000000-0x0FFFFF)
;   FXB=5 → $F0-$FF = physical 80-95  (offset 0x100000-0x1FFFFF)
;   For offset >= 0x200000: swap FXB to 6 or 7.
;
; Input:  A = offset low 16 bits, X = offset high 8 bits (bits 16-23)
; Output: tmp+24 set to 24-bit CPU address
; Clobbers: A, X
;===================================================================
room.setRomDataPtr:
  php
  rep #$31
  .ACCU 16
  .INDEX 16

  ; Store offset[15:0] into tmp+24 low word
  sta.b tmp+24

  ; X = offset[23:16].  Compute CPU bank from physical bank.
  ; Physical bank = 64 + X.  Block = (64 + X) >> 4 = 4 + (X >> 4).
  ; Bank within block = X & $0F.
  txa
  and #$00FF
  pha                       ; save offset high byte
  lsr a
  lsr a
  lsr a
  lsr a                     ; A = X >> 4 = block offset (0, 1, 2, 3)
  beq _srdp.exb             ; block 0 → EXB window ($E0)

  ; block 1+ → FXB window ($F0)
  ; Always set FXB = (4 + block_offset) so a previous call that set
  ; FXB to 6 or 7 doesn't leave stale state for a block-1 read.
  clc
  adc #4                    ; FXB value = 4 + block_offset (block 1→5, 2→6, 3→7)
  sep #$20
  sta.l FXB
  rep #$20

_srdp.fxbRestored:
  pla                       ; recover offset high byte
  and #$000F                ; bank within block
  clc
  adc #$00F0                ; CPU bank = $F0 + bank_within_block
  bra _srdp.storeBank

_srdp.exb:
  pla                       ; recover offset high byte
  and #$000F                ; bank within block
  clc
  adc #$00E0                ; CPU bank = $E0 + bank_within_block

_srdp.storeBank:
  sep #$20
  sta.b tmp+24+2       ; store bank byte
  rep #$20

  plp
  rts

;===================================================================
; room.setRomDataPtrLong -- JSL-callable wrapper for cross-bank use
; Same interface as setRomDataPtr: A=lo16, X=hi8 → tmp+24 set
;===================================================================
room.setRomDataPtrLong:
  jsr room.setRomDataPtr
  rtl


room.msu1Seek:
  php
  rep #$31
  pha
  phx

  ;drain any pending seek (non-fatal timeout)
  sep #$20
  ldx.w #ROOM_MSU1_SEEK_TIMEOUT
-   dex
    beq +
    lda.l MSU_STATUS
    bmi -
+
  rep #$31
  ;write 32-bit address
  lda 3,s   ;low 16 bits (was in A, now on stack)
  sta.l MSU_ADRESS
  lda 1,s   ;high 16 bits (was in X)
  sta.l MSU_ADRESS+2

  ;SD2SNES settle delay
  nop
  nop
  nop
  nop
  nop
  nop
  nop
  nop

  ;wait for seek complete
  sep #$20
  ldx.w #ROOM_MSU1_SEEK_TIMEOUT
-   dex
    beq _room.seekTimeout
    lda.l MSU_STATUS
    bmi -

  plx
  rep #$20        ;restore 16-bit A to match pha at entry
  pla
  plp
  rts

_room.seekTimeout:
  .ACCU 8
  .INDEX 16
  TRIGGER_ERROR E_Msu1SeekTimeout


/**
* Load room index entry for given room ID.
* Seeks to index table, reads data_offset and data_size into WRAM.
*
* @param a<16bit>  room ID
* @return carry    set if room exists (data_offset != 0), clear if missing
*/
room.loadIndex:
  php
  rep #$31

  ;bounds check: room ID must be < ROM_DATA_ROOM_SLOTS
  cmp #ROM_DATA_ROOM_SLOTS
  bcc +
  plp
  clc
  rts
+

  ;calculate linear offset: ROM_DATA_ROOM_INDEX + room_id * 8
  asl a
  asl a
  asl a
  clc
  adc.w #ROM_DATA_ROOM_INDEX
  ;A = low 16 bits of offset, X = high 8 bits (0 — index fits in first 64KB)
  ldx #0
  jsr room.setRomDataPtr

  ;read 8 bytes from ROM into index entry struct
  sep #$20
  ldy #0
  ldx #0
- lda [tmp+24],y
  sta.w GLOBAL.room.idx,x
  iny
  inx
  cpx #ROOM_INDEX_ENTRY_SIZE
  bne -

  ;check if data_offset is zero (room doesn't exist)
  rep #$20
  lda.w GLOBAL.room.idx.offset_lo
  ora.w GLOBAL.room.idx.offset_hi
  beq _room.loadIndex.missing

  plp
  sec
  rts

_room.loadIndex.missing:
  .ACCU 16
  .INDEX 16
  plp
  clc
  rts


/**
* Read 32-byte room header from MSU-1 into WRAM buffer.
* Seeks to dataOffset, then reads header bytes via CPU.
*/
room.loadHeader:
  php
  rep #$31

  ;set ROM pointer to room data block
  lda.w GLOBAL.room.idx.offset_lo
  ldx.w GLOBAL.room.idx.offset_hi
  jsr room.setRomDataPtr

  ;read 32 bytes of header from ROM into WRAM struct
  sep #$20
  ldy #0
  ldx #0
- lda [tmp+24],y
  sta.w GLOBAL.room.hdr,x
  iny
  inx
  cpx #ROOM_HEADER_SIZE
  bne -

  ;advance romReadPos past header (base + 32)
  rep #$20
  lda.w GLOBAL.room.idx.offset_lo
  clc
  adc #ROOM_HEADER_SIZE
  sta.w GLOBAL.room.romReadPos_lo
  lda.w GLOBAL.room.idx.offset_hi
  adc #0
  sta.w GLOBAL.room.romReadPos_hi

  plp
  rts


/**
* Read palette from MSU_DATA, write to both CGRAM and BW-RAM shadow.
* Delegates to superfree section to avoid room section size changes.
* Called during forced blank — direct CGRAM writes are safe.
*/
room.loadPalette:
  php
  rep #$31
  ; Set ROM pointer here (bank 0) before JSL into superfree section
  lda.w GLOBAL.room.romReadPos_lo
  ldx.w GLOBAL.room.romReadPos_hi
  jsr room.setRomDataPtr
  jsl room.loadPaletteShadow
  plp
  rts


/**
* Register VRAM DMA transfer from MSU_DATA (tileset).
* MSU_DATA stream is positioned right after the palette.
* Transfer length comes from room header chr_size field.
*/
room.loadTileset:
  php
  rep #$31

  ; Set ROM pointer to tileset data (romReadPos = after palette)
  lda.w GLOBAL.room.romReadPos_lo
  ldx.w GLOBAL.room.romReadPos_hi
  jsr room.setRomDataPtr

  ; DMA from ROM to VRAM (tileset CHR data)
  tsx
  sep #$20
  lda.b #DMA_TRANSFER.VRAM       ; normal incrementing source (not FIXED_SOURCE)
  pha                           ;1 byte: transfer type

  rep #$20
  lda.b tmp+24                  ; ROM source address (low 16 bits)
  pha                           ;2 bytes: source address

  sep #$20
  lda.b tmp+26                  ; ROM source bank
  pha                           ;1 byte: source bank

  rep #$20
  lda.w #ROOM_TILES_VRAM * 2    ;target: VRAM byte address 0
  pha                           ;2 bytes: target address

  ;chr_size from header (16-bit value, clamp to max 28KB)
  lda.w GLOBAL.room.hdr.chr_size
  cmp.w #ROOM_MAX_CHR_SIZE + 1
  bcc +
    lda.w #ROOM_MAX_CHR_SIZE
+
  pha                           ;2 bytes: transfer length

  jsr core.dma.registerTransfer
  txs                           ;restore stack

  ; Advance romReadPos past tileset
  rep #$20
  lda.w GLOBAL.room.romReadPos_lo
  clc
  adc.w GLOBAL.room.hdr.chr_size
  sta.w GLOBAL.room.romReadPos_lo
  lda.w GLOBAL.room.romReadPos_hi
  adc #0
  sta.w GLOBAL.room.romReadPos_hi

  plp
  rts


/**
* Write column-major tilemap to both VRAM and WRAM $7F.
* MSU_DATA stream is positioned right after the tileset.
* Uses VMAIN increment-by-32 mode to write one column at a time.
* Columns 0..min(width-1, 63) go to both VRAM and WRAM.
* Columns 64+ go to WRAM only (no VRAM, no drain).
*
* tmp+0  = total columns remaining
* tmp+2  = rows per column (height_tiles)
* tmp+4  = current VRAM column word address
* tmp+6  = WRAM offset (word index into $7F buffer)
* tmp+8  = VRAM columns remaining (min(width, 64))
*/
room.loadTilemapDual:
  php
  rep #$31

  ;set ROM pointer to tilemap data (romReadPos = after tileset)
  lda.w GLOBAL.room.romReadPos_lo
  ldx.w GLOBAL.room.romReadPos_hi
  jsr room.setRomDataPtr
  stz.b tmp+10                  ;ROM read offset within tilemap (Y alias)

  ;load dimensions from header
  lda.w GLOBAL.room.hdr.width_tiles
  sta.b tmp                     ;total columns to read from ROM

  lda.w GLOBAL.room.hdr.height_tiles
  sta.b tmp+2                   ;rows per column

  ;VRAM column address
  lda.w #ROOM_TILEMAP_VRAM_WORD
  sta.b tmp+4

  ;WRAM write offset (bytes into $7F0000)
  lda #0
  sta.b tmp+6

  ;VRAM columns = min(width_tiles, 64)
  lda.w GLOBAL.room.hdr.width_tiles
  cmp.w #65
  bcc +
    lda.w #64
+
  sta.b tmp+8

_room.dualTilemap.columnLoop:
  .ACCU 16
  .INDEX 16
  lda.b tmp                     ;total columns remaining
  bne +
  jmp _room.dualTilemap.done
+

  ;check if we still have VRAM columns to write
  lda.b tmp+8
  beq _room.dualTilemap.wramOnly

  ;--- write to both VRAM and WRAM ---

  ;handle nametable boundary at column 32
  lda.b tmp+4
  cmp.w #ROOM_TILEMAP_VRAM_WORD + 32
  bne +
    lda.w #ROOM_TILEMAP_VRAM_WORD + $0400
    sta.b tmp+4
+

  ;set VMAIN to increment by 32 (vertical write)
  sep #$20
  lda.b #VMAIN_INCREMENT_MODE | VMAIN_INCREMENT_32
  sta.l VMAIN
  rep #$20

  ;set VRAM address for this column
  lda.b tmp+4
  sta.l VMADDL

  ;read height_tiles words: write to both VRAM and WRAM
  ldy.b tmp+2                  ;row count
  ldx.b tmp+6                  ;WRAM offset
_room.dualTilemap.bothLoop:
  .ACCU 16
  .INDEX 16
  phy                           ;save row counter
  ldy.b tmp+10                  ;ROM read offset
  sep #$20
  lda [tmp+24],y                ;low byte from ROM
  sta.l VMDATAL
  sta.l SCROLL_TILEMAP_WRAM,x
  iny
  lda [tmp+24],y                ;high byte from ROM
  sta.l VMDATAH
  sta.l SCROLL_TILEMAP_WRAM+1,x
  iny
  rep #$20
  sty.b tmp+10                  ;save ROM offset
  ply                           ;restore row counter
  inx
  inx
  dey
  bne _room.dualTilemap.bothLoop

  ;update WRAM offset
  stx.b tmp+6

  ;advance VRAM column
  lda.b tmp+4
  inc a
  sta.b tmp+4

  ;decrement VRAM columns remaining
  lda.b tmp+8
  dec a
  sta.b tmp+8

  bra _room.dualTilemap.nextCol

_room.dualTilemap.wramOnly:
  .ACCU 16
  .INDEX 16
  ;--- columns beyond 64: write to WRAM only ---
  ldy.b tmp+2                  ;row count
  ldx.b tmp+6                  ;WRAM offset
_room.dualTilemap.wramLoop:
  .ACCU 16
  .INDEX 16
  phy
  ldy.b tmp+10                  ;ROM read offset
  sep #$20
  lda [tmp+24],y
  sta.l SCROLL_TILEMAP_WRAM,x
  iny
  lda [tmp+24],y
  sta.l SCROLL_TILEMAP_WRAM+1,x
  iny
  rep #$20
  sty.b tmp+10
  ply
  inx
  inx
  dey
  bne _room.dualTilemap.wramLoop

  ;update WRAM offset
  stx.b tmp+6

_room.dualTilemap.nextCol:
  .ACCU 16
  .INDEX 16
  ;decrement total columns
  lda.b tmp
  dec a
  sta.b tmp
  jmp _room.dualTilemap.columnLoop

_room.dualTilemap.done:
  .ACCU 16
  .INDEX 16
  ;restore VMAIN to normal increment-by-1 mode
  sep #$20
  lda.b #VMAIN_INCREMENT_MODE
  sta.l VMAIN
  rep #$20

  plp
  rts


/**
* Clear VRAM tilemap area to zero.
* Zeroes tilemap region so unused columns are blank.
* Must be called during force blank.
*/
room.clearTilemap:
  php
  rep #$31

  ;set VMAIN to increment by 1
  sep #$20
  lda.b #VMAIN_INCREMENT_MODE
  sta.l VMAIN
  rep #$20

  ;--- Zero tile 0 (32 bytes at VRAM $0000) so $0000 tilemap entries are blank ---
  lda.w #ROOM_TILES_VRAM
  sta.l VMADDL
  sep #$20
  lda #0
  .REPT 16
    sta.l VMDATAL
    sta.l VMDATAH
  .ENDR
  rep #$20

  ;--- Zero BG1 tilemap (all entries → tile 0 = blank) ---
  lda.w #ROOM_TILEMAP_VRAM_WORD
  sta.l VMADDL

  ;write $800 zero words (BG1 tilemap area only)
  ;A must be 8-bit: 16-bit sta to VMDATAL spills into VMDATAH,
  ;causing double auto-increment and overwriting verb font at $4000.
  sep #$20
  lda #0
  ldy.w #ROOM_TILEMAP_CLEAR_SIZE / 2
- sta.l VMDATAL
  sta.l VMDATAH
  dey
  bne -
  rep #$20

  ;--- Zero BG3 tilemap (dialog overlay: word $4C00, 32x32 = $800 bytes) ---
  ;Must clear directly during force blank since the NMI relay may be
  ;suppressed by dialogBootSuppress during early boot sequence.
  lda.w #$4C00
  sta.l VMADDL
  sep #$20
  lda #0
  ldy.w #$0400                       ;$800 bytes = $400 words
- sta.l VMDATAL
  sta.l VMDATAH
  dey
  bne -
  rep #$20

  plp
  rts


/**
* Drain excess tileset bytes from MSU_DATA stream.
* If chr_size > ROOM_MAX_CHR_SIZE, the DMA only transferred the clamped
* amount, leaving (chr_size - ROOM_MAX_CHR_SIZE) bytes unread.
* Must drain these so the stream is positioned at tilemap data.
*/
room.drainExcessTileset:
  php
  rep #$31

  lda.w GLOBAL.room.hdr.chr_size
  sec
  sbc.w #ROOM_MAX_CHR_SIZE
  beq _room.drainExcess.done
  bcc _room.drainExcess.done    ;chr_size <= max, nothing to drain

  ;A = number of excess bytes to drain
  tax
  sep #$20
- lda.l MSU_DATA                ;discard byte (auto-advance)
  dex
  bne -
  rep #$20

_room.drainExcess.done:
  .ACCU 16
  .INDEX 16
  plp
  rts


/**
* Drain ALL tileset bytes from MSU_DATA stream (Step 2).
* Skips the entire tileset so stream is positioned at tilemap data.
* Uses the full chr_size (not clamped), handling 32-bit size.
*/
room.drainFullTileset:
  php
  rep #$31

  ;drain chr_size bytes (16-bit loop, may need multiple passes for >64KB)
  ;most rooms have chr_size < 64KB so single pass suffices
  lda.w GLOBAL.room.hdr.chr_size
  beq _room.drainFull.checkHigh
  tax
  sep #$20
- lda.l MSU_DATA
  dex
  bne -
  rep #$20

_room.drainFull.checkHigh:
  .ACCU 16
  .INDEX 16
  ;check if chr_size_hi > 0 (tileset > 64KB, unlikely but handle it)
  lda.w GLOBAL.room.hdr.chr_size_hi
  beq _room.drainFull.done
  ;drain another 64KB block (extremely rare)
  tax
_room.drainFull.hiLoop:
  .ACCU 16
  .INDEX 16
  phx
  ldx #0
  sep #$20
- lda.l MSU_DATA
  dex
  bne -
  rep #$20
  plx
  dex
  bne _room.drainFull.hiLoop

_room.drainFull.done:
  .ACCU 16
  .INDEX 16
  plp
  rts


/**
* Read entire tilemap from MSU_DATA to WRAM $7F only.
* No VRAM writes — tilemap goes to VRAM via cache-remapped viewport load.
*
* Column-major order matches MSU stream layout.
*/
room.loadTilemapToWram:
  php
  rep #$31

  ; Sanity check: reject garbage room headers (prevents infinite loop)
  lda.w GLOBAL.room.hdr.width_tiles
  cmp #129                       ; max reasonable width: 128 tiles (1024px)
  bcs _room.wramTilemap.done     ; garbage → skip
  lda.w GLOBAL.room.hdr.height_tiles
  cmp #65                        ; max reasonable height: 64 tiles (512px)
  bcs _room.wramTilemap.done     ; garbage → skip

  ;set ROM pointer to tilemap (romReadPos = after tileset)
  lda.w GLOBAL.room.romReadPos_lo
  ldx.w GLOBAL.room.romReadPos_hi
  jsr room.setRomDataPtr
  stz.b tmp+10                  ;ROM read offset

  lda.w GLOBAL.room.hdr.width_tiles
  sta.b tmp                     ;total columns
  lda.w GLOBAL.room.hdr.height_tiles
  sta.b tmp+2                   ;rows per column

  ldx #0                        ;WRAM byte offset

_room.wramTilemap.colLoop:
  .ACCU 16
  .INDEX 16
  lda.b tmp
  beq _room.wramTilemap.done

  ldy.b tmp+2                  ;rows this column
_room.wramTilemap.rowLoop:
  .ACCU 16
  .INDEX 16
  phy
  ldy.b tmp+10
  sep #$20
  lda [tmp+24],y
  sta.l SCROLL_TILEMAP_WRAM,x
  iny
  lda [tmp+24],y
  sta.l SCROLL_TILEMAP_WRAM+1,x
  iny
  rep #$20
  sty.b tmp+10
  ply
  inx
  inx
  dey
  bne _room.wramTilemap.rowLoop

  lda.b tmp
  dec a
  sta.b tmp
  bra _room.wramTilemap.colLoop

_room.wramTilemap.done:
  .ACCU 16
  .INDEX 16
  plp
  rts


/**
* Compute ROM linear offset for tile data random access.
* tileDataRomOfs = roomDataOffset + ROOM_HEADER_SIZE + ROOM_PALETTE_SIZE
*
* This is the linear offset in rom_data.bin where tile 0's data begins.
* Individual tile N is at tileDataRomOfs + N * 32.
*/
room.computeTileDataBase:
  php
  rep #$31

  ;tileDataRomOfs = dataOffset + 32 (header) + 256 (palette)
  lda.w GLOBAL.room.idx.offset_lo
  clc
  adc.w #ROOM_HEADER_SIZE + ROOM_PALETTE_SIZE
  sta.w GLOBAL.room.tileDataRomOfs_lo
  lda.w GLOBAL.room.idx.offset_hi
  adc #0                        ;carry from low add
  sta.w GLOBAL.room.tileDataRomOfs_hi

  plp
  rts


/**
* Master room loader. Loads a complete room from MSU-1 data pack.
*
* @param a<16bit>  room ID (0-99)
* @return carry    set on success, clear if room doesn't exist
*/
room.load:
  php
  rep #$31

  ;save room ID
  sta.w GLOBAL.room.currentId

  ;disable ALL interrupts (NMI + V-IRQ) to prevent the dmaQueue
  ;IRQ handler from toggling INIDSP mid-write, which kills VRAM writes.
  ;sei alone doesn't block NMI, and nmi.stop doesn't block V-IRQ.
  sei                             ;block IRQ at CPU level
  sep #$20
  lda.w GLOBAL.interruptFlags
  pha                             ;save original interrupt flags
  lda #0
  sta.w GLOBAL.interruptFlags     ;clear NMI + IRQ enable bits
  sta.l NMITIMEN                  ;apply to hardware
  rep #$20

  ;enter force blank for unrestricted VRAM/CGRAM access
  sep #$20
  lda.b #INIDSP_FORCE_BLANK
  sta.l INIDSP
  rep #$20

  ;clear tilemap area
  jsr room.clearTilemap

  ;look up room in index
  lda.w GLOBAL.room.currentId
  jsr room.loadIndex
  bcs +
    ;room doesn't exist — restore display, re-enable interrupts, return failure
    sep #$20
    lda.w ScreenBrightness
    sta.l INIDSP
    pla                             ;restore saved interrupt flags
    sta.w GLOBAL.interruptFlags
    sta.l NMITIMEN
    rep #$20
    cli
    plp
    clc
    rts

+
  ;read 32-byte header (seeks to dataOffset internally)
  jsr room.loadHeader

  ;validate header: reject garbage data (rooms not in ROM data pack)
  lda.w GLOBAL.room.hdr.width_tiles
  cmp #129                       ; max 128 tiles
  bcs _room.loadBadHeader
  lda.w GLOBAL.room.hdr.height_tiles
  cmp #65                        ; max 64 tiles
  bcs _room.loadBadHeader
  bra _room.loadHeaderOk
_room.loadBadHeader:
  ; Invalid room data — bail out as room-not-found
  sep #$20
  lda.w ScreenBrightness
  sta.l INIDSP
  pla                             ;restore saved interrupt flags
  sta.w GLOBAL.interruptFlags
  sta.l NMITIMEN
  rep #$20
  cli
  plp
  clc                             ;return failure
  rts
_room.loadHeaderOk:

  ;MSU_DATA stream now positioned after header = palette data
  ;register CGRAM DMA (256 bytes)
  jsr room.loadPalette

  ;flush DMA queue for palette (we're in force blank)
  jsr core.dma.processQueue

  ;Advance romReadPos past tileset (tiles loaded on-demand by cache)
  lda.w GLOBAL.room.romReadPos_lo
  clc
  adc.w GLOBAL.room.hdr.chr_size
  sta.w GLOBAL.room.romReadPos_lo
  lda.w GLOBAL.room.romReadPos_hi
  adc.w GLOBAL.room.hdr.chr_size_hi
  sta.w GLOBAL.room.romReadPos_hi

  ;read all tilemap to WRAM $7F only (no VRAM writes)
  ;romReadPos points to tilemap data
  jsr room.loadTilemapToWram

  ;advance romReadPos past tilemap
  lda.w GLOBAL.room.romReadPos_lo
  clc
  adc.w GLOBAL.room.hdr.map_size
  sta.w GLOBAL.room.romReadPos_lo
  lda.w GLOBAL.room.romReadPos_hi
  adc.w GLOBAL.room.hdr.map_size_hi
  sta.w GLOBAL.room.romReadPos_hi

  ;compute base ROM offset for individual tile reads (do BEFORE walkbox load)
  jsr room.computeTileDataBase

  ;load walkbox data (seeks to box data offset in ROM)
  jsl room.loadWalkboxData

  ;--- Read room object data from ROM ---
  ;romReadPos needs to be set past walkbox data for object reads
  ;Compute: tileDataRomOfs + chr_size + map_size + col_size + box_size
  lda.w GLOBAL.room.tileDataRomOfs_lo
  clc
  adc.w GLOBAL.room.hdr.chr_size
  sta.w GLOBAL.room.romReadPos_lo
  lda.w GLOBAL.room.tileDataRomOfs_hi
  adc.w GLOBAL.room.hdr.chr_size_hi
  sta.w GLOBAL.room.romReadPos_hi
  ;add map_size
  lda.w GLOBAL.room.romReadPos_lo
  clc
  adc.w GLOBAL.room.hdr.map_size
  sta.w GLOBAL.room.romReadPos_lo
  lda.w GLOBAL.room.romReadPos_hi
  adc.w GLOBAL.room.hdr.map_size_hi
  sta.w GLOBAL.room.romReadPos_hi
  ;add col_size
  lda.w GLOBAL.room.romReadPos_lo
  clc
  adc.w GLOBAL.room.hdr.col_size
  sta.w GLOBAL.room.romReadPos_lo
  lda.w GLOBAL.room.romReadPos_hi
  adc.w GLOBAL.room.hdr.col_size_hi
  sta.w GLOBAL.room.romReadPos_hi
  ;add box_size
  lda.w GLOBAL.room.romReadPos_lo
  clc
  adc.w GLOBAL.room.hdr.box_size
  sta.w GLOBAL.room.romReadPos_lo
  lda.w GLOBAL.room.romReadPos_hi
  adc #0
  sta.w GLOBAL.room.romReadPos_hi

  ;set ROM pointer for object data reads
  lda.w GLOBAL.room.romReadPos_lo
  ldx.w GLOBAL.room.romReadPos_hi
  jsr room.setRomDataPtr
  stz.b tmp+10                    ;ROM read offset for object data

  lda.w SCUMM.boxDataSize
  bne +
  jmp _rl.noObjData
+
  ;read 8-byte header: count(2) + name_size(2) + verb_data_size(2) + reserved(2)
  ldy.b tmp+10
  sep #$20
.ACCU 8
  lda [tmp+24],y
  iny
  xba
  lda [tmp+24],y
  iny
  xba
  rep #$20
.ACCU 16
  sty.b tmp+10
  sta.w SCUMM.roomObjCount
  ldy.b tmp+10
  sep #$20
.ACCU 8
  lda [tmp+24],y
  iny
  xba
  lda [tmp+24],y
  iny
  xba
  rep #$20
.ACCU 16
  sta.w SCUMM.roomObjNameSize
  sep #$20
.ACCU 8
  lda [tmp+24],y
  iny
  xba
  lda [tmp+24],y
  iny
  xba
  rep #$20
.ACCU 16
  sta.w SCUMM.roomObjVerbSize
  sep #$20
.ACCU 8
  lda [tmp+24],y                           ;reserved lo
  iny
  lda [tmp+24],y                           ;reserved hi
  iny
  rep #$20
.ACCU 16
  sty.b tmp+10
  ;read object entries: count * 16 bytes
  lda.w SCUMM.roomObjCount
  beq _rl.noObjEntries
  asl a
  asl a
  asl a
  asl a                         ;byte count
  sta.b tmp+12                  ;save count
  ldy.b tmp+10                  ;ROM read offset
  ldx #0
  sep #$20
.ACCU 8
- lda [tmp+24],y
  sta.l SCUMM.roomObjTable,x
  iny
  inx
  cpx.b tmp+12
  bne -
  rep #$20
.ACCU 16
  sty.b tmp+10
_rl.noObjEntries:
  .ACCU 16
  .INDEX 16
  ;read verb index: count * 4 bytes
  lda.w SCUMM.roomObjCount
  beq _rl.noVerbIdx
  asl a
  asl a
  sta.b tmp+12
  ldy.b tmp+10
  ldx #0
  sep #$20
.ACCU 8
- lda [tmp+24],y
  sta.l SCUMM.roomObjVerbIdx,x
  iny
  inx
  cpx.b tmp+12
  bne -
  rep #$20
.ACCU 16
  sty.b tmp+10
_rl.noVerbIdx:
  .ACCU 16
  .INDEX 16
  ;read name table
  lda.w SCUMM.roomObjNameSize
  beq _rl.noNames
  sta.b tmp+12
  ldy.b tmp+10
  ldx #0
  sep #$20
.ACCU 8
- lda [tmp+24],y
  sta.l SCUMM.roomObjNames,x
  iny
  inx
  cpx.b tmp+12
  bne -
  rep #$20
.ACCU 16
  sty.b tmp+10
_rl.noNames:
  .ACCU 16
  .INDEX 16
  ;read verb data blobs
  lda.w SCUMM.roomObjVerbSize
  beq _rl.objDone
  sta.b tmp+12
  ldy.b tmp+10
  ldx #0
  sep #$20
.ACCU 8
- lda [tmp+24],y
  sta.l SCUMM.roomObjVerbData,x
  iny
  inx
  cpx.b tmp+12
  bne -
  rep #$20
.ACCU 16
  sty.b tmp+10
  bra _rl.objDone
_rl.noObjData:
  .ACCU 16
  .INDEX 16
  stz.w SCUMM.roomObjCount
  stz.w SCUMM.roomObjNameSize
  stz.w SCUMM.roomObjVerbSize
_rl.objDone:
  .ACCU 16
  .INDEX 16
  jsl room.initObjectStates             ;set objectState=1 for loaded room objs

  ;--- Load object patch (OCHR) data from MSU ---
  jsl room.loadOchrData

  ;initialize scroll state + tile cache
  jsr room.initScroll
  jsr room.initTileCache

  ;apply OCHR patches BEFORE viewport load so composited tile IDs
  ;are in SCROLL_TILEMAP_WRAM when loadInitialViewport caches tiles
  jsl room.applyVisibleObjectPatches

  ;viewport load deferred to processRoomChange (after camera correction)
  ;jsr room.loadInitialViewport

  ;keep INIDSP in forced blank ($80) — the play loop restores
  ;brightness after ENCD scripts + OCHR redraw complete
  sep #$20

  ;restore interrupt flags (NMI + V-IRQ)
  pla                             ;saved GLOBAL.interruptFlags
  sta.w GLOBAL.interruptFlags
  sta.l NMITIMEN
  rep #$20
  cli

  plp
  sec
  rts

.ends

;===================================================================
; room.findObject — AABB hit-test against room object table
; Input:  A = screenX (16-bit), SCUMM.scratch = screenY (16-bit)
; Output: A = object ID (0 = none found)
; Converts screen→room coords, iterates reverse (SCUMM priority).
;===================================================================
.bank 5 slot 0
.base BSL
.section "room findObject" free

room.findObject:
  rep #$31
  clc
  adc.w GLOBAL.room.cameraX            ;roomX = screenX + cameraX
  sta.b tmp                             ;tmp = roomX
  lda.w SCUMM.roomObjCount
  beq _fo.none
  dec a
  asl a
  asl a
  asl a
  asl a
  tax                                   ;X = byte offset of last entry

_fo.loop:
  ;read obj_id, check visibility
  lda.l SCUMM.roomObjTable,x           ;obj_id
  tay
  sep #$20
.ACCU 8
  lda.w SCUMM.objectState,y
  rep #$20
.ACCU 16
  and #$00FF
  beq _fo.next

  ;AABB X: roomX >= x_px AND roomX < x_px + width_px
  lda.l SCUMM.roomObjTable+6,x         ;width_px
  beq _fo.next
  clc
  adc.l SCUMM.roomObjTable+2,x         ;x_right = x_px + width
  sta.b tmp+2
  lda.b tmp                             ;roomX
  cmp.l SCUMM.roomObjTable+2,x         ;vs x_px
  bcc _fo.next
  cmp.b tmp+2                           ;vs x_right
  bcs _fo.next

  ;AABB Y: roomY >= y_px AND roomY < y_px + height_px
  lda.l SCUMM.roomObjTable+8,x         ;height_px
  beq _fo.next
  clc
  adc.l SCUMM.roomObjTable+4,x         ;y_bottom = y_px + height
  sta.b tmp+2
  lda.w SCUMM.scratch                   ;roomY (screenY, no Y scroll)
  cmp.l SCUMM.roomObjTable+4,x         ;vs y_px
  bcc _fo.next
  cmp.b tmp+2                           ;vs y_bottom
  bcs _fo.next

  ;HIT — return obj_id (still in Y from earlier)
  tya
  rtl

_fo.next:
  txa
  sec
  sbc #16
  tax
  bpl _fo.loop

_fo.none:
  lda #0
  rtl

.ends

;===================================================================
; room.initObjectStates — read initial_state bytes from MSU stream
; and set objectState[obj_id] = state for each loaded room object.
; The state table (1 byte per object) is appended to the .obj data
; in the MSU stream, positioned right after verb data.
;===================================================================
.bank 5 slot 0
.base BSL
.section "room initObjectStates" free

room.initObjectStates:
  rep #$31
  lda.w SCUMM.roomObjCount
  beq _ios.done
  sta.b tmp+14                          ;loop counter
  stz.b tmp+16                          ;entry byte offset (X alias)
  ldy.b tmp+10                          ;ROM read offset
_ios.loop:
  ldx.b tmp+16
  lda.l SCUMM.roomObjTable,x            ;obj_id (16-bit)
  tax                                   ;X = obj_id
  sep #$20
.ACCU 8
  lda [tmp+24],y                        ;read initial_state from ROM
  sta.w SCUMM.objectState,x
  iny
  rep #$20
.ACCU 16
  lda.b tmp+16
  clc
  adc #16                               ;advance to next 16-byte entry
  sta.b tmp+16
  lda.b tmp+14
  dec a
  sta.b tmp+14
  bne _ios.loop
  sty.b tmp+10                          ;save final ROM offset
_ios.done:
  rtl

.ends

;===================================================================
; Walkbox loader — superfree to avoid growing bank 0
;===================================================================
.bank 5 slot 0
.base BSL
.section "room walkbox loader" free

/**
* Load walkbox data via MSU seek (avoids draining col_size bytes).
* Computes absolute MSU offset: tileDataMsuBase + chr_size + map_size + col_size.
* Then seeks there and reads box_size bytes into $7F:4C00.
* Sets SCUMM.boxCount + SCUMM.boxMatrixPtr.
*
* Requires computeTileDataBase to have been called first.
*/
room.loadWalkboxData:
  php
  rep #$31

  ;check if this room has walkbox data
  lda.w GLOBAL.room.hdr.box_size
  bne _box.hasData
  jmp _box.none
_box.hasData:

  sta.w SCUMM.boxDataSize

  ;--- Compute ROM offset to box data ---
  ;box_offset = tileDataRomOfs + chr_size + map_size + col_size
  lda.w GLOBAL.room.tileDataRomOfs_lo
  clc
  adc.w GLOBAL.room.hdr.chr_size
  sta.b tmp
  lda.w GLOBAL.room.tileDataRomOfs_hi
  adc.w GLOBAL.room.hdr.chr_size_hi
  sta.b tmp+2

  ;add map_size
  lda.b tmp
  clc
  adc.w GLOBAL.room.hdr.map_size
  sta.b tmp
  lda.b tmp+2
  adc.w GLOBAL.room.hdr.map_size_hi
  sta.b tmp+2

  ;add col_size
  lda.b tmp
  clc
  adc.w GLOBAL.room.hdr.col_size
  sta.b tmp
  lda.b tmp+2
  adc.w GLOBAL.room.hdr.col_size_hi
  sta.b tmp+2

  ;--- Set ROM pointer to box data ---
  lda.b tmp
  ldx.b tmp+2
  jsl room.setRomDataPtrLong

  ;read box_size bytes from ROM to $7F:5000
  phy
  ldy #0                        ;ROM read offset
  ldx #0                        ;write offset
  sep #$20
_box.readLoop:
  lda [tmp+24],y               ;8-bit read from ROM
  sta.l $7F5000,x
  iny
  inx
  cpx.w SCUMM.boxDataSize
  bne _box.readLoop
  rep #$20
  ply

  ;parse boxCount from first 2 bytes
  lda.l $7F5000
  sta.w SCUMM.boxCount

  ;compute matrix pointer: $5002 + boxCount * 20
  lda.w SCUMM.boxCount
  asl a
  asl a
  sta.b tmp
  asl a
  asl a
  clc
  adc.b tmp
  clc
  adc.w #$5002
  sta.w SCUMM.boxMatrixPtr

  ;--- Save original routing matrix copy for createBoxMatrix ---
  ;matrixSize = boxCount * boxCount (use shift-add multiply)
  lda.w SCUMM.boxCount
  sta.b tmp             ;multiplicand
  sta.b tmp+2           ;multiplier
  stz.b tmp+4           ;result
  ldy #16
_box.mulLoop:
  lsr.b tmp+2
  bcc +
    lda.b tmp+4
    clc
    adc.b tmp
    sta.b tmp+4
+
  asl.b tmp
  dey
  bne _box.mulLoop

  ;tmp+4 = matrixSize (boxCount * boxCount)
  ;--- Copy 32-byte SCAL block BEFORE matrix copy (which may overwrite it) ---
  ;SCAL data is at $7F:(boxMatrixPtr + matrixSize)
  lda.w SCUMM.boxMatrixPtr
  clc
  adc.b tmp+4
  tax                         ; X = offset to SCAL data in $7F bank
  lda.l $7F0000,x
  sta.w SCUMM.scalSlot0_s1
  lda.l $7F0002,x
  sta.w SCUMM.scalSlot0_y1
  lda.l $7F0004,x
  sta.w SCUMM.scalSlot0_s2
  lda.l $7F0006,x
  sta.w SCUMM.scalSlot0_y2
  lda.l $7F0008,x
  sta.w SCUMM.scalSlot1_s1
  lda.l $7F000A,x
  sta.w SCUMM.scalSlot1_y1
  lda.l $7F000C,x
  sta.w SCUMM.scalSlot1_s2
  lda.l $7F000E,x
  sta.w SCUMM.scalSlot1_y2
  lda.l $7F0010,x
  sta.w SCUMM.scalSlot2_s1
  lda.l $7F0012,x
  sta.w SCUMM.scalSlot2_y1
  lda.l $7F0014,x
  sta.w SCUMM.scalSlot2_s2
  lda.l $7F0016,x
  sta.w SCUMM.scalSlot2_y2
  lda.l $7F0018,x
  sta.w SCUMM.scalSlot3_s1
  lda.l $7F001A,x
  sta.w SCUMM.scalSlot3_y1
  lda.l $7F001C,x
  sta.w SCUMM.scalSlot3_s2
  lda.l $7F001E,x
  sta.w SCUMM.scalSlot3_y2

  ;origMatrixPtr = boxMatrixPtr + matrixSize
  lda.w SCUMM.boxMatrixPtr
  clc
  adc.b tmp+4
  sta.w SCUMM.boxOrigMatrixPtr

  ;copy matrixSize bytes from $7F:boxMatrixPtr to $7F:boxOrigMatrixPtr
  ;uses 65816 block move: mvn dest_bank, src_bank (X=src, Y=dest, A=count-1)
  lda.b tmp+4
  beq _box.copyDone     ;zero-size matrix = nothing to copy
  dec a                 ;mvn takes count-1
  ldx.w SCUMM.boxMatrixPtr     ;X = source offset in $7F
  ldy.w SCUMM.boxOrigMatrixPtr ;Y = dest offset in $7F
  phb                   ;save data bank
  mvn $7F, $7F
  plb                   ;restore data bank
_box.copyDone:
  plp
  rtl

_box.none:
  stz.w SCUMM.boxCount
  stz.w SCUMM.boxDataSize
  stz.w SCUMM.boxMatrixPtr
  stz.w SCUMM.boxOrigMatrixPtr
  stz.w SCUMM.scalSlot0_s1
  stz.w SCUMM.scalSlot0_y1
  stz.w SCUMM.scalSlot0_s2
  stz.w SCUMM.scalSlot0_y2
  plp
  rtl

.ends


;===================================================================
; room.loadOchrData — load object patch data from MSU into SCUMM.ochrData
; MSU stream is already positioned after .obj data.
; Uses header field ochr_size (offset $1E) for data size.
;===================================================================
.bank 5 slot 0
.base BSL
.section "room loadOchrData" free

room.loadOchrData:
  php
  rep #$31

  ;clear OCHR state
  stz.w SCUMM.ochrDataSize
  stz.w SCUMM.ochrObjCount
  stz.w SCUMM.objDirtyFlag

  ;check if this room has OCHR data
  lda.w GLOBAL.room.hdr.ochr_size
  beq _ochr.none

  ;check if it fits in bank $7E buffer
  cmp.w #SCUMM_OCHR_MAX_SIZE_7E + 1
  bcs _ochr.tooLarge

  ;store size and read ROM data into SCUMM.ochrData
  sta.w SCUMM.ochrDataSize
  ;ROM pointer should still be valid (set during object data reads)
  ;tmp+10 tracks the ROM read offset
  phy
  ldy.b tmp+10                  ;ROM offset
  ldx #0
  sep #$20
.ACCU 8
- lda [tmp+24],y
  sta.l SCUMM.ochrData,x
  iny
  inx
  cpx.w SCUMM.ochrDataSize
  bne -
  rep #$20
.ACCU 16
  sty.b tmp+10
  ply

  ;parse OCHR header: obj_patch_count (LE16)
  lda.l SCUMM.ochrData
  sta.w SCUMM.ochrObjCount

  plp
  rtl

_ochr.tooLarge:
  ;with ROM, no need to drain — just skip

_ochr.none:
  plp
  rtl

.ends


;===================================================================
; room.applyVisibleObjectPatches — apply patches for all objects
; whose objectState != 0 (called once at room load time after
; tilemap is loaded into SCROLL_TILEMAP_WRAM).
;
; Iterates the OCHR index, checks each object's state, applies
; patches to SCROLL_TILEMAP_WRAM for visible objects.
;===================================================================
.bank 5 slot 0
.base BSL
.section "room applyVisibleObjPatches" free

room.applyVisibleObjectPatches:
  php
  rep #$31

  lda.w SCUMM.ochrObjCount
  beq _avop.done

  ;walk OCHR index: starts at offset 4 (after 4-byte header)
  ;each index entry: obj_id(LE16) + patch_offset(LE16) = 4 bytes
  ;data section starts at: 4 + ochrObjCount * 4

  lda.w SCUMM.ochrObjCount
  asl a
  asl a
  clc
  adc #4                        ;data_start = 4 + count * 4
  sta.b tmp+4                   ;tmp+4 = data section offset within OCHR blob

  lda.w SCUMM.ochrObjCount
  sta.b tmp+6                   ;loop counter
  lda #4
  sta.b tmp+8                   ;index read offset (starts at 4)

_avop.loop:
  ;read index entry
  ldx.b tmp+8
  lda.l SCUMM.ochrData,x      ;obj_id
  sta.b tmp                     ;save obj_id
  lda.l SCUMM.ochrData+2,x    ;patch_offset (relative to data section)
  sta.b tmp+2                   ;save patch_offset

  ;advance index pointer
  lda.b tmp+8
  clc
  adc #4
  sta.b tmp+8

  ;check if this object is visible (objectState != 0)
  ldx.b tmp                     ;obj_id
  sep #$20
.ACCU 8
  lda.w SCUMM.objectState,x
  rep #$20
.ACCU 16
  and #$00FF
  beq _avop.next                ;state == 0, skip

  ;apply this object's patches
  ;absolute offset in OCHR blob = data_start + patch_offset
  lda.b tmp+4
  clc
  adc.b tmp+2
  tax                           ;X = absolute offset to this object's patch data
  jsr room.applyPatchesAtX

_avop.next:
  dec.b tmp+6
  bne _avop.loop

_avop.done:
  plp
  rtl


;--- Helper: apply patches starting at OCHR blob offset X ---
;Reads patch_count, then iterates patches writing obj_words
;to SCROLL_TILEMAP_WRAM at (col * height_tiles + row) * 2.
;
; X = byte offset within SCUMM.ochrData to start of patch blob
; Clobbers: A, X, Y, tmp+10..tmp+18
room.applyPatchesAtX:
  rep #$31

  ;read patch header
  sep #$20
.ACCU 8
  lda.l SCUMM.ochrData,x      ;patch_count
  rep #$20
.ACCU 16
  and #$00FF
  beq _apX.ret
  sta.b tmp+10                  ;patch_count

  ;skip 4-byte header (count, col_min, col_max, reserved)
  txa
  clc
  adc #4
  sta.b tmp+12                  ;offset to first patch entry

  ;iterate patches: each is {col(u8), row(u8), obj_word(LE16)} = 4 bytes
  lda.b tmp+10
  sta.b tmp+14                  ;loop counter

_apX.patchLoop:
  ldx.b tmp+12
  ;read col
  sep #$20
.ACCU 8
  lda.l SCUMM.ochrData,x
  rep #$20
.ACCU 16
  and #$00FF
  sta.b tmp+16                  ;col

  ;read row
  sep #$20
.ACCU 8
  lda.l SCUMM.ochrData+1,x
  rep #$20
.ACCU 16
  and #$00FF
  sta.b tmp+18                  ;row

  ;read obj_word
  lda.l SCUMM.ochrData+2,x

  ;compute WRAM offset: (col * height_tiles + row) * 2
  pha                           ;save obj_word
  lda.b tmp+16                  ;col
  ;multiply col * height_tiles (shift-add, height_tiles in WRAM)
  phy
  tay                           ;Y = col (multiplicand counter)
  lda #0
  beq _apX.mulTest
_apX.mulAdd:
  clc
  adc.w GLOBAL.room.roomHeightTiles
_apX.mulTest:
  dey
  bpl _apX.mulAdd
  ;A = col * height_tiles
  clc
  adc.b tmp+18                  ;+ row
  asl a                         ;* 2 (word offset)
  ply
  tax                           ;X = WRAM byte offset

  pla                           ;obj_word
  sta.l SCROLL_TILEMAP_WRAM,x   ;write composited word

  ;advance to next patch entry
  lda.b tmp+12
  clc
  adc #4
  sta.b tmp+12

  dec.b tmp+14
  bne _apX.patchLoop

_apX.ret:
  rts

.ends


;===================================================================
; room.removeObjectPatch — restore background tilemap words for one
; object. Reads bg_words from the patch blob and writes them back
; to SCROLL_TILEMAP_WRAM. Sets dirty flag.
;
; Input: A = obj_id (16-bit)
; Clobbers: tmp+0..tmp+22
;===================================================================
.bank 5 slot 0
.base BSL
.section "room removeObjectPatch" free

room.removeObjectPatch:
  php
  rep #$31

  sta.b tmp                     ;obj_id

  ;find this object in the OCHR index
  lda.w SCUMM.ochrObjCount
  bne _rop.hasData
  jmp _rop.done
_rop.hasData:
  sta.b tmp+6                   ;loop counter

  ;data section offset
  asl a
  asl a
  clc
  adc #4
  sta.b tmp+4                   ;data_start

  lda #4
  sta.b tmp+8                   ;index offset

_rop.search:
  ldx.b tmp+8
  lda.l SCUMM.ochrData,x      ;obj_id from index
  cmp.b tmp
  beq _rop.found

  lda.b tmp+8
  clc
  adc #4
  sta.b tmp+8
  dec.b tmp+6
  bne _rop.search
  jmp _rop.done                 ;not found

_rop.found:
  ;get patch data offset
  lda.l SCUMM.ochrData+2,x    ;patch_offset
  clc
  adc.b tmp+4                   ;+ data_start = absolute offset
  tax

  ;read patch_count from blob header
  sep #$20
.ACCU 8
  lda.l SCUMM.ochrData,x
  rep #$20
.ACCU 16
  and #$00FF
  bne _rop.hasPatches
  jmp _rop.done
_rop.hasPatches:
  sta.b tmp+10                  ;patch_count

  ;read col_min, col_max for dirty tracking — merge with existing range
  sep #$20
.ACCU 8
  lda.l SCUMM.ochrData+1,x    ;col_min (new)
  rep #$20
.ACCU 16
  and #$00FF
  pha                           ;push new col_min
  sep #$20
.ACCU 8
  lda.l SCUMM.ochrData+2,x    ;col_max (new)
  rep #$20
.ACCU 16
  and #$00FF
  pha                           ;push new col_max

  lda.w SCUMM.objDirtyFlag
  beq _rop.dirtyFirst
  ;merge: colMin = min(existing, new)
  lda 3,s                       ;new col_min
  cmp.w SCUMM.objDirtyColMin
  bcs _rop.minOk
  sta.w SCUMM.objDirtyColMin
_rop.minOk:
  ;merge: colMax = max(existing, new)
  lda 1,s                       ;new col_max
  cmp.w SCUMM.objDirtyColMax
  bcc _rop.maxOk
  beq _rop.maxOk
  sta.w SCUMM.objDirtyColMax
_rop.maxOk:
  bra _rop.dirtyDone

_rop.dirtyFirst:
  ;first patch this frame — set all fields
  lda 3,s                       ;new col_min
  sta.w SCUMM.objDirtyColMin
  lda 1,s                       ;new col_max
  sta.w SCUMM.objDirtyColMax

_rop.dirtyDone:
  pla                           ;discard col_max
  pla                           ;discard col_min

  ;offset to patch entries = blobOffset + 4
  txa
  clc
  adc #4
  sta.b tmp+12                  ;patches start

  ;offset to bg_words = patches start + patch_count * 4
  lda.b tmp+10
  asl a
  asl a
  clc
  adc.b tmp+12
  sta.b tmp+14                  ;bg_words start

  ;iterate: read bg_word, compute WRAM offset from patch entry, write
  lda.b tmp+10
  sta.b tmp+16                  ;loop counter

_rop.loop:
  ;read col, row from patch entry
  ldx.b tmp+12
  sep #$20
.ACCU 8
  lda.l SCUMM.ochrData,x      ;col
  rep #$20
.ACCU 16
  and #$00FF
  sta.b tmp+18                  ;col

  sep #$20
.ACCU 8
  lda.l SCUMM.ochrData+1,x    ;row
  rep #$20
.ACCU 16
  and #$00FF
  sta.b tmp+20                  ;row

  ;read bg_word
  ldx.b tmp+14
  lda.l SCUMM.ochrData,x

  ;compute WRAM offset: (col * heightTiles + row) * 2
  pha
  lda.b tmp+18                  ;col
  phy
  tay
  lda #0
  beq _rop.mulTest
_rop.mulAdd:
  clc
  adc.w GLOBAL.room.roomHeightTiles
_rop.mulTest:
  dey
  bpl _rop.mulAdd
  clc
  adc.b tmp+20                  ;+ row
  asl a
  ply
  tax

  pla                           ;bg_word
  sta.l SCROLL_TILEMAP_WRAM,x

  ;advance
  lda.b tmp+12
  clc
  adc #4
  sta.b tmp+12

  lda.b tmp+14
  clc
  adc #2
  sta.b tmp+14

  dec.b tmp+16
  bne _rop.loop

  ;set dirty flag + objDirtyNext on first patch
  lda.w SCUMM.objDirtyFlag
  bne _rop.skipNext
  lda.w SCUMM.objDirtyColMin
  sta.w SCUMM.objDirtyNext
_rop.skipNext:
  lda #1
  sta.w SCUMM.objDirtyFlag

_rop.done:
  plp
  rtl

.ends


;===================================================================
; room.applyObjectPatch — write composited tilemap words for one
; object into SCROLL_TILEMAP_WRAM. Sets dirty flag.
;
; Input: A = obj_id (16-bit)
; Clobbers: tmp+0..tmp+22
;===================================================================
.bank 5 slot 0
.base BSL
.section "room applyObjectPatch" free

room.applyObjectPatch:
  php
  rep #$31

  sta.b tmp                     ;obj_id

  ;find this object in the OCHR index
  lda.w SCUMM.ochrObjCount
  bne _aop.hasData
  jmp _aop.done
_aop.hasData:
  sta.b tmp+6

  ;data section offset
  asl a
  asl a
  clc
  adc #4
  sta.b tmp+4

  lda #4
  sta.b tmp+8

_aop.search:
  ldx.b tmp+8
  lda.l SCUMM.ochrData,x
  cmp.b tmp
  beq _aop.found

  lda.b tmp+8
  clc
  adc #4
  sta.b tmp+8
  dec.b tmp+6
  bne _aop.search
  bra _aop.done

_aop.found:
  ;get absolute blob offset
  lda.l SCUMM.ochrData+2,x
  clc
  adc.b tmp+4
  tax

  ;read col_min/col_max for dirty tracking — merge with existing range
  sep #$20
.ACCU 8
  lda.l SCUMM.ochrData+1,x    ;col_min (new)
  rep #$20
.ACCU 16
  and #$00FF
  pha                           ;push new col_min
  sep #$20
.ACCU 8
  lda.l SCUMM.ochrData+2,x    ;col_max (new)
  rep #$20
.ACCU 16
  and #$00FF
  pha                           ;push new col_max

  lda.w SCUMM.objDirtyFlag
  beq _aop.dirtyFirst
  ;merge: colMin = min(existing, new)
  lda 3,s                       ;new col_min
  cmp.w SCUMM.objDirtyColMin
  bcs _aop.minOk
  sta.w SCUMM.objDirtyColMin
_aop.minOk:
  ;merge: colMax = max(existing, new)
  lda 1,s                       ;new col_max
  cmp.w SCUMM.objDirtyColMax
  bcc _aop.maxOk
  beq _aop.maxOk
  sta.w SCUMM.objDirtyColMax
_aop.maxOk:
  bra _aop.dirtyDone

_aop.dirtyFirst:
  ;first patch this frame — set all fields
  lda 3,s                       ;new col_min
  sta.w SCUMM.objDirtyColMin
  lda 1,s                       ;new col_max
  sta.w SCUMM.objDirtyColMax

_aop.dirtyDone:
  pla                           ;discard col_max
  pla                           ;discard col_min

  ;apply patches using shared helper
  jsr room.applyPatchesAtX

  ;set dirty flag + objDirtyNext on first patch
  lda.w SCUMM.objDirtyFlag
  bne _aop.skipNext
  lda.w SCUMM.objDirtyColMin
  sta.w SCUMM.objDirtyNext
_aop.skipNext:
  lda #1
  sta.w SCUMM.objDirtyFlag

_aop.done:
  plp
  rtl

.ends


;===================================================================
; room.refreshObjectColumns — instant VRAM refresh for dirty columns
; after OCHR patches change object visibility. Enters force blank,
; processes ALL dirty columns with direct VRAM DMA writes, then
; restores display. Called per-frame from play loop.
; Must be in bank 0 to use jsr room.stageColumnForNmi.
;===================================================================
.base BSL
.bank 0 slot 0
.section "room refreshObjectColumns" free

room.refreshObjectColumns:
  php
  rep #$31

  lda.w SCUMM.objDirtyFlag
  bne _roc.hasDirty
  jmp _roc.done
_roc.hasDirty:

  ;--- enter force blank for direct VRAM access ---
  ; Save brightness BEFORE core.nmi.stop (which zeros ScreenBrightness)
  sep #$20
  .ACCU 8
  lda.w ScreenBrightness
  pha                             ;save brightness
  rep #$20

  sei                             ;block IRQ
  jsr core.nmi.stop               ;disable NMI

  sep #$20
  .ACCU 8
  lda.w GLOBAL.HDMA.CHANNEL.ENABLE
  pha                             ;save HDMA channels
  lda #0
  sta.w GLOBAL.HDMA.CHANNEL.ENABLE
  sta.l HDMAEN                    ;kill HDMA (runs during force blank!)
  lda.b #INIDSP_FORCE_BLANK
  sta.l INIDSP                    ;force blank on

  ;clear any pending NMI flags from syncScroll — we will overwrite
  ;the staging buffers, so NMI must not transfer stale data
  stz.w GLOBAL.room.nmiColFlag
  stz.w GLOBAL.room.nmiTileFlag

  rep #$20
  .ACCU 16

  ;--- process all dirty columns (may do 2 passes if flag==2) ---
_roc.passLoop:
_roc.colLoop:
  .ACCU 16
  .INDEX 16

  ;reset staging counters for this column
  stz.w GLOBAL.room.nmiTileCount
  stz.w GLOBAL.room.nmiTileStageLen

  ;stage this column (cache-miss handling + tilemap remap)
  lda.w SCUMM.objDirtyNext
  jsr room.stageColumnForNmi

  ;--- flush staged tile data to VRAM via DMA ch7 ---
  rep #$31
  lda.w GLOBAL.room.nmiTileCount
  beq _roc.noTiles

  sep #$20
  .ACCU 8
  lda.b #VMAIN_INCREMENT_MODE
  sta.l VMAIN
  lda.b #$01                     ;A->B, increment A, 2-register write
  sta.l DMAP7
  lda.b #$18                     ;B-bus: VMDATAL
  sta.l DMADEST7
  lda.b #$7F                     ;source bank: $7F
  sta.l DMASRC7B
  rep #$20
  .ACCU 16

  ldx #0                         ;VRAM address array offset
  ldy #0                         ;staging buffer offset

_roc.tileDmaLoop:
  .ACCU 16
  .INDEX 16
  phx
  lda.l SCROLL_NMI_SLOTS_WRAM,x
  sta.l VMADDL
  plx

  tya
  clc
  adc #SCROLL_TILE_STAGE_WRAM & $ffff
  sta.l DMASRC7L

  lda #32
  sta.l DMALEN7L

  sep #$20
  .ACCU 8
  lda.b #$80
  sta.l MDMAEN
  rep #$20
  .ACCU 16

  tya
  clc
  adc #32
  tay
  inx
  inx

  dec.w GLOBAL.room.nmiTileCount
  bne _roc.tileDmaLoop

_roc.noTiles:
  .ACCU 16
  .INDEX 16

  ;--- flush staged tilemap column to VRAM via DMA ch7 ---
  sep #$20
  .ACCU 8
  lda.b #VMAIN_INCREMENT_MODE | VMAIN_INCREMENT_32
  sta.l VMAIN
  rep #$20
  .ACCU 16

  lda.w GLOBAL.room.nmiColVramAddr
  sta.l VMADDL

  sep #$20
  .ACCU 8
  lda.b #$01                     ;A->B, increment A, 2-register write
  sta.l DMAP7
  lda.b #$18                     ;B-bus: VMDATAL
  sta.l DMADEST7
  lda.b #$7E                     ;source bank: $7E (WRAM)
  sta.l DMASRC7B
  rep #$20
  .ACCU 16

  lda #GLOBAL.room.colStaging & $ffff
  sta.l DMASRC7L

  lda.w GLOBAL.room.nmiColRows
  asl a
  sta.l DMALEN7L

  sep #$20
  .ACCU 8
  lda.b #$80
  sta.l MDMAEN
  rep #$20
  .ACCU 16

  ;--- advance to next column ---
  lda.w SCUMM.objDirtyNext
  inc a
  sta.w SCUMM.objDirtyNext
  cmp.w SCUMM.objDirtyColMax
  bcc _roc.colNext
  beq _roc.colNext
  bra _roc.passDone
_roc.colNext:
  .ACCU 16
  .INDEX 16
  jmp _roc.colLoop

_roc.passDone:

  ;pass complete — check if another pass needed
  lda.w SCUMM.objDirtyFlag
  cmp #2
  bne _roc.clearDirty
  ;first pass done — start second pass
  lda #1
  sta.w SCUMM.objDirtyFlag
  lda.w SCUMM.objDirtyColMin
  sta.w SCUMM.objDirtyNext
  jmp _roc.passLoop

_roc.clearDirty:
  stz.w SCUMM.objDirtyFlag

  ;--- restore VMAIN, HDMA, brightness, interrupts ---
  sep #$20
  .ACCU 8
  lda.b #VMAIN_INCREMENT_MODE
  sta.l VMAIN

  pla                             ;restore HDMA channels
  sta.w GLOBAL.HDMA.CHANNEL.ENABLE
  sta.l HDMAEN
  pla                             ;restore brightness
  sta.w ScreenBrightness
  sta.l INIDSP                    ;exit force blank
  rep #$20
  .ACCU 16

  jsr core.nmi.start              ;re-enable NMI
  cli                             ;re-enable IRQ

_roc.done:
  .ACCU 16
  .INDEX 16
  plp
  rts

.ends


;===================================================================
; room.loadPaletteShadow — read MSU_DATA palette into CGRAM + BW-RAM
; Called via JSL from room.loadPalette during forced blank.
; Writes 256 bytes to both CGRAM port ($2122) and BWRAM_CGRAM_SHADOW.
;===================================================================
.bank 0 slot 0
.section "room palette shadow copy" superfree
.base BSL

room.loadPaletteShadow:
  php
  rep #$31
  .ACCU 16
  .INDEX 16
  ; tmp+24 already set by caller (room.loadPalette in bank 0)

  ; Set CGRAM write address to 0
  sep #$20
  .ACCU 8
  lda #0
  sta.l $002121

  ; Read 256 bytes from ROM, write to CGRAM and BW-RAM shadow
  rep #$10
  .INDEX 16
  ldy #0
  ldx #0
_rps.loop:
  lda [tmp+24],y
  sta.l $002122                     ; CGRAM data port
  sta.l BWRAM_CGRAM_SHADOW,x
  iny
  inx
  cpx #BWRAM_CGRAM_SHADOW_SIZE
  bne _rps.loop

  ; Advance romReadPos past palette
  rep #$20
  .ACCU 16
  lda.w GLOBAL.room.romReadPos_lo
  clc
  adc #BWRAM_CGRAM_SHADOW_SIZE
  sta.w GLOBAL.room.romReadPos_lo
  lda.w GLOBAL.room.romReadPos_hi
  adc #0
  sta.w GLOBAL.room.romReadPos_hi

  plp
  rtl

.ends
