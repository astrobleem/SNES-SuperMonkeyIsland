/**
* Room scroll routines: horizontal scrolling via D-pad,
* tilemap column staging for NMI VRAM writes,
* VRAM tile cache with MSU-1 streaming.
*/

.include "src/object/room/room_scroll.h"
.section "room scroll"


/**
* Return the ZP01 priority bit for a tile, given its WRAM tilemap byte offset.
*
* The priority bitmap is column-major, 1 bit per tile, matching the
* SCROLL_TILEMAP_WRAM layout. For a tile at WRAM byte offset X (16-bit):
*   tile_idx    = X >> 1
*   pri_byte    = tile_idx >> 3 = X >> 4
*   bit_in_byte = tile_idx & 7  = (X >> 1) & 7
*
* Input:  A = WRAM byte offset (16-bit)
* Output: carry = priority bit (0 = background, 1 = foreground)
* Clobbers: A, Y
*/
_scroll.priorityBit:
  .ACCU 16
  .INDEX 16
  phx                            ;preserve caller's X
  phy                            ;preserve caller's Y
  pha                            ;save offset for byte math
  lsr a                          ;A = tile_idx
  and.w #$0007                  ;A = bit_in_byte
  sta.b tmp+28                  ;save bit_in_byte (avoid clobbering Y)
  pla                            ;A = offset
  lsr a
  lsr a
  lsr a
  lsr a                          ;A = pri_byte_idx
  tax                            ;X = byte offset
  sep #$20
  .ACCU 8
  lda.l SCROLL_PRIORITY_WRAM,x  ;A = byte containing the bit
  ldx.b tmp+28                  ;X = bit_in_byte (reuse X as shift count)
_spb.shift:
  cpx #0
  beq _spb.test
  lsr a
  dex
  bra _spb.shift
_spb.test:
  lsr a                          ;carry = bit 0 of byte = priority bit
  rep #$20
  .ACCU 16
  ply                            ;restore caller's Y
  plx                            ;restore caller's X
  rts


/**
* Initialize scroll state after a room is loaded.
*/
room.initScroll:
  php
  rep #$31

  stz.w GLOBAL.room.cameraX
  stz.w GLOBAL.room.cameraXOld

  lda.w GLOBAL.room.hdr.width_tiles
  sta.w GLOBAL.room.roomWidthTiles
  lda.w GLOBAL.room.hdr.height_tiles
  sta.w GLOBAL.room.roomHeightTiles

  lda.w GLOBAL.room.hdr.width_px
  sec
  sbc.w #ROOM_VIEWPORT_WIDTH_PX
  bcs +
    lda #0
+
  .ACCU 16
  .INDEX 16
  sta.w GLOBAL.room.maxScrollX

  sep #$20
  stz.w GLOBAL.room.nmiColFlag
  stz.w GLOBAL.room.nmiBg2ColFlag
  stz.w GLOBAL.room.nmiTileFlag
  stz.w GLOBAL.room.viewportDirty
  stz.w GLOBAL.room.nmiBg2ColFlag
  rep #$20

  stz.w GLOBAL.room.refreshIdx

  plp
  rts


/**
* Initialize tile cache: clear tileIdToSlot and slotToTileId tables.
*/
room.initTileCache:
  php
  rep #$31

  ;start ring buffer at slot 1 (slot 0 is reserved as blank tile)
  lda #1
  sta.w GLOBAL.room.cacheNextSlot
  stz.w GLOBAL.room.cacheMissCount

  ;fill tileIdToSlot[0..2047] with $FFFF
  lda.w #ROOM_TILE_NOT_CACHED
  ldx #0
  ldy.w #ROOM_MAX_LOOKUP_TILES
_initCache.tile2slot:
  .ACCU 16
  .INDEX 16
  sta.l SCROLL_TILE2SLOT_WRAM,x
  inx
  inx
  dey
  bne _initCache.tile2slot

  ;fill slotToTileId[0..895] with $FFFF
  ldx #0
  ldy.w #ROOM_CACHE_SLOTS
_initCache.slot2tile:
  .ACCU 16
  .INDEX 16
  sta.l SCROLL_SLOT2TILE_WRAM,x
  inx
  inx
  dey
  bne _initCache.slot2tile

  plp
  rts


/**
* Allocate a VRAM cache slot (ring buffer, O(1)).
* Evicts old tile if slot occupied.
*
* @param a<16bit> new tile ID to cache
* @return a<16bit> allocated VRAM slot index (0-895)
*/
room.allocCacheSlot:
  php
  rep #$31

  ;save new tile ID
  sta.b tmp+20                  ;newTileId

  ;get current slot
  lda.w GLOBAL.room.cacheNextSlot
  sta.b tmp+22                  ;slot

  ;evict old mapping: oldTileId = slotToTileId[slot]
  asl a                         ;slot * 2 for word index
  tax
  lda.l SCROLL_SLOT2TILE_WRAM,x
  cmp.w #ROOM_TILE_NOT_CACHED
  beq _allocSlot.noEvict

  ;invalidate old: tileIdToSlot[oldTileId] = $FFFF
  asl a                         ;oldTileId * 2
  tax
  lda.w #ROOM_TILE_NOT_CACHED
  sta.l SCROLL_TILE2SLOT_WRAM,x

_allocSlot.noEvict:
  .ACCU 16
  .INDEX 16
  ;write new mappings
  ;slotToTileId[slot] = newTileId
  lda.b tmp+22                  ;slot
  asl a
  tax
  lda.b tmp+20                  ;newTileId
  sta.l SCROLL_SLOT2TILE_WRAM,x

  ;tileIdToSlot[newTileId] = slot
  lda.b tmp+20                  ;newTileId
  asl a
  tax
  lda.b tmp+22                  ;slot
  sta.l SCROLL_TILE2SLOT_WRAM,x

  ;advance ring buffer: cacheNextSlot wraps from 895 to 1 (slot 0 reserved)
  lda.b tmp+22
  inc a
  cmp.w #ROOM_CACHE_SLOTS
  bcc +
    lda #1
+
  .ACCU 16
  .INDEX 16
  sta.w GLOBAL.room.cacheNextSlot

  ;return slot in A
  lda.b tmp+22

  plp
  rts


/**
* Load initial viewport tiles during force blank.
* Two-pass per column:
*   Pass 1: check cache, handle misses (MSU seek + VRAM tile write),
*           buffer remapped tilemap words to colStaging
*   Pass 2: write remapped tilemap column to VRAM (increment-by-32)
*
* tmp+0  = columns remaining
* tmp+2  = WRAM byte offset (advances per column)
* tmp+4  = VRAM tilemap column address
* tmp+6  = staging write offset (reset per column)
* tmp+8  = row counter
* tmp+10 = original tilemap word
* tmp+12 = tileId
* tmp+14 = slot
* tmp+16 = MSU seek addr low (scratch)
*
* Called from room.load while still in force blank.
*/
room.loadInitialViewport:
  php
  rep #$31

  ;clear BG2 room tilemap at VRAM $5800 (1024 words = 32x32)
  ;prevents stale z-plane data from previous room
  sep #$20
  lda.b #VMAIN_INCREMENT_MODE
  sta.l VMAIN
  rep #$20
  lda.w #ROOM_BG2_TILEMAP_VRAM_WORD
  sta.l VMADDL
  ldx #1024
  sep #$20
  lda #0
_initVP.clearBg2:
  sta.l VMDATAL
  sta.l VMDATAH
  dex
  bne _initVP.clearBg2
  rep #$20

  ;how many columns to load: min(widthTiles, 32)
  lda.w GLOBAL.room.roomWidthTiles
  cmp.w #ROOM_VIEWPORT_TILES + 1
  bcc +
    lda.w #ROOM_VIEWPORT_TILES
+
  sta.b tmp                     ;columns remaining

  ;--- Compute start column from camera position ---
  ;startCol = cameraX >> 3 (tile column of left screen edge)
  lda.w GLOBAL.room.cameraX
  lsr a
  lsr a
  lsr a
  sta.b tmp+22                  ;startCol (saved for VRAM addr calc)

  ;clamp columns: if startCol + viewport > widthTiles, reduce count
  clc
  adc.b tmp                     ;startCol + columns
  cmp.w GLOBAL.room.roomWidthTiles
  bcc +
  beq +
    ;reduce columns = widthTiles - startCol
    lda.w GLOBAL.room.roomWidthTiles
    sec
    sbc.b tmp+22
    sta.b tmp                   ;clamped columns remaining
+

  ;compute WRAM offset = startCol * roomHeightTiles * 2
  lda #0
  ldy.b tmp+22
  beq _initVP.mulDone
_initVP.mulLoop:
  clc
  adc.w GLOBAL.room.roomHeightTiles
  dey
  bne _initVP.mulLoop
_initVP.mulDone:
  asl a
  sta.b tmp+2                   ;WRAM tilemap byte offset

  ;compute VRAM start address from startCol
  ;VRAM = ROOM_TILEMAP_VRAM_WORD + (startCol & 31) + ((startCol & 32) ? $0400 : 0)
  lda.b tmp+22
  and.w #$001F                  ;col & 31
  sta.b tmp+4
  lda.b tmp+22
  and.w #$0020                  ;bit 5 = nametable 1
  beq +
    lda.b tmp+4
    clc
    adc.w #$0400
    sta.b tmp+4
+
  lda.b tmp+4
  clc
  adc.w #ROOM_TILEMAP_VRAM_WORD
  sta.b tmp+4                   ;VRAM tilemap column address

_initVP.colLoop:
  .ACCU 16
  .INDEX 16
  lda.b tmp
  bne _initVP.colContinue
  jmp _initVP.done
_initVP.colContinue:
  .ACCU 16
  .INDEX 16

  ;=== Pass 1: cache-check each row, tile-write misses, buffer remap ===
  stz.b tmp+6                   ;staging write offset = 0
  lda.w GLOBAL.room.roomHeightTiles
  sta.b tmp+8                   ;row counter
  ldx.b tmp+2                   ;X = WRAM read offset

_initVP.p1Loop:
  .ACCU 16
  .INDEX 16
  ;read tilemap word from WRAM
  lda.l SCROLL_TILEMAP_WRAM,x
  sta.b tmp+10                  ;original tilemap word
  phx                           ;save WRAM offset

  ;extract tile ID (bits 0-10, custom 11-bit format)
  and.w #$07FF
  sta.b tmp+12                  ;tileId

  ;check cache: tileIdToSlot[tileId]
  asl a
  tax
  lda.l SCROLL_TILE2SLOT_WRAM,x
  cmp.w #ROOM_TILE_NOT_CACHED
  bne _initVP.p1Hit

  ;--- cache miss: allocate slot, MSU seek, write tile to VRAM ---
  lda.b tmp+12                  ;tileId
  jsr room.allocCacheSlot        ;returns slot in A (clobbers X, Y)
  sta.b tmp+14                  ;allocated slot

  ;compute ROM address: tileDataRomOfs + tileId * 32
  ;tileId < 2048, so tileId * 32 fits in 16 bits
  lda.b tmp+12
  asl a
  asl a
  asl a
  asl a
  asl a                          ;A = tileId * 32
  clc
  adc.w GLOBAL.room.tileDataRomOfs_lo
  sta.b tmp+16                  ;ROM addr low
  lda.w #0
  adc.w GLOBAL.room.tileDataRomOfs_hi
  tax                            ;X = ROM addr high
  lda.b tmp+16                  ;A = ROM addr low
  jsr room.setRomDataPtr         ;tmp+24 = 24-bit CPU address

  ;set VMAIN increment-by-1 for tile data write
  sep #$20
  lda.b #VMAIN_INCREMENT_MODE
  sta.l VMAIN
  rep #$20

  ;VRAM word address = slot * 16
  lda.b tmp+14
  asl a
  asl a
  asl a
  asl a
  sta.l VMADDL

  ;phase A: read 32 bytes from ROM into bank $7E staging buffer
  ldx #0
  ldy #0
_initVP.tileStage:
  .ACCU 16
  .INDEX 16
  sep #$20
  lda [tmp+24],y
  sta.w GLOBAL.room.vpTileStaging,x
  rep #$20
  iny
  inx
  cpx #32
  bne _initVP.tileStage

  ;phase B: write 16 words from staging to VRAM (same pattern as Pass 2)
  ldx #0
  ldy #16
_initVP.tileWrite:
  .ACCU 16
  .INDEX 16
  lda.w GLOBAL.room.vpTileStaging,x
  sep #$20
  sta.l VMDATAL
  xba
  sta.l VMDATAH
  rep #$20
  inx
  inx
  dey
  bne _initVP.tileWrite

  lda.b tmp+14                  ;slot
  bra _initVP.p1Remap

_initVP.p1Hit:
  .ACCU 16
  .INDEX 16
  ;A = cached slot

_initVP.p1Remap:
  .ACCU 16
  .INDEX 16
  ;A = VRAM slot index
  sta.b tmp+14

  ;remap custom format → SNES tilemap word + ZP01 priority bit
  ;custom: VH_pppTTTTTTTTTTT → SNES: VHPpppTTTTTTTTTT
  ;slot replaces tile ID; palette shifts from bits 13-11 to 12-10.
  ;Priority bit 13 comes from SCROLL_PRIORITY_WRAM (column-major, 1 bit
  ;per tile). Current WRAM offset is on top of stack via the outer phx.
  lda.b tmp+10                  ;original custom word
  and.w #$C000                  ;V/H flip (bits 15-14)
  sta.b tmp+16                  ;save flip bits
  lda.b tmp+10
  and.w #$3800                  ;palette (bits 13-11)
  lsr a                          ;shift to SNES position (bits 12-10)
  ora.b tmp+14                  ;OR with slot (bits 9-0)
  ora.b tmp+16                  ;OR with flip bits
  sta.b tmp+18                  ;stash partial remapped word

  ;priority bit: tile_idx = WRAM_offset >> 1;
  ;pri_byte_idx = tile_idx >> 3; bit_in_byte = tile_idx & 7.
  ;Use a shared helper so both remap paths agree on the math.
  lda 1,s                        ;peek saved WRAM byte offset (from outer phx)
  jsr _scroll.priorityBit        ;carry = priority bit
  lda.b tmp+18                  ;restore remapped word
  bcc +
    ora.w #$2000                ;set SNES priority bit 13
+

  ;store remapped word to colStaging
  ldy.b tmp+6
  sta.w GLOBAL.room.colStaging,y
  iny
  iny
  sty.b tmp+6

  plx                            ;restore WRAM read offset
  inx
  inx

  dec.b tmp+8
  beq _initVP.p1End
  jmp _initVP.p1Loop
_initVP.p1End:
  .ACCU 16
  .INDEX 16

  ;save advanced WRAM offset for next column
  stx.b tmp+2

  ;=== Pass 1b: BG2 tile cache-miss handling (if hasBg2Mask) ===
  ;Walk the BG2 column; allocate + ROM-load any BG2 tile IDs that BG1 Pass 1
  ;didn't already seed. Without this, Pass 2b looks up $FFFF from the tile
  ;cache and writes garbage slot indices, producing black rectangles at mask
  ;holes. Safe to run during force blank; uses VMAIN=1 for tile writes.
  sep #$20
  lda.w GLOBAL.room.hasBg2Mask
  bne _initVP.p1bEnter
    rep #$20
    jmp _initVP.p1bDone
_initVP.p1bEnter:
  rep #$20

  ;rewind to start of this BG2 column: tmp+2 just got advanced
  lda.b tmp+2
  sec
  sbc.w GLOBAL.room.roomHeightTiles
  sbc.w GLOBAL.room.roomHeightTiles
  tax                               ;X = WRAM offset, start of this column
  lda.w GLOBAL.room.roomHeightTiles
  sta.b tmp+8                       ;row counter

_initVP.p1bLoop:
  .ACCU 16
  .INDEX 16
  lda.l SCROLL_BG2MAP_WRAM,x
  beq _initVP.p1bNext               ;tile 0 = transparent, skip
  and.w #$07FF                      ;tile ID (11-bit custom format)
  sta.b tmp+12

  ;check cache: tileIdToSlot[tileId]
  asl a
  phx                                ;save WRAM offset
  tax
  lda.l SCROLL_TILE2SLOT_WRAM,x
  cmp.w #ROOM_TILE_NOT_CACHED
  beq _initVP.p1bMiss
  plx                                ;cached — restore, skip
  bra _initVP.p1bNext

_initVP.p1bMiss:
  .ACCU 16
  .INDEX 16
  ;allocate slot
  lda.b tmp+12                      ;tileId
  jsr room.allocCacheSlot            ;returns slot in A (clobbers X, Y)
  sta.b tmp+14                      ;allocated slot

  ;compute ROM address: tileDataRomOfs + tileId * 32
  lda.b tmp+12
  asl a
  asl a
  asl a
  asl a
  asl a                              ;A = tileId * 32
  clc
  adc.w GLOBAL.room.tileDataRomOfs_lo
  sta.b tmp+16
  lda.w #0
  adc.w GLOBAL.room.tileDataRomOfs_hi
  tax
  lda.b tmp+16
  jsr room.setRomDataPtr             ;tmp+24 = 24-bit CPU address

  ;VMAIN increment-by-1 for tile data write
  sep #$20
  lda.b #VMAIN_INCREMENT_MODE
  sta.l VMAIN
  rep #$20

  ;VRAM word address = slot * 16
  lda.b tmp+14
  asl a
  asl a
  asl a
  asl a
  sta.l VMADDL

  ;read 32 bytes from ROM into staging buffer
  ldx #0
  ldy #0
_initVP.p1bStage:
  .ACCU 16
  .INDEX 16
  sep #$20
  lda [tmp+24],y
  sta.w GLOBAL.room.vpTileStaging,x
  rep #$20
  iny
  inx
  cpx #32
  bne _initVP.p1bStage

  ;write 16 words from staging to VRAM
  ldx #0
  ldy #16
_initVP.p1bWrite:
  .ACCU 16
  .INDEX 16
  lda.w GLOBAL.room.vpTileStaging,x
  sep #$20
  sta.l VMDATAL
  xba
  sta.l VMDATAH
  rep #$20
  inx
  inx
  dey
  bne _initVP.p1bWrite

  plx                                ;restore WRAM offset

_initVP.p1bNext:
  .ACCU 16
  .INDEX 16
  inx
  inx
  dec.b tmp+8
  beq _initVP.p1bDone
  jmp _initVP.p1bLoop

_initVP.p1bDone:
  .ACCU 16
  .INDEX 16

  ;=== Pass 2: write remapped tilemap column to VRAM ===
  ;handle nametable wrapping: NT0→NT1 or NT1→NT0
  lda.b tmp+4
  cmp.w #ROOM_TILEMAP_VRAM_WORD + $0400 + 32
  bcc _initVP.noWrapNT1
    ;past end of NT1 → wrap to NT0
    lda.w #ROOM_TILEMAP_VRAM_WORD
    sta.b tmp+4
    bra _initVP.ntOk
_initVP.noWrapNT1:
  cmp.w #ROOM_TILEMAP_VRAM_WORD + $0020  ;$3820 — past end of NT0?
  bcc _initVP.ntOk                       ;below boundary → no wrap
  cmp.w #ROOM_TILEMAP_VRAM_WORD + $0400  ;$3C00 — already in NT1?
  bcs _initVP.ntOk                       ;already NT1+ → no wrap
    ;at or past end of NT0, not yet NT1 → wrap to NT1
    lda.w #ROOM_TILEMAP_VRAM_WORD + $0400
    sta.b tmp+4
_initVP.ntOk:

  ;set VMAIN increment-by-32 for vertical tilemap column
  sep #$20
  lda.b #VMAIN_INCREMENT_MODE | VMAIN_INCREMENT_32
  sta.l VMAIN
  rep #$20

  ;set VRAM address for this column
  lda.b tmp+4
  sta.l VMADDL

  ;write heightTiles words from colStaging
  ldx #0
  ldy.w GLOBAL.room.roomHeightTiles
_initVP.p2Loop:
  .ACCU 16
  .INDEX 16
  lda.w GLOBAL.room.colStaging,x
  sep #$20
  sta.l VMDATAL
  xba
  sta.l VMDATAH
  rep #$20
  inx
  inx
  dey
  bne _initVP.p2Loop

  ;=== Pass 2b: write BG2 z-plane column to VRAM (if hasBg2Mask) ===
  sep #$20
  lda.w GLOBAL.room.hasBg2Mask
  beq _initVP.bg2Skip8
  rep #$20

  ;BG2 VRAM address: room tilemap at $5800 + row 13 offset (yScroll=110)
  lda.b tmp+4
  and.w #$001F
  clc
  adc.w #ROOM_BG2_TILEMAP_VRAM_WORD + (ROOM_BG2_ROW_OFFSET * 32)
  sta.l VMADDL

  ;walk the BG2 column from SCROLL_BG2MAP_WRAM at same WRAM offset as BG1
  ;tmp+2 is already advanced past this column; rewind by height_tiles*2
  lda.b tmp+2
  sec
  sbc.w GLOBAL.room.roomHeightTiles
  sbc.w GLOBAL.room.roomHeightTiles
  tax                              ;X = start of this column in BG2 WRAM
  ldy.w GLOBAL.room.roomHeightTiles
_initVP.bg2Loop:
  lda.l SCROLL_BG2MAP_WRAM,x
  beq _initVP.bg2Zero
  ;remap custom → SNES: tile ID → slot, palette shift, flip; no priority
  pha                              ;save original word
  and.w #$07FF                    ;tile ID
  asl a
  phx
  tax
  lda.l SCROLL_TILE2SLOT_WRAM,x   ;slot
  sta.b tmp+20                    ;save slot
  plx
  pla                              ;restore original word
  pha
  and.w #$C000                    ;flip bits
  sta.b tmp+22
  pla
  and.w #$3800                    ;palette
  lsr a                            ;shift to SNES position
  ora.b tmp+20                    ;OR slot
  ora.b tmp+22                    ;OR flip
  bra _initVP.bg2Write
_initVP.bg2Zero:
  lda #0
_initVP.bg2Write:
  sep #$20
  sta.l VMDATAL
  xba
  sta.l VMDATAH
  rep #$20
  inx
  inx
  dey
  bne _initVP.bg2Loop
  bra _initVP.bg2Skip
_initVP.bg2Skip8:
  rep #$20
_initVP.bg2Skip:

  ;advance VRAM tilemap column address
  lda.b tmp+4
  inc a
  sta.b tmp+4

  ;decrement columns remaining
  lda.b tmp
  dec a
  sta.b tmp
  jmp _initVP.colLoop

_initVP.done:
  .ACCU 16
  .INDEX 16
  ;restore VMAIN to increment-by-1
  sep #$20
  lda.b #VMAIN_INCREMENT_MODE
  sta.l VMAIN
  rep #$20

  plp
  rts


/**
* Force-blank viewport reload for large camera jumps.
* Called from syncScroll when camera moved by >4 tile columns in one frame.
* Enters force blank, reinits tile cache, reloads all visible columns,
* then exits force blank. Safe to call during gameplay.
*/
room.reloadViewport:
  php
  rep #$31

  ;save brightness BEFORE core.nmi.stop (which zeros ScreenBrightness)
  sep #$20
  lda.w ScreenBrightness
  pha                             ;save brightness
  rep #$20

  ;block all interrupts for safe VRAM access
  sei
  jsr core.nmi.stop

  ;save HDMA state
  sep #$20
  lda.w GLOBAL.HDMA.CHANNEL.ENABLE
  pha                             ;save HDMA

  ;enter force blank, kill HDMA
  lda #0
  sta.w GLOBAL.HDMA.CHANNEL.ENABLE
  sta.l HDMAEN                    ;HDMA runs during force blank — must disable
  lda.b #INIDSP_FORCE_BLANK
  sta.l INIDSP

  ;clear pending NMI staging (we will overwrite VRAM directly)
  stz.w GLOBAL.room.nmiColFlag
  stz.w GLOBAL.room.nmiBg2ColFlag
  stz.w GLOBAL.room.nmiTileFlag
  rep #$20
  stz.w GLOBAL.room.nmiTileCount
  stz.w GLOBAL.room.nmiTileStageLen

  ;reinit tile cache + reload all visible columns at current cameraX
  jsr room.initTileCache
  jsr room.loadInitialViewport

  ;restore HDMA + brightness
  sep #$20
  pla                             ;saved HDMA
  sta.w GLOBAL.HDMA.CHANNEL.ENABLE ;NMI will re-enable at next VBlank
  pla                             ;saved brightness
  sta.w ScreenBrightness
  sta.l INIDSP                    ;exit force blank with original brightness

  ;re-enable interrupts
  rep #$20
  jsr core.nmi.start
  cli

  plp
  rts

room.reloadViewport_long:
  jsr room.reloadViewport
  rtl


/**
* Remap viewport tilemap in VRAM for a camera snap.
* Rewrites all 32 viewport tilemap columns using existing cache slots.
* Tiles not yet in cache are loaded from MSU-1 on the spot.
* Must be called in force blank (caller handles blank entry/exit).
*/
room.remapViewport:
  php
  rep #$31

  ;save brightness BEFORE core.nmi.stop (which zeros ScreenBrightness)
  sep #$20
  lda.w ScreenBrightness
  pha
  rep #$31

  ;block interrupts for safe VRAM writes
  sei
  jsr core.nmi.stop

  ;save HDMA state and disable
  sep #$20
  lda.w GLOBAL.HDMA.CHANNEL.ENABLE
  pha
  lda #0
  sta.w GLOBAL.HDMA.CHANNEL.ENABLE
  sta.l HDMAEN
  lda.b #INIDSP_FORCE_BLANK
  sta.l INIDSP

  ;clear pending NMI staging
  stz.w GLOBAL.room.nmiColFlag
  stz.w GLOBAL.room.nmiBg2ColFlag
  stz.w GLOBAL.room.nmiTileFlag
  rep #$20
  stz.w GLOBAL.room.nmiTileCount
  stz.w GLOBAL.room.nmiTileStageLen

  ;just call loadInitialViewport — it handles cache hits (fast path)
  ;and cache misses (MSU seek + VRAM write). Tile data already cached
  ;for most tiles, so this is fast.
  jsr room.loadInitialViewport

  ;restore HDMA + brightness
  sep #$20
  pla
  sta.w GLOBAL.HDMA.CHANNEL.ENABLE
  pla
  sta.w ScreenBrightness
  sta.l INIDSP

  ;re-enable interrupts
  rep #$20
  jsr core.nmi.start
  cli

  plp
  rts


/**
* Per-frame scroll sync. Uses GLOBAL.room.cameraX (set by
* scummvm.moveCamera) to drive BG1 scrolling and tile streaming.
* Detects tile boundary crossings, stages new columns for NMI.
*/
room.syncScroll:
  php
  rep #$31

  lda.w GLOBAL.room.maxScrollX
  bne _syncScroll.canScroll
  jmp _syncScroll.done
_syncScroll.canScroll:
  .ACCU 16
  .INDEX 16

  ;clamp cameraX to [0, maxScrollX]
  lda.w GLOBAL.room.cameraX
  bpl +
    stz.w GLOBAL.room.cameraX
+
  .ACCU 16
  .INDEX 16
  lda.w GLOBAL.room.cameraX
  cmp.w GLOBAL.room.maxScrollX
  bcc +
  beq +
    lda.w GLOBAL.room.maxScrollX
    sta.w GLOBAL.room.cameraX
+
  .ACCU 16
  .INDEX 16

  ;apply to PPU scroll register
  lda.w GLOBAL.room.cameraX
  sta.w xScrollBG1

  ;setCameraAt snap pending? reload viewport now (safe: currentRoom is stable here)
  sep #$20                              ; 8-bit for byte read
  lda.w GLOBAL.room.viewportDirty
  rep #$20                              ; restore 16-bit
  beq _syncScroll.noDirty
    sep #$20
    stz.w GLOBAL.room.viewportDirty     ; clear flag (8-bit stz = 1 byte only)
    rep #$20
    jsr room.reloadViewport
    lda.w GLOBAL.room.cameraX
    sta.w GLOBAL.room.cameraXOld        ; sync so boundary-detection sees delta=0
_syncScroll.noDirty:

  ;boundary detection (old tile col vs new)
  lda.w GLOBAL.room.cameraXOld
  lsr a
  lsr a
  lsr a
  sta.b tmp

  lda.w GLOBAL.room.cameraX
  lsr a
  lsr a
  lsr a
  sta.b tmp+2

  lda.b tmp+2
  cmp.b tmp
  beq _syncScroll.bgRefresh

  lda.b tmp+2
  cmp.b tmp
  bcc _syncScroll.scrolledLeft

  ;scrolled right — stage rightmost visible column
  lda.w GLOBAL.room.cameraX
  clc
  adc.w #ROOM_VIEWPORT_WIDTH_PX - 1
  lsr a
  lsr a
  lsr a
  cmp.w GLOBAL.room.roomWidthTiles
  bcc +
    lda.w GLOBAL.room.roomWidthTiles
    dec a
+
  .ACCU 16
  .INDEX 16
  jsr room.stageColumnForNmi
  stz.w GLOBAL.room.refreshIdx
  bra _syncScroll.updateOld

_syncScroll.scrolledLeft:
  .ACCU 16
  .INDEX 16
  lda.b tmp+2
  jsr room.stageColumnForNmi
  stz.w GLOBAL.room.refreshIdx
  bra _syncScroll.updateOld

_syncScroll.bgRefresh:
  .ACCU 16
  .INDEX 16
  ;skip bgRefresh while OCHR dirty processing is active
  lda.w SCUMM.objDirtyFlag
  bne _syncScroll.bgRefreshSkip
  ;no boundary crossing — refresh one viewport column in background
  lda.w GLOBAL.room.cameraX
  lsr a
  lsr a
  lsr a                              ;leftCol = cameraX >> 3
  clc
  adc.w GLOBAL.room.refreshIdx       ;refreshCol = leftCol + refreshIdx
  cmp.w GLOBAL.room.roomWidthTiles
  bcs _syncScroll.bgRefreshSkip      ;out of bounds, skip
  jsr room.stageColumnForNmi
_syncScroll.bgRefreshSkip:
  .ACCU 16
  .INDEX 16
  lda.w GLOBAL.room.refreshIdx
  inc a
  cmp.w #ROOM_VIEWPORT_TILES         ;wrap at 32
  bcc +
    lda #0
+
  .ACCU 16
  .INDEX 16
  sta.w GLOBAL.room.refreshIdx

_syncScroll.updateOld:
  .ACCU 16
  .INDEX 16
  lda.w GLOBAL.room.cameraX
  cmp.w GLOBAL.room.cameraXOld
  beq _syncScroll.done              ;already synced
  bcc _syncScroll.advanceLeft

  ;camera moved right: old = min(old + 8, cameraX)
  lda.w GLOBAL.room.cameraXOld
  clc
  adc #8
  cmp.w GLOBAL.room.cameraX
  bcc +
  beq +
    lda.w GLOBAL.room.cameraX       ;clamp to target
+
  sta.w GLOBAL.room.cameraXOld
  bra _syncScroll.done

_syncScroll.advanceLeft:
  ;camera moved left: old = max(old - 8, cameraX)
  lda.w GLOBAL.room.cameraXOld
  sec
  sbc #8
  bcc _syncScroll.clampLeft         ;underflow — clamp to cameraX
  cmp.w GLOBAL.room.cameraX
  bcs +                             ;old-8 >= cameraX — use old-8
_syncScroll.clampLeft:
    lda.w GLOBAL.room.cameraX       ;clamp to target
+
  sta.w GLOBAL.room.cameraXOld

_syncScroll.done:
  .ACCU 16
  .INDEX 16
  plp
  rts


/**
* Stage a single tilemap column for NMI VRAM write.
* Cache-aware: checks each tile, MSU-1 seeks for cache misses.
* Remaps tilemap entries to use VRAM cache slots.
*
* Pass 1: handle cache misses — allocate slots, MSU read to staging buffer
* Pass 2: remap all tilemap entries, store to colStaging for NMI
*
* tmp+6  = tile data staging byte offset (persists across rows)
* tmp+8  = VRAM addr array byte offset (persists across rows)
* tmp+10 = column index
* tmp+12 = WRAM byte offset
* tmp+14 = row counter (per pass)
* tmp+16 = tileId (per row)
* tmp+18 = slot (per row)
*
* @param a<16bit> room column index to write
*/
room.stageColumnForNmi:
  php
  rep #$31

  sta.b tmp+10                  ;column index

  ;--- compute WRAM source offset: col * heightTiles * 2 ---
  sta.b tmp+12
  lda #0
  ldy.b tmp+12
  beq _stageCol.mulDone
_stageCol.mulLoop:
  .ACCU 16
  .INDEX 16
  clc
  adc.w GLOBAL.room.roomHeightTiles
  dey
  bne _stageCol.mulLoop
_stageCol.mulDone:
  .ACCU 16
  .INDEX 16
  asl a
  sta.b tmp+12                  ;WRAM byte offset

  ;--- Pass 1: handle cache misses, stage tile data for NMI ---
  ;Initialize staging offsets from current accumulated values
  ;(per-frame reset done in SCUMM play loop before callers run)
  lda.w GLOBAL.room.nmiTileStageLen
  sta.b tmp+6                   ;tile data staging byte offset
  lda.w GLOBAL.room.nmiTileCount
  asl a                         ;* 2 for word offset
  sta.b tmp+8                   ;VRAM addr array byte offset

  ldx.b tmp+12                  ;X = WRAM source offset
  lda.w GLOBAL.room.roomHeightTiles
  sta.b tmp+14                  ;row counter

_stageCol.p1Loop:
  .ACCU 16
  .INDEX 16
  lda.l SCROLL_TILEMAP_WRAM,x
  and.w #$07FF                  ;extract tileId (11-bit custom format)
  sta.b tmp+16                  ;save tileId
  phx                            ;save WRAM offset

  ;check cache: tileIdToSlot[tileId]
  asl a
  tax
  lda.l SCROLL_TILE2SLOT_WRAM,x
  cmp.w #ROOM_TILE_NOT_CACHED
  bne _stageCol.p1Skip

  ;--- cache miss: allocate slot ---
  lda.b tmp+16                  ;tileId
  jsr room.allocCacheSlot        ;returns slot in A (clobbers X, Y)
  sta.b tmp+18                  ;allocated slot

  ;record VRAM word address for NMI: slot * 16
  asl a
  asl a
  asl a
  asl a
  ldx.b tmp+8                   ;VRAM addr array offset
  sta.l SCROLL_NMI_SLOTS_WRAM,x
  inx
  inx
  stx.b tmp+8

  ;ROM read: tileDataRomOfs + tileId * 32
  lda.b tmp+16                  ;tileId
  asl a
  asl a
  asl a
  asl a
  asl a                          ;tileId * 32 (fits 16 bits)
  clc
  adc.w GLOBAL.room.tileDataRomOfs_lo
  pha                            ;push ROM addr low
  lda.w #0
  adc.w GLOBAL.room.tileDataRomOfs_hi
  tax                            ;X = ROM addr high
  pla                            ;A = ROM addr low
  jsr room.setRomDataPtr         ;tmp+24 = 24-bit CPU address

  ;read 32 bytes from ROM to tile staging buffer
  ldx.b tmp+6                   ;staging byte offset
  ldy #0
_stageCol.tileRead:
  .ACCU 16
  .INDEX 16
  sep #$20
  lda [tmp+24],y
  sta.l SCROLL_TILE_STAGE_WRAM,x
  rep #$20
  iny
  inx
  cpy #32
  bne _stageCol.tileRead
  stx.b tmp+6                   ;update staging offset

  ;increment tile count
  lda.w GLOBAL.room.nmiTileCount
  inc a
  sta.w GLOBAL.room.nmiTileCount

_stageCol.p1Skip:
  .ACCU 16
  .INDEX 16
  plx                            ;restore WRAM offset
  inx
  inx
  dec.b tmp+14                   ;row counter
  beq _stageCol.p1Done
  jmp _stageCol.p1Loop
_stageCol.p1Done:
  .ACCU 16
  .INDEX 16

  ;save staging length
  lda.b tmp+6
  sta.w GLOBAL.room.nmiTileStageLen

  ;--- Pass 1b: BG2 tile cache-miss staging (if hasBg2Mask) ---
  ;Mirror of loadInitialViewport Pass 1b: BG2 tile IDs are disjoint from BG1
  ;because the converter replaced BG1 tilemap with masked-variant IDs. Without
  ;this, new scroll-in columns' BG2 tiles resolve to $FFFF in the cache and
  ;Pass 3 emits garbage slot indices → black rectangles during horizontal
  ;scroll in z-masked rooms. Uses the same NMI tile queue as BG1.
  sep #$20
  lda.w GLOBAL.room.hasBg2Mask
  bne _stageCol.p1bEnter
    rep #$20
    jmp _stageCol.p1bDone
_stageCol.p1bEnter:
  rep #$20

  ldx.b tmp+12                  ;X = WRAM source offset, start of this column
  lda.w GLOBAL.room.roomHeightTiles
  sta.b tmp+14                  ;row counter

_stageCol.p1bLoop:
  .ACCU 16
  .INDEX 16
  lda.l SCROLL_BG2MAP_WRAM,x
  beq _stageCol.p1bNext         ;tile 0 = transparent, skip
  and.w #$07FF                  ;tileId
  sta.b tmp+16

  ;check cache
  asl a
  phx                            ;save WRAM offset
  tax
  lda.l SCROLL_TILE2SLOT_WRAM,x
  cmp.w #ROOM_TILE_NOT_CACHED
  beq _stageCol.p1bMiss
  plx                            ;cached — restore, skip
  bra _stageCol.p1bNext

_stageCol.p1bMiss:
  .ACCU 16
  .INDEX 16
  ;allocate slot
  lda.b tmp+16                  ;tileId
  jsr room.allocCacheSlot        ;returns slot in A (clobbers X, Y)
  sta.b tmp+18                  ;slot

  ;record VRAM word address for NMI: slot * 16
  asl a
  asl a
  asl a
  asl a
  ldx.b tmp+8                   ;X = VRAM addr array offset (long,Y not supported)
  sta.l SCROLL_NMI_SLOTS_WRAM,x
  inx
  inx
  stx.b tmp+8

  ;ROM read: tileDataRomOfs + tileId * 32
  lda.b tmp+16                  ;tileId
  asl a
  asl a
  asl a
  asl a
  asl a                          ;tileId * 32
  clc
  adc.w GLOBAL.room.tileDataRomOfs_lo
  pha                            ;push ROM addr low
  lda.w #0
  adc.w GLOBAL.room.tileDataRomOfs_hi
  tax                            ;X = ROM addr high
  pla                            ;A = ROM addr low
  jsr room.setRomDataPtr         ;tmp+24 = 24-bit CPU address

  ;copy 32 bytes to tile staging buffer
  ldx.b tmp+6                   ;staging byte offset
  ldy #0
_stageCol.p1bTileRead:
  .ACCU 16
  .INDEX 16
  sep #$20
  lda [tmp+24],y
  sta.l SCROLL_TILE_STAGE_WRAM,x
  rep #$20
  iny
  inx
  cpy #32
  bne _stageCol.p1bTileRead
  stx.b tmp+6

  ;increment tile count
  lda.w GLOBAL.room.nmiTileCount
  inc a
  sta.w GLOBAL.room.nmiTileCount

  plx                            ;restore WRAM offset
_stageCol.p1bNext:
  .ACCU 16
  .INDEX 16
  inx
  inx
  dec.b tmp+14
  beq _stageCol.p1bSave
  jmp _stageCol.p1bLoop

_stageCol.p1bSave:
  ;re-save staging length (grew with BG2 tiles added)
  lda.b tmp+6
  sta.w GLOBAL.room.nmiTileStageLen
_stageCol.p1bDone:
  .ACCU 16
  .INDEX 16

  ;--- Pass 2: remap all tilemap entries, store to colStaging ---
  ldx.b tmp+12                  ;WRAM source offset (restart)
  ldy #0                        ;staging buffer offset
  lda.w GLOBAL.room.roomHeightTiles
  sta.b tmp+14                  ;row counter

_stageCol.p2Loop:
  .ACCU 16
  .INDEX 16
  lda.l SCROLL_TILEMAP_WRAM,x
  sta.b tmp+16                  ;original word
  and.w #$07FF                  ;tileId (11-bit custom format)
  asl a                          ;* 2 for word index
  phx
  tax
  lda.l SCROLL_TILE2SLOT_WRAM,x  ;slot
  plx
  sta.b tmp+18                  ;cached slot

  ;remap custom → SNES: palette bits 13-11 → 12-10, flip stays, priority=0
  lda.b tmp+16
  and.w #$C000                  ;V/H flip
  sta.b tmp+22                  ;save flip
  lda.b tmp+16
  and.w #$3800                  ;palette (bits 13-11)
  lsr a                          ;shift to SNES position (bits 12-10)
  ora.b tmp+18                  ;OR slot
  ora.b tmp+22                  ;OR flip
  sta.b tmp+20                  ;stash partial remapped word

  ;priority bit: use current X (WRAM byte offset) directly.
  phx                            ;preserve X for the outer loop
  txa                            ;A = WRAM byte offset
  jsr _scroll.priorityBit        ;carry = priority bit
  plx                            ;restore
  lda.b tmp+20                  ;restore partial word
  bcc +
    ora.w #$2000                ;set SNES priority bit 13
+
  sta.w GLOBAL.room.colStaging,y

  inx
  inx
  iny
  iny
  dec.b tmp+14
  bne _stageCol.p2Loop

  ;--- compute VRAM tilemap address ---
  lda.b tmp+10                  ;column index
  and.w #$001F                  ;col & 31
  sta.b tmp+14

  lda.b tmp+10
  and.w #$0020                  ;bit 5 = nametable 1
  beq +
    lda.b tmp+14
    clc
    adc.w #$0400
    sta.b tmp+14
+
  .ACCU 16
  .INDEX 16

  lda.b tmp+14
  clc
  adc.w #ROOM_TILEMAP_VRAM_WORD
  sta.w GLOBAL.room.nmiColVramAddr

  lda.w GLOBAL.room.roomHeightTiles
  sta.w GLOBAL.room.nmiColRows

  ;--- Pass 3: stage BG2 column (if hasBg2Mask) ---
  sep #$20
  lda.w GLOBAL.room.hasBg2Mask
  bne _stageCol.hasBg2
  rep #$20
  bra _stageCol.noBg2
_stageCol.hasBg2:
  rep #$20

  ldx.b tmp+12                  ;WRAM source offset (restart)
  ldy #0
  lda.w GLOBAL.room.roomHeightTiles
  sta.b tmp+14
_stageCol.p3Loop:
  lda.l SCROLL_BG2MAP_WRAM,x
  beq _stageCol.p3Zero
  sta.b tmp+16
  pha
  and.w #$07FF
  asl a
  phx
  tax
  lda.l SCROLL_TILE2SLOT_WRAM,x
  sta.b tmp+18
  plx
  pla
  and.w #$C000
  sta.b tmp+22
  lda.b tmp+16
  and.w #$3800
  lsr a
  ora.b tmp+18
  ora.b tmp+22
  bra _stageCol.p3Store
_stageCol.p3Zero:
  lda #0
_stageCol.p3Store:
  sta.w GLOBAL.room.bg2ColStaging,y
  inx
  inx
  iny
  iny
  dec.b tmp+14
  bne _stageCol.p3Loop

  ;BG2 VRAM address: room tilemap at $5800 + row 13 offset (yScroll=110)
  lda.b tmp+10                    ;column index
  and.w #$001F
  clc
  adc.w #ROOM_BG2_TILEMAP_VRAM_WORD + (ROOM_BG2_ROW_OFFSET * 32)
  sta.w GLOBAL.room.nmiBg2ColAddr

  sep #$20
  lda #1
  sta.w GLOBAL.room.nmiBg2ColFlag
  rep #$20

_stageCol.noBg2:

  ;set NMI flags
  sep #$20
  lda #1
  sta.w GLOBAL.room.nmiColFlag
  lda.w GLOBAL.room.nmiTileCount
  beq +
    lda #1
    sta.w GLOBAL.room.nmiTileFlag
+
  .ACCU 8
  .INDEX 16
  rep #$20

  plp
  rts


.ends
