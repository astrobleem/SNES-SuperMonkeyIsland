;
; SCUMM v5 Bytecode Interpreter for SNES
;
; OOP class that runs MI1's SCUMM scripts. One object manages all
; 25 SCUMM script slots. play() runs the scheduler once per frame.
;
; Bytecode fetch: [dp:tmp],y where tmp holds 24-bit pointer into
; $7F script cache, Y is the SCUMM PC offset within the script.
;
; Dispatch: 256-entry jsr (table,x) jump table. Handler returns
; with carry clear = continue, carry set = yield.
;

.include "src/object/scummvm/scummvm.h"

.section "scummvm class"

;===================================================================
; METHOD: init
; Read MSU-1 script section header, zero all state, start script 1
;===================================================================
  METHOD init
  rep #$31

  ;--- Set DBR=$7E so sta.w targets WRAM, not ROM ---
  ;core.object.create does NOT set DBR; during boot it may be $00/$C0.
  phb
  sep #$20
  lda #$7E
  pha
  plb
  rep #$20

  ;--- Zero all WRAM state ---
  ;zero script slots (25 * 64 = 1600 bytes)
  ldx #0
  lda #0
_init.zeroSlots:
  sta.w SCUMM.slots,x
  inx
  inx
  cpx #_sizeof_scummSlot * SCUMM_MAX_SLOTS
  bcc _init.zeroSlots

  ;zero global variables (800 * 2 = 1600 bytes)
  ldx #0
_init.zeroGlobals:
  sta.w SCUMM.globalVars,x
  inx
  inx
  cpx #SCUMM_MAX_GLOBALS * 2
  bcc _init.zeroGlobals

  ;zero bit variables (256 bytes)
  ldx #0
_init.zeroBits:
  sta.w SCUMM.bitVars,x
  inx
  inx
  cpx #256
  bcc _init.zeroBits

  ;zero VM state
  stz.w SCUMM.running
  stz.w SCUMM.currentSlot
  stz.w SCUMM.currentSlotPtr
  stz.w SCUMM.currentOpcode
  stz.w SCUMM.resultVar
  stz.w SCUMM.scratch
  stz.w SCUMM.scratch2
  stz.w SCUMM.cacheWritePtr
  stz.w SCUMM.cutsceneNest
  stz.w SCUMM.currentRoom
  stz.w SCUMM.newRoom
  stz.w SCUMM.bgInitDone
  stz.w SCUMM.gcInProgress
  stz.w SCUMM.roomEncdPtr
  stz.w SCUMM.roomEncdLen
  stz.w SCUMM.roomExcdPtr
  stz.w SCUMM.roomExcdLen
  stz.w SCUMM.roomLscrCount

  ;zero LSCR table (56 * 4 = 224 bytes)
  ldx #0
  lda #0
_init.zeroLscr:
  sta.w SCUMM.roomLscrTable,x
  inx
  inx
  cpx #_sizeof_lscrEntry * SCUMM_LSCR_MAX
  bcc _init.zeroLscr

  ;zero actor state (256 * 16 = 4096 bytes)
  ldx #0
  lda #0
_init.zeroActors:
  sta.w SCUMM.actors,x
  inx
  inx
  cpx #_sizeof_scummActor * SCUMM_MAX_ACTORS
  bcc _init.zeroActors

  ;zero object state table (1024 bytes)
  ldx #0
  lda #0
_init.zeroObjState:
  sta.w SCUMM.objectState,x
  inx
  inx
  cpx #SCUMM_MAX_OBJECTS
  bcc _init.zeroObjState

  ;zero verb table (20 * 16 = 320 bytes)
  ldx #0
  lda #0
_init.zeroVerbs:
  sta.w SCUMM.verbs,x
  inx
  inx
  cpx #_sizeof_scummVerb * SCUMM_MAX_VERBS
  bcc _init.zeroVerbs

  ;zero verb names buffer (256 bytes)
  ldx #0
_init.zeroVerbNames:
  sta.w SCUMM.verbNames,x
  inx
  inx
  cpx #SCUMM_VERB_NAMES_SIZE
  bcc _init.zeroVerbNames

  stz.w SCUMM.verbNamesPtr
  stz.w SCUMM.verbDirty

  ;zero verb tilemap (2048 bytes)
  ldx #0
_init.zeroVerbTilemap:
  sta.w SCUMM.verbTilemap,x
  inx
  inx
  cpx #VERB_TILEMAP_SIZE
  bcc _init.zeroVerbTilemap

  ;zero walk state arrays (16 actors × 2B targets + 16B anim)
  ldx #0
  lda #0
_init.zeroWalk:
  sta.w SCUMM.actorTargetX,x
  sta.w SCUMM.actorTargetY,x
  inx
  inx
  cpx #SCUMM_WALK_ACTORS * 2
  bcc _init.zeroWalk
  ldx #0
  sep #$20
  lda #0
_init.zeroWalk2:
  sta.w SCUMM.actorAnimFrame,x
  sta.w SCUMM.actorAnimTimer,x
  lda #$FF
  sta.w SCUMM.actorLastFrame,x
  lda #0
  inx
  cpx #SCUMM_WALK_ACTORS
  bcc _init.zeroWalk2
  rep #$20

  ;zero script cache in $7F
  ldx #0
  lda #0
_init.zeroCache:
  sta.l SCUMM_CACHE_WRAM,x
  inx
  inx
  cpx #SCUMM_CACHE_SIZE
  bcc _init.zeroCache

  ;--- Read script section offset from MSU-1 header ---
  ; MSU header at offset $0024 has 32-bit script section offset
  lda.w #SCUMM_MSU_SCRIPT_HDR_OFFSET
  ldx #0
  jsr room.msu1Seek

  ; Read LE32 into scriptSectionLo/Hi using XBA word-read pattern
  sep #$20
  lda.l MSU_DATA
  xba
  lda.l MSU_DATA
  xba
  rep #$20
  sta.w SCUMM.scriptSectionLo
  sep #$20
  lda.l MSU_DATA
  xba
  lda.l MSU_DATA
  xba
  rep #$20
  sta.w SCUMM.scriptSectionHi

  ; Check that script section exists
  lda.w SCUMM.scriptSectionLo
  ora.w SCUMM.scriptSectionHi
  bne +
    TRIGGER_ERROR E_ScummVmBadOpcode
+

  ;--- Seek to script section and read 32-byte header ---
  lda.w SCUMM.scriptSectionLo
  ldx.w SCUMM.scriptSectionHi
  jsr room.msu1Seek

  ; Skip magic (4 bytes) + version (1) + reserved (1) = 6 bytes
  sep #$20
  lda.l MSU_DATA
  lda.l MSU_DATA
  lda.l MSU_DATA
  lda.l MSU_DATA
  lda.l MSU_DATA
  lda.l MSU_DATA
  rep #$20

  ; Read global_slots (LE16) -- XBA word-read
  sep #$20
  lda.l MSU_DATA
  xba
  lda.l MSU_DATA
  xba
  rep #$20
  sta.w SCUMM.globalSlots

  ; Read room_slots (LE16) -- XBA word-read
  sep #$20
  lda.l MSU_DATA
  xba
  lda.l MSU_DATA
  xba
  rep #$20
  sta.w SCUMM.roomSlots

  ; Skip 6 reserved bytes (bytes 10-15)
  sep #$20
  lda.l MSU_DATA
  lda.l MSU_DATA
  lda.l MSU_DATA
  lda.l MSU_DATA
  lda.l MSU_DATA
  lda.l MSU_DATA
  rep #$20

  ; Read global_index_offset (LE32, bytes 16-19) -- XBA word-read
  sep #$20
  lda.l MSU_DATA
  xba
  lda.l MSU_DATA
  xba
  rep #$20
  sta.w SCUMM.globalIndexLo
  sep #$20
  lda.l MSU_DATA
  xba
  lda.l MSU_DATA
  xba
  rep #$20
  sta.w SCUMM.globalIndexHi

  ; Read room_index_offset (LE32, bytes 20-23) -- XBA word-read
  sep #$20
  lda.l MSU_DATA
  xba
  lda.l MSU_DATA
  xba
  rep #$20
  sta.w SCUMM.roomIndexLo
  sep #$20
  lda.l MSU_DATA
  xba
  lda.l MSU_DATA
  xba
  rep #$20
  sta.w SCUMM.roomIndexHi

  ;--- Set SCUMM v5 system variables (from ScummVM resetScummVars) ---
  ; Use indexed addressing: ldx #var*2 / lda #val / sta.w globalVars,x
  ; (wla-dx ramsection + constant = 24-bit → linker error without index)
  lda #1
  ldx #1*2
  sta.w SCUMM.globalVars,x          ; VAR(1)  = VAR_EGO = 1 (Guybrush)
  lda #13
  ldx #8*2
  sta.w SCUMM.globalVars,x          ; VAR(8)  = VAR_NUM_ACTOR = 13
  lda #1
  ldx #15*2
  sta.w SCUMM.globalVars,x          ; VAR(15) = VAR_ACTOR_RANGE_MIN = 1
  lda #12
  ldx #16*2
  sta.w SCUMM.globalVars,x          ; VAR(16) = VAR_ACTOR_RANGE_MAX = 12
  lda #1400
  ldx #40*2
  sta.w SCUMM.globalVars,x          ; VAR(40) = VAR_HEAPSPACE = 1400
  lda #3
  ldx #46*2
  sta.w SCUMM.globalVars,x          ; VAR(46) = VAR_SOUNDCARD = 3 (SB)
  lda #19
  ldx #47*2
  sta.w SCUMM.globalVars,x          ; VAR(47) = VAR_VIDEOMODE = 19 (VGA)
  lda #1
  ldx #49*2
  sta.w SCUMM.globalVars,x          ; VAR(49) = VAR_FIXEDDISK = 1
  lda #17
  ldx #7*2
  sta.w SCUMM.globalVars,x          ; VAR(7) = room 1 key object (MI1 boot)

  ;--- Init cursor state ---
  lda #128
  sta.w SCUMM.cursorX
  lda #80
  sta.w SCUMM.cursorY
  lda #1
  sta.w SCUMM.cursorEnabled
  stz.w SCUMM.sentenceVerb
  lda #$FFFF
  sta.w SCUMM.highlightVerb
  stz.w SCUMM.cursorTileDone
  lda #1
  ldx #48*2
  sta.w SCUMM.globalVars,x            ; VAR(48) = VAR_USERPUT = 1

  ;--- Set starting room (triggers room load on first play frame) ---
  ; MI1 starting room = 1; currentRoom already 0 from zero pass
  lda #1
  sta.w SCUMM.newRoom

  ;--- Seed ego actor as "moving" so boot script wait loop exits ---
  ; MI1 boot script (script 1) loops on getActorMoving(VAR_EGO) waiting
  ; for the intro cutscene to walk the ego. We skip the intro, so seed
  ; actor 1's moving field directly.
  sep #$20
  lda #1
  sta.w SCUMM.actors.2.moving
  rep #$20

  ;--- Start MI1 boot script (script 1) ---
  lda #1
  jsr _scummvm.startScriptSlot

  ;--- Mark VM as running ---
  lda #1
  sta.w SCUMM.running

  ;--- Init default verb bar (room 10 scripts don't run yet) ---
  jsl scummvm.initDefaultVerbs

  plb                               ; restore DBR
  rts


;===================================================================
; METHOD: play -- per-frame SCUMM scheduler
; Iterates all 25 slots, runs RUNNING slots until they yield.
;===================================================================
  METHOD play
  rep #$31

  lda.w SCUMM.running
  beq _play.done

  ; Check for pending room change
  lda.w SCUMM.newRoom
  cmp.w SCUMM.currentRoom
  beq _play.noRoomChange
  jsr _scummvm.processRoomChange
_play.noRoomChange:

  ; Update cursor (joypad input, position, SCUMM vars, OAM)
  jsl scummvm.updateCursor

  ; Iterate slots 0..24
  stz.w SCUMM.currentSlot
  stz.w SCUMM.currentSlotPtr

_play.slotLoop:
  ldx.w SCUMM.currentSlotPtr

  ; Check status == RUNNING
  lda.w SCUMM.slots.status,x
  and #$00FF
  cmp #SCUMM_SLOT_RUNNING
  bne _play.nextSlot

  ; Check freezeCount == 0
  lda.w SCUMM.slots.freezeCount,x
  and #$00FF
  bne _play.nextSlot

  ; Check delay > 0
  lda.w SCUMM.slots.delay,x
  beq _play.runSlot

  ; Decrement delay
  dec a
  sta.w SCUMM.slots.delay,x
  bra _play.nextSlot

_play.runSlot:
  jsr _scummvm.executeSlot

_play.nextSlot:
  ; Advance to next slot
  lda.w SCUMM.currentSlotPtr
  clc
  adc #_sizeof_scummSlot
  sta.w SCUMM.currentSlotPtr

  lda.w SCUMM.currentSlot
  inc a
  sta.w SCUMM.currentSlot
  cmp #SCUMM_MAX_SLOTS
  bcc _play.slotLoop

  ; Update actor movement + animation (after scripts have run)
  jsr _scummvm.updateActors
  ; Render visible actors to OAM buffer
  jsr _scummvm.renderActors

  ; Render verb bar if dirty
  lda.w SCUMM.verbDirty
  beq _play.verbClean
  jsl scummvm.renderVerbBar
_play.verbClean:
  ; DMA verb tilemap to VRAM if pending
  lda.w SCUMM.verbDmaPending
  beq _play.done
  stz.w SCUMM.verbDmaPending
  sep #$20
  tsx
  lda #DMA_TRANSFER.VRAM
  pha
  pea SCUMM.verbTilemap
  lda #$7E
  pha
  rep #$31
  pea VERB_TILEMAP_VRAM_ADDR
  pea VERB_TILEMAP_SIZE
  jsr core.dma.registerTransfer
  txs

_play.done:
  rts


; buildCgramHdmaTable moved to superfree section at end of file


;-------------------------------------------------------------------
; _scummvm.processRoomChange -- load new room background
; Called when SCUMM.newRoom != SCUMM.currentRoom
;-------------------------------------------------------------------
_scummvm.processRoomChange:
  rep #$31

  ; Set up PPU for BG1 room display (once)
  lda.w SCUMM.bgInitDone
  beq +
  jmp _prc.bgReady
+

  sep #$20
  ; Mode 1, BG1 tilemap at $7000 (word $3800), 64 tiles wide
  lda.b #$39                        ; $38 = tilemap base $3800, +1 = 64-wide
  sta.w BG1TilemapVram
  ; BG2 tilemap at $9000 (word $4800), 32x32
  lda.b #$48
  sta.w BG2TilemapVram
  ; Tile data: BG1=$0000, BG2=$4000 (high nibble)
  lda.b #$40
  sta.w BGTilesVram12
  ; Enable BG1 + BG2 on main screen
  lda.w MainScreen
  ora.b #(T_BG1_ENABLE | T_BG2_ENABLE)
  sta.w MainScreen
  ; Set mode 1
  lda.b #BGMODE_MODE_1
  sta.w ScreenMode
  rep #$20

  ; Set BG2 Y scroll
  lda #112
  sta.w yScrollBG2
  stz.w xScrollBG2

  ; DMA verb font tiles to VRAM $8000 (word $4000)
  sep #$20
  tsx
  lda #DMA_TRANSFER.VRAM
  pha
  pea VerbFontTiles
  lda.b #:VerbFontTiles
  pha
  rep #$31
  pea VERB_FONT_VRAM_ADDR
  pea VerbFontTiles.LEN
  jsr core.dma.registerTransfer
  txs

  ; Set up HDMA to disable BG1 below scanline 144 (verb area)
  sep #$20
  jsr core.dma_channel.allocate
  bcc +
    ; A = channel id (0-7), convert to register offset (channel * 16)
    sta.w SCUMM.hdmaChannel
    rep #$31
    and #$00FF
    asl a
    asl a
    asl a
    asl a
    tax
    ; DMAP: $00 = direct, 1-register, A-bus to B-bus
    sep #$20
    lda #$00
    sta.l DMAP0,x
    ; Target register: $2C (low byte of $212C = TM/MainScreen)
    lda #$2C
    sta.l DMADEST0,x
    ; Table address (24-bit pointer to VerbHdmaTable in ROM)
    lda.b #:VerbHdmaTable
    sta.l DMASRC0B,x
    rep #$20
    lda.w #VerbHdmaTable
    sta.l DMASRC0L,x
    ; Enable this channel in HDMA
    rep #$20
    lda.w SCUMM.hdmaChannel
    and #$00FF
    tax
    sep #$20
    lda.l dmaBitflagLut,x
    ora.w GLOBAL.HDMA.CHANNEL.ENABLE
    sta.w GLOBAL.HDMA.CHANNEL.ENABLE
+

  ; Set up HDMA to write verb palette colors to CGRAM at scanline 144
  sep #$20
  jsr core.dma_channel.allocate
  bcc +
    sta.w SCUMM.hdmaCgramChannel
    rep #$31
    and #$00FF
    asl a
    asl a
    asl a
    asl a
    tax
    ; DMAP: mode 3 = write pp,pp,pp+1,pp+1 (4 bytes per transfer)
    sep #$20
    lda #DMAP_2_REG_WRITE_TWICE_EACH
    sta.l DMAP0,x
    ; Target register: $21 (low byte of $2121=CGADD, $2122=CGDATA)
    lda #$21
    sta.l DMADEST0,x
    ; Table address (24-bit pointer to WRAM CGRAM HDMA table)
    lda.b #$7E
    sta.l DMASRC0B,x
    rep #$20
    lda.w #SCUMM.cgramHdmaTable
    sta.l DMASRC0L,x
    ; Enable this channel in HDMA
    rep #$20
    lda.w SCUMM.hdmaCgramChannel
    and #$00FF
    tax
    sep #$20
    lda.l dmaBitflagLut,x
    ora.w GLOBAL.HDMA.CHANNEL.ENABLE
    sta.w GLOBAL.HDMA.CHANNEL.ENABLE
+

  rep #$31
  lda #1
  sta.w SCUMM.bgInitDone

_prc.bgReady:
  ; Load room via Phase 0 room loader
  lda.w SCUMM.newRoom
  jsr room.load
  bcc _prc.failed

  ; Build CGRAM HDMA table with room's palette 7 colors
  jsl scummvm.buildCgramHdmaTable

  ; Kill old room/local script slots
  jsr _scummvm.killRoomScripts

  ; Flush cache (global scripts reload on demand)
  stz.w SCUMM.cacheWritePtr

  ; Load room scripts (ENCD/EXCD/LSCR) from MSU-1
  lda.w SCUMM.newRoom
  jsr _scummvm.loadRoomScripts

  ; Reload surviving global scripts into fresh cache positions
  ; (must run even if room has no scripts — cache was flushed above)
  jsr _scummvm.reloadGlobalScripts

  ; Update current room + SCUMM variables BEFORE starting ENCD
  ; (ENCD uses currentRoom for putActor, getActorRoom, etc.)
  lda.w SCUMM.newRoom
  sta.w SCUMM.currentRoom
  ldx #4*2                          ; VAR(4) = VAR_ROOM
  sta.w SCUMM.globalVars,x
  ldx #143*2                        ; VAR(143) = room state (MI1 ENCD guard check)
  sta.w SCUMM.globalVars,x

  ; Auto-start ENCD if present
  lda.w SCUMM.roomEncdLen
  beq _prc.noEncd
  jsr _scummvm.startEncdSlot
_prc.noEncd:

  ; Load actor costume tiles + palette to VRAM/CGRAM
  jsr _scummvm.loadActorCostumes

  ; Fade up brightness
  sep #$20
  lda.b #$0F
  sta.w ScreenBrightness
  rep #$20

_prc.failed:
  rts


;===================================================================
; METHOD: kill
;===================================================================
  METHOD kill
  rep #$31
  stz.w SCUMM.running
  rts


;===================================================================
; _scummvm.executeSlot -- run opcodes for current slot until yield
;
; Sets up [tmp] pointing into $7F cache and Y = slot.pc,
; then loops: fetch opcode, dispatch via jsr (table,x).
; Handler returns carry set to yield, carry clear to continue.
;===================================================================
_scummvm.executeSlot:
  rep #$31

  ; Set up tmp (ZP) as 24-bit pointer to script bytecode
  ; tmp+0,1 = SCUMM_CACHE_BASE + slot.cachePtr (low 16)
  ; tmp+2   = $7F
  ldx.w SCUMM.currentSlotPtr
  lda.w SCUMM.slots.cachePtr,x
  clc
  adc #SCUMM_CACHE_BASE
  sta.b tmp
  sep #$20
  lda #$7F
  sta.b tmp+2
  rep #$20

  ; Y = slot.pc
  ldx.w SCUMM.currentSlotPtr
  ldy.w SCUMM.slots.pc,x

_scummvm.fetchLoop:
  ; Read opcode byte (16-bit load, mask to 8-bit)
  lda [tmp],y
  and #$00FF
  sta.w SCUMM.currentOpcode
  iny                       ; advance PC past opcode byte

  ; Dispatch: opcode * 2 for word-indexed table
  asl a
  tax
  jsr (_scummvm.dispatchTable,x)
  bcc _scummvm.fetchLoop    ; carry clear = keep going

  ; Carry set = yield. Save Y back to slot.pc
  ldx.w SCUMM.currentSlotPtr
  tya
  sta.w SCUMM.slots.pc,x
  rts


;===================================================================
; Parameter Decoder Helpers
;
; These read parameters from the bytecode stream.
; Y = SCUMM PC (advanced as bytes are consumed).
; [tmp] = bytecode pointer.
;===================================================================

;-------------------------------------------------------------------
; _scummvm.fetchByte -- read next byte, zero-extend to 16-bit
; Returns: A = byte value, Y advanced by 1
;-------------------------------------------------------------------
_scummvm.fetchByte:
  lda [tmp],y
  and #$00FF
  iny
  rts

;-------------------------------------------------------------------
; _scummvm.fetchWord -- read next 16-bit LE word
; Returns: A = word value, Y advanced by 2
;-------------------------------------------------------------------
_scummvm.fetchWord:
  lda [tmp],y
  iny
  iny
  rts

;-------------------------------------------------------------------
; _scummvm.getActorPtr -- convert actor number to table offset
; Input: A = actor number (0-12)
; Output: X = byte offset into SCUMM.actors, carry set if valid
; Clobbers: A
; If actor >= SCUMM_MAX_ACTORS, returns X=0 and carry clear
;-------------------------------------------------------------------
_scummvm.getActorPtr:
  and #$00FF              ; mask to byte
  cmp #SCUMM_MAX_ACTORS
  bcc _getActorPtr.ok
    ldx #0                ; out of bounds → point to actor 0 (unused)
    clc                   ; carry clear = invalid
    rts
_getActorPtr.ok:
  asl a                   ; *2
  asl a                   ; *4
  asl a                   ; *8
  asl a                   ; *16 = _sizeof_scummActor
  tax
  sec                     ; carry set = valid
  rts

;-------------------------------------------------------------------
; _scummvm.getVarOrDirectWord -- decode p16 parameter
; Input: A = flag bitmask to test against currentOpcode
; If flag SET in opcode: FETCH_WORD -> readVariable (var reference)
; If flag CLEAR: FETCH_WORD (literal value)
; Returns: A = resolved value
;-------------------------------------------------------------------
_scummvm.getVarOrDirectWord:
  and.w SCUMM.currentOpcode   ; test flag bit against opcode
  beq +
    ; Flag set: word is a variable reference
    jsr _scummvm.fetchWord
    jmp _scummvm.readVariable
+
  ; Flag clear: word is literal
  jsr _scummvm.fetchWord
  rts

;-------------------------------------------------------------------
; _scummvm.getVarOrDirectByte -- decode p8 parameter
; Input: A = flag bitmask to test against currentOpcode
; If flag SET: FETCH_WORD -> readVariable (2-byte var ref)
; If flag CLEAR: FETCH_BYTE (1-byte literal)
; Returns: A = resolved value
;-------------------------------------------------------------------
_scummvm.getVarOrDirectByte:
  and.w SCUMM.currentOpcode   ; test flag bit against opcode
  beq +
    ; Flag set: read variable reference (2 bytes)
    jsr _scummvm.fetchWord
    jmp _scummvm.readVariable
+
  ; Flag clear: literal byte
  jsr _scummvm.fetchByte
  rts

;-------------------------------------------------------------------
; _scummvm.getResultPos -- read result variable position
; Reads 2-byte variable reference, stores in SCUMM.resultVar
;-------------------------------------------------------------------
_scummvm.getResultPos:
  jsr _scummvm.fetchWord
  sta.w SCUMM.resultVar
  rts


;-------------------------------------------------------------------
; _scummvm.skipWordVararg -- skip getWordVararg argument list
; SCUMM v5 format: { sub_opcode_byte, word_arg } ... 0xFF
; Each non-0xFF byte is followed by a 2-byte word (var ref or literal).
; Preserves A on stack (caller typically has script number pushed).
;-------------------------------------------------------------------
_scummvm.skipWordVararg:
-
  jsr _scummvm.fetchByte
  cmp #$00FF
  beq +
  jsr _scummvm.fetchWord          ; skip the 2-byte argument
  bra -
+
  rts


;-------------------------------------------------------------------
; _scummvm.skipP8fromScratch -- skip one p8 param using SCUMM.scratch
; Input: A = flag bitmask to test against SCUMM.scratch
; If flag SET: fetchWord (2-byte var ref), else fetchByte (1-byte literal)
;-------------------------------------------------------------------
_scummvm.skipP8fromScratch:
  and.w SCUMM.scratch
  beq +
  jmp _scummvm.fetchWord
+
  jmp _scummvm.fetchByte


;-------------------------------------------------------------------
; _scummvm.skipNullString -- skip bytes until $00 terminator
;-------------------------------------------------------------------
_scummvm.skipNullString:
-
  jsr _scummvm.fetchByte
  cmp #0
  bne -
  rts


;-------------------------------------------------------------------
; _scummvm.skipPrintString -- skip SCUMM print string
; Bytes $01-$08 are embedded var references (2 extra bytes each).
; $00 terminates the string.
;-------------------------------------------------------------------
_scummvm.skipPrintString:
-
  jsr _scummvm.fetchByte
  cmp #0
  beq +                            ; $00 = end of string
  cmp #$0009
  bcs -                            ; >= $09 = normal char, loop
  ; $01-$08: embedded var ref, consume 2 extra bytes
  jsr _scummvm.fetchWord
  bra -
+
  rts


;===================================================================
; Variable System
;===================================================================

;-------------------------------------------------------------------
; _scummvm.readVariable -- read a SCUMM variable
; Input: A = raw variable encoding (16-bit)
; Returns: A = variable value (16-bit)
;-------------------------------------------------------------------
_scummvm.readVariable:
  sta.w SCUMM.scratch
  and #SCUMM_VAR_TYPE_MASK
  beq _readVar.global

  cmp #SCUMM_VAR_LOCAL_MASK
  beq _readVar.local

  ; Bit variable ($8000-$BFFF)
  lda.w SCUMM.scratch
  and #SCUMM_VAR_INDEX_MASK
  pha
  lsr a
  lsr a
  lsr a
  tax
  pla
  and #$0007
  pha
  lda #1
  sta.w SCUMM.scratch2
  pla
  beq _readBit.test
_readBit.shift:
  asl.w SCUMM.scratch2
  dec a
  bne _readBit.shift
_readBit.test:
  lda.w SCUMM.bitVars,x
  and #$00FF
  and.w SCUMM.scratch2
  beq +
    lda #1
+
  rts

_readVar.global:
  lda.w SCUMM.scratch
  and #SCUMM_VAR_INDEX_MASK
  asl a
  tax
  lda.w SCUMM.globalVars,x
  rts

_readVar.local:
  lda.w SCUMM.scratch
  and #SCUMM_VAR_INDEX_MASK
  asl a
  clc
  adc.w SCUMM.currentSlotPtr
  tax
  lda.w SCUMM.slots.localVars,x
  rts


;-------------------------------------------------------------------
; _scummvm.writeVariable -- write a SCUMM variable
; Input: A = value to write
;        SCUMM.resultVar = target variable encoding
;-------------------------------------------------------------------
_scummvm.writeVariable:
  sta.w SCUMM.scratch2
  lda.w SCUMM.resultVar
  and #SCUMM_VAR_TYPE_MASK
  beq _writeVar.global

  cmp #SCUMM_VAR_LOCAL_MASK
  beq _writeVar.local

  ; Bit variable
  lda.w SCUMM.resultVar
  and #SCUMM_VAR_INDEX_MASK
  pha
  lsr a
  lsr a
  lsr a
  tax
  pla
  and #$0007
  pha
  lda #1
  sta.w SCUMM.scratch
  pla
  beq _writeBit.apply
_writeBit.shift:
  asl.w SCUMM.scratch
  dec a
  bne _writeBit.shift
_writeBit.apply:
  lda.w SCUMM.scratch2
  beq _writeBit.clear
    sep #$20
    lda.w SCUMM.bitVars,x
    ora.w SCUMM.scratch
    sta.w SCUMM.bitVars,x
    rep #$20
    rts
_writeBit.clear:
    sep #$20
    lda.w SCUMM.scratch
    eor #$FF
    and.w SCUMM.bitVars,x
    sta.w SCUMM.bitVars,x
    rep #$20
    rts

_writeVar.global:
  lda.w SCUMM.resultVar
  and #SCUMM_VAR_INDEX_MASK
  asl a
  tax
  lda.w SCUMM.scratch2
  sta.w SCUMM.globalVars,x
  rts

_writeVar.local:
  lda.w SCUMM.resultVar
  and #SCUMM_VAR_INDEX_MASK
  asl a
  clc
  adc.w SCUMM.currentSlotPtr
  tax
  lda.w SCUMM.scratch2
  sta.w SCUMM.slots.localVars,x
  rts


;===================================================================
; Script Loader -- MSU-1 -> $7F Cache
;===================================================================

;-------------------------------------------------------------------
; _scummvm.copyMsuToCache -- copy bytes from MSU-1 into $7F cache
; Input: A = byte count to copy
; Assumes: MSU-1 data port is already seeked to correct position
; Uses cacheWritePtr as destination offset (updated on return)
; Output: A = cachePtr where data was written, X = byte count
; Clobbers: SCUMM.scratch, SCUMM.scratch2
;-------------------------------------------------------------------
_scummvm.copyMsuToCache:
  sta.w SCUMM.scratch           ; scratch = byte count

  ; Save starting cacheWritePtr (= destination offset)
  lda.w SCUMM.cacheWritePtr
  sta.w SCUMM.scratch2          ; scratch2 = cachePtr result

  ; X = destination offset into $7F bank
  ldx.w SCUMM.cacheWritePtr

  ; Copy loop: read MSU_DATA byte-by-byte into $7F cache
  phy
  ldy.w SCUMM.scratch           ; Y = remaining count
  beq _copyMsu.done
_copyMsu.loop:
  sep #$20
  lda.l MSU_DATA
  sta.l SCUMM_CACHE_WRAM,x
  rep #$20
  inx
  dey
  bne _copyMsu.loop
_copyMsu.done:
  ply

  ; Update cacheWritePtr
  lda.w SCUMM.cacheWritePtr
  clc
  adc.w SCUMM.scratch
  sta.w SCUMM.cacheWritePtr

  ; Return: A = cachePtr, X = byte count
  lda.w SCUMM.scratch2
  ldx.w SCUMM.scratch
  rts


;-------------------------------------------------------------------
; _scummvm.loadGlobalScript -- load a global script into cache
; Input: A = script number (0-based)
; Output: A = cachePtr (offset within cache), X = size
;-------------------------------------------------------------------
_scummvm.loadGlobalScript:
  sta.w SCUMM.scratch

  ; Compute index entry MSU offset: globalIndexOffset + scriptNum * 8
  asl a
  asl a
  asl a
  clc
  adc.w SCUMM.globalIndexLo
  sta.w SCUMM.scratch2
  lda #0
  adc.w SCUMM.globalIndexHi
  tax
  lda.w SCUMM.scratch2
  jsr room.msu1Seek

  ; Read 8-byte index entry: offset32 + size32
  sep #$20
  lda.l MSU_DATA
  xba
  lda.l MSU_DATA
  xba
  rep #$20
  pha                        ;push offset_lo
  sep #$20
  lda.l MSU_DATA
  xba
  lda.l MSU_DATA
  xba
  rep #$20
  pha                        ;push offset_hi
  sep #$20
  lda.l MSU_DATA
  xba
  lda.l MSU_DATA
  xba
  rep #$20
  pha                        ;push size_lo
  sep #$20
  lda.l MSU_DATA
  lda.l MSU_DATA
  rep #$20

  ; Stack: [size_lo] [offset_hi] [offset_lo]
  ; Check for null entry (offset == 0)
  lda 5,s
  ora 3,s
  bne _loadGlobal.exists

  ; Script doesn't exist
  pla
  pla
  pla
  lda #0
  tax
  rts

_loadGlobal.exists:
  lda 1,s
  sta.w SCUMM.scratch

  ; Check cache space
  lda.w SCUMM.cacheWritePtr
  clc
  adc.w SCUMM.scratch
  cmp #SCUMM_CACHE_SIZE
  bcc _loadGlobal.cacheOk

  ; Cache full — try GC before giving up
  jsr _scummvm.cacheGC

  ; Retry space check after GC
  lda.w SCUMM.cacheWritePtr
  clc
  adc.w SCUMM.scratch
  cmp #SCUMM_CACHE_SIZE
  bcc _loadGlobal.cacheOk

  ; Still full after GC — genuinely out of space
  TRIGGER_ERROR E_ScummVmCacheFull

_loadGlobal.cacheOk:
  ; Seek to script data
  lda 3,s
  tax                 ;X = offset_hi (high 16 bits)
  lda 5,s             ;A = offset_lo (low 16 bits)
  jsr room.msu1Seek

  ; Copy bytecode from MSU-1 into cache via helper
  lda.w SCUMM.scratch
  jsr _scummvm.copyMsuToCache
  ; A = cachePtr, X = byte count

  ; Clean up stack (size_lo, offset_hi, offset_lo)
  sta.w SCUMM.scratch2
  pla
  pla
  pla

  lda.w SCUMM.scratch2
  ldx.w SCUMM.scratch
  rts


;-------------------------------------------------------------------
; _scummvm.startScriptSlot -- find dead slot, load script, init it
; Input: A = script number to start
;-------------------------------------------------------------------
_scummvm.startScriptSlot:
  sta.w SCUMM.scratch

  ; Find a dead slot
  ldx #0
  ldy #0
_startScript.findSlot:
  lda.w SCUMM.slots.status,x
  and #$00FF
  cmp #SCUMM_SLOT_DEAD
  beq _startScript.foundSlot
  txa
  clc
  adc #_sizeof_scummSlot
  tax
  iny
  cpy #SCUMM_MAX_SLOTS
  bcc _startScript.findSlot

  ; No free slot
  rts

_startScript.foundSlot:
  phx                             ; save slot offset

  ; Check if LSCR (script number >= 200)
  lda.w SCUMM.scratch
  cmp #SCUMM_LSCR_BASE
  bcs _startScript.local

  ;--- Global script path ---
  lda.w SCUMM.scratch
  pha                           ;push script number

  ; Load the script into cache
  phy
  jsr _scummvm.loadGlobalScript
  ply

  ; Check if script was found
  cpx #0
  bne _startScript.globalInit

  pla                           ;discard saved script number
  plx
  rts

_startScript.globalInit:
  ; A = cachePtr, X = size (from loadGlobalScript)
  sta.w SCUMM.scratch2          ; scratch2 = cachePtr
  stx.w SCUMM.scratch           ; scratch = cacheLen
  pla                           ;A = saved script number
  plx                           ;X = slot offset
  ldy #SCUMM_WHERE_GLOBAL
  bra _startScript.initSlot

  ;--- Local (LSCR) script path ---
_startScript.local:
  ; SCUMM.scratch = script number (>= 200)
  lda.w SCUMM.scratch
  pha                           ;push script number (for initSlot)
  sec
  sbc #SCUMM_LSCR_BASE          ; table index (0-55)
  asl a
  asl a                          ; * 4 = byte offset into lscrEntry table
  tax
  lda.w SCUMM.roomLscrTable.cacheLen,x
  beq _startScript.localNone     ; cacheLen == 0 → not loaded, bail
  sta.w SCUMM.scratch            ; scratch = cacheLen
  lda.w SCUMM.roomLscrTable.cachePtr,x
  sta.w SCUMM.scratch2           ; scratch2 = cachePtr

  pla                            ;A = script number
  plx                            ;X = slot offset (from foundSlot push)
  ldy #SCUMM_WHERE_LOCAL
  bra _startScript.initSlot

_startScript.localNone:
  pla                            ; discard script number
  plx                            ; discard slot offset
  rts

  ;--- Common slot initialization ---
  ; A = script number, X = slot byte offset, Y = WHERE value
  ; SCUMM.scratch2 = cachePtr, SCUMM.scratch = cacheLen
_startScript.initSlot:
  sep #$20
  sta.w SCUMM.slots.number,x
  lda #SCUMM_SLOT_RUNNING
  sta.w SCUMM.slots.status,x
  tya
  sta.w SCUMM.slots.where,x
  lda #0
  sta.w SCUMM.slots.freezeCount,x
  sta.w SCUMM.slots.cutsceneOverride,x
  rep #$20

  lda.w SCUMM.scratch2
  sta.w SCUMM.slots.cachePtr,x
  lda.w SCUMM.scratch
  sta.w SCUMM.slots.cacheLen,x

  lda #0
  sta.w SCUMM.slots.pc,x
  sta.w SCUMM.slots.delay,x

  ; Zero local variables
  phx
  ldy #0
_startScript.zeroLocals:
  sta.w SCUMM.slots.localVars,x
  inx
  inx
  iny
  cpy #SCUMM_MAX_LOCALS
  bcc _startScript.zeroLocals
  plx

  rts


;-------------------------------------------------------------------
; _scummvm.killRoomScripts -- kill all slots with where != GLOBAL
; Preserves Y (SCUMM PC)
;-------------------------------------------------------------------
_scummvm.killRoomScripts:
  phx
  phy
  ldx #0
  ldy #0
_killRoom.loop:
  lda.w SCUMM.slots.status,x
  and #$00FF
  cmp #SCUMM_SLOT_DEAD
  beq _killRoom.next
  lda.w SCUMM.slots.where,x
  and #$00FF
  beq _killRoom.next             ; where == 0 (GLOBAL) → keep
  sep #$20
  lda #SCUMM_SLOT_DEAD
  sta.w SCUMM.slots.status,x
  rep #$20
_killRoom.next:
  txa
  clc
  adc #_sizeof_scummSlot
  tax
  iny
  cpy #SCUMM_MAX_SLOTS
  bcc _killRoom.loop
  ply
  plx
  rts


;-------------------------------------------------------------------
; _scummvm.reloadGlobalScripts -- reload all surviving GLOBAL slots
; into fresh cache positions after cache flush + room script load.
; Updates cachePtr/cacheLen for each slot; preserves slot.pc so
; the script resumes at the same bytecode offset.
;-------------------------------------------------------------------
_scummvm.reloadGlobalScripts:
  phx
  phy
  ldx #0
  ldy #0
_reloadGlobal.loop:
  ; Skip dead slots
  lda.w SCUMM.slots.status,x
  and #$00FF
  cmp #SCUMM_SLOT_DEAD
  beq _reloadGlobal.next
  ; Skip non-GLOBAL slots (where != 0)
  lda.w SCUMM.slots.where,x
  and #$00FF
  bne _reloadGlobal.next

  ; This is a live GLOBAL slot — reload its script
  phx
  phy
  lda.w SCUMM.slots.number,x
  and #$00FF
  jsr _scummvm.loadGlobalScript       ; A = new cachePtr, X = size
  sta.w SCUMM.scratch2                ; scratch2 = new cachePtr
  stx.w SCUMM.scratch                 ; scratch = new cacheLen
  ply
  plx

  ; Update slot cache pointers (X = slot byte offset)
  lda.w SCUMM.scratch                 ; was size 0? (script not found)
  beq _reloadGlobal.next              ; shouldn't happen, but guard
  lda.w SCUMM.scratch2
  sta.w SCUMM.slots.cachePtr,x
  lda.w SCUMM.scratch
  sta.w SCUMM.slots.cacheLen,x
  ; slot.pc is NOT reset — bytecode is identical, just at new offset

_reloadGlobal.next:
  txa
  clc
  adc #_sizeof_scummSlot
  tax
  iny
  cpy #SCUMM_MAX_SLOTS
  bcc _reloadGlobal.loop
  ply
  plx
  rts


;-------------------------------------------------------------------
; _scummvm.cacheGC -- garbage-collect script cache
; Flushes cache and reloads all live scripts from MSU-1.
; Prevents recursion via SCUMM.gcInProgress flag.
;-------------------------------------------------------------------
_scummvm.cacheGC:
  lda.w SCUMM.gcInProgress
  bne _cacheGC.done               ; prevent recursive GC
  lda #1
  sta.w SCUMM.gcInProgress
  phx
  phy

  ; Flush cache
  stz.w SCUMM.cacheWritePtr

  ; Reload room scripts (ENCD/EXCD/LSCR) from MSU-1
  lda.w SCUMM.currentRoom
  jsr _scummvm.loadRoomScripts

  ; Reload all live GLOBAL scripts
  jsr _scummvm.reloadGlobalScripts

  ; Update LOCAL/ROOM slots to use reloaded room script cache offsets
  jsr _scummvm.updateRoomSlotPtrs

  ply
  plx
  stz.w SCUMM.gcInProgress
_cacheGC.done:
  rts


;-------------------------------------------------------------------
; _scummvm.updateRoomSlotPtrs -- fix LOCAL/ROOM slot cache pointers
; Called after cacheGC reloads room scripts at new cache offsets.
; ROOM slots (ENCD) → use roomEncdPtr/Len
; LOCAL slots (LSCR 200-255) → use roomLscrTable entry
;-------------------------------------------------------------------
_scummvm.updateRoomSlotPtrs:
  phx
  phy
  ldx #0
  ldy #0
_updateRoomPtrs.loop:
  lda.w SCUMM.slots.status,x
  and #$00FF
  beq _updateRoomPtrs.next        ; skip dead slots

  lda.w SCUMM.slots.where,x
  and #$00FF
  cmp #SCUMM_WHERE_ROOM
  beq _updateRoomPtrs.room
  cmp #SCUMM_WHERE_LOCAL
  beq _updateRoomPtrs.local
  bra _updateRoomPtrs.next        ; GLOBAL already handled

_updateRoomPtrs.room:
  ; ROOM slot = ENCD script
  lda.w SCUMM.roomEncdPtr
  sta.w SCUMM.slots.cachePtr,x
  lda.w SCUMM.roomEncdLen
  sta.w SCUMM.slots.cacheLen,x
  bra _updateRoomPtrs.next

_updateRoomPtrs.local:
  ; LOCAL slot = LSCR (number 200-255)
  lda.w SCUMM.slots.number,x
  and #$00FF
  sec
  sbc #SCUMM_LSCR_BASE            ; index = number - 200
  asl a
  asl a                            ; * 4 = sizeof(lscrEntry)
  phx
  tax
  lda.w SCUMM.roomLscrTable.cachePtr,x
  sta.w SCUMM.scratch
  lda.w SCUMM.roomLscrTable.cacheLen,x
  sta.w SCUMM.scratch2
  plx
  lda.w SCUMM.scratch
  sta.w SCUMM.slots.cachePtr,x
  lda.w SCUMM.scratch2
  sta.w SCUMM.slots.cacheLen,x

_updateRoomPtrs.next:
  txa
  clc
  adc #_sizeof_scummSlot
  tax
  iny
  cpy #SCUMM_MAX_SLOTS
  bcc _updateRoomPtrs.loop
  ply
  plx
  rts


;-------------------------------------------------------------------
; _scummvm.loadRoomScripts -- load ENCD/EXCD/LSCR from MSU-1
; Input: A = room number
; Output: carry set = scripts loaded, carry clear = none
; Clobbers: A, X, scratch/scratch2
;-------------------------------------------------------------------
_scummvm.loadRoomScripts:
  rep #$31
  sta.w SCUMM.scratch

  ;--- Zero LSCR table + ENCD/EXCD pointers ---
  stz.w SCUMM.roomEncdPtr
  stz.w SCUMM.roomEncdLen
  stz.w SCUMM.roomExcdPtr
  stz.w SCUMM.roomExcdLen
  stz.w SCUMM.roomLscrCount
  phx
  ldx #0
  lda #0
_loadRoom.zeroTable:
  sta.w SCUMM.roomLscrTable,x
  inx
  inx
  cpx #_sizeof_lscrEntry * SCUMM_LSCR_MAX
  bcc _loadRoom.zeroTable
  plx

  ;--- Seek to room index entry: roomIndexOffset + room * 8 ---
  lda.w SCUMM.scratch
  asl a
  asl a
  asl a                          ; room * 8
  clc
  adc.w SCUMM.roomIndexLo
  sta.w SCUMM.scratch2
  lda #0
  adc.w SCUMM.roomIndexHi
  tax
  lda.w SCUMM.scratch2
  phy
  jsr room.msu1Seek
  ply

  ;--- Read 8-byte index entry: offset32 + size32 ---
  sep #$20
  lda.l MSU_DATA
  xba
  lda.l MSU_DATA
  xba
  rep #$20
  pha                            ;push offset_lo
  sep #$20
  lda.l MSU_DATA
  xba
  lda.l MSU_DATA
  xba
  rep #$20
  pha                            ;push offset_hi
  ; Read size32 (discard — we parse the block header instead)
  sep #$20
  lda.l MSU_DATA
  lda.l MSU_DATA
  lda.l MSU_DATA
  lda.l MSU_DATA
  rep #$20

  ; Stack: [offset_hi] [offset_lo]
  ; Check for null entry (offset == 0)
  lda 3,s
  ora 1,s
  bne _loadRoom.exists

  ; No scripts for this room
  pla
  pla
  clc
  rts

_loadRoom.exists:
  ;--- Seek to room script block ---
  lda 1,s                        ;offset_hi
  tax
  lda 3,s                        ;offset_lo
  phy
  jsr room.msu1Seek
  ply
  pla                            ;discard offset_hi
  pla                            ;discard offset_lo

  ;--- Read block header ---
  ; encd_size (LE16)
  sep #$20
  lda.l MSU_DATA
  xba
  lda.l MSU_DATA
  xba
  rep #$20
  sta.w SCUMM.roomEncdLen

  ; excd_size (LE16)
  sep #$20
  lda.l MSU_DATA
  xba
  lda.l MSU_DATA
  xba
  rep #$20
  sta.w SCUMM.roomExcdLen

  ; lscr_count (u8) + reserved (u8)
  sep #$20
  lda.l MSU_DATA
  rep #$20
  and #$00FF
  sta.w SCUMM.roomLscrCount
  sep #$20
  lda.l MSU_DATA                 ;drain reserved byte
  rep #$20

  ;--- Read per-LSCR header entries ---
  ; For each LSCR: number(u8) + size(LE16) → store in table
  lda.w SCUMM.roomLscrCount
  beq _loadRoom.copyEncd
  pha                            ;push remaining count
_loadRoom.lscrHdr:
  ; Read lscr_number (u8)
  sep #$20
  lda.l MSU_DATA
  rep #$20
  and #$00FF
  sec
  sbc #SCUMM_LSCR_BASE           ; table index (0-55)
  asl a
  asl a                           ; * 4 byte offset
  tax

  ; Read lscr_size (LE16)
  sep #$20
  lda.l MSU_DATA
  xba
  lda.l MSU_DATA
  xba
  rep #$20
  sta.w SCUMM.roomLscrTable.cacheLen,x

  lda 1,s
  dec a
  sta 1,s
  bne _loadRoom.lscrHdr
  pla                            ;discard count

_loadRoom.copyEncd:
  ;--- Copy ENCD from MSU → cache ---
  lda.w SCUMM.roomEncdLen
  beq _loadRoom.copyExcd
  lda.w SCUMM.cacheWritePtr
  sta.w SCUMM.roomEncdPtr
  lda.w SCUMM.roomEncdLen
  jsr _scummvm.copyMsuToCache

_loadRoom.copyExcd:
  ;--- Copy EXCD from MSU → cache ---
  lda.w SCUMM.roomExcdLen
  beq _loadRoom.copyLscr
  lda.w SCUMM.cacheWritePtr
  sta.w SCUMM.roomExcdPtr
  lda.w SCUMM.roomExcdLen
  jsr _scummvm.copyMsuToCache

_loadRoom.copyLscr:
  ;--- Copy LSCR bytecodes from MSU → cache ---
  ; LSCRs are stored in number-ascending order in MSU, matching table iteration
  phx
  ldx #0
_loadRoom.lscrLoop:
  cpx #_sizeof_lscrEntry * SCUMM_LSCR_MAX
  bcs _loadRoom.lscrDone
  lda.w SCUMM.roomLscrTable.cacheLen,x
  beq _loadRoom.lscrNext          ; no entry at this index
  ; Save table offset, copy this LSCR
  phx
  lda.w SCUMM.cacheWritePtr
  sta.w SCUMM.scratch2            ; save cachePtr for this entry
  lda.w SCUMM.roomLscrTable.cacheLen,x
  jsr _scummvm.copyMsuToCache
  ; Write cachePtr back into the table
  plx
  lda.w SCUMM.scratch2
  sta.w SCUMM.roomLscrTable.cachePtr,x
_loadRoom.lscrNext:
  inx
  inx
  inx
  inx                              ; next lscrEntry (4 bytes)
  bra _loadRoom.lscrLoop
_loadRoom.lscrDone:
  plx

  sec                              ; success
  rts


;-------------------------------------------------------------------
; _scummvm.startEncdSlot -- start ENCD script in a new slot
; Uses roomEncdPtr/roomEncdLen. Finds dead slot, inits as ROOM.
;-------------------------------------------------------------------
_scummvm.startEncdSlot:
  rep #$31

  ; Find a dead slot
  ldx #0
  ldy #0
_startEncd.findSlot:
  lda.w SCUMM.slots.status,x
  and #$00FF
  cmp #SCUMM_SLOT_DEAD
  beq _startEncd.found
  txa
  clc
  adc #_sizeof_scummSlot
  tax
  iny
  cpy #SCUMM_MAX_SLOTS
  bcc _startEncd.findSlot
  rts                              ; no free slot

_startEncd.found:
  ; X = slot byte offset
  ; Set up SCUMM.scratch2 = cachePtr, SCUMM.scratch = cacheLen
  lda.w SCUMM.roomEncdPtr
  sta.w SCUMM.scratch2
  lda.w SCUMM.roomEncdLen
  sta.w SCUMM.scratch
  ; A = 0 (ENCD script number), Y = WHERE_ROOM
  lda #0
  ldy #SCUMM_WHERE_ROOM
  jmp _startScript.initSlot


;-------------------------------------------------------------------
; _scummvm.findSlotByNumber -- find slot running script N
; Input: A = script number
; Output: X = slot byte offset, carry set if found
;-------------------------------------------------------------------
_scummvm.findSlotByNumber:
  sta.w SCUMM.scratch
  ldx #0
  ldy #0
_findSlot.loop:
  lda.w SCUMM.slots.status,x
  and #$00FF
  cmp #SCUMM_SLOT_DEAD
  beq _findSlot.next
  lda.w SCUMM.slots.number,x
  and #$00FF
  cmp.w SCUMM.scratch
  beq _findSlot.found
_findSlot.next:
  txa
  clc
  adc #_sizeof_scummSlot
  tax
  iny
  cpy #SCUMM_MAX_SLOTS
  bcc _findSlot.loop
  clc
  rts
_findSlot.found:
  sec
  rts


;===================================================================
; 256-Entry Dispatch Table
;===================================================================
.include "src/object/scummvm/scummvm_dispatch_table.inc"


;===================================================================
; Opcode Handlers
;
; Register conventions:
;   Y = SCUMM PC (bytecode offset). Advance as bytes consumed.
;   A = scratch. SCUMM.currentOpcode has original byte.
;   X = scratch (not preserved).
;   [tmp] = 24-bit bytecode ptr. Do NOT clobber.
;   Carry on return: clear=continue, set=yield.
;   All handlers assume rep #$31 (16-bit A/X/Y).
;===================================================================

;-------------------------------------------------------------------
; op_stub -- unimplemented opcode, fatal error
;-------------------------------------------------------------------
op_stub:
  ldx.w SCUMM.currentSlotPtr
  tya
  sta.w SCUMM.slots.pc,x
  TRIGGER_ERROR E_ScummVmBadOpcode


;-------------------------------------------------------------------
; Tier 1 -- Boot critical opcodes
;-------------------------------------------------------------------

; stopObjectCode ($00, $A0)
op_stopObjectCode:
  ldx.w SCUMM.currentSlotPtr
  sep #$20
  lda #SCUMM_SLOT_DEAD
  sta.w SCUMM.slots.status,x
  rep #$20
  sec
  rts

; breakHere ($80)
op_breakHere:
  sec
  rts

; jumpRelative ($18) -- 2-byte signed relative offset
op_jumpRelative:
  jsr _scummvm.fetchWord    ; A = signed relative offset, Y past word
  sta.w SCUMM.scratch
  tya
  clc
  adc.w SCUMM.scratch       ; Y' = Y + offset
  tay
  clc
  rts

; move ($1A, $9A)
op_move:
  jsr _scummvm.getResultPos
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord
  jsr _scummvm.writeVariable
  clc
  rts

; startScript ($0A, $2A, $4A, $6A, $8A, $AA, $CA, $EA)
op_startScript:
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte
  pha
  jsr _scummvm.skipWordVararg
  pla
  phy                           ; save SCUMM PC (startScriptSlot clobbers Y)
  jsr _scummvm.startScriptSlot
  ply                           ; restore SCUMM PC
  clc
  rts

; stopScript ($62, $E2)
op_stopScript:
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte
  and #$00FF
  beq _stopScript.self
  phy                           ; save SCUMM PC (findSlotByNumber clobbers Y)
  jsr _scummvm.findSlotByNumber
  ply                           ; restore SCUMM PC
  bcc _stopScript.done
  sep #$20
  lda #SCUMM_SLOT_DEAD
  sta.w SCUMM.slots.status,x
  rep #$20
_stopScript.done:
  clc
  rts
_stopScript.self:
  ldx.w SCUMM.currentSlotPtr
  sep #$20
  lda #SCUMM_SLOT_DEAD
  sta.w SCUMM.slots.status,x
  rep #$20
  sec
  rts


;-------------------------------------------------------------------
; Tier 2 -- Conditional branches
;-------------------------------------------------------------------

; SCUMM v5 conditional convention (from ScummVM source):
;   if (condition TRUE) jumpRelative();      // Y += signed offset
;   else ignoreScriptWord();                 // skip 2 bytes (already consumed)
; Jump targets are signed relative offsets from the byte AFTER the target word.

; Helper: apply relative jump from SCUMM.scratch2 to Y
_scummvm.takeRelJump:
  tya
  clc
  adc.w SCUMM.scratch2
  tay
  rts

; isEqual ($48, $C8) -- getVar + p16[7] + jump
; ScummVM: if(b==a) skip, else jump → jump when NOT equal
op_isEqual:
  jsr _scummvm.getResultPos
  lda.w SCUMM.resultVar
  jsr _scummvm.readVariable
  pha
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord
  sta.w SCUMM.scratch
  jsr _scummvm.fetchWord
  sta.w SCUMM.scratch2
  pla
  cmp.w SCUMM.scratch
  beq +                          ; equal → condition TRUE → skip jump
    jsr _scummvm.takeRelJump     ; not equal → condition FALSE → take jump
+
  clc
  rts

; isNotEqual ($08, $88) -- getVar + p16[7] + jump
; ScummVM: if(b!=a) skip, else jump → jump when equal
op_isNotEqual:
  jsr _scummvm.getResultPos
  lda.w SCUMM.resultVar
  jsr _scummvm.readVariable
  pha
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord
  sta.w SCUMM.scratch
  jsr _scummvm.fetchWord
  sta.w SCUMM.scratch2
  pla
  cmp.w SCUMM.scratch
  bne +                          ; not equal → condition TRUE → skip jump
    jsr _scummvm.takeRelJump     ; equal → condition FALSE → take jump
+
  clc
  rts

; notEqualZero ($A8) -- getVar + jump
; ScummVM: if(a!=0) skip, else jump → jump when zero
op_notEqualZero:
  jsr _scummvm.fetchWord
  jsr _scummvm.readVariable
  pha
  jsr _scummvm.fetchWord
  sta.w SCUMM.scratch2
  pla
  cmp #0
  bne +                          ; not zero → condition TRUE → skip jump
    jsr _scummvm.takeRelJump     ; zero → condition FALSE → take jump
+
  clc
  rts

; equalZero ($28) -- getVar + jump
; ScummVM: if(a==0) skip, else jump → jump when NOT zero
op_equalZero:
  jsr _scummvm.fetchWord
  jsr _scummvm.readVariable
  pha
  jsr _scummvm.fetchWord
  sta.w SCUMM.scratch2
  pla
  cmp #0
  beq +                          ; zero → condition TRUE → skip jump
    jsr _scummvm.takeRelJump     ; not zero → condition FALSE → take jump
+
  clc
  rts

; isGreater ($78, $F8) -- getVar + p16[7] + jump
; ScummVM: if(b>a) skip, else jump → skip when A < scratch
op_isGreater:
  jsr _scummvm.getResultPos
  lda.w SCUMM.resultVar
  jsr _scummvm.readVariable
  pha
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord
  sta.w SCUMM.scratch
  jsr _scummvm.fetchWord
  sta.w SCUMM.scratch2
  pla
  cmp.w SCUMM.scratch
  bcc +                          ; A < scratch → b > a → condition TRUE → skip
    jsr _scummvm.takeRelJump     ; A >= scratch → b <= a → condition FALSE → jump
+
  clc
  rts

; isLess ($44, $C4) -- getVar + p16[7] + jump
; ScummVM: if(b<a) skip, else jump → skip when A > scratch
op_isLess:
  jsr _scummvm.getResultPos
  lda.w SCUMM.resultVar
  jsr _scummvm.readVariable
  pha
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord
  sta.w SCUMM.scratch
  jsr _scummvm.fetchWord
  sta.w SCUMM.scratch2
  pla
  cmp.w SCUMM.scratch
  beq _isLess.doJump             ; A == scratch → b >= a → condition FALSE → jump
  bcs +                          ; A > scratch → b < a → condition TRUE → skip
_isLess.doJump:
    jsr _scummvm.takeRelJump     ; A <= scratch → b >= a → condition FALSE → jump
+
  clc
  rts

; isLessEqual ($38, $B8) -- getVar + p16[7] + jump
; ScummVM: if(b<=a) skip, else jump → skip when A >= scratch
op_isLessEqual:
  jsr _scummvm.getResultPos
  lda.w SCUMM.resultVar
  jsr _scummvm.readVariable
  pha
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord
  sta.w SCUMM.scratch
  jsr _scummvm.fetchWord
  sta.w SCUMM.scratch2
  pla
  cmp.w SCUMM.scratch
  bcs +                          ; A >= scratch → b <= a → condition TRUE → skip
    jsr _scummvm.takeRelJump     ; A < scratch → b > a → condition FALSE → jump
+
  clc
  rts

; isGreaterEqual ($04, $84) -- getVar + p16[7] + jump
; ScummVM: if(b>=a) skip, else jump → skip when A <= scratch
op_isGreaterEqual:
  jsr _scummvm.getResultPos
  lda.w SCUMM.resultVar
  jsr _scummvm.readVariable
  pha
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord
  sta.w SCUMM.scratch
  jsr _scummvm.fetchWord
  sta.w SCUMM.scratch2
  pla
  cmp.w SCUMM.scratch
  beq +                          ; A == scratch → b >= a → condition TRUE → skip
  bcc +                          ; A < scratch → b > a → condition TRUE → skip
    jsr _scummvm.takeRelJump     ; A > scratch → b < a → condition FALSE → jump
+
  clc
  rts


;-------------------------------------------------------------------
; Tier 3 -- Arithmetic opcodes
;-------------------------------------------------------------------

; add ($5A, $DA)
op_add:
  jsr _scummvm.getResultPos
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord
  pha
  lda.w SCUMM.resultVar
  jsr _scummvm.readVariable
  clc
  adc 1,s
  sta.w SCUMM.scratch
  pla
  lda.w SCUMM.scratch
  jsr _scummvm.writeVariable
  clc
  rts

; subtract ($3A, $BA)
op_subtract:
  jsr _scummvm.getResultPos
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord
  pha
  lda.w SCUMM.resultVar
  jsr _scummvm.readVariable
  sec
  sbc 1,s
  sta.w SCUMM.scratch
  pla
  lda.w SCUMM.scratch
  jsr _scummvm.writeVariable
  clc
  rts

; increment ($46)
op_increment:
  jsr _scummvm.getResultPos
  lda.w SCUMM.resultVar
  jsr _scummvm.readVariable
  inc a
  jsr _scummvm.writeVariable
  clc
  rts

; decrement ($C6)
op_decrement:
  jsr _scummvm.getResultPos
  lda.w SCUMM.resultVar
  jsr _scummvm.readVariable
  dec a
  jsr _scummvm.writeVariable
  clc
  rts


;-------------------------------------------------------------------
; Misc opcodes for boot path
;-------------------------------------------------------------------

; setVarRange ($26, $A6)
op_setVarRange:
  jsr _scummvm.getResultPos
  jsr _scummvm.fetchByte
  sta.w SCUMM.scratch

  lda.w SCUMM.currentOpcode
  and #SCUMM_FLAG_BIT5
  bne _setVarRange.wordMode

_setVarRange.byteMode:
  lda.w SCUMM.scratch
  beq _setVarRange.done
_setVarRange.byteLoop:
  jsr _scummvm.fetchByte
  jsr _scummvm.writeVariable
  lda.w SCUMM.resultVar
  inc a
  sta.w SCUMM.resultVar
  lda.w SCUMM.scratch
  dec a
  sta.w SCUMM.scratch
  bne _setVarRange.byteLoop
  bra _setVarRange.done

_setVarRange.wordMode:
  lda.w SCUMM.scratch
  beq _setVarRange.done
_setVarRange.wordLoop:
  jsr _scummvm.fetchWord
  jsr _scummvm.writeVariable
  lda.w SCUMM.resultVar
  inc a
  sta.w SCUMM.resultVar
  lda.w SCUMM.scratch
  dec a
  sta.w SCUMM.scratch
  bne _setVarRange.wordLoop

_setVarRange.done:
  clc
  rts

; delay ($2E) -- 3-byte LE delay value
op_delay:
  jsr _scummvm.fetchByte
  sta.w SCUMM.scratch
  jsr _scummvm.fetchByte
  xba
  ora.w SCUMM.scratch
  ldx.w SCUMM.currentSlotPtr
  sta.w SCUMM.slots.delay,x
  jsr _scummvm.fetchByte
  sec
  rts

; delayVariable ($2B)
op_delayVariable:
  jsr _scummvm.fetchWord
  jsr _scummvm.readVariable
  ldx.w SCUMM.currentSlotPtr
  sta.w SCUMM.slots.delay,x
  sec
  rts

; dummy ($A7)
op_dummy:
  clc
  rts

; cutscene ($40) -- read arg list, increment nest level
op_cutscene:
  jsr _scummvm.skipWordVararg
  lda.w SCUMM.cutsceneNest
  inc a
  sta.w SCUMM.cutsceneNest
  ldx.w SCUMM.currentSlotPtr
  sep #$20
  lda.w SCUMM.slots.cutsceneOverride,x
  inc a
  sta.w SCUMM.slots.cutsceneOverride,x
  rep #$20
  clc
  rts

; endCutscene ($C0)
op_endCutscene:
  lda.w SCUMM.cutsceneNest
  beq +
  dec a
  sta.w SCUMM.cutsceneNest
+
  ldx.w SCUMM.currentSlotPtr
  lda.w SCUMM.slots.cutsceneOverride,x
  and #$00FF
  beq +
  dec a
  sep #$20
  sta.w SCUMM.slots.cutsceneOverride,x
  rep #$20
+
  clc
  rts

; override ($58)
op_override:
  jsr _scummvm.fetchWord
  clc
  rts

; freezeScripts ($60, $E0)
op_freezeScripts:
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte
  sta.w SCUMM.scratch
  ldx #0
  ldy #0
_freeze.loop:
  cpx.w SCUMM.currentSlotPtr
  beq _freeze.next
  lda.w SCUMM.slots.status,x
  and #$00FF
  cmp #SCUMM_SLOT_RUNNING
  bne _freeze.next

  lda.w SCUMM.scratch
  beq _freeze.unfreeze
  lda.w SCUMM.slots.freezeCount,x
  and #$00FF
  inc a
  sep #$20
  sta.w SCUMM.slots.freezeCount,x
  rep #$20
  bra _freeze.next
_freeze.unfreeze:
  lda.w SCUMM.slots.freezeCount,x
  and #$00FF
  beq _freeze.next
  dec a
  sep #$20
  sta.w SCUMM.slots.freezeCount,x
  rep #$20

_freeze.next:
  txa
  clc
  adc #_sizeof_scummSlot
  tax
  iny
  cpy #SCUMM_MAX_SLOTS
  bcc _freeze.loop
  clc
  rts

; stopObjectScript ($6E, $EE)
op_stopObjectScript:
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord
  clc
  rts

; isScriptRunning ($68, $E8)
op_isScriptRunning:
  jsr _scummvm.getResultPos
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte
  phy                           ; save SCUMM PC (findSlotByNumber clobbers Y)
  jsr _scummvm.findSlotByNumber
  ply                           ; restore SCUMM PC
  bcs +
    lda #0
    bra _isScriptRunning.write
+
    lda #1
_isScriptRunning.write:
  jsr _scummvm.writeVariable
  clc
  rts

; debug ($6B, $EB)
op_debug:
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord
  clc
  rts

; and ($17, $97)
op_and:
  jsr _scummvm.getResultPos
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord
  pha
  lda.w SCUMM.resultVar
  jsr _scummvm.readVariable
  and 1,s
  sta.w SCUMM.scratch
  pla
  lda.w SCUMM.scratch
  jsr _scummvm.writeVariable
  clc
  rts

; or ($57, $D7)
op_or:
  jsr _scummvm.getResultPos
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord
  pha
  lda.w SCUMM.resultVar
  jsr _scummvm.readVariable
  ora 1,s
  sta.w SCUMM.scratch
  pla
  lda.w SCUMM.scratch
  jsr _scummvm.writeVariable
  clc
  rts

; expression ($AC) -- stack-based expression evaluator
op_expression:
  jsr _scummvm.getResultPos
_expression.loop:
  jsr _scummvm.fetchByte
  cmp #$FF
  bne _expression.notEnd
  jmp _expression.end
_expression.notEnd:
  sta.w SCUMM.scratch

  lda.w SCUMM.scratch
  and #$001F
  cmp #$01
  beq _expression.number         ; 0x01 = PUSH value
  cmp #$02
  beq _expression.add            ; 0x02 = ADD
  cmp #$03
  beq _expression.sub            ; 0x03 = SUB
  cmp #$04
  beq _expression.mul            ; 0x04 = MUL
  cmp #$05
  beq _expression.div            ; 0x05 = DIV
  bra _expression.loop           ; unknown sub-op → skip

_expression.number:
  lda.w SCUMM.currentOpcode
  pha                              ; save real opcode
  lda.w SCUMM.scratch
  sta.w SCUMM.currentOpcode        ; set sub-opcode for flag check
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord
  sta.w SCUMM.scratch2             ; save result
  pla
  sta.w SCUMM.currentOpcode        ; restore real opcode
  lda.w SCUMM.scratch2
  pha                              ; push value onto RPN stack
  jmp _expression.loop

_expression.add:
  pla
  sta.w SCUMM.scratch2
  pla
  clc
  adc.w SCUMM.scratch2
  pha
  jmp _expression.loop

_expression.sub:
  pla
  sta.w SCUMM.scratch2
  pla
  sec
  sbc.w SCUMM.scratch2
  pha
  jmp _expression.loop

_expression.mul:
  pla                              ; B (second operand)
  sta.w SCUMM.scratch2
  pla                              ; A (first operand)
  jsr _scummvm.mul16
  pha
  jmp _expression.loop

_expression.div:
  pla                              ; divisor
  sta.w SCUMM.scratch2
  pla                              ; dividend
  ldx.w SCUMM.scratch2
  beq _expression.divZero
  jsr _scummvm.div16
  pha
  jmp _expression.loop
_expression.divZero:
  lda #0
  pha
  jmp _expression.loop

_expression.end:
  pla
  jsr _scummvm.writeVariable
  clc
  rts

; chainScript ($42, $C2)
op_chainScript:
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte
  pha
  jsr _scummvm.skipWordVararg
  ldx.w SCUMM.currentSlotPtr
  sep #$20
  lda #SCUMM_SLOT_DEAD
  sta.w SCUMM.slots.status,x
  rep #$20
  pla
  phy                           ; save Y (startScriptSlot clobbers Y)
  jsr _scummvm.startScriptSlot
  ply                           ; restore Y
  sec
  rts

; cursorCommand ($2C) -- subop-based, consume parameters + apply cursor state
op_cursorCommand:
  jsr _scummvm.fetchWord
  and #$001F
  cmp #$0A
  beq _cursor.twoArgs
  cmp #$0B
  beq _cursor.twoArgs
  cmp #$0C
  beq _cursor.oneArg
  cmp #$0D
  beq _cursor.oneArg
  cmp #$0E
  beq _cursor.argList
  ; Subops 1-7: cursor/userput state (no extra bytecode params)
  cmp #$01
  beq _cursor.cursorOn
  cmp #$02
  beq _cursor.cursorOff
  cmp #$05
  bne +
_cursor.cursorOn:
  lda #1
  sta.w SCUMM.cursorEnabled
  clc
  rts
+
  cmp #$06
  bne +
  lda #1
  ldx #48*2
  sta.w SCUMM.globalVars,x
  clc
  rts
+
  cmp #$07
  bne +
  stz.w SCUMM.cursorEnabled
  lda #0
  ldx #48*2
  sta.w SCUMM.globalVars,x
  clc
  rts
+
_cursor.cursorOff:
  stz.w SCUMM.cursorEnabled
  clc
  rts
_cursor.twoArgs:
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte
  lda #SCUMM_FLAG_BIT6
  jsr _scummvm.getVarOrDirectByte
  clc
  rts
_cursor.oneArg:
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte
  clc
  rts
_cursor.argList:
  jsr _scummvm.fetchByte
  cmp #$00FF
  bne _cursor.argList
  clc
  rts

; systemOps ($98)
op_systemOps:
  jsr _scummvm.fetchByte
  clc
  rts

;-------------------------------------------------------------------
; Actor / resource stubs -- consume params correctly, no-op for now
;-------------------------------------------------------------------

; resourceRoutines ($0C, $8C) -- resource preload/cache management
; Sub-opcode byte controls flag bits, not the main opcode.
; All are no-ops for MSU-1 on-demand loading; just skip params.
op_resourceRoutines:
  jsr _scummvm.fetchByte     ; read sub-opcode byte
  sta.w SCUMM.scratch        ; save full sub-opcode

  and #$003F                 ; mask to get key
  cmp #$11
  beq _resRoutines.done      ; clearHeap: no params
  cmp #$14
  beq _resRoutines.flObject  ; loadFlObject: p8 + p16

  ; Default: one p8 parameter (flag = bit 7 of MAIN opcode, per ScummVM)
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte
  bra _resRoutines.done

_resRoutines.flObject:
  ; loadFlObject: p8[7] room + p16 object (per ScummVM)
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte   ; room
  jsr _scummvm.fetchWord            ; object ID (always p16)

_resRoutines.done:
  clc
  rts

; putActorInRoom ($2D, $6D, $AD, $ED)
; Params: p8[7]=actor, p8[6]=room
op_putActorInRoom:
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte    ; actor number
  jsr _scummvm.getActorPtr           ; X = actor table offset
  stx.w SCUMM.scratch2              ; save actor offset

  lda #SCUMM_FLAG_BIT6
  jsr _scummvm.getVarOrDirectByte    ; room number
  ldx.w SCUMM.scratch2
  sep #$20
  sta.w SCUMM.actors.room,x
  ; room=0 means "remove from room" → clear visible; otherwise set visible
  cmp #0
  beq +
    lda #1
    sta.w SCUMM.actors.visible,x
    bra ++
+
    stz.w SCUMM.actors.visible,x
++
  rep #$20

  clc
  rts

; getActorMoving ($56, $D6)
; Params: result + p8[7]=actor
; Returns actor's moving field (0=stationary, non-zero=moving)
op_getActorMoving:
  jsr _scummvm.getResultPos
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte    ; actor number
  jsr _scummvm.getActorPtr           ; X = actor table offset
  lda.w SCUMM.actors.moving,x
  and #$00FF                         ; db field — mask high byte
  jsr _scummvm.writeVariable
  clc
  rts

; getObjectState ($0F, $8F) -- result + p16[7], return 0
op_getObjectState:
  jsr _scummvm.getResultPos
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord    ; object ID
  tax
  cpx #SCUMM_MAX_OBJECTS
  bcs _getObjState.zero              ; out of bounds → return 0
    lda.w SCUMM.objectState,x
    and #$00FF                       ; byte field → mask high
    jsr _scummvm.writeVariable
    clc
    rts
_getObjState.zero:
  lda #0
  jsr _scummvm.writeVariable
  clc
  rts

; getObjectOwner ($10, $90) -- result + p16[7], return 0
op_getObjectOwner:
  jsr _scummvm.getResultPos
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord    ; object ID
  lda #0
  jsr _scummvm.writeVariable
  clc
  rts

; setState ($07, $47, $87, $C7) -- getVarOrDirectWord[7] + getVarOrDirectByte[6], no-op
op_setState:
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord    ; object ID (p16 with BIT7)
  sta.w SCUMM.scratch                ; save object ID
  lda #SCUMM_FLAG_BIT6
  jsr _scummvm.getVarOrDirectByte    ; state (p8 with BIT6)
  sta.w SCUMM.scratch2               ; save state
  ; Bounds check object ID
  ldx.w SCUMM.scratch
  cpx #SCUMM_MAX_OBJECTS
  bcs +                              ; out of bounds → skip
    sep #$20
    lda.w SCUMM.scratch2
    sta.w SCUMM.objectState,x        ; objectState[objID] = state
    rep #$20
+
  clc
  rts

; putActor ($01, $21, $41, $61, $81, $A1, $C1, $E1) -- p8[7]=actor, p16[6]=x, p16[5]=y
op_putActor:
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte    ; actor number
  jsr _scummvm.getActorPtr           ; X = actor table offset (clamped if invalid)
  stx.w SCUMM.scratch2              ; save actor offset

  lda #SCUMM_FLAG_BIT6
  jsr _scummvm.getVarOrDirectWord    ; x coordinate
  ldx.w SCUMM.scratch2
  sta.w SCUMM.actors.x,x

  lda #SCUMM_FLAG_BIT5
  jsr _scummvm.getVarOrDirectWord    ; y coordinate
  ldx.w SCUMM.scratch2
  sta.w SCUMM.actors.y,x

  ; putActor defaults to current room (like ScummVM)
  sep #$20
  lda.w SCUMM.currentRoom
  sta.w SCUMM.actors.room,x
  lda #1
  sta.w SCUMM.actors.visible,x
  rep #$20

  clc
  rts

; getActorRoom ($03, $83) -- result + p8[7], return actor's room
op_getActorRoom:
  jsr _scummvm.getResultPos
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte    ; actor number
  jsr _scummvm.getActorPtr
  lda.w SCUMM.actors.room,x
  and #$00FF                        ; byte field → 16-bit
  jsr _scummvm.writeVariable
  clc
  rts

; panCameraTo ($12, $92) -- p16[7] (always 2 bytes), no-op
op_panCameraTo:
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord
  clc
  rts

; setCameraAt ($32, $B2) -- p16[7] (always 2 bytes), no-op
op_setCameraAt:
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord
  clc
  rts

; lights ($70, $F0) -- p8[7] + byte + byte, no-op
op_lights:
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte    ; luminance
  jsr _scummvm.fetchByte             ; color1
  jsr _scummvm.fetchByte             ; color2
  clc
  rts

; loadRoom ($72, $F2) -- p8[7], no-op for now
op_loadRoom:
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte    ; room number
  and #$00FF
  sta.w SCUMM.newRoom                ; request room change (processed in play loop)
  clc
  rts

; setOwnerOf ($29, $69, $A9, $E9) -- p16[7] + p8[6], no-op
op_setOwnerOf:
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord    ; object
  lda #SCUMM_FLAG_BIT6
  jsr _scummvm.getVarOrDirectByte    ; owner
  clc
  rts

; getActorX ($43, $C3) -- result + p16[7], return actor's X
op_getActorX:
  jsr _scummvm.getResultPos
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord    ; actor number (p16 format)
  jsr _scummvm.getActorPtr
  lda.w SCUMM.actors.x,x
  jsr _scummvm.writeVariable
  clc
  rts

; getActorY ($23, $A3) -- result + p16[7], return actor's Y
op_getActorY:
  jsr _scummvm.getResultPos
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord    ; actor number (p16 format)
  jsr _scummvm.getActorPtr
  lda.w SCUMM.actors.y,x
  jsr _scummvm.writeVariable
  clc
  rts

; actorOps ($13, $93) -- p8[7]=actor + sub-opcode sequence terminated by $FF
op_actorOps:
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte    ; actor number
  jsr _scummvm.getActorPtr           ; X = actor table offset
  ; Save actor table offset on stack (preserved across sub-opcode loop)
  phx

_actorOps.subLoop:
  jsr _scummvm.fetchByte
  cmp #$FF
  bne _actorOps.dispatch
  plx                                ; clean up actor offset from stack
  jmp _actorOps.done
_actorOps.dispatch:
  sta.w SCUMM.scratch                ; save full sub-opcode byte (flags in upper bits)
  and #$001F                         ; sub-opcode key (ScummVM: _opcode & 0x1F)
  ; ScummVM v5 actorOps sub-opcodes (1-based):
  ;   0x01=setCostume(p8), 0x02=walkSpeed(2xp8), 0x03=sound(p8),
  ;   0x04=walkAnimNr(p8), 0x05=talkAnimNr(2xp8), 0x06=standFrame(p8),
  ;   0x07=palette(3xp8), 0x08=init(0), 0x09=elevation(p16),
  ;   0x0A=animDefault(0), 0x0B=palette2(2xp8), 0x0C=talkColor(p8),
  ;   0x0D=actorName(string), 0x0E=initFrame(p8), 0x10=width(p8),
  ;   0x11=scale(2xp8), 0x12=neverZClip(0), 0x13=setZClip(p8),
  ;   0x14=ignoreBoxes(0), 0x15=followBoxes(0), 0x16=animSpeed(p8),
  ;   0x17=shadow(p8)
  ;--- Sub 0x01: setCostume — wire to actor table
  cmp #$01
  bne +
    jmp _actorOps.sub_setCostume
+
  ;--- Sub 0x02: walkSpeed (2 params: p8[7] + p8[6])
  cmp #$02
  beq _actorOps.jmp_2param
  ;--- Sub 0x05: talkAnimNr (2 params: p8[7] + p8[6])
  cmp #$05
  beq _actorOps.jmp_2param
  ;--- Sub 0x07: palette (3 params: p8[7] + p8[6] + p8[5])
  cmp #$07
  bne +
    jmp _actorOps.sub_default
+
  ;--- Sub 0x0B: palette2 (2 params: p8[7] + p8[6])
  cmp #$0B
  beq _actorOps.jmp_2param
  ;--- Sub 0x11: scale (2 params: p8[7] + p8[6])
  cmp #$11
  beq _actorOps.jmp_2param
  ;--- Sub 0x0D: actorName (null-terminated string)
  cmp #$0D
  bne +
    jmp _actorOps.sub_string
+
  ;--- Sub 0x09: elevation (1 param: p16[7] — WORD)
  cmp #$09
  bne +
    jmp _actorOps.sub_p16
+
  ;--- Sub 0x08: init (0 params)
  cmp #$08
  beq _actorOps.sub_none
  ;--- Sub 0x0A: animDefault (0 params)
  cmp #$0A
  beq _actorOps.sub_none
  ;--- Sub 0x12: neverZClip (0 params)
  cmp #$12
  beq _actorOps.sub_none
  ;--- Sub 0x14: ignoreBoxes (0 params)
  cmp #$14
  beq _actorOps.sub_none
  ;--- Sub 0x15: followBoxes (0 params)
  cmp #$15
  beq _actorOps.sub_none
  ;--- Sub 0x0E: initFrame — wire to actor table
  cmp #$0E
  bne +
    jmp _actorOps.sub_initFrame
+
  ;--- Everything else: 1 param p8[7]
  ; (0x03=sound, 0x04=walkAnimNr, 0x06=standFrame, 0x0C=talkColor,
  ;  0x10=width, 0x13=setZClip, 0x16=animSpeed, 0x17=shadow + unknown)
  bra _actorOps.sub_1param

_actorOps.jmp_2param:
  jmp _actorOps.sub_2param

_actorOps.sub_1param:
  lda.w SCUMM.scratch
  and #$0080
  beq +
  jsr _scummvm.fetchWord
  jmp _actorOps.subLoop
+
  jsr _scummvm.fetchByte
  jmp _actorOps.subLoop

_actorOps.sub_setCostume:
  ; Sub 0x00: p8[7] — store costume to actor table
  lda.w SCUMM.scratch
  and #$0080
  beq +
    jsr _scummvm.fetchWord
    jsr _scummvm.readVariable
    bra ++
+
    jsr _scummvm.fetchByte
++
  pha                                ; save costume value
  lda 3,s                           ; actor offset (past pushed costume)
  tax
  pla
  sep #$20
  sta.w SCUMM.actors.costume,x
  rep #$20
  jmp _actorOps.subLoop

_actorOps.sub_initFrame:
  ; Sub 0x08: p8[7] — store initFrame to actor table
  lda.w SCUMM.scratch
  and #$0080
  beq +
    jsr _scummvm.fetchWord
    jsr _scummvm.readVariable
    bra ++
+
    jsr _scummvm.fetchByte
++
  pha
  lda 3,s
  tax
  pla
  sep #$20
  sta.w SCUMM.actors.initFrame,x
  rep #$20
  jmp _actorOps.subLoop

_actorOps.sub_none:
  jmp _actorOps.subLoop

_actorOps.sub_2param:
  lda.w SCUMM.scratch
  and #$0080
  beq +
  jsr _scummvm.fetchWord
  bra ++
+
  jsr _scummvm.fetchByte
++
  lda.w SCUMM.scratch
  and #$0040
  beq +
  jsr _scummvm.fetchWord
  jmp _actorOps.subLoop
+
  jsr _scummvm.fetchByte
  jmp _actorOps.subLoop

_actorOps.sub_2word:
  ; Sub 0x14 textOffset: p16[7] + p16[6] (word params)
  lda.w SCUMM.scratch
  and #$0080
  beq +
  jsr _scummvm.fetchWord
  jsr _scummvm.readVariable
  bra ++
+
  jsr _scummvm.fetchWord
++
  lda.w SCUMM.scratch
  and #$0040
  beq +
  jsr _scummvm.fetchWord
  jsr _scummvm.readVariable
  jmp _actorOps.subLoop
+
  jsr _scummvm.fetchWord
  jmp _actorOps.subLoop

_actorOps.sub_p16:
  ; Sub 0x16 elevation: p16[7] (word param)
  lda.w SCUMM.scratch
  and #$0080
  beq +
  jsr _scummvm.fetchWord
  jsr _scummvm.readVariable
  jmp _actorOps.subLoop
+
  jsr _scummvm.fetchWord
  jmp _actorOps.subLoop

_actorOps.sub_default:
  ; Sub 0x07: 5 params — p8[7] + p8[6] + p8[5] then reuse sub-op as flags for 2 more
  ; Read first 3 params using original sub-op byte flags
  lda.w SCUMM.scratch
  and #$0080
  beq +
  jsr _scummvm.fetchWord
  bra ++
+
  jsr _scummvm.fetchByte
++
  lda.w SCUMM.scratch
  and #$0040
  beq +
  jsr _scummvm.fetchWord
  bra ++
+
  jsr _scummvm.fetchByte
++
  lda.w SCUMM.scratch
  and #$0020
  beq +
  jsr _scummvm.fetchWord
  bra ++
+
  jsr _scummvm.fetchByte
++
  ; Next 2 params reuse BIT7 and BIT6 from same sub-op byte
  lda.w SCUMM.scratch
  and #$0080
  beq +
  jsr _scummvm.fetchWord
  bra ++
+
  jsr _scummvm.fetchByte
++
  lda.w SCUMM.scratch
  and #$0040
  beq +
  jsr _scummvm.fetchWord
  jmp _actorOps.subLoop
+
  jsr _scummvm.fetchByte
  jmp _actorOps.subLoop

_actorOps.sub_string:
  jsr _scummvm.fetchByte
  cmp #0
  bne _actorOps.sub_string
  jmp _actorOps.subLoop

_actorOps.done:
  clc
  rts

;===================================================================
; Batch stub opcodes — consume params correctly, no-op behavior
; These allow ENCD and LSCR scripts to run without crashing.
;===================================================================

;-------------------------------------------------------------------
; Sound opcodes — wired to Terrific Audio Driver (TAD)
;-------------------------------------------------------------------

; stopSound ($3C, $BC) -- p8[7] sound ID → stop all SFX
op_stopSound:
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte
  ; Stop all sound effects via TAD
  phy
  sep #$20
  lda.b #TadCommand_STOP_SOUND_EFFECTS
  ldx #0
  ldy #0
  jsl Tad_QueueCommand
  rep #$31
  ply
  clc
  rts

; startSound ($1C, $9C) -- p8[7] sound ID → queue SFX
op_startSound:
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte
  ; Queue sound effect via TAD (A = sfx id)
  phy
  sep #$20
  jsl Tad_QueueSoundEffect
  rep #$31
  ply
  clc
  rts

; startMusic ($02, $82) -- p8[7] song ID → load song
op_startMusic:
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte
  phy
  pha                               ; save song ID
  lda.w SCUMM.musicMode
  bne _startMusic.msu1
  ; TAD path
  pla
  sep #$20
  jsl Tad_LoadSongIfChanged
  rep #$31
  ply
  clc
  rts
_startMusic.msu1:
  pla                               ; A = song ID
  jsr _scummvm.msu1PlayTrack
  ply
  clc
  rts

; stopMusic ($20) -- no params → pause music
op_stopMusic:
  phy
  lda.w SCUMM.musicMode
  bne _stopMusic.msu1
  ; TAD path
  sep #$20
  lda.b #TadCommand_PAUSE
  ldx #0
  ldy #0
  jsl Tad_QueueCommand
  rep #$31
  ply
  clc
  rts
_stopMusic.msu1:
  jsr _scummvm.msu1StopTrack
  ply
  clc
  rts

; isSoundRunning ($7C, $FC) -- result + p8[7] → check TAD state
op_isSoundRunning:
  jsr _scummvm.getResultPos
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte    ; consume sound ID param
  ; Stub: always return 1 (sound is playing)
  ; Prevents ENCD from falling through to soundKludge that reads past script end
  ; TODO: replace with real TAD/MSU-1 state when audio is wired
  lda #1
  jsr _scummvm.writeVariable
  clc
  rts

; soundKludge ($4C, $CC) -- iMUSE vararg, consume params (stub)
op_soundKludge:
  ldx #16                          ; max 16 args (ScummVM limit)
-
  jsr _scummvm.fetchByte
  cmp #$00FF
  beq +
  dex
  beq +                            ; safety: stop after 16 args
  jsr _scummvm.fetchWord
  bra -
+
  clc
  rts


;-------------------------------------------------------------------
; MSU-1 Audio Helpers — used when musicMode = MSU-1
;-------------------------------------------------------------------

; Play MSU-1 audio track (A = track number, 16-bit)
_scummvm.msu1PlayTrack:
  sep #$20
  sta.l MSU_TRACK
  lda.b #0
  sta.l MSU_TRACK+1
  ; Wait for audio busy to clear
- lda.l MSU_STATUS
  and.b #MSU_STATUS_AUDIO_BUSY
  bne -
  ; Start playing with repeat (music loops)
  lda.b #MSU_CONTROL_PLAY | MSU_CONTROL_REPEAT
  sta.l MSU_CONTROL
  ; Check for audio error (missing PCM file → graceful silence)
  lda.l MSU_STATUS
  and.b #MSU_STATUS_AUDIO_ERROR
  beq +
    lda.b #MSU_VOLUME_MUTE
    sta.l MSU_VOLUME
    lda.b #0
    sta.l MSU_CONTROL
    rep #$20
    rts
+
  ; Set volume to full (after play start, prevents DC offset click)
  lda.b #MSU_VOLUME_FULL
  sta.l MSU_VOLUME
  rep #$20
  rts

; Stop MSU-1 audio track
_scummvm.msu1StopTrack:
  sep #$20
  lda.b #MSU_VOLUME_MUTE
  sta.l MSU_VOLUME
  lda.b #0
  sta.l MSU_CONTROL
  rep #$20
  rts

; Check if MSU-1 audio is playing (carry set = playing)
_scummvm.msu1IsPlaying:
  sep #$20
  lda.l MSU_STATUS
  and.b #MSU_STATUS_AUDIO_PLAY
  rep #$20
  beq +
    sec
    rts
+
  clc
  rts


;-------------------------------------------------------------------
; setClass ($5D, $DD) -- p16 object + vararg class list, no-op
;-------------------------------------------------------------------
op_setClass:
  jsr _scummvm.fetchWord             ; object ID (always p16)
  ; Vararg: {aux_byte, word_value}* terminated by $FF
-
  jsr _scummvm.fetchByte
  cmp #$00FF
  beq +
  jsr _scummvm.fetchWord             ; class word arg
  bra -
+
  clc
  rts


;-------------------------------------------------------------------
; matrixOps ($30, $B0) -- sub-opcode with box params, no-op
;-------------------------------------------------------------------
op_matrixOps:
  jsr _scummvm.fetchByte             ; sub-opcode byte
  sta.w SCUMM.scratch
  and #$001F                         ; key
  cmp #$04
  beq _matrixOps.done                ; createBoxMatrix: no params
  cmp #$01
  beq _matrixOps.twoP8
  cmp #$02
  beq _matrixOps.twoP8
  cmp #$03
  beq _matrixOps.twoP8
  ; Unknown sub-op: no params
  bra _matrixOps.done

_matrixOps.twoP8:
  ; box: p8[bit7 of sub], val: p8[bit6 of sub]
  lda.w SCUMM.scratch
  and #$0080
  beq +
  jsr _scummvm.fetchWord             ; var ref
  bra ++
+
  jsr _scummvm.fetchByte             ; literal
++
  lda.w SCUMM.scratch
  and #$0040
  beq +
  jsr _scummvm.fetchWord
  bra _matrixOps.done
+
  jsr _scummvm.fetchByte

_matrixOps.done:
  clc
  rts


;-------------------------------------------------------------------
; roomOps ($33, $B3) -- sub-opcode with variable params, no-op
; Only sub-opcodes actually used by MI1 need full param decode.
;-------------------------------------------------------------------
op_roomOps:
  jsr _scummvm.fetchByte             ; sub-opcode byte
  sta.w SCUMM.scratch
  and #$001F

  cmp #$01
  beq _roomOps.scroll                ; scroll: 2x p16
  cmp #$03
  beq _roomOps.setScreen             ; setScreen: 2x p16
  cmp #$04
  beq _roomOps.palColor              ; setPalColor: 3x p16 + p8[7]
  cmp #$05
  beq _roomOps.shake                 ; shake: 1x p8[7]
  cmp #$07
  beq _roomOps.scale                 ; roomScale v5: complex
  cmp #$08
  bne +
  jmp _roomOps.scaleSimple           ; roomScale simple: 3x p8
+
  cmp #$0A
  bne +
  jmp _roomOps.fade                  ; roomFade: 1x p16
+
  cmp #$0B
  bne +
  jmp _roomOps.intensity             ; rgbRoomIntensity: 3x p16 + aux + 2x p8
+
  cmp #$0C
  bne +
  jmp _roomOps.intensity             ; roomShadow (same format)
+
  ; Default: no params
  clc
  rts

_roomOps.scroll:
  ; minX/maxX or b/h: 2x p16
  jsr _scummvm.fetchWord
  jsr _scummvm.fetchWord
  clc
  rts

_roomOps.setScreen:
  jsr _scummvm.fetchWord
  jsr _scummvm.fetchWord
  clc
  rts

_roomOps.palColor:
  ; r, g, b: 3x p16, index: p8[bit7 of sub]
  jsr _scummvm.fetchWord
  jsr _scummvm.fetchWord
  jsr _scummvm.fetchWord
  lda.w SCUMM.scratch
  and #$0080
  beq +
  jsr _scummvm.fetchWord
  clc
  rts
+
  jsr _scummvm.fetchByte
  clc
  rts

_roomOps.shake:
  lda.w SCUMM.scratch
  and #$0080
  beq +
  jsr _scummvm.fetchWord
  clc
  rts
+
  jsr _scummvm.fetchByte
  clc
  rts

_roomOps.scale:
  ; scale1: p8[7], y1: p8[6]
  lda.w SCUMM.scratch
  and #$0080
  beq +
  jsr _scummvm.fetchWord
  bra ++
+
  jsr _scummvm.fetchByte
++
  lda.w SCUMM.scratch
  and #$0040
  beq +
  jsr _scummvm.fetchWord
  bra ++
+
  jsr _scummvm.fetchByte
++
  ; aux1 byte, then p8[7], p8[6]
  jsr _scummvm.fetchByte
  sta.w SCUMM.scratch
  lda.w SCUMM.scratch
  and #$0080
  beq +
  jsr _scummvm.fetchWord
  bra ++
+
  jsr _scummvm.fetchByte
++
  lda.w SCUMM.scratch
  and #$0040
  beq +
  jsr _scummvm.fetchWord
  bra ++
+
  jsr _scummvm.fetchByte
++
  ; aux2 byte, then p8[7]
  jsr _scummvm.fetchByte
  sta.w SCUMM.scratch
  lda.w SCUMM.scratch
  and #$0080
  beq +
  jsr _scummvm.fetchWord
  clc
  rts
+
  jsr _scummvm.fetchByte
  clc
  rts

_roomOps.scaleSimple:
  ; scale: p8[7], startcolor: p8[6], endcolor: p8[5]
  lda.w SCUMM.scratch
  and #$0080
  beq +
  jsr _scummvm.fetchWord
  bra ++
+
  jsr _scummvm.fetchByte
++
  lda.w SCUMM.scratch
  and #$0040
  beq +
  jsr _scummvm.fetchWord
  bra ++
+
  jsr _scummvm.fetchByte
++
  lda.w SCUMM.scratch
  and #$0020
  beq +
  jsr _scummvm.fetchWord
  clc
  rts
+
  jsr _scummvm.fetchByte
  clc
  rts

_roomOps.intensity:
  ; r, g, b: 3x p16
  jsr _scummvm.fetchWord
  jsr _scummvm.fetchWord
  jsr _scummvm.fetchWord
  ; aux byte, then startcolor: p8[7], endcolor: p8[6]
  jsr _scummvm.fetchByte
  sta.w SCUMM.scratch
  lda.w SCUMM.scratch
  and #$0080
  beq +
  jsr _scummvm.fetchWord
  bra ++
+
  jsr _scummvm.fetchByte
++
  lda.w SCUMM.scratch
  and #$0040
  beq +
  jsr _scummvm.fetchWord
  clc
  rts
+
  jsr _scummvm.fetchByte
  clc
  rts

_roomOps.fade:
  ; roomFade/screenEffect: 1x p16[7]
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord
  clc
  rts


;-------------------------------------------------------------------
; loadRoomWithEgo ($24, $64, $A4, $E4) -- p16 + p8[6] + word + word
; Sets newRoom and yields (no-op for actor placement)
;-------------------------------------------------------------------
op_loadRoomWithEgo:
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord    ; object (p16[7])
  lda #SCUMM_FLAG_BIT6
  jsr _scummvm.getVarOrDirectByte    ; room number
  and #$00FF
  sta.w SCUMM.newRoom                ; request room change
  ; Place ego actor at (x, y) from bytecode (ScummVM: a->putActor(x, y, room))
  jsr _scummvm.fetchWord             ; x
  sta.w SCUMM.scratch                ; save x
  jsr _scummvm.fetchWord             ; y
  sta.w SCUMM.scratch2               ; save y
  ; Check x != -1 (ScummVM skips putActor if x == -1)
  lda.w SCUMM.scratch
  cmp #$FFFF
  beq _loadRoomEgo.done
  ; Get ego actor pointer (VAR_EGO = global[1] = actor number)
  lda #1                             ; global var 1 = VAR_EGO
  jsr _scummvm.readVariable          ; A = ego actor number
  jsr _scummvm.getActorPtr           ; X = actor table offset
  bcc _loadRoomEgo.done              ; invalid actor → skip
  ; Write position + room
  lda.w SCUMM.scratch
  sta.w SCUMM.actors.x,x
  lda.w SCUMM.scratch2
  sta.w SCUMM.actors.y,x
  lda.w SCUMM.newRoom
  sep #$20
  sta.w SCUMM.actors.room,x
  lda #1
  sta.w SCUMM.actors.visible,x
  sta.w SCUMM.actors.moving,x       ; ScummVM: startWalkActor sets moving
  rep #$20
_loadRoomEgo.done:
  clc
  rts


; ifState ($4F, $CF) / ifNotState ($2F, $6F, $AF, $EF)
; p16[7] + p8[6] + jump(2) — always skip branch (stub)
; ifState ($0F variant) — if objectState[obj] == state, skip; else jump
op_ifState:
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord    ; object ID
  sta.w SCUMM.scratch                ; save obj ID
  lda #SCUMM_FLAG_BIT6
  jsr _scummvm.getVarOrDirectByte    ; expected state
  sta.w SCUMM.scratch2               ; save expected
  ; Look up actual state
  ldx.w SCUMM.scratch
  cpx #SCUMM_MAX_OBJECTS
  bcs _ifState.jump                  ; out of bounds → treat as 0, probably mismatch
  lda.w SCUMM.objectState,x
  and #$00FF
  cmp.w SCUMM.scratch2
  beq +                              ; match → skip jump (condition TRUE)
_ifState.jump:
    jsr _scummvm.takeRelJump         ; no match → take jump
+
  clc
  rts

; ifNotState ($2F variant) — if objectState[obj] != state, skip; else jump
op_ifNotState:
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord    ; object ID
  sta.w SCUMM.scratch
  lda #SCUMM_FLAG_BIT6
  jsr _scummvm.getVarOrDirectByte    ; expected state
  sta.w SCUMM.scratch2
  ldx.w SCUMM.scratch
  cpx #SCUMM_MAX_OBJECTS
  bcs +                              ; out of bounds → state=0, != anything → skip
  lda.w SCUMM.objectState,x
  and #$00FF
  cmp.w SCUMM.scratch2
  bne +                              ; not equal → skip jump (condition TRUE)
    jsr _scummvm.takeRelJump         ; equal → take jump
+
  clc
  rts


;-------------------------------------------------------------------
; Actor stubs — consume params, no-op
;-------------------------------------------------------------------

; animateActor ($11, $51, $91, $D1) -- p8[7]=actor, p8[6]=frame
op_animateActor:
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte    ; actor number
  jsr _scummvm.getActorPtr
  stx.w SCUMM.scratch2

  lda #SCUMM_FLAG_BIT6
  jsr _scummvm.getVarOrDirectByte    ; animation frame
  ldx.w SCUMM.scratch2
  sep #$20
  sta.w SCUMM.actors.initFrame,x
  rep #$20
  clc
  rts

; faceActor ($09, $49, $89, $C9) -- p8[7]=actor, p16[6]=direction
op_faceActor:
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte    ; actor number
  jsr _scummvm.getActorPtr
  stx.w SCUMM.scratch2

  lda #SCUMM_FLAG_BIT6
  jsr _scummvm.getVarOrDirectWord    ; direction
  ldx.w SCUMM.scratch2
  sta.w SCUMM.actors.facing,x
  clc
  rts

; walkActorToActor ($0D, $4D, $8D, $CD) -- p8[7] + p8[6] + byte, no-op
op_walkActorToActor:
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte    ; actor
  lda #SCUMM_FLAG_BIT6
  jsr _scummvm.getVarOrDirectByte    ; target actor
  jsr _scummvm.fetchByte             ; options byte
  clc
  rts

; walkActorTo ($1E, $3E, $5E, $7E, $9E, $BE, $DE, $FE) -- p8[7]=actor, p16[6]=x, p16[5]=y
; MVP: instantly teleport actor to target position (no walking animation)
op_walkActorTo:
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte    ; actor number
  jsr _scummvm.getActorPtr
  stx.w SCUMM.scratch2              ; save actor struct offset

  lda #SCUMM_FLAG_BIT6
  jsr _scummvm.getVarOrDirectWord    ; x
  pha                                ; save target x

  lda #SCUMM_FLAG_BIT5
  jsr _scummvm.getVarOrDirectWord    ; y
  sta.w SCUMM.scratch               ; target y

  ; Derive actor number from struct offset (offset / 16)
  lda.w SCUMM.scratch2
  lsr a
  lsr a
  lsr a
  lsr a                              ; actor number
  asl a                              ; × 2 for word index
  tax

  ; Store walk targets in parallel arrays
  pla                                ; target x
  sta.w SCUMM.actorTargetX,x
  lda.w SCUMM.scratch               ; target y
  sta.w SCUMM.actorTargetY,x

  ; Initialize animation state for this actor
  txa
  lsr a                              ; back to byte index
  tax
  lda #WALK_ANIM_SPEED
  sep #$20
  sta.w SCUMM.actorAnimTimer,x
  lda #0
  sta.w SCUMM.actorAnimFrame,x

  ; Set actor.moving = 1
  ldx.w SCUMM.scratch2
  lda #1
  sta.w SCUMM.actors.moving,x
  rep #$20

  clc
  rts

; isActorInBox ($1F, $5F, $9F, $DF) -- p8[7] + p8[6] + jump, return false
op_isActorInBox:
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte    ; actor
  lda #SCUMM_FLAG_BIT6
  jsr _scummvm.getVarOrDirectByte    ; box
  jsr _scummvm.fetchWord             ; jump offset (skip — always false)
  clc
  rts


;-------------------------------------------------------------------
; wait ($AE) -- sub-opcode with conditional waits, stub as no-op
; Each wait variant would normally yield until condition met.
; Stub: consume params and continue (don't actually wait).
;-------------------------------------------------------------------
op_wait:
  jsr _scummvm.fetchByte             ; sub-opcode byte
  sta.w SCUMM.scratch
  and #$001F

  cmp #$01
  beq _wait.forActor                 ; waitForActor: p8[7] + word

  ; waitForMessage ($02), waitForCamera ($03), waitForSentence ($04):
  ; No additional params. Stub: just continue.
  clc
  rts

_wait.forActor:
  lda.w SCUMM.scratch
  and #$0080
  beq +
  jsr _scummvm.fetchWord             ; actor as var ref
  bra ++
+
  jsr _scummvm.fetchByte             ; actor as literal
++
  jsr _scummvm.fetchWord             ; jump offset (consumed, ignored)
  clc
  rts


;-------------------------------------------------------------------
; drawObject ($05, $25, $45, $65, $85, $A5, $C5, $E5)
; p16 object + sub-opcode + sub params, no-op
;-------------------------------------------------------------------
op_drawObject:
  jsr _scummvm.fetchWord             ; object ID (always p16)
  jsr _scummvm.fetchByte             ; sub-opcode byte
  and #$001F
  cmp #$01
  beq _drawObj.setXY
  cmp #$02
  beq _drawObj.setState
  ; $1F or default: no extra params
  clc
  rts

_drawObj.setXY:
  jsr _scummvm.fetchWord             ; xpos
  jsr _scummvm.fetchWord             ; ypos
  clc
  rts

_drawObj.setState:
  jsr _scummvm.fetchWord             ; state
  clc
  rts


;===================================================================
; Print / Verb / Sentence / Object / String opcode stubs
; Correctly consume all bytecode parameters without behavior.
;===================================================================

;-------------------------------------------------------------------
; print ($14, $94) -- actor + sub-opcode loop, no-op
; Format: getVarOrDirectByte(BIT7) actor, then sub-opcode loop
;-------------------------------------------------------------------
op_print:
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte    ; actor
_print.subLoop:
  jsr _scummvm.fetchByte
  cmp #$00FF
  beq _print.done
  sta.w SCUMM.scratch                ; save sub-opcode for flag testing
  and #$000F                         ; sub-key is low 4 bits
  cmp #$00
  beq _print.pos                     ; $00: pos (2x p16)
  cmp #$01
  beq _print.color                   ; $01: color (p8[7])
  cmp #$02
  beq _print.clipping                ; $02: clipping (p16)
  cmp #$0F
  beq _print.text                    ; $0F: text (print string)
  ; $03,$04,$06,$07,$08: no params
  jmp _print.subLoop

_print.pos:
  jsr _scummvm.fetchWord             ; x
  jsr _scummvm.fetchWord             ; y
  jmp _print.subLoop

_print.color:
  lda #$0080
  jsr _scummvm.skipP8fromScratch
  jmp _print.subLoop

_print.clipping:
  jsr _scummvm.fetchWord             ; right
  jmp _print.subLoop

_print.text:
  jsr _scummvm.skipPrintString
  jmp _print.subLoop

_print.done:
  clc
  rts


;-------------------------------------------------------------------
; printEgo ($D8) -- same sub-opcode loop as print, no actor param
;-------------------------------------------------------------------
op_printEgo:
  jmp _print.subLoop


;-------------------------------------------------------------------
; verbOps ($7A, $FA) -- verb setup: store verb data for display
; Delegates to superfree section to avoid bank 0 overflow
;-------------------------------------------------------------------
op_verbOps:
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte    ; A = verb ID, Y = advanced PC
  and #$00FF
  sta.w SCUMM.resultVar              ; save verb ID
  jsl scummvm.verbOps_impl
  clc
  rts


;-------------------------------------------------------------------
; doSentence ($19,$39,$59,$79,$99,$B9,$D9,$F9)
; verb + objectA + objectB, with special sentinels $FE/$FC
;-------------------------------------------------------------------
op_doSentence:
  lda.w SCUMM.currentOpcode
  and #$0080
  bne _doSentence.verbVar
  ; bit7 clear: verb is literal byte
  jsr _scummvm.fetchByte
  cmp #$00FE
  beq _doSentence.done               ; $FE = stop sentence, no more params
  cmp #$00FC
  beq _doSentence.done               ; $FC = stop sentence (v5 alt)
  bra _doSentence.readObjects

_doSentence.verbVar:
  jsr _scummvm.fetchWord             ; verb as variable reference
  jsr _scummvm.readVariable

_doSentence.readObjects:
  lda #SCUMM_FLAG_BIT6
  jsr _scummvm.getVarOrDirectWord    ; objectA
  lda #SCUMM_FLAG_BIT5
  jsr _scummvm.getVarOrDirectWord    ; objectB

_doSentence.done:
  clc
  rts


;-------------------------------------------------------------------
; startObject ($37,$77,$B7,$F7) -- p16 object + p8[6] script + varargs
;-------------------------------------------------------------------
op_startObject:
  jsr _scummvm.fetchWord             ; object ID (always p16)
  lda #SCUMM_FLAG_BIT6
  jsr _scummvm.getVarOrDirectByte    ; script number
  jsr _scummvm.skipWordVararg        ; variable args
  clc
  rts


;-------------------------------------------------------------------
; stringOps ($27) -- sub-opcode dispatch, no-op
;-------------------------------------------------------------------
op_stringOps:
  jsr _scummvm.fetchByte             ; sub-opcode byte
  sta.w SCUMM.scratch
  and #$001F

  cmp #$01
  beq _stringOps.putCode             ; putCodeInString: p8[7] + null string
  cmp #$04
  beq _stringOps.getChar             ; getStringChar: result + p8[7] + p8[6]
  cmp #$03
  beq _stringOps.threeP8             ; setStringChar: p8[7] + p8[6] + p8[5]

  ; $02 (copyString), $05 (createString): p8[7] + p8[6]
  bra _stringOps.twoP8

_stringOps.putCode:
  lda #$0080
  jsr _scummvm.skipP8fromScratch     ; stringId
  jsr _scummvm.skipNullString         ; string data
  clc
  rts

_stringOps.getChar:
  jsr _scummvm.fetchWord             ; result variable
  ; fall through to twoP8

_stringOps.twoP8:
  lda #$0080
  jsr _scummvm.skipP8fromScratch     ; param1
  lda #$0040
  jsr _scummvm.skipP8fromScratch     ; param2
  clc
  rts

_stringOps.threeP8:
  lda #$0080
  jsr _scummvm.skipP8fromScratch     ; param1
  lda #$0040
  jsr _scummvm.skipP8fromScratch     ; param2
  lda #$0020
  jsr _scummvm.skipP8fromScratch     ; param3
  clc
  rts


;-------------------------------------------------------------------
; saveRestoreVerbs ($AB) -- 3x p8 params for all sub-ops
;-------------------------------------------------------------------
op_saveRestoreVerbs:
  jsr _scummvm.fetchByte             ; sub-opcode byte
  sta.w SCUMM.scratch                ; save for flag testing
  ; All sub-ops (save=$01, restore=$02, delete=$03) take:
  ; p8[7] + p8[6] + p8[5]
  lda #$0080
  jsr _scummvm.skipP8fromScratch     ; param1 (begin verb)
  lda #$0040
  jsr _scummvm.skipP8fromScratch     ; param2 (end verb)
  lda #$0020
  jsr _scummvm.skipP8fromScratch     ; param3 (mode)
  clc
  rts


;===================================================================
; Remaining opcode stubs — batch implementation
; All consume params correctly and return safe defaults.
;===================================================================

;-------------------------------------------------------------------
; result + p8[7] → return 0  (getActor* family + misc getters)
; Same pattern as getActorMoving/getActorRoom
;-------------------------------------------------------------------
op_getActorElevation:
op_getAnimCounter:
op_getActorScale:
op_getActorFacing:
op_getActorWidth:
op_getActorCostume:
op_getActorWalkBox:
op_getInventoryCount:
op_getRandomNr:
op_getStringWidth:
  jsr _scummvm.getResultPos
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte
  lda #0
  jsr _scummvm.writeVariable
  clc
  rts

;-------------------------------------------------------------------
; result + p16 → return 0  (getClosestObjActor)
;-------------------------------------------------------------------
op_getClosestObjActor:
  jsr _scummvm.getResultPos
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord    ; object (p16[7])
  lda #0
  jsr _scummvm.writeVariable
  clc
  rts

;-------------------------------------------------------------------
; result + p16[7] + p16[6] → return 0  (getDist, getVerbEntrypoint, actorFromPos)
;-------------------------------------------------------------------
op_getDist:
op_getVerbEntrypoint:
op_actorFromPos:
  jsr _scummvm.getResultPos
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord
  lda #SCUMM_FLAG_BIT6
  jsr _scummvm.getVarOrDirectWord
  lda #0
  jsr _scummvm.writeVariable
  clc
  rts

;-------------------------------------------------------------------
; result + p8[7] + p8[6] → return 0  (findObject, findInventory)
;-------------------------------------------------------------------
op_findObject:
op_findInventory:
  jsr _scummvm.getResultPos
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte
  lda #SCUMM_FLAG_BIT6
  jsr _scummvm.getVarOrDirectByte
  lda #0
  jsr _scummvm.writeVariable
  clc
  rts

;-------------------------------------------------------------------
; actorFollowCamera ($52, $D2) — p8[7], no-op
;-------------------------------------------------------------------
op_actorFollowCamera:
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte
  clc
  rts

;-------------------------------------------------------------------
; putActorAtObject ($0E, $4E, $8E, $CE) — p8[7] + p16[6], no-op
; walkActorToObject ($36, $76, $B6, $F6) — p8[7] + p16[6], no-op
;-------------------------------------------------------------------
op_putActorAtObject:
op_walkActorToObject:
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte    ; actor
  lda #SCUMM_FLAG_BIT6
  jsr _scummvm.getVarOrDirectWord    ; object
  clc
  rts

;-------------------------------------------------------------------
; pickupObject ($25, $65, $A5, $E5) — p16[7] + p8[6], no-op
;-------------------------------------------------------------------
op_pickupObject:
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord    ; object
  lda #SCUMM_FLAG_BIT6
  jsr _scummvm.getVarOrDirectByte    ; room
  clc
  rts

;-------------------------------------------------------------------
; pickupObjectOld ($50, $D0) — p16[7] only, no-op
;-------------------------------------------------------------------
op_pickupObjectOld:
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord    ; object
  clc
  rts

;-------------------------------------------------------------------
; multiply ($1B, $9B) / divide ($5B, $DB) — result + p16[7], return 0
; Same param format as add/subtract but returns 0 (stub)
;-------------------------------------------------------------------
op_multiply:
op_divide:
  jsr _scummvm.getResultPos
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord    ; operand
  lda #0
  jsr _scummvm.writeVariable
  clc
  rts

;-------------------------------------------------------------------
; ifClassOfIs ($1D, $9D) — p16[7] + varargs(word until 0) + jump(2)
; Always skip branch (class check fails)
;-------------------------------------------------------------------
op_ifClassOfIs:
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord    ; object
  ; Vararg: {aux_byte, word_value}* terminated by $FF (same as setClass)
-
  jsr _scummvm.fetchByte
  cmp #$00FF
  beq +
  jsr _scummvm.fetchWord             ; class word arg
  bra -
+
  jsr _scummvm.fetchWord             ; jump offset (skip — always false stub)
  clc
  rts

;-------------------------------------------------------------------
; setObjectName ($54, $D4) — p16[7] + null-terminated string, no-op
;-------------------------------------------------------------------
op_setObjectName:
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord    ; object
  jsr _scummvm.skipNullString        ; name string
  clc
  rts

;-------------------------------------------------------------------
; drawBox ($3F, $7F, $BF, $FF) — x(p16[7]) + y(p16[6]) + aux(1) + x2(p16[7]') + y2(p16[6]') + color(p8[5]')
; ScummVM re-reads _opcode from the aux byte for x2/y2/color flag bits
;-------------------------------------------------------------------
op_drawBox:
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord    ; x (main opcode bit 7)
  lda #SCUMM_FLAG_BIT6
  jsr _scummvm.getVarOrDirectWord    ; y (main opcode bit 6)
  jsr _scummvm.fetchByte             ; aux opcode byte
  cmp #0
  beq _drawBox.done                  ; aux==0: no more params
  sta.w SCUMM.currentOpcode          ; aux byte becomes new opcode for flag checks
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord    ; x2 (aux bit 7)
  lda #SCUMM_FLAG_BIT6
  jsr _scummvm.getVarOrDirectWord    ; y2 (aux bit 6)
  lda #SCUMM_FLAG_BIT5
  jsr _scummvm.getVarOrDirectByte    ; color (aux bit 5)
_drawBox.done:
  clc
  rts

;-------------------------------------------------------------------
; oldRoomEffect ($5C, $DC) — sub-opcode + optional p16, no-op
;-------------------------------------------------------------------
op_oldRoomEffect:
  jsr _scummvm.fetchByte             ; sub-opcode byte
  and #$001F
  cmp #$03
  bne _oldRoomEffect.done
  jsr _scummvm.fetchWord             ; setScreen: p16
_oldRoomEffect.done:
  clc
  rts

;-------------------------------------------------------------------
; pseudoRoom ($CC) — byte pairs until byte == 0, no-op
;-------------------------------------------------------------------
op_pseudoRoom:
_pseudoRoom.loop:
  jsr _scummvm.fetchByte
  cmp #0
  beq _pseudoRoom.done
  jsr _scummvm.fetchByte             ; room number
  bra _pseudoRoom.loop
_pseudoRoom.done:
  clc
  rts


;-------------------------------------------------------------------
; _scummvm.mul16 -- signed 16x16 → 16 multiply (truncated)
; Input: A = multiplicand, SCUMM.scratch2 = multiplier
; Output: A = product (low 16 bits, signed)
; Clobbers: SCUMM.scratch, SCUMM.scratch2
;-------------------------------------------------------------------
_scummvm.mul16:
  phx
  ; Sign = (A ^ scratch2) bit 15
  sta.w SCUMM.scratch              ; save multiplicand
  eor.w SCUMM.scratch2
  and #$8000
  tax                              ; X = sign flag (0 or $8000)
  ; |multiplicand|
  lda.w SCUMM.scratch
  bpl _mul16.mndPos
  eor #$FFFF
  inc a
_mul16.mndPos:
  pha                              ; push |multiplicand| on stack
  ; |multiplier|
  lda.w SCUMM.scratch2
  bpl _mul16.mplPos
  eor #$FFFF
  inc a
_mul16.mplPos:
  sta.w SCUMM.scratch2             ; scratch2 = |multiplier| (shifts right)
  ; result = 0
  stz.w SCUMM.scratch              ; scratch = result accumulator
  ; Shift-and-add loop
_mul16.loop:
  lda.w SCUMM.scratch2
  beq _mul16.done                  ; multiplier == 0, done
  lsr a
  sta.w SCUMM.scratch2             ; multiplier >>= 1, carry = old bit 0
  bcc _mul16.noadd                 ; bit was 0, skip addition
  lda.w SCUMM.scratch              ; result
  clc
  adc 1,s                          ; + multiplicand (on stack)
  sta.w SCUMM.scratch
_mul16.noadd:
  lda 1,s                          ; multiplicand
  asl a
  sta 1,s                          ; multiplicand <<= 1
  bra _mul16.loop
_mul16.done:
  pla                              ; discard multiplicand from stack
  lda.w SCUMM.scratch              ; A = |result|
  ; Apply sign
  cpx #0
  beq _mul16.pos
  eor #$FFFF
  inc a
_mul16.pos:
  plx
  rts

;-------------------------------------------------------------------
; _scummvm.div16 -- signed 16÷16 → 16 divide (truncated toward zero)
; Input: A = dividend, SCUMM.scratch2 = divisor (non-zero)
; Output: A = quotient
; Clobbers: Y, SCUMM.scratch, SCUMM.scratch2
;-------------------------------------------------------------------
_scummvm.div16:
  phx
  phy
  ; Sign = (A ^ scratch2) bit 15
  sta.w SCUMM.scratch              ; save dividend
  eor.w SCUMM.scratch2
  and #$8000
  tax                              ; X = sign flag
  ; |dividend|
  lda.w SCUMM.scratch
  bpl _div16.dvdPos
  eor #$FFFF
  inc a
_div16.dvdPos:
  sta.w SCUMM.scratch              ; scratch = |dividend| (shifts left, becomes quotient)
  ; |divisor|
  lda.w SCUMM.scratch2
  bpl _div16.dvsPos
  eor #$FFFF
  inc a
_div16.dvsPos:
  sta.w SCUMM.scratch2             ; scratch2 = |divisor|
  ; Restoring division: 16 iterations
  ; scratch = dividend/quotient, scratch2 = divisor, stack = remainder
  lda #0
  pha                              ; push remainder (0)
  ldy #16                          ; loop counter
_div16.loop:
  ; remainder = (remainder << 1) | bit 15 of dividend
  lda.w SCUMM.scratch
  asl a
  sta.w SCUMM.scratch              ; dividend <<= 1, carry = old bit 15
  lda 1,s                          ; remainder
  rol a                            ; (remainder << 1) | carry
  ; if remainder >= divisor
  cmp.w SCUMM.scratch2
  bcc _div16.less
  ; remainder -= divisor, set quotient bit
  sec
  sbc.w SCUMM.scratch2
  sta 1,s                          ; update remainder
  lda.w SCUMM.scratch
  ora #$0001                       ; set bit 0 of quotient
  sta.w SCUMM.scratch
  bra _div16.next
_div16.less:
  sta 1,s                          ; update remainder (shifted only)
_div16.next:
  dey
  bne _div16.loop
  pla                              ; discard remainder
  lda.w SCUMM.scratch              ; A = |quotient|
  ; Apply sign
  cpx #0
  beq _div16.pos
  eor #$FFFF
  inc a
_div16.pos:
  ply
  plx
  rts

;===================================================================
; _scummvm.loadActorCostumes
; DMA costume tiles + palette to VRAM/CGRAM during room change.
; MVP: always loads costume 1 (Guybrush standing frame).
;===================================================================
_scummvm.loadActorCostumes:
  rep #$31

  ; Save brightness BEFORE core.nmi.stop (which zeros ScreenBrightness)
  lda.w ScreenBrightness
  and #$00FF
  pha                               ; save on stack (16-bit push)

  ; Disable both NMI and IRQ — DMA queue IRQ also corrupts VMADDL/VMAIN
  jsr core.nmi.stop
  sei
  sep #$20
  lda.b #INIDSP_FORCE_BLANK
  sta.l INIDSP
  rep #$20

  ; --- DMA costume palette to CGRAM sprite palette 0 (color 128) ---
  sep #$20
  lda.b #128                          ; color index 128 = sprite palette 0
  sta.l CGADD

  lda.b #$00                          ; A→B, increment source, 1-reg write
  sta.l $4360                         ; DMA6 control
  lda.b #$22                          ; destination: CGDATA ($2122)
  sta.l $4361
  rep #$20
  lda.w #Costume1Pal
  sta.l $4362                         ; source address low
  sep #$20
  lda.b #:Costume1Pal
  sta.l $4364                         ; source bank
  rep #$20
  lda.w #32                           ; 16 colors x 2 bytes
  sta.l $4365                         ; transfer length
  sep #$20
  lda.b #$40                          ; channel 6 bit
  sta.l MDMAEN                        ; start DMA

  ; --- DMA costume CHR to VRAM word $6000 (byte $C000) ---
  ; ObjSel=3 means sprite name base at word $6000
  lda.b #VMAIN_INCREMENT_MODE         ; word-access, increment on high byte write
  sta.l VMAIN
  rep #$20
  lda #$6000                          ; VRAM word address
  sta.l VMADDL

  ; DMA channel 7: A→B, increment source, write to $2118/$2119 (VMDATAL/H)
  sep #$20
  lda.b #$01                          ; A→B, increment, 2-reg write (word)
  sta.l $4370                         ; DMA7 control
  lda.b #$18                          ; destination: VMDATAL ($2118)
  sta.l $4371
  rep #$20
  lda.w #Costume1Chr
  sta.l $4372                         ; source address low
  sep #$20
  lda.b #:Costume1Chr
  sta.l $4374                         ; source bank
  rep #$20
  lda.w #Costume1ChrEnd - Costume1Chr
  sta.l $4375                         ; transfer length
  sep #$20
  lda.b #$80                          ; channel 7 bit
  sta.l MDMAEN                        ; start DMA

  ; Set ObjSel so sprites read tiles from VRAM word $6000 (byte $C000)
  ; Bits 0-1 = 11 = name base at word $6000
  lda.b #$03
  sta.w ObjSel

  ; Restore display + re-enable NMI/IRQ
  rep #$20
  pla                               ; restore saved brightness (16-bit pull)
  sep #$20
  sta.l INIDSP
  sta.w ScreenBrightness            ; restore WRAM copy too

  ; Initialize actor 1 animation state
  ldx #1                              ; actor 1 byte offset
  lda #$FF
  sta.w SCUMM.actorLastFrame,x        ; force DMA on first render
  lda #0
  sta.w SCUMM.actorAnimFrame,x
  sta.w SCUMM.actorAnimTimer,x

  cli
  rep #$20
  jsr core.nmi.start

  rts


;===================================================================
; _scummvm.renderActors
; Write OAM entries for visible actors in current room.
; MVP: only renders actor 1 (Guybrush) using hardcoded costume frame.
; Called at end of ScummVM.play(), after slot scheduler.
;
; Writes to GLOBAL.oamBuffer (Table 0) and GLOBAL.oamTable1 (Table 1).
; Sets GLOBAL.oamUploadFlag so the engine DMAs to OAM during VBlank.
;===================================================================

;===================================================================
; _scummvm.updateActors
; Per-frame walk movement + animation. MVP: actor 1 only.
;===================================================================
.define WALK_SPEED 2

_scummvm.updateActors:
  rep #$31

  ; Skip if actor not placed in a room yet (room=0 means not initialized)
  lda.w SCUMM.actors.2.room
  and #$00FF
  bne +
  rts
+
  ; Check if actor 1 is moving
  lda.w SCUMM.actors.2.moving
  and #$00FF
  bne +
  rts
+
  ; dx = targetX - x
  ldx #2                            ; actor 1 word offset
  lda.w SCUMM.actorTargetX,x
  sec
  sbc.w SCUMM.actors.2.x
  sta.w SCUMM.scratch               ; dx

  lda.w SCUMM.actorTargetY,x
  sec
  sbc.w SCUMM.actors.2.y
  sta.w SCUMM.scratch2              ; dy

  ; |dx|
  lda.w SCUMM.scratch
  bpl +
  eor #$FFFF
  inc a
+
  sta.w SCUMM.actorOamCount         ; |dx| temp

  ; |dy|
  lda.w SCUMM.scratch2
  bpl +
  eor #$FFFF
  inc a
+
  ; A = |dy|
  clc
  adc.w SCUMM.actorOamCount         ; |dx|+|dy|
  cmp #WALK_SPEED + 1
  bcs _ua.notArrived

  ; --- Arrived ---
  ldx #2
  lda.w SCUMM.actorTargetX,x
  sta.w SCUMM.actors.2.x
  lda.w SCUMM.actorTargetY,x
  sta.w SCUMM.actors.2.y
  sep #$20
  stz.w SCUMM.actors.2.moving
  ldx #1
  stz.w SCUMM.actorAnimFrame,x
  lda #$FF
  sta.w SCUMM.actorLastFrame,x
  rep #$20
  rts

_ua.notArrived:
  ; Move X
  lda.w SCUMM.actorOamCount         ; |dx|
  cmp #WALK_SPEED + 1
  bcc +
  lda #WALK_SPEED
+
  ldx.w SCUMM.scratch               ; dx sign
  bpl _ua.dxPos
  eor #$FFFF
  inc a
_ua.dxPos:
  clc
  adc.w SCUMM.actors.2.x
  sta.w SCUMM.actors.2.x

  ; Move Y
  lda.w SCUMM.scratch2
  bpl +
  eor #$FFFF
  inc a
+
  cmp #WALK_SPEED + 1
  bcc +
  lda #WALK_SPEED
+
  ldx.w SCUMM.scratch2              ; dy sign
  bpl _ua.dyPos
  eor #$FFFF
  inc a
_ua.dyPos:
  clc
  adc.w SCUMM.actors.2.y
  sta.w SCUMM.actors.2.y

  ; Update facing: recompute |dy|
  lda.w SCUMM.scratch2
  bpl +
  eor #$FFFF
  inc a
+
  cmp.w SCUMM.actorOamCount         ; |dy| vs |dx|
  bcs _ua.faceVertical
  lda.w SCUMM.scratch
  bmi _ua.faceWest
  lda #90
  bra _ua.setFacing
_ua.faceWest:
  lda #270
  bra _ua.setFacing
_ua.faceVertical:
  lda.w SCUMM.scratch2
  bmi _ua.faceNorth
  lda #180
  bra _ua.setFacing
_ua.faceNorth:
  lda #0
_ua.setFacing:
  sta.w SCUMM.actors.2.facing

  ; Advance walk animation
  sep #$20
  ldx #1
  lda.w SCUMM.actorAnimTimer,x
  dec a
  sta.w SCUMM.actorAnimTimer,x
  bne _ua.animDone
  lda #WALK_ANIM_SPEED
  sta.w SCUMM.actorAnimTimer,x
  lda.w SCUMM.actorAnimFrame,x
  inc a
  cmp #WALK_CYCLE_LEN
  bcc +
  lda #0
+
  sta.w SCUMM.actorAnimFrame,x
_ua.animDone:
  rep #$20
  rts

_scummvm.renderActors:
  jsl scummvm.renderActors_impl
  rts


  CLASS ScummVM

.ends


;===================================================================
; Costume frame data — embedded in ROM (superfree bank)
; Guybrush standing south idle (cost_017 pic00: 19x47, 13 tiles)
;===================================================================
.section "CostumeData" superfree

;--- Walk cycle table (12 steps → pic index) ---
WalkCycleTable:
  .db 0, 1, 2, 3, 3, 2, 4, 5, 6, 7, 8, 9
.define WALK_CYCLE_LEN 12
.define WALK_ANIM_SPEED 5

;--- Frame lookup tables (10 entries for pics 0-9) ---
CostumeFrameChrLo:
  .dw Costume_pic00_chr, Costume_pic01_chr, Costume_pic02_chr, Costume_pic03_chr, Costume_pic04_chr
  .dw Costume_pic05_chr, Costume_pic06_chr, Costume_pic07_chr, Costume_pic08_chr, Costume_pic09_chr

CostumeFrameChrHi:
  .db :Costume_pic00_chr, :Costume_pic01_chr, :Costume_pic02_chr, :Costume_pic03_chr, :Costume_pic04_chr
  .db :Costume_pic05_chr, :Costume_pic06_chr, :Costume_pic07_chr, :Costume_pic08_chr, :Costume_pic09_chr

CostumeFrameChrLen:
  .dw Costume_pic00_chrEnd - Costume_pic00_chr
  .dw Costume_pic01_chrEnd - Costume_pic01_chr
  .dw Costume_pic02_chrEnd - Costume_pic02_chr
  .dw Costume_pic03_chrEnd - Costume_pic03_chr
  .dw Costume_pic04_chrEnd - Costume_pic04_chr
  .dw Costume_pic05_chrEnd - Costume_pic05_chr
  .dw Costume_pic06_chrEnd - Costume_pic06_chr
  .dw Costume_pic07_chrEnd - Costume_pic07_chr
  .dw Costume_pic08_chrEnd - Costume_pic08_chr
  .dw Costume_pic09_chrEnd - Costume_pic09_chr

CostumeFrameOamLo:
  .dw Costume_pic00_oam, Costume_pic01_oam, Costume_pic02_oam, Costume_pic03_oam, Costume_pic04_oam
  .dw Costume_pic05_oam, Costume_pic06_oam, Costume_pic07_oam, Costume_pic08_oam, Costume_pic09_oam

CostumeFrameOamHi:
  .db :Costume_pic00_oam, :Costume_pic01_oam, :Costume_pic02_oam, :Costume_pic03_oam, :Costume_pic04_oam
  .db :Costume_pic05_oam, :Costume_pic06_oam, :Costume_pic07_oam, :Costume_pic08_oam, :Costume_pic09_oam

;--- Backward-compat aliases for loadActorCostumes ---
Costume1Chr:
Costume_pic00_chr: .incbin "data/snes_converted/costumes/cost_017/pic00.chr"
Costume_pic00_chrEnd:
Costume1ChrEnd:

Costume1Pal:
CostumePal: .incbin "data/snes_converted/costumes/cost_017/palette.pal"

Costume1Oam:
Costume_pic00_oam: .incbin "data/snes_converted/costumes/cost_017/pic00.oam"
Costume1OamEnd:

;--- Remaining walk frames (pics 1-9) ---
Costume_pic01_chr: .incbin "data/snes_converted/costumes/cost_017/pic01.chr"
Costume_pic01_chrEnd:
Costume_pic01_oam: .incbin "data/snes_converted/costumes/cost_017/pic01.oam"

Costume_pic02_chr: .incbin "data/snes_converted/costumes/cost_017/pic02.chr"
Costume_pic02_chrEnd:
Costume_pic02_oam: .incbin "data/snes_converted/costumes/cost_017/pic02.oam"

Costume_pic03_chr: .incbin "data/snes_converted/costumes/cost_017/pic03.chr"
Costume_pic03_chrEnd:
Costume_pic03_oam: .incbin "data/snes_converted/costumes/cost_017/pic03.oam"

Costume_pic04_chr: .incbin "data/snes_converted/costumes/cost_017/pic04.chr"
Costume_pic04_chrEnd:
Costume_pic04_oam: .incbin "data/snes_converted/costumes/cost_017/pic04.oam"

Costume_pic05_chr: .incbin "data/snes_converted/costumes/cost_017/pic05.chr"
Costume_pic05_chrEnd:
Costume_pic05_oam: .incbin "data/snes_converted/costumes/cost_017/pic05.oam"

Costume_pic06_chr: .incbin "data/snes_converted/costumes/cost_017/pic06.chr"
Costume_pic06_chrEnd:
Costume_pic06_oam: .incbin "data/snes_converted/costumes/cost_017/pic06.oam"

Costume_pic07_chr: .incbin "data/snes_converted/costumes/cost_017/pic07.chr"
Costume_pic07_chrEnd:
Costume_pic07_oam: .incbin "data/snes_converted/costumes/cost_017/pic07.oam"

Costume_pic08_chr: .incbin "data/snes_converted/costumes/cost_017/pic08.chr"
Costume_pic08_chrEnd:
Costume_pic08_oam: .incbin "data/snes_converted/costumes/cost_017/pic08.oam"

Costume_pic09_chr: .incbin "data/snes_converted/costumes/cost_017/pic09.chr"
Costume_pic09_chrEnd:
Costume_pic09_oam: .incbin "data/snes_converted/costumes/cost_017/pic09.oam"

.ends


;===================================================================
; Dynamic actor renderer — superfree bank (called via jsl from bank 0)
; Looks up current walk cycle frame, DMAs CHR on frame change,
; renders OAM entries using [_oamSrcPtr],y indirect long addressing.
; D register = ScummVM object ZP (preserved across jsl).
; DBR = $7E (WRAM bank, preserved across jsl).
;===================================================================
.section "scummvm render impl" superfree

scummvm.renderActors_impl:
  rep #$31

  ; Check actor 1 (Guybrush) is visible in current room
  lda.w SCUMM.actors.2.visible
  and #$00FF
  bne +
  jmp _ri.skipActors
+
  lda.w SCUMM.actors.2.room
  and #$00FF
  cmp.w SCUMM.currentRoom
  beq +
  jmp _ri.skipActors
+

  ; --- Determine current pic index from walk cycle ---
  sep #$20
  ldx #1                              ; actor 1 byte index
  lda.w SCUMM.actorAnimFrame,x       ; walk cycle step (0-11)
  rep #$20
  and #$00FF
  tax
  lda.l WalkCycleTable,x
  and #$00FF
  sta.w SCUMM.scratch                 ; pic index (0-9)

  ; --- CHR DMA if frame changed ---
  sep #$20
  ldx #1
  lda.w SCUMM.actorLastFrame,x
  rep #$20
  and #$00FF
  cmp.w SCUMM.scratch
  bne +
  jmp _ri.chrReady
+

  ; Store new lastFrame
  lda.w SCUMM.scratch
  sep #$20
  ldx #1
  sta.w SCUMM.actorLastFrame,x
  rep #$20

  ; --- DMA new CHR to VRAM $6000 (brief force-blank) ---
  ; Save brightness before disabling NMI (which zeros ScreenBrightness)
  lda.w ScreenBrightness
  and #$00FF
  pha                                 ; save brightness (16-bit push)

  ; Inline core.nmi.stop: clear NMI enable bit
  sep #$20
  lda.w GLOBAL.interruptFlags
  and #NMITIMEN_NMI_ENABLE ~$ff
  sta.w GLOBAL.interruptFlags
  sta.l NMITIMEN
  sei

  lda.b #INIDSP_FORCE_BLANK
  sta.l INIDSP
  rep #$20

  ; Look up CHR source from frame tables
  lda.w SCUMM.scratch                 ; pic index
  asl a                               ; x2 for word tables
  tax
  lda.l CostumeFrameChrLo,x
  sta.l $4372                         ; DMA source address low
  lda.l CostumeFrameChrLen,x
  sta.l $4375                         ; DMA transfer length

  ; Bank byte (byte table, needs original pic index)
  lda.w SCUMM.scratch
  and #$00FF
  tax
  sep #$20
  lda.l CostumeFrameChrHi,x
  sta.l $4374                         ; DMA source bank

  ; Set VRAM destination
  lda.b #VMAIN_INCREMENT_MODE
  sta.l VMAIN
  rep #$20
  lda #$6000
  sta.l VMADDL

  ; DMA channel 7: word write to VMDATAL/H
  sep #$20
  lda.b #$01                          ; A->B, increment, 2-reg write
  sta.l $4370
  lda.b #$18                          ; destination: VMDATAL
  sta.l $4371
  lda.b #$80                          ; channel 7
  sta.l MDMAEN

  ; Refresh cursor OBJ palette 1 while still in force-blank
  lda #$91                            ; CGRAM address $91 (OBJ pal1 color 1)
  sta.l $2121
  lda #$00                            ; color 1 = $0000 (black outline)
  sta.l $2122
  sta.l $2122
  lda #$FF                            ; color 2 = $7FFF (white fill)
  sta.l $2122
  lda #$7F
  sta.l $2122

  ; Restore brightness + inline core.nmi.start
  rep #$20
  pla                                 ; brightness (16-bit pull)
  sep #$20
  sta.l INIDSP
  sta.w ScreenBrightness
  cli
  lda.w GLOBAL.interruptFlags
  ora #NMITIMEN_NMI_ENABLE
  sta.w GLOBAL.interruptFlags
  sta.l NMITIMEN
  rep #$20

_ri.chrReady:
  ; --- Set up OAM source pointer (24-bit) in ZP ---
  lda.w SCUMM.scratch                 ; pic index
  asl a                               ; x2 for word table
  tax
  lda.l CostumeFrameOamLo,x
  sta.b _oamSrcPtr                    ; low 16 bits

  lda.w SCUMM.scratch
  and #$00FF
  tax
  sep #$20
  lda.l CostumeFrameOamHi,x
  sta.b _oamSrcPtr + 2               ; bank byte
  rep #$20

  ; Read entry count from OAM header byte 0
  ldy #0
  lda [_oamSrcPtr],y
  and #$00FF
  sta.w SCUMM.actorOamCount

  ; Compute screen X = actor.x - cameraX
  lda.w SCUMM.actors.2.x
  sec
  sbc.w GLOBAL.room.cameraX
  sta.w SCUMM.actorScreenX

  ; Screen Y = actor.y (no vertical scroll in MI1)
  lda.w SCUMM.actors.2.y
  sta.w SCUMM.actorScreenY

  ; Default position if both zero (actor not yet positioned)
  lda.w SCUMM.actorScreenX
  ora.w SCUMM.actorScreenY
  bne _ri.posReady
  lda #128
  sta.w SCUMM.actorScreenX
  lda #110
  sta.w SCUMM.actorScreenY
_ri.posReady:

  ; Clear OAM Table 1 bytes for our sprites (5 bytes covers sprites 0-19)
  sep #$20
  lda #0
  ldx #4
- sta.w GLOBAL.oamTable1,x
  dex
  bpl -

  ; Compute flip mask based on facing direction
  ; Facing 270 (west) = H-flip all sprites
  lda #$30                            ; default: priority 3, no flip
  ldx.w SCUMM.actors.2.facing
  cpx #270
  bne +
  lda #$70                            ; priority 3 + H-flip ($40)
+
  sta.w SCUMM.actorFlipMask

  ; --- OAM render loop ---
  ; Y = source offset into OAM data (skip 6-byte header)
  ; X = destination offset into GLOBAL.oamBuffer
  rep #$20
  ldx.w GLOBAL.currentOamSlot
  ldy #6

_ri.entryLoop:
  rep #$20
  lda [_oamSrcPtr],y                  ; dx byte
  iny
  and #$00FF
  cmp #$0080
  bcc +
  ora #$FF00
+
  ; If facing west, mirror dx: new_dx = -(dx + 8)
  pha
  sep #$20
  lda.w SCUMM.actorFlipMask
  rep #$20
  and #$0040                          ; test H-flip bit
  beq _ri.noFlipDx
  pla
  clc
  adc #8
  eor #$FFFF
  inc a                               ; negate
  bra _ri.applyDx
_ri.noFlipDx:
  pla
_ri.applyDx:
  clc
  adc.w SCUMM.actorScreenX
  sta.w SCUMM.scratch

  lda [_oamSrcPtr],y                  ; dy byte
  iny
  and #$00FF
  cmp #$0080
  bcc +
  ora #$FF00
+
  clc
  adc.w SCUMM.actorScreenY
  sta.w SCUMM.scratch2

  ; Bounds check
  lda.w SCUMM.scratch
  bmi _ri.hideEntry
  cmp #$0100
  bcs _ri.hideEntry
  lda.w SCUMM.scratch2
  bmi _ri.hideEntry
  cmp #$00E0
  bcs _ri.hideEntry

  ; Write visible OAM entry
  sep #$20
  lda.w SCUMM.scratch
  sta.w GLOBAL.oamBuffer,x
  inx
  lda.w SCUMM.scratch2
  sta.w GLOBAL.oamBuffer,x
  inx
  lda [_oamSrcPtr],y                  ; tile_id
  sta.w GLOBAL.oamBuffer,x
  iny
  inx
  lda [_oamSrcPtr],y                  ; flags
  ora.w SCUMM.actorFlipMask           ; priority 3 + H-flip if facing west
  sta.w GLOBAL.oamBuffer,x
  iny
  inx
  bra _ri.nextEntry

_ri.hideEntry:
  sep #$20
  lda #0
  sta.w GLOBAL.oamBuffer,x
  inx
  lda #$F0                            ; off-screen Y
  sta.w GLOBAL.oamBuffer,x
  inx
  lda #0
  sta.w GLOBAL.oamBuffer,x
  iny                                 ; skip tile_id in source
  inx
  sta.w GLOBAL.oamBuffer,x
  iny                                 ; skip flags in source
  inx

_ri.nextEntry:
  rep #$20
  dec.w SCUMM.actorOamCount
  beq +
  jmp _ri.entryLoop
+

  stx.w GLOBAL.currentOamSlot

_ri.skipActors:
  ; --- Cursor OAM entry (appended after actor sprites) ---
  rep #$20
  lda.w SCUMM.cursorEnabled
  beq _ri.noCursor

  ldx.w GLOBAL.currentOamSlot
  sep #$20
  lda.w SCUMM.cursorX
  sta.w GLOBAL.oamBuffer,x
  inx
  lda.w SCUMM.cursorY
  sta.w GLOBAL.oamBuffer,x
  inx
  lda.b #CURSOR_TILE_ID
  sta.w GLOBAL.oamBuffer,x
  inx
  lda.b #$32                          ; priority 3, OBJ palette 1
  sta.w GLOBAL.oamBuffer,x
  inx
  rep #$20
  stx.w GLOBAL.currentOamSlot
_ri.noCursor:

  ; Signal engine to upload OAM buffer during next VBlank
  sep #$20
  lda #1
  sta.w GLOBAL.oamUploadFlag
  rep #$20

_ri.done:
  rtl

.ends

;===========================================================================
; verbOps implementation — superfree section (bank 0 too full)
; Called via jsl from op_verbOps. Y = SCUMM PC, [tmp] = script base.
; SCUMM.resultVar = verb ID. All sub-opcodes handled here.
;===========================================================================
.section "scummvm verbOps impl" superfree

scummvm.verbOps_impl:
  ; Set data bank to $7E for WRAM access
  phb
  sep #$20
  lda #$7E
  pha
  plb
  rep #$20

  ; Find existing slot with this verb ID, or first empty slot
  phy                                ; save Y (SCUMM PC)
  ldx #0
  ldy #$FFFF                         ; Y = first empty slot
_voi.findSlot:
  sep #$20
  lda.w SCUMM.verbs.1.id,x
  beq _voi.findEmpty
  cmp.w SCUMM.resultVar
  beq _voi.foundExact
  bra _voi.findAdvance
_voi.findEmpty:
  rep #$20
  cpy #$FFFF
  bne _voi.findAdvance
  txy
_voi.findAdvance:
  rep #$20
  txa
  clc
  adc #_sizeof_scummVerb
  tax
  cpx #_sizeof_scummVerb * SCUMM_MAX_VERBS
  bcc _voi.findSlot
  tyx                                ; X = empty slot (or $FFFF)
  bra _voi.foundDone
_voi.foundExact:
  rep #$20
_voi.foundDone:
  txa
  sta.w SCUMM.scratch2
  ply                                ; restore Y (SCUMM PC)

; --- Sub-opcode loop ---
_voi.subLoop:
  jsr _voi.fetchByte
  cmp #$00FF
  bne +
  plb                                ; restore DB
  rtl
+
  sta.w SCUMM.scratch
  and #$001F

  cmp #$01
  beq _voi.p16
  cmp #$02
  bne +
  jmp _voi.doName
+
  cmp #$03
  bne +
  jmp _voi.doColor
+
  cmp #$04
  bne +
  jmp _voi.doHiColor
+
  cmp #$05
  bne +
  jmp _voi.doSetXY
+
  cmp #$06
  bne +
  jmp _voi.doOn
+
  cmp #$07
  bne +
  jmp _voi.doOff
+
  cmp #$08
  bne +
  jmp _voi.doDelete
+
  cmp #$09
  bne +
  jmp _voi.doNew
+
  cmp #$0A
  bcc _voi.subLoop
  cmp #$10
  bne +
  jmp _voi.doDimColor
+
  cmp #$11
  beq _voi.doP8
  cmp #$13
  bne +
  jmp _voi.doKey
+
  cmp #$14
  beq _voi.p16
  cmp #$16
  beq _voi.p16_p8
  cmp #$17
  beq _voi.p16
  bra _voi.doP8

; --- Skip helpers ---
_voi.p16:
  jsr _voi.fetchWord
  jmp _voi.subLoop

_voi.doP8:
  lda.w SCUMM.scratch
  and #$0080
  beq +
  jsr _voi.fetchWord
  jmp _voi.subLoop
+
  jsr _voi.fetchByte
  jmp _voi.subLoop

_voi.p16_p8:
  jsr _voi.fetchWord
  jmp _voi.doP8

; --- Fetch helpers (duplicate of bank 0 routines for cross-bank use) ---
_voi.fetchByte:
  lda [tmp],y
  and #$00FF
  iny
  rts

_voi.fetchWord:
  lda [tmp],y
  iny
  iny
  rts

; Read p8 param resolving variable refs via SCUMM.scratch flags
_voi.readP8:
  lda.w SCUMM.scratch
  and #$0080
  beq +
  jsr _voi.fetchWord
  jmp _voi.readVar
+
  jmp _voi.fetchByte

; Minimal readVariable (inline for superfree)
; Input: A = variable index (encoded). Output: A = value.
_voi.readVar:
  pha
  and #SCUMM_VAR_TYPE_MASK
  beq _voi.readGlobal
  cmp #SCUMM_VAR_LOCAL_MASK
  beq _voi.readLocal
  ; bit variable — return 0/1
  pla
  and #SCUMM_VAR_INDEX_MASK
  ; index in A, divide by 8 for byte offset, bit within byte
  pha
  lsr a
  lsr a
  lsr a
  tax
  pla
  and #$0007
  phx
  tax
  lda.l _voi.bitTable,x
  plx
  and.w SCUMM.bitVars,x
  beq +
  lda #1
+
  rts

_voi.readGlobal:
  pla
  and #SCUMM_VAR_INDEX_MASK
  asl a                              ; *2 for word index
  tax
  lda.w SCUMM.globalVars,x
  rts

_voi.readLocal:
  pla
  and #SCUMM_VAR_INDEX_MASK
  asl a
  clc
  adc.w SCUMM.currentSlotPtr
  tax
  lda.w SCUMM.slots.1.localVars,x
  rts

_voi.bitTable:
  .db $01, $02, $04, $08, $10, $20, $40, $80

; --- Storage handlers ---

_voi.doNew:
  ldx.w SCUMM.scratch2
  cpx #$FFFF
  bne +
  jmp _voi.subLoop
+
  lda.w SCUMM.resultVar
  sep #$20
  sta.w SCUMM.verbs.1.id,x
  rep #$20
  jmp _voi.subLoop

_voi.doOn:
  ldx.w SCUMM.scratch2
  cpx #$FFFF
  bne +
  jmp _voi.subLoop
+
  sep #$20
  lda.w SCUMM.verbs.1.flags,x
  ora #SCUMM_VERB_FLAG_ON
  sta.w SCUMM.verbs.1.flags,x
  rep #$20
  lda #1
  sta.w SCUMM.verbDirty
  jmp _voi.subLoop

_voi.doOff:
  ldx.w SCUMM.scratch2
  cpx #$FFFF
  bne +
  jmp _voi.subLoop
+
  sep #$20
  lda.w SCUMM.verbs.1.flags,x
  and #$FE
  sta.w SCUMM.verbs.1.flags,x
  rep #$20
  lda #1
  sta.w SCUMM.verbDirty
  jmp _voi.subLoop

_voi.doDelete:
  ldx.w SCUMM.scratch2
  cpx #$FFFF
  bne +
  jmp _voi.subLoop
+
  stz.w SCUMM.verbs.1.id,x
  stz.w SCUMM.verbs.1.flags,x
  lda #1
  sta.w SCUMM.verbDirty
  jmp _voi.subLoop

_voi.doName:
  ldx.w SCUMM.scratch2
  cpx #$FFFF
  bne _voi.doName.store
  ; skip null string
-
  jsr _voi.fetchByte
  cmp #0
  bne -
  jmp _voi.subLoop
_voi.doName.store:
  lda.w SCUMM.verbNamesPtr
  sta.w SCUMM.verbs.1.namePtr,x
  ldx.w SCUMM.verbNamesPtr
  lda #0
  sta.w SCUMM.scratch                ; char count
_voi.nameChar:
  jsr _voi.fetchByte
  cmp #0
  beq _voi.nameDone
  sep #$20
  sta.w SCUMM.verbNames,x
  rep #$20
  inx
  inc.w SCUMM.scratch
  bra _voi.nameChar
_voi.nameDone:
  txa
  sta.w SCUMM.verbNamesPtr
  ldx.w SCUMM.scratch2
  lda.w SCUMM.scratch
  sep #$20
  sta.w SCUMM.verbs.1.nameLen,x
  rep #$20
  lda #1
  sta.w SCUMM.verbDirty
  jmp _voi.subLoop

_voi.doColor:
  jsr _voi.readP8
  ldx.w SCUMM.scratch2
  cpx #$FFFF
  beq _voi.doColor.skip
  sep #$20
  sta.w SCUMM.verbs.1.color,x
  rep #$20
_voi.doColor.skip:
  jmp _voi.subLoop

_voi.doHiColor:
  jsr _voi.readP8
  ldx.w SCUMM.scratch2
  cpx #$FFFF
  beq _voi.doHiColor.skip
  sep #$20
  sta.w SCUMM.verbs.1.hiColor,x
  rep #$20
_voi.doHiColor.skip:
  jmp _voi.subLoop

_voi.doDimColor:
  jsr _voi.readP8
  ldx.w SCUMM.scratch2
  cpx #$FFFF
  beq _voi.doDimColor.skip
  sep #$20
  sta.w SCUMM.verbs.1.dimColor,x
  rep #$20
_voi.doDimColor.skip:
  jmp _voi.subLoop

_voi.doKey:
  jsr _voi.readP8
  ldx.w SCUMM.scratch2
  cpx #$FFFF
  beq _voi.doKey.skip
  sep #$20
  sta.w SCUMM.verbs.1.key,x
  rep #$20
_voi.doKey.skip:
  jmp _voi.subLoop

_voi.doSetXY:
  ; Read X param: test SCUMM.scratch bit 7
  lda.w SCUMM.scratch
  and #$0080
  beq +
  jsr _voi.fetchWord
  jsr _voi.readVar
  bra _voi.xyGotX
+
  jsr _voi.fetchWord
_voi.xyGotX:
  pha
  ; Read Y param: test SCUMM.scratch bit 6
  lda.w SCUMM.scratch
  and #$0040
  beq +
  jsr _voi.fetchWord
  jsr _voi.readVar
  bra _voi.xyGotY
+
  jsr _voi.fetchWord
_voi.xyGotY:
  sta.w SCUMM.scratch
  pla
  ldx.w SCUMM.scratch2
  cpx #$FFFF
  beq _voi.xySkip
  ; Store raw SCUMM pixel coordinates (renderer handles conversion)
  sep #$20
  sta.w SCUMM.verbs.1.x,x
  lda.w SCUMM.scratch
  sta.w SCUMM.verbs.1.y,x
  rep #$20
  lda #1
  sta.w SCUMM.verbDirty
_voi.xySkip:
  jmp _voi.subLoop

.ends


;===================================================================
; Default verb initializer (superfree — called via jsl from init)
; Hardcodes MI1's standard 10 verbs until proper boot flow runs.
; Table format: 8 bytes per entry (fixed size, no variable-length names)
;   id(1), x_pixel(1), y_pixel(1), nameLen(1), nameOffset(2), pad(2)
; Names stored separately for easy addressing.
;===================================================================
.section "ScummVMDefaultVerbs" superfree

scummvm.initDefaultVerbs:
  phb
  sep #$20
  lda #$7E
  pha
  plb
  rep #$31

  lda #0
  sta.w SCUMM.verbNamesPtr             ; reset name write pointer

  ; Process 10 verb entries
  ldx #0                               ; X = table index (0..9) * 4
  ldy #0                               ; Y = verb slot offset

_idv.loop:
  cpx #_idv.tableEnd - _idv.table
  bcs _idv.done

  ; Read id
  sep #$20
  lda.l _idv.table,x
  beq _idv.done
  sta.w SCUMM.verbs.1.id,y

  ; Read x, y pixel coords
  lda.l _idv.table+1,x
  sta.w SCUMM.verbs.1.x,y

  lda.l _idv.table+2,x
  sta.w SCUMM.verbs.1.y,y

  ; Set flags = ON
  lda #SCUMM_VERB_FLAG_ON
  sta.w SCUMM.verbs.1.flags,y

  ; Read name length
  lda.l _idv.table+3,x
  sta.w SCUMM.verbs.1.nameLen,y
  rep #$20
  and #$00FF
  sta.w SCUMM.scratch                  ; name length

  ; Set name pointer = current verbNamesPtr
  lda.w SCUMM.verbNamesPtr
  sta.w SCUMM.verbs.1.namePtr,y

  ; Copy name: read offset from table entry bytes 4-5
  phx
  phy
  lda.l _idv.table+4,x                ; name ROM offset (relative to _idv.names)
  and #$00FF
  tax                                  ; X = name source offset
  ldy.w SCUMM.verbNamesPtr            ; Y = dest offset in verbNames
  lda.w SCUMM.scratch                  ; char count
  sta.w SCUMM.scratch2

_idv.copy:
  sep #$20
  lda.l _idv.names,x
  sta.w SCUMM.verbNames,y
  rep #$20
  inx
  iny
  dec.w SCUMM.scratch2
  bne _idv.copy

  tya
  sta.w SCUMM.verbNamesPtr
  ply                                  ; restore verb slot offset
  plx                                  ; restore table index

  ; Advance to next entry (6 bytes per table row)
  rep #$20
  txa
  clc
  adc #6
  tax

  ; Advance verb slot
  tya
  clc
  adc #_sizeof_scummVerb
  tay

  bra _idv.loop

_idv.done:
  lda #1
  sta.w SCUMM.verbDirty
  plb
  rtl

; Table: id, x_pixel, y_pixel, nameLen, nameOffset (1 byte into _idv.names)
_idv.table:
  ;     id   x    y   len  nameOff
  .db  $01,   0, 144,   7, _idv.n0 - _idv.names, 0
  .db  $04,   0, 152,   4, _idv.n1 - _idv.names, 0
  .db  $02,   0, 160,   4, _idv.n2 - _idv.names, 0
  .db  $03,   0, 168,   5, _idv.n3 - _idv.names, 0
  .db  $09,  80, 152,   7, _idv.n4 - _idv.names, 0
  .db  $08,  80, 160,   7, _idv.n5 - _idv.names, 0
  .db  $0A,  80, 168,   7, _idv.n6 - _idv.names, 0
  .db  $07, 168, 152,   3, _idv.n7 - _idv.names, 0
  .db  $05, 168, 160,   4, _idv.n8 - _idv.names, 0
  .db  $06, 168, 168,   4, _idv.n9 - _idv.names, 0
_idv.tableEnd:

_idv.names:
_idv.n0: .db "Walk to"
_idv.n1: .db "Give"
_idv.n2: .db "Open"
_idv.n3: .db "Close"
_idv.n4: .db "Pick up"
_idv.n5: .db "Look at"
_idv.n6: .db "Talk to"
_idv.n7: .db "Use"
_idv.n8: .db "Push"
_idv.n9: .db "Pull"

.ends


;===================================================================
; Verb bar renderer (superfree — called via jsl from play method)
; Builds BG2 tilemap from verb table, then DMA uploads it.
;===================================================================
.section "ScummVMVerbRenderer" superfree

scummvm.renderVerbBar:
  phb
  sep #$20
  lda #$7E
  pha
  plb
  rep #$31

  ; Clear verb tilemap buffer (2048 bytes = 1024 words)
  ldx #0
  lda #0
-
  sta.w SCUMM.verbTilemap,x
  inx
  inx
  cpx #VERB_TILEMAP_SIZE
  bcc -

  ; Iterate verb slots
  ldx #0                                ; X = verb slot offset

_rvb.verbLoop:
  ; Check if slot is active (id != 0 and flags & ON)
  sep #$20
  lda.w SCUMM.verbs.1.id,x
  bne +
  jmp _rvb.nextVerb
+
  lda.w SCUMM.verbs.1.flags,x
  and #SCUMM_VERB_FLAG_ON
  bne +
  jmp _rvb.nextVerb
+
  rep #$20

  ; Get verb name length
  lda.w SCUMM.verbs.1.nameLen,x
  and #$00FF
  bne +
  jmp _rvb.nextVerb
+

  ; Compute tilemap offset: (y * 32 + x) * 2
  ; X pos: scale 320->256 by *4/5, then /8 for tiles
  ; For simplicity: tile_x = scumm_x * 4 / 5 / 8 = scumm_x * 4 / 40
  ; Y pos: scumm_y is relative to 144, divide by 8
  ; tile_y = (scumm_y - 144) / 8
  lda.w SCUMM.verbs.1.x,x
  and #$00FF
  ; X is SCUMM pixel coordinate; convert to tile column: x / 8
  lsr a
  lsr a
  lsr a
  sta.w SCUMM.scratch

  lda.w SCUMM.verbs.1.y,x
  and #$00FF
  ; Y is stored as SCUMM pixel coord; convert to tile row in verb area
  ; verb area starts at SCUMM y=144, BG2 tilemap row 0 = screen y=144
  ; tile_y = (y - 144) / 8
  sec
  sbc #144
  lsr a
  lsr a
  lsr a
  ; tilemap offset = (tile_y * 32 + tile_x) * 2
  asl a
  asl a
  asl a
  asl a
  asl a                                 ; tile_y * 32
  clc
  adc.w SCUMM.scratch                   ; + tile_x
  asl a                                 ; * 2 (word entries)
  sta.w SCUMM.scratch                   ; tilemap byte offset

  ; Get name pointer and length
  phx                                   ; save verb slot offset
  lda.w SCUMM.verbs.1.nameLen,x
  and #$00FF
  sta.w SCUMM.scratch2                  ; char count
  lda.w SCUMM.verbs.1.namePtr,x
  tay                                   ; Y = offset into verbNames

  ; Write tile indices for each character
  ; tile index = char - $20 (ASCII space = tile 0)
  ; All verbs use palette 7 (verb font palette via HDMA)
  ; Highlight palette swap disabled until proper HDMA integration
  rep #$20
  lda #$3C00                            ; priority 1 + palette 7
_rvb.paletteSet:
  sta.w SCUMM.actorOamCount            ; reuse as palette word

_rvb.charLoop:
  sep #$20
  lda.w SCUMM.verbNames,y
  rep #$20
  and #$00FF
  sec
  sbc #$20                              ; tile index = ASCII - 0x20
  ora.w SCUMM.actorOamCount            ; priority + palette bits
  phx
  ldx.w SCUMM.scratch                   ; X = tilemap byte offset
  sta.w SCUMM.verbTilemap,x
  plx
  ; advance tilemap offset by 2 (next tile word)
  inc.w SCUMM.scratch
  inc.w SCUMM.scratch
  ; advance name pointer
  iny
  ; decrement char count
  dec.w SCUMM.scratch2
  bne _rvb.charLoop

  plx                                   ; restore verb slot offset

_rvb.nextVerb:
  rep #$20
  txa
  clc
  adc #_sizeof_scummVerb
  tax
  cpx #_sizeof_scummVerb * SCUMM_MAX_VERBS
  bcs +
  jmp _rvb.verbLoop
+

  ; Clear dirty flag, set DMA pending flag
  stz.w SCUMM.verbDirty
  lda #1
  sta.w SCUMM.verbDmaPending

  plb
  rtl

.ends

;-------------------------------------------------------------------
; scummvm.buildCgramHdmaTable -- fill WRAM CGRAM HDMA table
; Briefly enters force blank to read room's palette 7 colors 1-3
; from CGRAM, then writes the full table to SCUMM.cgramHdmaTable.
; Table restores room colors at scanline 0, sets verb colors at 140.
; JSL/RTL. DBR=$7E assumed for absolute addressing.
;-------------------------------------------------------------------
.base BSL
.section "ScummVMBuildCgramHdma" superfree

scummvm.buildCgramHdmaTable:
  php
  rep #$31
  lda.w #SCUMM.cgramHdmaTable & $FFFF
  tax

  ; Enter force blank to read CGRAM
  sep #$20
  lda.b #INIDSP_FORCE_BLANK
  sta.l INIDSP

  ; Set CGRAM read address to $71 (palette 7 color 1)
  lda #$71
  sta.l $2121

  ; -- Repeat 3 lines at scanline 0: restore room palette 7 colors 1-3 --
  lda #$83
  sta.w 0,x
  ; Color 1: CGRAM[$71] = room value
  lda #$71
  sta.w 1,x
  sta.w 2,x
  lda.l $213B
  sta.w 3,x
  lda.l $213B
  sta.w 4,x
  ; Color 2: CGRAM[$72] = room value (CGADD auto-incremented)
  lda #$72
  sta.w 5,x
  sta.w 6,x
  lda.l $213B
  sta.w 7,x
  lda.l $213B
  sta.w 8,x
  ; Color 3: CGRAM[$73] = room value (CGADD auto-incremented)
  lda #$73
  sta.w 9,x
  sta.w 10,x
  lda.l $213B
  sta.w 11,x
  lda.l $213B
  sta.w 12,x

  ; Restore display brightness (exit force blank)
  lda.w ScreenBrightness
  sta.l INIDSP

  ; -- Scanlines 3-127: 125 lines, harmless CGRAM[$70] = $0000 --
  lda #125
  sta.w 13,x
  lda #$70
  sta.w 14,x
  sta.w 15,x
  stz.w 16,x
  stz.w 17,x

  ; -- Scanlines 128-139: 12 lines, harmless CGRAM[$70] = $0000 --
  lda #12
  sta.w 18,x
  lda #$70
  sta.w 19,x
  sta.w 20,x
  stz.w 21,x
  stz.w 22,x

  ; -- Scanlines 140-143: repeat 4, set verb colors --
  lda #$84
  sta.w 23,x
  ; CGRAM[$00] = $0000 (backdrop = black)
  stz.w 24,x
  stz.w 25,x
  stz.w 26,x
  stz.w 27,x
  ; CGRAM[$71] = $6318 (light grey inner fill)
  lda #$71
  sta.w 28,x
  sta.w 29,x
  lda #$18
  sta.w 30,x
  lda #$63
  sta.w 31,x
  ; CGRAM[$72] = $294A (dark grey shadow)
  lda #$72
  sta.w 32,x
  sta.w 33,x
  lda #$4A
  sta.w 34,x
  lda #$29
  sta.w 35,x
  ; CGRAM[$73] = $7FFF (white letter body)
  lda #$73
  sta.w 36,x
  sta.w 37,x
  lda #$FF
  sta.w 38,x
  lda #$7F
  sta.w 39,x

  ; -- Scanlines 144-223: 80 lines, harmless CGRAM[$70] = $0000 --
  lda #80
  sta.w 40,x
  lda #$70
  sta.w 41,x
  sta.w 42,x
  stz.w 43,x
  stz.w 44,x

  ; Terminator
  stz.w 45,x

  plp
  rtl

.ends


;===================================================================
; Cursor tile data — 8x8 4bpp arrow sprite (32 bytes)
; Hardcoded arrow pointing upper-left
;===================================================================
.section "CursorTileData" superfree

CursorTileData:
; 8x8 4bpp tile: 2 bitplanes interleaved per row (planes 0-1), then planes 2-3
; Arrow shape (1=outline black, 2=fill white):
; Row 0: 1 0 0 0 0 0 0 0
; Row 1: 1 1 0 0 0 0 0 0
; Row 2: 1 2 1 0 0 0 0 0
; Row 3: 1 2 2 1 0 0 0 0
; Row 4: 1 2 2 2 1 0 0 0
; Row 5: 1 2 2 2 2 1 0 0
; Row 6: 1 2 1 1 0 0 0 0
; Row 7: 1 1 0 1 1 0 0 0
; Palette: index 0=transparent, index 1=black (outline), index 2=white (fill)
; Bitplanes 0-1 (interleaved rows):
; Color = BP0 + BP1*2.  Color 1 (outline): BP0=1,BP1=0.  Color 2 (fill): BP0=0,BP1=1.
  .db %10000000, %00000000   ; row 0: 1 0 0 0 0 0 0 0
  .db %11000000, %00000000   ; row 1: 1 1 0 0 0 0 0 0
  .db %10100000, %01000000   ; row 2: 1 2 1 0 0 0 0 0
  .db %10010000, %01100000   ; row 3: 1 2 2 1 0 0 0 0
  .db %10001000, %01110000   ; row 4: 1 2 2 2 1 0 0 0
  .db %10000100, %01111000   ; row 5: 1 2 2 2 2 1 0 0
  .db %10110000, %01000000   ; row 6: 1 2 1 1 0 0 0 0
  .db %11011000, %00000000   ; row 7: 1 1 0 1 1 0 0 0
; Bitplanes 2-3 (all zero — indices 0-3 only need planes 0-1):
  .db $00, $00, $00, $00, $00, $00, $00, $00
  .db $00, $00, $00, $00, $00, $00, $00, $00
CursorTileDataEnd:

.ends


;===================================================================
; Cursor update — superfree (called via jsl from play method)
; Reads joypad, moves cursor, writes SCUMM vars, handles A-button
; click for walk and verb selection.
;===================================================================
.section "ScummVMCursorUpdate" superfree

scummvm.updateCursor:
  phb
  sep #$20
  lda #$7E
  pha
  plb
  rep #$31

  ;--- DMA cursor tile to VRAM once ---
  lda.w SCUMM.cursorTileDone
  beq +
  jmp _uc.tileDone
+

  lda #1
  sta.w SCUMM.cursorTileDone

  ; Brief force-blank for DMA
  lda.w ScreenBrightness
  and #$00FF
  pha
  sep #$20
  lda.w GLOBAL.interruptFlags
  and #NMITIMEN_NMI_ENABLE ~$ff
  sta.w GLOBAL.interruptFlags
  sta.l NMITIMEN
  sei
  lda.b #INIDSP_FORCE_BLANK
  sta.l INIDSP
  rep #$20

  ; DMA cursor tile (32 bytes) to VRAM
  sep #$20
  lda.b #VMAIN_INCREMENT_MODE
  sta.l VMAIN
  rep #$20
  lda #CURSOR_TILE_VRAM_WORD
  sta.l VMADDL

  sep #$20
  lda.b #$01                          ; A->B, increment, 2-reg write
  sta.l $4370
  lda.b #$18                          ; VMDATAL
  sta.l $4371
  rep #$20
  lda.w #CursorTileData
  sta.l $4372
  sep #$20
  lda.b #:CursorTileData
  sta.l $4374
  rep #$20
  lda.w #CursorTileDataEnd - CursorTileData
  sta.l $4375
  sep #$20
  lda.b #$80                          ; channel 7
  sta.l MDMAEN

  ; Write cursor palette (OBJ palette 1) to CGRAM while in force-blank
  lda #$91                             ; CGRAM address $91 (obj pal1 color1)
  sta.l $2121
  lda #$00                             ; $0000 = black (low)
  sta.l $2122
  lda #$00                             ; (high)
  sta.l $2122
  lda #$FF                             ; $7FFF = white (low)
  sta.l $2122
  lda #$7F                             ; (high)
  sta.l $2122

  ; Restore brightness + NMI
  rep #$20
  pla
  sep #$20
  sta.l INIDSP
  sta.w ScreenBrightness
  cli
  lda.w GLOBAL.interruptFlags
  ora #NMITIMEN_NMI_ENABLE
  sta.w GLOBAL.interruptFlags
  sta.l NMITIMEN
  rep #$20

_uc.tileDone:

  ;--- Read joypad state (direct WRAM access — can't jsr bank 0 from superfree) ---
  lda.w inputDevice.press
  sta.w SCUMM.scratch                 ; current press state
  lda.w inputDevice.trigger
  sta.w SCUMM.scratch2                ; newly triggered buttons

  ;--- D-pad movement ---
  lda.w SCUMM.scratch
  bit.w #JOY_DIR_UP
  beq _uc.noUp
  lda.w SCUMM.cursorY
  sec
  sbc #CURSOR_SPEED
  bpl +
  lda #0
+
  sta.w SCUMM.cursorY
_uc.noUp:

  lda.w SCUMM.scratch
  bit.w #JOY_DIR_DOWN
  beq _uc.noDown
  lda.w SCUMM.cursorY
  clc
  adc #CURSOR_SPEED
  cmp #224
  bcc +
  lda #223
+
  sta.w SCUMM.cursorY
_uc.noDown:

  lda.w SCUMM.scratch
  bit.w #JOY_DIR_LEFT
  beq _uc.noLeft
  lda.w SCUMM.cursorX
  sec
  sbc #CURSOR_SPEED
  bpl +
  lda #0
+
  sta.w SCUMM.cursorX
_uc.noLeft:

  lda.w SCUMM.scratch
  bit.w #JOY_DIR_RIGHT
  beq _uc.noRight
  lda.w SCUMM.cursorX
  clc
  adc #CURSOR_SPEED
  cmp #256
  bcc +
  lda #255
+
  sta.w SCUMM.cursorX
_uc.noRight:

  ;--- Write SCUMM mouse variables ---
  lda.w SCUMM.cursorX
  ldx #42*2
  sta.w SCUMM.globalVars,x            ; VAR(42) = VAR_MOUSE_X
  ldx #44*2
  sta.w SCUMM.globalVars,x            ; VAR(44) = VAR_VIRT_MOUSE_X

  lda.w SCUMM.cursorY
  ldx #43*2
  sta.w SCUMM.globalVars,x            ; VAR(43) = VAR_MOUSE_Y
  ldx #45*2
  sta.w SCUMM.globalVars,x            ; VAR(45) = VAR_VIRT_MOUSE_Y

  ;--- Handle A button click ---
  lda.w SCUMM.scratch2
  bit.w #JOY_BUTTON_A
  bne +
  jmp _uc.noClick
+
  lda.w SCUMM.cursorEnabled
  bne +
  jmp _uc.noClick
+
  ; Check if cursor is in room area (Y < 144)
  lda.w SCUMM.cursorY
  cmp #144
  bcc +
  jmp _uc.verbAreaClick
+

  ;--- Click-to-walk: initialize position if actor at (0,0) ---
  ; Scripts may call putActorInRoom (sets room+visible) without putActor (sets x/y).
  ; If x=0 and y=0, snap to the renderActors fallback position before walking.
  lda.w SCUMM.actors.2.x
  ora.w SCUMM.actors.2.y
  bne _uc.posOk
  lda.w GLOBAL.room.cameraX
  clc
  adc #128
  sta.w SCUMM.actors.2.x
  lda #110
  sta.w SCUMM.actors.2.y
_uc.posOk:

  ;--- Convert screen X to room X ---
  lda.w SCUMM.cursorX
  clc
  adc.w GLOBAL.room.cameraX           ; roomX = screenX + scrollX
  pha                                  ; save target room X
  lda.w SCUMM.cursorY                 ; roomY = cursorY (no Y scroll)
  sta.w SCUMM.scratch

  ; Set walk target for actor 1 (Guybrush)
  ; actor 1 word index = 2 (actor*2)
  ldx #2
  pla
  sta.w SCUMM.actorTargetX,x          ; target X
  lda.w SCUMM.scratch
  sta.w SCUMM.actorTargetY,x          ; target Y

  ; Init walk animation
  ldx #1                              ; actor 1 byte index
  sep #$20
  lda #WALK_ANIM_SPEED
  sta.w SCUMM.actorAnimTimer,x
  lda #0
  sta.w SCUMM.actorAnimFrame,x
  rep #$20

  ; Set actor.moving = 1
  sep #$20
  lda #1
  sta.w SCUMM.actors.2.moving
  rep #$20

  jmp _uc.noClick

_uc.verbAreaClick:
  ;--- Verb area click: hit-test against verb entries ---
  ldx #0                              ; X = verb slot offset
  lda.w SCUMM.cursorX                 ; cursor X in screen pixels
  sta.w SCUMM.actorScreenX            ; reuse scratch (screen X)
  lda.w SCUMM.cursorY
  sta.w SCUMM.actorScreenY            ; screen Y

_uc.verbHitLoop:
  sep #$20
  lda.w SCUMM.verbs.1.id,x
  beq _uc.verbHitNext
  lda.w SCUMM.verbs.1.flags,x
  and #SCUMM_VERB_FLAG_ON
  beq _uc.verbHitNext
  rep #$20

  ; Check Y: verb.y <= cursorY < verb.y + 8
  lda.w SCUMM.verbs.1.y,x
  and #$00FF
  cmp.w SCUMM.actorScreenY
  beq +
  bcs _uc.verbHitNext                 ; verb.y > cursorY
+
  clc
  adc #8
  cmp.w SCUMM.actorScreenY
  bcc _uc.verbHitNext                 ; verb.y + 8 <= cursorY
  beq _uc.verbHitNext

  ; Check X: verb.x <= cursorX < verb.x + nameLen*8
  lda.w SCUMM.verbs.1.x,x
  and #$00FF
  cmp.w SCUMM.actorScreenX
  beq +
  bcs _uc.verbHitNext                 ; verb.x > cursorX
+
  pha
  lda.w SCUMM.verbs.1.nameLen,x
  and #$00FF
  asl a
  asl a
  asl a                               ; nameLen * 8
  clc
  adc 1,s                             ; verb.x + nameLen*8
  sta 1,s
  pla
  cmp.w SCUMM.actorScreenX
  bcc _uc.verbHitNext                 ; right edge <= cursorX
  beq _uc.verbHitNext

  ; Hit! Store verb ID as sentenceVerb
  sep #$20
  lda.w SCUMM.verbs.1.id,x
  rep #$20
  and #$00FF
  sta.w SCUMM.sentenceVerb
  jmp _uc.noClick

_uc.verbHitNext:
  rep #$20
  txa
  clc
  adc #_sizeof_scummVerb
  tax
  cpx #_sizeof_scummVerb * SCUMM_MAX_VERBS
  bcs +
  jmp _uc.verbHitLoop
+

_uc.noClick:
  ;--- Verb hover highlight ---
  ; Check if cursor is in verb area for highlight tracking
  rep #$20
  lda.w SCUMM.cursorY
  cmp #144
  bcc _uc.clearHighlight

  ; Hit-test for hover (same logic as click)
  ldx #0
_uc.hoverLoop:
  sep #$20
  lda.w SCUMM.verbs.1.id,x
  beq _uc.hoverNext
  lda.w SCUMM.verbs.1.flags,x
  and #SCUMM_VERB_FLAG_ON
  beq _uc.hoverNext
  rep #$20

  ; Check Y bounds
  lda.w SCUMM.verbs.1.y,x
  and #$00FF
  cmp.w SCUMM.cursorY
  beq +
  bcs _uc.hoverNext
+
  clc
  adc #8
  cmp.w SCUMM.cursorY
  bcc _uc.hoverNext
  beq _uc.hoverNext

  ; Check X bounds
  lda.w SCUMM.verbs.1.x,x
  and #$00FF
  cmp.w SCUMM.cursorX
  beq +
  bcs _uc.hoverNext
+
  pha
  lda.w SCUMM.verbs.1.nameLen,x
  and #$00FF
  asl a
  asl a
  asl a
  clc
  adc 1,s
  sta 1,s
  pla
  cmp.w SCUMM.cursorX
  bcc _uc.hoverNext
  beq _uc.hoverNext

  ; Hover match — check if changed
  cpx.w SCUMM.highlightVerb
  beq _uc.highlightDone               ; same as before, skip redraw
  stx.w SCUMM.highlightVerb
  lda #1
  sta.w SCUMM.verbDirty               ; force verb redraw with highlight
  jmp _uc.highlightDone

_uc.hoverNext:
  rep #$20
  txa
  clc
  adc #_sizeof_scummVerb
  tax
  cpx #_sizeof_scummVerb * SCUMM_MAX_VERBS
  bcs +
  jmp _uc.hoverLoop
+

_uc.clearHighlight:
  lda.w SCUMM.highlightVerb
  cmp #$FFFF
  beq _uc.highlightDone
  lda #$FFFF
  sta.w SCUMM.highlightVerb
  lda #1
  sta.w SCUMM.verbDirty               ; force redraw without highlight

_uc.highlightDone:
  plb
  rtl

.ends
