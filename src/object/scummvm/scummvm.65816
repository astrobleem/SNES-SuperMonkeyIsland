;
; SCUMM v5 Bytecode Interpreter for SNES
;
; OOP class that runs MI1's SCUMM scripts. One object manages all
; 25 SCUMM script slots. play() runs the scheduler once per frame.
;
; Bytecode fetch: [dp:tmp],y where tmp holds 24-bit pointer into
; $7F script cache, Y is the SCUMM PC offset within the script.
;
; Dispatch: 256-entry jsr (table,x) jump table. Handler returns
; with carry clear = continue, carry set = yield.
;

.include "src/object/scummvm/scummvm.h"

.bank 0 slot 0
.base BSL
.section "scummvm class"

;===================================================================
; METHOD: init
; Read MSU-1 script section header, zero all state, start script 1
;===================================================================
  METHOD init
  rep #$31

  ;--- Set DBR=$7E so sta.w targets WRAM, not ROM ---
  ;core.object.create does NOT set DBR; during boot it may be $00/$C0.
  phb
  sep #$20
  lda #$7E
  pha
  plb
  rep #$20

  ;--- Zero all WRAM state ---
  ;zero script slots (25 * 64 = 1600 bytes)
  ldx #0
  lda #0
_init.zeroSlots:
  .ACCU 16
  .INDEX 16
  sta.w SCUMM.slots,x
  inx
  inx
  cpx #_sizeof_scummSlot * SCUMM_MAX_SLOTS
  bcc _init.zeroSlots

  ;zero global variables (800 * 2 = 1600 bytes)
  ldx #0
_init.zeroGlobals:
  .ACCU 16
  .INDEX 16
  sta.w SCUMM.globalVars,x
  inx
  inx
  cpx #SCUMM_MAX_GLOBALS * 2
  bcc _init.zeroGlobals

  ;zero bit variables (256 bytes)
  ldx #0
_init.zeroBits:
  .ACCU 16
  .INDEX 16
  sta.w SCUMM.bitVars,x
  inx
  inx
  cpx #256
  bcc _init.zeroBits

  ; Set bitVar[361] — "game initialized" flag
  ; Normally set by script 188 (game-init kickstart), which is not in our
  ; MI1 extraction.  Without this bit, room 1 ENCD skips starting LSCR 200
  ; and Guybrush never gets placed.
  ; Bit 361 = byte 45, bit 1 → mask $02
  sep #$20
  ldx #45
  lda #$02
  sta.w SCUMM.bitVars,x
  rep #$20

  ;zero VM state
  stz.w SCUMM.running
  stz.w SCUMM.currentSlot
  stz.w SCUMM.currentSlotPtr
  stz.w SCUMM.currentOpcode
  stz.w SCUMM.resultVar
  stz.w SCUMM.scratch
  stz.w SCUMM.scratch2
  stz.w SCUMM.cacheWritePtr
  stz.w SCUMM.cutsceneNest
  ; Zero cutscene arrays (5 levels: Ptr 10B, Script 5B, Data 10B)
  ldx #0
- stz.w SCUMM.cutScenePtr,x
  stz.w SCUMM.cutSceneData,x
  inx
  inx
  cpx #10
  bcc -
  ldx #0
  sep #$20
  .ACCU 8
- stz.w SCUMM.cutSceneScript,x
  inx
  cpx #5
  bcc -
  rep #$20
  .ACCU 16
  stz.w SCUMM.currentRoom
  stz.w SCUMM.newRoom
  stz.w SCUMM.bgInitDone
  stz.w SCUMM.gcInProgress
  stz.w SCUMM.hdmaChannel          ; zeros both hdmaChannel + hdmaCgramChannel (adjacent db's)
  stz.w SCUMM.cgramHdmaTable       ; zero first entry so HDMA terminates immediately if read
  stz.w SCUMM.roomEncdPtr
  stz.w SCUMM.roomEncdLen
  stz.w SCUMM.roomExcdPtr
  stz.w SCUMM.roomExcdLen
  stz.w SCUMM.roomLscrCount
  stz.w SCUMM.cursorObject
  stz.w SCUMM.sentenceObject

  ;zero LSCR table (56 * 4 = 224 bytes)
  ldx #0
  lda #0
_init.zeroLscr:
  .ACCU 16
  .INDEX 16
  sta.w SCUMM.roomLscrTable,x
  inx
  inx
  cpx #_sizeof_lscrEntry * SCUMM_LSCR_MAX
  bcc _init.zeroLscr

  ;zero actor state (256 * 16 = 4096 bytes)
  ldx #0
  lda #0
_init.zeroActors:
  .ACCU 16
  .INDEX 16
  sta.w SCUMM.actors,x
  inx
  inx
  cpx #_sizeof_scummActor * SCUMM_MAX_ACTORS
  bcc _init.zeroActors

  ;zero object state table (1024 bytes)
  ldx #0
  lda #0
_init.zeroObjState:
  .ACCU 16
  .INDEX 16
  sta.w SCUMM.objectState,x
  inx
  inx
  cpx #SCUMM_MAX_OBJECTS
  bcc _init.zeroObjState

  ;zero verb table (20 * 16 = 320 bytes)
  ldx #0
  lda #0
_init.zeroVerbs:
  .ACCU 16
  .INDEX 16
  sta.w SCUMM.verbs,x
  inx
  inx
  cpx #_sizeof_scummVerb * SCUMM_MAX_VERBS
  bcc _init.zeroVerbs

  ;zero verb names buffer (256 bytes)
  ldx #0
_init.zeroVerbNames:
  .ACCU 16
  .INDEX 16
  sta.w SCUMM.verbNames,x
  inx
  inx
  cpx #SCUMM_VERB_NAMES_SIZE
  bcc _init.zeroVerbNames

  stz.w SCUMM.verbNamesPtr
  stz.w SCUMM.verbDirty

  ;zero verb tilemap (2048 bytes)
  ldx #0
_init.zeroVerbTilemap:
  .ACCU 16
  .INDEX 16
  sta.w SCUMM.verbTilemap,x
  inx
  inx
  cpx #VERB_TILEMAP_SIZE
  bcc _init.zeroVerbTilemap

  ; Kick NMI DMA so VRAM $4800 gets zeroed immediately (prevents stale
  ; title-screen verb data showing during the first intro cutscene).
  sep #$20
  lda #1
  sta.w SCUMM.verbTilemapNmiPending
  rep #$31

  ;zero walk state arrays (16 actors × 2B targets + 16B anim)
  ldx #0
  lda #0
_init.zeroWalk:
  .ACCU 16
  .INDEX 16
  sta.w SCUMM.actorTargetX,x
  sta.w SCUMM.actorTargetY,x
  inx
  inx
  cpx #SCUMM_WALK_ACTORS * 2
  bcc _init.zeroWalk
  ldx #0
  sep #$20
  lda #0
_init.zeroWalk2:
  .ACCU 8
  .INDEX 16
  sta.w SCUMM.actorAnimFrame,x
  sta.w SCUMM.actorAnimTimer,x
  lda #$FF
  sta.w SCUMM.actorLastFrame,x
  lda #0
  inx
  cpx #SCUMM_WALK_ACTORS
  bcc _init.zeroWalk2
  rep #$20

  ;init resource mapper (identity: mapper[i] = i)
  ldx #0
  sep #$20
_init.fillMapper:
  .ACCU 8
  .INDEX 16
  txa
  sta.w SCUMM.resourceMapper,x
  inx
  cpx #256
  bcc _init.fillMapper
  rep #$20

  ;zero script cache in $7F
  ldx #0
  lda #0
_init.zeroCache:
  .ACCU 16
  .INDEX 16
  sta.l SCUMM_CACHE_WRAM,x
  inx
  inx
  cpx #SCUMM_CACHE_SIZE
  bcc _init.zeroCache

  ;--- Read script section offset from MSU-1 header ---
  ; MSU header at offset $0024 has 32-bit script section offset
  lda.w #SCUMM_MSU_SCRIPT_HDR_OFFSET
  ldx #0
  jsr room.msu1Seek

  ; Read LE32 into scriptSectionLo/Hi using XBA word-read pattern
  sep #$20
  lda.l MSU_DATA
  xba
  lda.l MSU_DATA
  xba
  rep #$20
  sta.w SCUMM.scriptSectionLo
  sep #$20
  lda.l MSU_DATA
  xba
  lda.l MSU_DATA
  xba
  rep #$20
  sta.w SCUMM.scriptSectionHi

  ; Check that script section exists
  lda.w SCUMM.scriptSectionLo
  ora.w SCUMM.scriptSectionHi
  bne +
    TRIGGER_ERROR E_ScummVmBadOpcode
+
  .ACCU 16
  .INDEX 16

  ;--- Seek to script section and read 32-byte header ---
  lda.w SCUMM.scriptSectionLo
  ldx.w SCUMM.scriptSectionHi
  jsr room.msu1Seek

  ; Skip magic (4 bytes) + version (1) + reserved (1) = 6 bytes
  sep #$20
  lda.l MSU_DATA
  lda.l MSU_DATA
  lda.l MSU_DATA
  lda.l MSU_DATA
  lda.l MSU_DATA
  lda.l MSU_DATA
  rep #$20

  ; Read global_slots (LE16) -- XBA word-read
  sep #$20
  lda.l MSU_DATA
  xba
  lda.l MSU_DATA
  xba
  rep #$20
  sta.w SCUMM.globalSlots

  ; Read room_slots (LE16) -- XBA word-read
  sep #$20
  lda.l MSU_DATA
  xba
  lda.l MSU_DATA
  xba
  rep #$20
  sta.w SCUMM.roomSlots

  ; Skip 6 reserved bytes (bytes 10-15)
  sep #$20
  lda.l MSU_DATA
  lda.l MSU_DATA
  lda.l MSU_DATA
  lda.l MSU_DATA
  lda.l MSU_DATA
  lda.l MSU_DATA
  rep #$20

  ; Read global_index_offset (LE32, bytes 16-19) -- XBA word-read
  sep #$20
  lda.l MSU_DATA
  xba
  lda.l MSU_DATA
  xba
  rep #$20
  sta.w SCUMM.globalIndexLo
  sep #$20
  lda.l MSU_DATA
  xba
  lda.l MSU_DATA
  xba
  rep #$20
  sta.w SCUMM.globalIndexHi

  ; Read room_index_offset (LE32, bytes 20-23) -- XBA word-read
  sep #$20
  lda.l MSU_DATA
  xba
  lda.l MSU_DATA
  xba
  rep #$20
  sta.w SCUMM.roomIndexLo
  sep #$20
  lda.l MSU_DATA
  xba
  lda.l MSU_DATA
  xba
  rep #$20
  sta.w SCUMM.roomIndexHi

  ;--- Set SCUMM v5 system variables (from ScummVM resetScummVars) ---
  ; Use indexed addressing: ldx #var*2 / lda #val / sta.w globalVars,x
  ; (wla-dx ramsection + constant = 24-bit → linker error without index)
  lda #1
  ldx #1*2
  sta.w SCUMM.globalVars,x          ; VAR(1)  = VAR_EGO = 1 (Guybrush)
  lda #13
  ldx #8*2
  sta.w SCUMM.globalVars,x          ; VAR(8)  = VAR_NUM_ACTOR = 13
  lda #1
  ldx #15*2
  sta.w SCUMM.globalVars,x          ; VAR(15) = VAR_ACTOR_RANGE_MIN = 1
  lda #12
  ldx #16*2
  sta.w SCUMM.globalVars,x          ; VAR(16) = VAR_ACTOR_RANGE_MAX = 12
  lda #1400
  ldx #40*2
  sta.w SCUMM.globalVars,x          ; VAR(40) = VAR_HEAPSPACE = 1400
  lda #3
  ldx #46*2
  sta.w SCUMM.globalVars,x          ; VAR(46) = VAR_SOUNDCARD = 3 (SB)
  lda #19
  ldx #47*2
  sta.w SCUMM.globalVars,x          ; VAR(47) = VAR_VIDEOMODE = 19 (VGA)
  lda #1
  ldx #49*2
  sta.w SCUMM.globalVars,x          ; VAR(49) = VAR_FIXEDDISK = 1
  lda #$0100
  ldx #7*2
  sta.w SCUMM.globalVars,x          ; VAR(7) = $0100 = Part 1 fresh start (script 188 switch)
  ; Set objectState[256] = 1 so script 35's getObjectState check passes
  sep #$20
  lda #1
  ldx #256
  sta.w SCUMM.objectState,x
  rep #$20

  ;--- Init cursor state ---
  lda #128
  sta.w SCUMM.cursorX
  lda #80
  sta.w SCUMM.cursorY
  lda #1
  sta.w SCUMM.cursorEnabled
  sta.w SCUMM.userPut
  stz.w SCUMM.sentenceVerb
  stz.w SCUMM.sentenceObjectA
  stz.w SCUMM.sentenceObjectB
  stz.w SCUMM.sentenceDirty
  lda #$FFFF
  sta.w SCUMM.highlightVerb
  stz.w SCUMM.cursorTileDone
  stz.w SCUMM.pendingVerb
  stz.w SCUMM.pendingObject
  lda #1
  ldx #48*2
  sta.w SCUMM.globalVars,x            ; VAR(48) = VAR_USERPUT = 1

  ;--- Init dialog state ---
  stz.w SCUMM.dialogActive
  stz.w SCUMM.dialogTimer
  stz.w SCUMM.dialogX
  stz.w SCUMM.dialogY
  stz.w SCUMM.dialogColor
  stz.w SCUMM.dialogActor
  sep #$20
  stz.w SCUMM.dialogFontNmiPending
  nop
  nop
  rep #$20
  stz.w SCUMM.dialogCharCount

  ;zero dialog tilemap (2048 bytes) + set DMA pending to clear VRAM
  ldx #0
  lda #0
_init.zeroDialogTilemap:
  .ACCU 16
  .INDEX 16
  sta.w SCUMM.dialogTilemap,x
  inx
  inx
  cpx #DIALOG_TILEMAP_SIZE
  bcc _init.zeroDialogTilemap
  lda #1
  sta.w SCUMM.dialogDmaPending
  lda #400
  sta.w SCUMM.dialogBootSuppress   ; suppress CD text for ~6.7 sec

  ;--- Init inventory state ---
  stz.w SCUMM.inventoryCount
  stz.w SCUMM.inventoryScroll
  stz.w SCUMM.inventoryDirty
  stz.w SCUMM.invNameCount

  ;--- Init camera state (superfree helper) ---
  jsl scummvm.initCameraVars

  ;--- Set starting room (triggers room load on first play frame) ---
  ; MI1 room 1 is entered via pseudo-room 130 (pier/lookout direction).
  ; ENCD checks VAR_ROOM against 130/131/132 to determine entry direction.
  ; Without pseudo-room, class 10 stays on exits → transitions blocked.
  ; Set up mapper: 130/131/132 all resolve to real room 1.
  sep #$20
  lda #1
  ldx #130
  sta.w SCUMM.resourceMapper,x
  inx
  sta.w SCUMM.resourceMapper,x
  inx
  sta.w SCUMM.resourceMapper,x
  rep #$20
  lda #130
  sta.w SCUMM.newRoom

  ;--- Pre-seed ego for room 1 (skipping MI1 intro) ---
  ; Set costume 1 (Guybrush standard) so loadActorCostumes DMAs correct data.
  ; ENCD may override this, triggering dirty-slot CHR+palette DMA.
  ldx #1*16                         ; actor 1 struct offset
  lda #160
  sta.w SCUMM.actors.x,x
  lda #100
  sta.w SCUMM.actors.y,x
  sep #$20
  lda #1
  sta.w SCUMM.actors.costume,x
  lda #90                           ; facing east
  sta.w SCUMM.actors.facing,x
  lda #1
  sta.w SCUMM.actors.visible,x
  rep #$20

  ;--- Zero walk path state (prevent garbage movement before walkActorTo) ---
  ldx #0
  lda #0
_init.zeroWalkPaths:
  .ACCU 16
  .INDEX 16
  sta.w SCUMM.walkPathLen,x
  sta.w SCUMM.walkPathIdx,x
  sta.w SCUMM.actorWalkBox,x
  sta.w SCUMM.actorIgnoreBoxes,x
  inx
  cpx #SCUMM_WALK_ACTORS
  bcc _init.zeroWalkPaths

  ;--- Init actorLastFrame to $FF (force CHR DMA on first render) ---
  sep #$20
  ldx #0
  lda #$FF
_init.lastFrame:
  .ACCU 8
  .INDEX 16
  sta.w SCUMM.actorLastFrame,x
  inx
  cpx #SCUMM_WALK_ACTORS
  bcc _init.lastFrame

  ;--- Init renderSlotLastScale to $FF (unscaled) ---
  ldx #0
  lda #$FF
_init.lastScale:
  .ACCU 8
  .INDEX 16
  sta.w SCUMM.renderSlotLastScale,x
  inx
  cpx #SCUMM_MAX_RENDER_SLOTS
  bcc _init.lastScale
  rep #$20

  ;--- Start MI1 boot script (script 1) ---
  ; Boot script puts actors 8-11 in room 0 then loops waiting for ego to
  ; be moving before calling startScript(35).  With correct SCUMM
  ; conditional semantics the loop waits for moving!=0, but updateActors
  ; clears the seed before the check runs.  Start script 35 directly to
  ; bypass the wait; boot script continues its loop independently.
  lda #1
  jsr _scummvm.startScriptSlot

  ;--- Start script 35 directly (bypass boot script's ego-moving wait) ---
  ; Boot script 1 loops waiting for ego moving before calling
  ; startScript(35).  We start 35 directly so the game-init chain runs
  ; immediately.  gv7 (VAR_BOOT_PARAM) is already set to $0100 above.
  lda #35
  jsr _scummvm.startScriptSlot

  ;--- Mark VM as running ---
  lda #1
  sta.w SCUMM.running

  ;--- Request ego costume fixup after first scheduler pass ---
  ; Boot script + ENCD set costume 1 (standard Guybrush walk).
  ; Force costume 1 after the ENCD has executed to ensure correct data.
  sta.w SCUMM.egoFixupPending

  ;--- Init default verb bar (room 10 scripts don't run yet) ---
  jsl scummvm.initDefaultVerbs

  plb                               ; restore DBR
  rts


;===================================================================
; METHOD: play -- per-frame SCUMM scheduler
; Iterates all 25 slots, runs RUNNING slots until they yield.
;===================================================================
  METHOD play
  rep #$31

  lda.w SCUMM.running
  bne +
  jmp _play.done
+
  .ACCU 16
  .INDEX 16

  ; Check for pending room change (sanitize to 8-bit room numbers)
  lda.w SCUMM.newRoom
  and #$00FF
  sta.w SCUMM.newRoom
  lda.w SCUMM.currentRoom
  and #$00FF
  sta.w SCUMM.currentRoom
  lda.w SCUMM.newRoom
  cmp.w SCUMM.currentRoom
  beq _play.noRoomChange
  jsr _scummvm.processRoomChange
_play.noRoomChange:
  .ACCU 16
  .INDEX 16

  ; Update cursor (joypad input, position, SCUMM vars, OAM)
  jsl scummvm.updateCursor

  ; --- Start button → abort cutscene / skip attract loop ---
  ; Use .press (held) not .trigger (rising-edge) because _play
  ; only runs every ~130 real frames; a 1-frame trigger is always missed.
  lda.w inputDevice.press
  bit.w #JOY_BUTTON_START
  beq _play.noAbort
  ; If a cutscene is active, try the override mechanism first
  lda.w SCUMM.cutsceneNest
  beq _play.directSkip
_play.scanOverride:
  dec a
  bmi _play.directSkip                ; scanned all levels — no target found
  pha
  asl a
  tax
  lda.w SCUMM.cutScenePtr,x
  beq _play.scanPop                   ; this level has no target — try lower
  pla                                 ; A = found level index
  inc a
  sta.w SCUMM.cutsceneNest            ; collapse nest to found_level + 1
  ldx #5*2                            ; VAR_OVERRIDE (var 5)
  lda #1
  sta.w SCUMM.globalVars,x            ; VAR_OVERRIDE = 1
  bra _play.noAbort
_play.scanPop:
  pla
  bra _play.scanOverride
_play.directSkip:
  ; Override can't fire (csNest=0 or no target found).
  ; The endCutscene START check handles the redirect directly.
  ; Nothing to do here — _play will catch it next time csNest > 0.
  nop

_play.noAbort:
  .ACCU 16
  .INDEX 16

  ; Iterate slots 0..24
  stz.w SCUMM.currentSlot
  stz.w SCUMM.currentSlotPtr

_play.slotLoop:
  .ACCU 16
  .INDEX 16
  ldx.w SCUMM.currentSlotPtr

  ; Check status == RUNNING
  lda.w SCUMM.slots.status,x
  and #$00FF
  cmp #SCUMM_SLOT_RUNNING
  bne _play.nextSlot

  ; Check freezeCount == 0
  lda.w SCUMM.slots.freezeCount,x
  and #$00FF
  bne _play.nextSlot

  ; Check delay > 0
  lda.w SCUMM.slots.delay,x
  beq _play.runSlot

  ; Decrement delay
  dec a
  sta.w SCUMM.slots.delay,x
  bra _play.nextSlot

_play.runSlot:
  .ACCU 16
  .INDEX 16
  jsl scummvm.executeSlot

_play.nextSlot:
  .ACCU 16
  .INDEX 16
  ; Advance to next slot
  lda.w SCUMM.currentSlotPtr
  clc
  adc #_sizeof_scummSlot
  sta.w SCUMM.currentSlotPtr

  lda.w SCUMM.currentSlot
  inc a
  sta.w SCUMM.currentSlot
  cmp #SCUMM_MAX_SLOTS
  bcc _play.slotLoop

  ; Post-ENCD ego costume fixup: force costume 1 if pending
  lda.w SCUMM.egoFixupPending
  beq _play.noEgoFixup
  stz.w SCUMM.egoFixupPending
  ldx #1*16                         ; actor 1 struct offset
  sep #$20
  lda #1
  sta.w SCUMM.actors.costume,x
  ; Update render slot 0 to match
  ldx #0
  sta.w SCUMM.renderSlotCostume,x
  lda #$FF
  sta.w SCUMM.renderSlotLastPic,x
  lda #1
  sta.w SCUMM.renderSlotDirty,x
  rep #$20
  ; (removed forced cursor/userput re-enable — scripts own this state)
  nop
  nop
  nop
  nop
  nop
  nop
  nop
  nop
  nop
_play.noEgoFixup:
  .ACCU 16
  .INDEX 16

  ; Update actor movement + animation (after scripts have run)
  jsl scummvm.updateActors

  ; Execute pending verb if ego (actor 1) has arrived at target
  rep #$20
  lda.w SCUMM.pendingVerb
  beq _play.noPendingVerb
  sep #$20
  lda.w SCUMM.actors.2.moving         ; actor 1 still moving?
  rep #$20
  bne _play.noPendingVerb              ; yes — wait for arrival
  ; Actor 1 stopped → execute pending verb on pending object
  lda.w SCUMM.pendingVerb
  sta.w SCUMM.scratch                  ; scratch = verb ID
  lda.w SCUMM.pendingObject
  sta.w SCUMM.scratch2                 ; scratch2 = obj_id
  jsl scummvm.getVerbEntrypoint_impl   ; A = entry offset (0 = none)
  cmp #0
  beq _play.clearPending
  sta.w SCUMM.scratch                  ; scratch = entry offset
  lda.w SCUMM.pendingObject
  jsl scummvm.startObjectScript
_play.clearPending:
  .ACCU 16
  .INDEX 16
  stz.w SCUMM.pendingVerb
  stz.w SCUMM.pendingObject
_play.noPendingVerb:
  .ACCU 16
  .INDEX 16

  ; Update camera position (follow actor / pan)
  jsl scummvm.moveCamera
  ; Reset NMI tile staging for this frame (before any stageColumnForNmi calls)
  stz.w GLOBAL.room.nmiTileCount
  stz.w GLOBAL.room.nmiTileStageLen
  ; Sync tile scroll streamer with new camera position
  jsr room.syncScroll
  ; Refresh dirty tilemap columns from object patches
  jsr room.refreshObjectColumns

  ; Render visible actors to OAM buffer
  jsr _scummvm.renderActors

  ; Render verb bar if dirty + user input enabled (must run before DMA registration)
  rep #$31
  jsl scummvm.renderVerbBarChecked
  nop
  nop
  nop
  nop
  nop
  nop
  nop
  nop
_play.verbClean:
  .ACCU 16
  .INDEX 16
  ; Tick dialog timer
  rep #$20
  lda.w SCUMM.dialogActive
  beq _play.noDialog
  lda.w SCUMM.dialogTimer
  beq _play.clearDialog
  dec a
  sta.w SCUMM.dialogTimer
  bra _play.noDialog
_play.clearDialog:
  .ACCU 16
  .INDEX 16
  stz.w SCUMM.dialogActive
  jsl scummvm.clearDialogTilemap
_play.noDialog:
  .ACCU 16
  .INDEX 16
  ; Re-render sentence line if dirty
  lda.w SCUMM.sentenceDirty
  beq _play.noSentence
  jsl scummvm.renderSentenceLine
_play.noSentence:
  .ACCU 16
  .INDEX 16

  ; Register pending DMA transfers (CHR, cursor, verb, dialog) via superfree helper
  jsl scummvm.registerPendingDma

_play.done:
  .ACCU 16
  .INDEX 16
  rts


; buildCgramHdmaTable moved to superfree section at end of file


;-------------------------------------------------------------------
; _scummvm.processRoomChange -- load new room background
; Called when SCUMM.newRoom != SCUMM.currentRoom
;-------------------------------------------------------------------
_scummvm.processRoomChange:
  rep #$31

  ; Set up PPU for BG1 room display (once)
  lda.w SCUMM.bgInitDone
  beq +
  jmp _prc.bgReady
+
  .ACCU 16
  .INDEX 16

  sep #$20
  ; Mode 1, BG1 tilemap at $7000 (word $3800), 64 tiles wide
  lda.b #$39                        ; $38 = tilemap base $3800, +1 = 64-wide
  sta.w BG1TilemapVram
  ; BG2 tilemap at $9000 (word $4800), 32x32
  lda.b #$48
  sta.w BG2TilemapVram
  ; Tile data: BG1=$0000, BG2=$4000 (high nibble)
  lda.b #$40
  sta.w BGTilesVram12
  ; BG3 tilemap at $9800 (word $4C00), 32x32
  lda.b #$4C
  sta.w BG3TilemapVram
  ; BG3+BG4 tile data: BG3 at word $5000 (byte $A000)
  lda.b #$05
  sta.w BGTilesVram34
  ; Enable BG1 + BG2 + BG3 on main screen
  lda.w MainScreen
  ora.b #(T_BG1_ENABLE | T_BG2_ENABLE | T_BG3_ENABLE)
  sta.w MainScreen
  ; Set mode 1 with BG3 priority (bit 3)
  lda.b #(BGMODE_MODE_1 | BGMODE_PRIORITY_LAYER_3)
  sta.w ScreenMode
  rep #$20

  ; Set BG2 Y scroll
  lda #110
  sta.w yScrollBG2
  stz.w xScrollBG2
  ; BG3 scroll = 0,0 (text layer, no scrolling)
  stz.w xScrollBG3
  stz.w yScrollBG3

  ; Verb font tiles DMA: set NMI pending flag (same pattern as dialogFontNmiPending)
  sep #$20
  lda #1
  sta.w SCUMM.verbFontNmiPending

  ; Dialog font DMA now handled by NMI (SCUMM.dialogFontNmiPending set during init)

  ; Set up HDMA to disable BG1 below scanline 144 (verb area)
  sep #$20
  jsr core.dma_channel.allocate
  bcc +
    ; A = channel id (0-7), convert to register offset (channel * 16)
    sta.w SCUMM.hdmaChannel
    rep #$31
    and #$00FF
    asl a
    asl a
    asl a
    asl a
    tax
    ; DMAP: $00 = direct, 1-register, A-bus to B-bus
    sep #$20
    lda #$00
    sta.l DMAP0,x
    ; Target register: $2C (low byte of $212C = TM/MainScreen)
    lda #$2C
    sta.l DMADEST0,x
    ; Table address (24-bit pointer to VerbHdmaTable in ROM)
    lda.b #:VerbHdmaTable
    sta.l DMASRC0B,x
    rep #$20
    lda.w #VerbHdmaTable
    sta.l DMASRC0L,x
    ; Enable this channel in HDMA
    rep #$20
    lda.w SCUMM.hdmaChannel
    and #$00FF
    tax
    sep #$20
    lda.l dmaBitflagLut,x
    ora.w GLOBAL.HDMA.CHANNEL.ENABLE
    sta.w GLOBAL.HDMA.CHANNEL.ENABLE
+
  .ACCU 8
  .INDEX 16

  ; Set up HDMA to write verb palette colors to CGRAM at scanline 144
  sep #$20
  jsr core.dma_channel.allocate
  bcc +
    sta.w SCUMM.hdmaCgramChannel
    rep #$31
    and #$00FF
    asl a
    asl a
    asl a
    asl a
    tax
    ; DMAP: mode 3 = write pp,pp,pp+1,pp+1 (4 bytes per transfer)
    sep #$20
    lda #DMAP_2_REG_WRITE_TWICE_EACH
    sta.l DMAP0,x
    ; Target register: $21 (low byte of $2121=CGADD, $2122=CGDATA)
    lda #$21
    sta.l DMADEST0,x
    ; Table address (24-bit pointer to WRAM CGRAM HDMA table)
    lda.b #$7E
    sta.l DMASRC0B,x
    rep #$20
    lda.w #SCUMM.cgramHdmaTable
    sta.l DMASRC0L,x
    ; Enable this channel in HDMA
    rep #$20
    lda.w SCUMM.hdmaCgramChannel
    and #$00FF
    tax
    sep #$20
    lda.l dmaBitflagLut,x
    ora.w GLOBAL.HDMA.CHANNEL.ENABLE
    sta.w GLOBAL.HDMA.CHANNEL.ENABLE
+
  .ACCU 8
  .INDEX 16

  rep #$31
  lda #1
  sta.w SCUMM.bgInitDone

_prc.bgReady:
  .ACCU 16
  .INDEX 16

  ; Clear BG3 dialog tilemap on every room change so stale text
  ; (e.g. "CD tracks detected." from global script 176) doesn't persist.
  jsl scummvm.clearDialogTilemap
  ; Clear BG2 verb tilemap so stale verb text (from title screen or previous
  ; scene) doesn't show in scanlines 144-223 during intro cutscenes.
  jsl scummvm.clearVerbTilemap

  ; Resolve pseudo-room → real room via resourceMapper for loading
  lda.w SCUMM.newRoom
  and #$00FF
  tax
  sep #$20
  lda.w SCUMM.resourceMapper,x
  rep #$20
  and #$00FF

  ; Save resolved room number
  pha

  ; --- Fade out before room change ---
  ; Step brightness down by 3 per frame (~5 frames from $0F to $00).
  ; HDMA stays enabled so current room renders normally while dimming.
_prc.fadeOut:
  sep #$20
  .ACCU 8
  lda.w ScreenBrightness
  beq _prc.fadeOutDone
  sec
  sbc #3
  bcs +
    lda #0
+
  sta.w ScreenBrightness
  rep #$20
  .ACCU 16
  jsr core.nmi.waitFrame
  bra _prc.fadeOut
_prc.fadeOutDone:
  rep #$20
  .ACCU 16

  ; Disable HDMA and zero ScreenBrightness before room.load.
  ; HDMA runs during forced blanking and corrupts CGRAM entries that
  ; buildCgramHdmaTable needs to read. Zeroing GLOBAL.HDMA.CHANNEL.ENABLE
  ; prevents NMI from re-enabling HDMA. Zeroing ScreenBrightness keeps
  ; force blank active after room.load exits.
  sep #$20
  lda.w ScreenBrightness
  pha
  lda.w GLOBAL.HDMA.CHANNEL.ENABLE
  pha
  lda #0
  sta.w GLOBAL.HDMA.CHANNEL.ENABLE
  sta.l HDMAEN
  stz.w ScreenBrightness
  rep #$20

  ; --- Room 0 fast path: just set currentRoom=0 and return ---
  ; This allows scripts to "clear" the current room so a subsequent
  ; loadRoom(N) triggers a fresh room load even if N==old currentRoom.
  lda.w SCUMM.newRoom
  and #$00FF
  bne _prc.doRoomLoad

  ; Room 0: clear room state + BG1 VRAM tilemap via superfree thunk
  jsl scummvm.clearRoom0
  .db $EA, $EA, $EA, $EA, $EA
  .db $EA, $EA, $EA, $EA, $EA

  ; Restore stack: hdmaEnable[8], brightness[8], roomNum[16]
  sep #$20
  pla                                   ; pop saved hdmaEnable
  sta.w GLOBAL.HDMA.CHANNEL.ENABLE
  sta.l HDMAEN
  pla                                   ; pop saved brightness
  sta.w ScreenBrightness
  sta.l INIDSP
  rep #$20
  pla                                   ; pop saved roomNum
  jmp _prc.failed                       ; skip everything else

_prc.doRoomLoad:
  ; Restore room number and load via Phase 0 room loader
  lda 3,s
  jsr room.load
  bcs +
  ; room.load failed — virtual room (no MSU data): clear BG1 + proceed
  ; Stack: roomNum[16], brightness[8], hdmaEnable[8]
  sep #$20
  pla
  sta.w GLOBAL.HDMA.CHANNEL.ENABLE
  sta.l HDMAEN
  pla
  sta.w ScreenBrightness
  sta.l INIDSP
  rep #$20
  pla                                ; discard roomNum (do NOT cancel room change)
  jsl scummvm.clearRoom0             ; blank BG1 so virtual room has black background
  jmp _prc.failed
+
  .ACCU 16
  .INDEX 16

  ; Reload dialog font tiles into VRAM $A000 (word $5000)
  ; room.load overwrites the font DMA'd during init; force blank is still active
  jsl scummvm.loadDialogFont

  ; Build CGRAM HDMA table with room's palette 7 colors
  ; (HDMA disabled, force blank active — CGRAM reads are safe)
  jsl scummvm.buildCgramHdmaTable

  ; Restore HDMA enable + ScreenBrightness, exit force blank
  ; Stack: roomNum[16], brightness[8], hdmaEnable[8]
  ; NOTE: Only write GLOBAL.HDMA.CHANNEL.ENABLE — do NOT write HDMAEN ($420C)
  ; directly. Mid-frame HDMA enable causes the hardware to process the table
  ; at the wrong scanline position, corrupting CGRAM entries. The NMI handler
  ; copies GLOBAL.HDMA.CHANNEL.ENABLE → HDMAEN at the start of each VBlank,
  ; which is the only safe time to (re-)enable HDMA channels.
  sep #$20
  pla                                   ; pop saved hdmaEnable
  sta.w GLOBAL.HDMA.CHANNEL.ENABLE      ; NMI will enable at next VBlank
  pla                                   ; pop saved brightness (discard)
  ; ScreenBrightness stays 0 — screen dark until play loop deferred restore
  ; after ENCD + refreshObjectColumns. Prevents 1-frame flash of incorrect
  ; object states (e.g., rowboat visible before ENCD hides it).
  rep #$20
  pla

  ; --- Set VAR_NEW_ROOM before any scripts run ---
  ; ScummVM: VAR(VAR_NEW_ROOM) = room  (before runExitScript)
  ; VAR_NEW_ROOM = var 59 in SCUMM v5. Scripts read this to know destination.
  lda.w SCUMM.newRoom
  ldx #59*2
  sta.w SCUMM.globalVars,x

  ; --- Run exit scripts BEFORE tearing down old room ---
  ; ScummVM order: VAR_EXIT_SCRIPT (var[30]), EXCD, VAR_EXIT_SCRIPT2 (var[31])

  ; Run VAR_EXIT_SCRIPT (globalVar[30]) — script 7 in MI1
  ldx #30*2
  lda.w SCUMM.globalVars,x
  and #$00FF
  beq _prc.noExitScript
  jsr _scummvm.startScriptSlot
_prc.noExitScript:
  .ACCU 16
  .INDEX 16

  ; Run EXCD (room exit script) if present
  lda.w SCUMM.roomExcdLen
  beq _prc.noExcd
  jsr _scummvm.startExcdSlot
_prc.noExcd:
  .ACCU 16
  .INDEX 16

  ; Run VAR_EXIT_SCRIPT2 (globalVar[31]) — MI1 doesn't use, but guard anyway
  ldx #31*2
  lda.w SCUMM.globalVars,x
  and #$00FF
  beq _prc.noExitScript2
  jsr _scummvm.startScriptSlot
_prc.noExitScript2:
  .ACCU 16
  .INDEX 16

  ; Kill old room/local script slots
  jsr _scummvm.killRoomScripts

  ; Flush cache (global scripts reload on demand)
  stz.w SCUMM.cacheWritePtr

  ; Load room scripts using real room number (resolve again)
  lda.w SCUMM.newRoom
  and #$00FF
  tax
  sep #$20
  lda.w SCUMM.resourceMapper,x
  rep #$20
  and #$00FF
  jsr _scummvm.loadRoomScripts

  ; Reload surviving global scripts into fresh cache positions
  ; (must run even if room has no scripts — cache was flushed above)
  jsr _scummvm.reloadGlobalScripts

  ; Update current room + SCUMM variables BEFORE starting ENCD
  ; Store REQUESTED room (could be pseudo) in both currentRoom and VAR_ROOM
  ; ScummVM: _currentRoom = room, VAR(VAR_ROOM) = room (NOT resolved)
  lda.w SCUMM.newRoom
  sta.w SCUMM.currentRoom
  ldx #4*2                          ; VAR(4) = VAR_ROOM (SCUMM v5)
  sta.w SCUMM.globalVars,x
  ; VAR_NEW_ROOM (var 59) already set above before exit scripts

  ; Set camera to follow ego actor (ScummVM: startScene sets camera._follows)
  ldx #1*2                           ; VAR_EGO = globalVar[1]
  lda.w SCUMM.globalVars,x           ; ego actor number
  and #$00FF
  sta.w SCUMM.cameraFollows

  ; Update camera limits + snap to followed actor
  jsl scummvm.snapCameraToRoom

  ; --- Reload viewport at corrected camera position ---
  ; Use room.reloadViewport which properly handles NMI stop, force blank,
  ; HDMA disable, NMI staging flag clearing, tile cache reinit, and cleanup.
  jsr room.reloadViewport
  ; Sync scroll state so syncScroll doesn't see stale delta on next frame
  lda.w GLOBAL.room.cameraX
  sta.w GLOBAL.room.cameraXOld
  sta.w xScrollBG1

  ; --- Run entry scripts in ScummVM order ---
  ; 1. VAR_ENTRY_SCRIPT (globalVar[28]) — script 5 in MI1
  ldx #28*2
  lda.w SCUMM.globalVars,x
  and #$00FF
  beq _prc.noEntryScript
  jsr _scummvm.startScriptSlot
_prc.noEntryScript:
  .ACCU 16
  .INDEX 16

  ; 2. ENCD (room entry script)
  lda.w SCUMM.roomEncdLen
  beq _prc.noEncd
  jsr _scummvm.startEncdSlot
  ; Run ENCD synchronously so object states are correct before brightness
  ; restore. ScummVM does this in startScene(). Eliminates 5-frame blackout.
  jsr _scummvm.runEncdInline
_prc.noEncd:
  .ACCU 16
  .INDEX 16

  ; 3. VAR_ENTRY_SCRIPT2 (globalVar[29]) — script 6 in MI1 (palette cycling)
  ldx #29*2
  lda.w SCUMM.globalVars,x
  and #$00FF
  beq _prc.noEntryScript2
  jsr _scummvm.startScriptSlot
_prc.noEntryScript2:
  .ACCU 16
  .INDEX 16

  ; Load actor costume tiles + palette to VRAM/CGRAM
  jsr _scummvm.loadActorCostumes

  ; Assign walkboxes for all visible actors in this room
  jsr _scummvm.assignActorWalkboxes

  ; Clear any stale BG3 text from boot scripts before making screen visible
  jsl scummvm.clearDialogTilemap

  ; --- Fade in (no ENCD case) ---
_prc.fadeInNoEncd:
  sep #$20
  .ACCU 8
  lda.w ScreenBrightness
  cmp #$0F
  bcs _prc.fadeInNoEncdDone
  clc
  adc #3
  cmp #$0F
  bcc +
    lda #$0F
+
  sta.w ScreenBrightness
  rep #$20
  .ACCU 16
  jsr core.nmi.waitFrame
  bra _prc.fadeInNoEncd
_prc.fadeInNoEncdDone:
  rep #$20
  .ACCU 16

_prc.failed:
  .ACCU 16
  .INDEX 16
  rts

;-------------------------------------------------------------------
; _scummvm.assignActorWalkboxes — scan visible actors, assign walkbox
; Called after room load when BOXD data is fresh in $7F:5002.
; For each actor 1..SCUMM_WALK_ACTORS-1 in the current room with
; visible=1, calls findBox to determine which walkbox they're in.
;-------------------------------------------------------------------
_scummvm.assignActorWalkboxes:
  rep #$31
  .ACCU 16
  .INDEX 16

  ; Zero all actorWalkBox entries so actors without a valid box default to 0
  sep #$20
  .ACCU 8
  ldx #SCUMM_WALK_ACTORS - 1
- stz.w SCUMM.actorWalkBox,x
  dex
  bpl -
  rep #$20
  .ACCU 16

  lda #1                             ; start at actor 1 (skip actor 0 sentinel)
_aaw.loop:
  .ACCU 16
  .INDEX 16
  pha                                ; save actor index
  asl a
  asl a
  asl a
  asl a                              ; * 16 = struct offset
  tax
  sep #$20
  .ACCU 8
  lda.w SCUMM.actors.visible,x
  beq _aaw.skip
  lda.w SCUMM.actors.room,x
  cmp.w SCUMM.currentRoom
  bne _aaw.skip
  rep #$20
  .ACCU 16
  lda.w SCUMM.actors.x,x
  sta.b tmp
  lda.w SCUMM.actors.y,x
  sta.b tmp+2
  jsl scummvm.findBox_long            ; A = boxIdx or $FF (cross-bank)
  cmp #$00FF
  beq _aaw.skip16
  pha                                ; save boxIdx
  lda 3,s                            ; actor index from outer push
  and #$00FF
  tax
  pla
  sep #$20
  .ACCU 8
  sta.w SCUMM.actorWalkBox,x
_aaw.skip:
  .ACCU 8
  rep #$20
  .ACCU 16
_aaw.skip16:
  .ACCU 16
  pla                                ; recover actor index
  inc a
  cmp #SCUMM_WALK_ACTORS
  bcc _aaw.loop
  rts


;===================================================================
; METHOD: kill
;===================================================================
  METHOD kill
  rep #$31
  stz.w SCUMM.running
  rts


;===================================================================
; Script Loader -- MSU-1 -> $7F Cache
;===================================================================

;-------------------------------------------------------------------
; _scummvm.copyMsuToCache -- copy bytes from MSU-1 into $7F cache
; Input: A = byte count to copy
; Assumes: MSU-1 data port is already seeked to correct position
; Uses cacheWritePtr as destination offset (updated on return)
; Output: A = cachePtr where data was written, X = byte count
; Clobbers: SCUMM.scratch, SCUMM.scratch2
;-------------------------------------------------------------------
_scummvm.copyMsuToCache:
  sta.w SCUMM.scratch           ; scratch = byte count

  ; Save starting cacheWritePtr (= destination offset)
  lda.w SCUMM.cacheWritePtr
  sta.w SCUMM.scratch2          ; scratch2 = cachePtr result

  ; X = destination offset into $7F bank
  ldx.w SCUMM.cacheWritePtr

  ; Copy loop: read MSU_DATA byte-by-byte into $7F cache
  phy
  ldy.w SCUMM.scratch           ; Y = remaining count
  beq _copyMsu.done
_copyMsu.loop:
  .ACCU 16
  .INDEX 16
  sep #$20
  lda.l MSU_DATA
  sta.l SCUMM_CACHE_WRAM,x
  rep #$20
  inx
  dey
  bne _copyMsu.loop
_copyMsu.done:
  .ACCU 16
  .INDEX 16
  ply

  ; Update cacheWritePtr
  lda.w SCUMM.cacheWritePtr
  clc
  adc.w SCUMM.scratch
  sta.w SCUMM.cacheWritePtr

  ; Return: A = cachePtr, X = byte count
  lda.w SCUMM.scratch2
  ldx.w SCUMM.scratch
  rts


;-------------------------------------------------------------------
; _scummvm.loadGlobalScript -- load a global script into cache
; Input: A = script number (0-based)
; Output: A = cachePtr (offset within cache), X = size
;-------------------------------------------------------------------
_scummvm.loadGlobalScript:
  sta.w SCUMM.scratch

  ; Compute index entry MSU offset: globalIndexOffset + scriptNum * 8
  asl a
  asl a
  asl a
  clc
  adc.w SCUMM.globalIndexLo
  sta.w SCUMM.scratch2
  lda #0
  adc.w SCUMM.globalIndexHi
  tax
  lda.w SCUMM.scratch2
  jsr room.msu1Seek

  ; Read 8-byte index entry: offset32 + size32
  sep #$20
  lda.l MSU_DATA
  xba
  lda.l MSU_DATA
  xba
  rep #$20
  pha                        ;push offset_lo
  sep #$20
  lda.l MSU_DATA
  xba
  lda.l MSU_DATA
  xba
  rep #$20
  pha                        ;push offset_hi
  sep #$20
  lda.l MSU_DATA
  xba
  lda.l MSU_DATA
  xba
  rep #$20
  pha                        ;push size_lo
  sep #$20
  lda.l MSU_DATA
  lda.l MSU_DATA
  rep #$20

  ; Stack: [size_lo] [offset_hi] [offset_lo]
  ; Check for null entry (offset == 0)
  lda 5,s
  ora 3,s
  bne _loadGlobal.exists

  ; Script doesn't exist
  pla
  pla
  pla
  lda #0
  tax
  rts

_loadGlobal.exists:
  .ACCU 16
  .INDEX 16
  lda 1,s
  sta.w SCUMM.scratch

  ; Check cache space
  lda.w SCUMM.cacheWritePtr
  clc
  adc.w SCUMM.scratch
  cmp #SCUMM_CACHE_SIZE
  bcc _loadGlobal.cacheOk

  ; Cache full — try GC before giving up
  jsr _scummvm.cacheGC

  ; Retry space check after GC
  lda.w SCUMM.cacheWritePtr
  clc
  adc 1,s
  cmp #SCUMM_CACHE_SIZE
  bcc _loadGlobal.cacheOk

  ; Still full after GC — genuinely out of space
  TRIGGER_ERROR E_ScummVmCacheFull

_loadGlobal.cacheOk:
  .ACCU 16
  .INDEX 16
  ; Seek to script data
  lda 3,s
  tax                 ;X = offset_hi (high 16 bits)
  lda 5,s             ;A = offset_lo (low 16 bits)
  jsr room.msu1Seek

  ; Copy bytecode from MSU-1 into cache via helper
  lda 1,s
  jsr _scummvm.copyMsuToCache
  ; A = cachePtr, X = byte count

  ; Clean up stack (size_lo, offset_hi, offset_lo)
  sta.w SCUMM.scratch2
  pla
  pla
  pla

  lda.w SCUMM.scratch2
  ldx.w SCUMM.scratch
  rts


;-------------------------------------------------------------------
; _scummvm.startScriptSlot -- find dead slot, load script, init it
; Input: A = script number to start
;-------------------------------------------------------------------
_scummvm.startScriptSlot:
  sta.w SCUMM.scratch

  ; Stop any existing instance of this script (ScummVM: runScript calls stopScript first)
  and #$00FF
  pha                           ; save script number
  ldx #0
  ldy #0
_startScript.stopLoop:
  .ACCU 16
  .INDEX 16
  lda.w SCUMM.slots.status,x
  and #$00FF
  cmp #SCUMM_SLOT_DEAD
  beq _startScript.stopNext
  lda.w SCUMM.slots.number,x
  and #$00FF
  cmp 1,s                      ; compare with saved script number on stack
  bne _startScript.stopNext
  jsr scummvm.killSlotCleanup
  bra _startScript.stopDone     ; only one instance possible
_startScript.stopNext:
  .ACCU 16
  .INDEX 16
  txa
  clc
  adc #_sizeof_scummSlot
  tax
  iny
  cpy #SCUMM_MAX_SLOTS
  bcc _startScript.stopLoop
_startScript.stopDone:
  .ACCU 16
  .INDEX 16
  pla                           ; restore script number
  sta.w SCUMM.scratch

  ; Find a dead slot
  ldx #0
  ldy #0
_startScript.findSlot:
  .ACCU 16
  .INDEX 16
  lda.w SCUMM.slots.status,x
  and #$00FF
  cmp #SCUMM_SLOT_DEAD
  beq _startScript.foundSlot
  txa
  clc
  adc #_sizeof_scummSlot
  tax
  iny
  cpy #SCUMM_MAX_SLOTS
  bcc _startScript.findSlot

  ; No free slot
  clc
  rts

_startScript.foundSlot:
  .ACCU 16
  .INDEX 16
  phx                             ; save slot offset

  ; Check if LSCR (script number >= 200)
  lda.w SCUMM.scratch
  cmp #SCUMM_LSCR_BASE
  bcs _startScript.local

  ;--- Global script path ---
  lda.w SCUMM.scratch
  pha                           ;push script number

  ; Load the script into cache
  phy
  jsr _scummvm.loadGlobalScript
  ply

  ; Check if script was found
  cpx #0
  bne _startScript.globalInit

  pla                           ;discard saved script number
  plx
  clc
  rts

_startScript.globalInit:
  .ACCU 16
  .INDEX 16
  ; A = cachePtr, X = size (from loadGlobalScript)
  sta.w SCUMM.scratch2          ; scratch2 = cachePtr
  stx.w SCUMM.scratch           ; scratch = cacheLen
  pla                           ;A = saved script number
  plx                           ;X = slot offset
  ldy #SCUMM_WHERE_GLOBAL
  bra _startScript.initSlot

  ;--- Local (LSCR) script path ---
_startScript.local:
  .ACCU 16
  .INDEX 16
  ; SCUMM.scratch = script number (>= 200)
  lda.w SCUMM.scratch
  pha                           ;push script number (for initSlot)
  sec
  sbc #SCUMM_LSCR_BASE          ; table index (0-55)
  asl a
  asl a                          ; * 4 = byte offset into lscrEntry table
  tax
  lda.w SCUMM.roomLscrTable.cacheLen,x
  beq _startScript.localNone     ; cacheLen == 0 → not loaded, bail
  sta.w SCUMM.scratch            ; scratch = cacheLen
  lda.w SCUMM.roomLscrTable.cachePtr,x
  sta.w SCUMM.scratch2           ; scratch2 = cachePtr

  pla                            ;A = script number
  plx                            ;X = slot offset (from foundSlot push)
  ldy #SCUMM_WHERE_LOCAL
  bra _startScript.initSlot

_startScript.localNone:
  .ACCU 16
  .INDEX 16
  pla                            ; discard script number
  plx                            ; discard slot offset
  clc
  rts

  ;--- Common slot initialization ---
  ; A = script number, X = slot byte offset, Y = WHERE value
  ; SCUMM.scratch2 = cachePtr, SCUMM.scratch = cacheLen
_startScript.initSlot:
  .ACCU 16
  .INDEX 16
  sep #$20
  sta.w SCUMM.slots.number,x
  lda #SCUMM_SLOT_RUNNING
  sta.w SCUMM.slots.status,x
  tya
  sta.w SCUMM.slots.where,x
  lda #0
  sta.w SCUMM.slots.freezeCount,x
  sta.w SCUMM.slots.cutsceneOverride,x
  rep #$20

  lda.w SCUMM.scratch2
  sta.w SCUMM.slots.cachePtr,x
  lda.w SCUMM.scratch
  sta.w SCUMM.slots.cacheLen,x

  lda #0
  sta.w SCUMM.slots.pc,x
  sta.w SCUMM.slots.delay,x

  ; Zero local variables
  phx
  ldy #0
_startScript.zeroLocals:
  .ACCU 16
  .INDEX 16
  sta.w SCUMM.slots.localVars,x
  inx
  inx
  iny
  cpy #SCUMM_MAX_LOCALS
  bcc _startScript.zeroLocals
  plx

  sec                            ; carry = success
  rts


;-------------------------------------------------------------------
; _scummvm.killRoomScripts -- kill all slots with where != GLOBAL
; Preserves Y (SCUMM PC)
;-------------------------------------------------------------------
_scummvm.killRoomScripts:
  phx
  phy
  ldx #0
  ldy #0
_killRoom.loop:
  .ACCU 16
  .INDEX 16
  lda.w SCUMM.slots.status,x
  and #$00FF
  cmp #SCUMM_SLOT_DEAD
  beq _killRoom.next
  lda.w SCUMM.slots.where,x
  and #$00FF
  beq _killRoom.next             ; where == 0 (GLOBAL) → keep
  sep #$20
  lda #SCUMM_SLOT_DEAD
  sta.w SCUMM.slots.status,x
  rep #$20
_killRoom.next:
  .ACCU 16
  .INDEX 16
  txa
  clc
  adc #_sizeof_scummSlot
  tax
  iny
  cpy #SCUMM_MAX_SLOTS
  bcc _killRoom.loop
  ply
  plx
  rts


;-------------------------------------------------------------------
; _scummvm.reloadGlobalScripts -- reload all surviving GLOBAL slots
; into fresh cache positions after cache flush + room script load.
; Updates cachePtr/cacheLen for each slot; preserves slot.pc so
; the script resumes at the same bytecode offset.
;-------------------------------------------------------------------
_scummvm.reloadGlobalScripts:
  phx
  phy
  ldx #0
  ldy #0
_reloadGlobal.loop:
  .ACCU 16
  .INDEX 16
  ; Skip dead slots
  lda.w SCUMM.slots.status,x
  and #$00FF
  cmp #SCUMM_SLOT_DEAD
  beq _reloadGlobal.next
  ; Skip non-GLOBAL slots (where != 0)
  lda.w SCUMM.slots.where,x
  and #$00FF
  bne _reloadGlobal.next

  ; This is a live GLOBAL slot — reload its script
  phx
  phy
  lda.w SCUMM.slots.number,x
  and #$00FF
  jsr _scummvm.loadGlobalScript       ; A = new cachePtr, X = size
  sta.w SCUMM.scratch2                ; scratch2 = new cachePtr
  stx.w SCUMM.scratch                 ; scratch = new cacheLen
  ply
  plx

  ; Update slot cache pointers (X = slot byte offset)
  lda.w SCUMM.scratch                 ; was size 0? (script not found)
  beq _reloadGlobal.next              ; shouldn't happen, but guard
  lda.w SCUMM.scratch2
  sta.w SCUMM.slots.cachePtr,x
  lda.w SCUMM.scratch
  sta.w SCUMM.slots.cacheLen,x
  ; slot.pc is NOT reset — bytecode is identical, just at new offset

_reloadGlobal.next:
  .ACCU 16
  .INDEX 16
  txa
  clc
  adc #_sizeof_scummSlot
  tax
  iny
  cpy #SCUMM_MAX_SLOTS
  bcc _reloadGlobal.loop
  ply
  plx
  rts


;-------------------------------------------------------------------
; _scummvm.cacheGC -- garbage-collect script cache
; Flushes cache and reloads all live scripts from MSU-1.
; Prevents recursion via SCUMM.gcInProgress flag.
;-------------------------------------------------------------------
_scummvm.cacheGC:
  lda.w SCUMM.gcInProgress
  bne _cacheGC.done               ; prevent recursive GC
  lda #1
  sta.w SCUMM.gcInProgress
  phx
  phy

  ; Flush cache
  stz.w SCUMM.cacheWritePtr

  ; Reload room scripts (ENCD/EXCD/LSCR) from MSU-1
  lda.w SCUMM.currentRoom
  jsr _scummvm.loadRoomScripts

  ; Reload all live GLOBAL scripts
  jsr _scummvm.reloadGlobalScripts

  ; Update LOCAL/ROOM slots to use reloaded room script cache offsets
  jsr _scummvm.updateRoomSlotPtrs

  ply
  plx
  stz.w SCUMM.gcInProgress
_cacheGC.done:
  .ACCU 16
  .INDEX 16
  rts


;-------------------------------------------------------------------
; _scummvm.updateRoomSlotPtrs -- fix LOCAL/ROOM slot cache pointers
; Called after cacheGC reloads room scripts at new cache offsets.
; ROOM slots (ENCD) → use roomEncdPtr/Len
; LOCAL slots (LSCR 200-255) → use roomLscrTable entry
;-------------------------------------------------------------------
_scummvm.updateRoomSlotPtrs:
  phx
  phy
  ldx #0
  ldy #0
_updateRoomPtrs.loop:
  .ACCU 16
  .INDEX 16
  lda.w SCUMM.slots.status,x
  and #$00FF
  beq _updateRoomPtrs.next        ; skip dead slots

  lda.w SCUMM.slots.where,x
  and #$00FF
  cmp #SCUMM_WHERE_ROOM
  beq _updateRoomPtrs.room
  cmp #SCUMM_WHERE_LOCAL
  beq _updateRoomPtrs.local
  bra _updateRoomPtrs.next        ; GLOBAL already handled

_updateRoomPtrs.room:
  .ACCU 16
  .INDEX 16
  ; ROOM slot = ENCD script
  lda.w SCUMM.roomEncdPtr
  sta.w SCUMM.slots.cachePtr,x
  lda.w SCUMM.roomEncdLen
  sta.w SCUMM.slots.cacheLen,x
  bra _updateRoomPtrs.next

_updateRoomPtrs.local:
  .ACCU 16
  .INDEX 16
  ; LOCAL slot = LSCR (number 200-255)
  lda.w SCUMM.slots.number,x
  and #$00FF
  sec
  sbc #SCUMM_LSCR_BASE            ; index = number - 200
  asl a
  asl a                            ; * 4 = sizeof(lscrEntry)
  phx
  tax
  lda.w SCUMM.roomLscrTable.cachePtr,x
  sta.w SCUMM.scratch
  lda.w SCUMM.roomLscrTable.cacheLen,x
  sta.w SCUMM.scratch2
  plx
  lda.w SCUMM.scratch
  sta.w SCUMM.slots.cachePtr,x
  lda.w SCUMM.scratch2
  sta.w SCUMM.slots.cacheLen,x

_updateRoomPtrs.next:
  .ACCU 16
  .INDEX 16
  txa
  clc
  adc #_sizeof_scummSlot
  tax
  iny
  cpy #SCUMM_MAX_SLOTS
  bcc _updateRoomPtrs.loop
  ply
  plx
  rts


;-------------------------------------------------------------------
; _scummvm.loadRoomScripts -- load ENCD/EXCD/LSCR from MSU-1
; Input: A = room number
; Output: carry set = scripts loaded, carry clear = none
; Clobbers: A, X, scratch/scratch2
;-------------------------------------------------------------------
_scummvm.loadRoomScripts:
  rep #$31
  sta.w SCUMM.scratch

  ;--- Zero LSCR table + ENCD/EXCD pointers ---
  stz.w SCUMM.roomEncdPtr
  stz.w SCUMM.roomEncdLen
  stz.w SCUMM.roomExcdPtr
  stz.w SCUMM.roomExcdLen
  stz.w SCUMM.roomLscrCount
  phx
  ldx #0
  lda #0
_loadRoom.zeroTable:
  .ACCU 16
  .INDEX 16
  sta.w SCUMM.roomLscrTable,x
  inx
  inx
  cpx #_sizeof_lscrEntry * SCUMM_LSCR_MAX
  bcc _loadRoom.zeroTable
  plx

  ;--- Seek to room index entry: roomIndexOffset + room * 8 ---
  lda.w SCUMM.scratch
  asl a
  asl a
  asl a                          ; room * 8
  clc
  adc.w SCUMM.roomIndexLo
  sta.w SCUMM.scratch2
  lda #0
  adc.w SCUMM.roomIndexHi
  tax
  lda.w SCUMM.scratch2
  phy
  jsr room.msu1Seek
  ply

  ;--- Read 8-byte index entry: offset32 + size32 ---
  sep #$20
  lda.l MSU_DATA
  xba
  lda.l MSU_DATA
  xba
  rep #$20
  pha                            ;push offset_lo
  sep #$20
  lda.l MSU_DATA
  xba
  lda.l MSU_DATA
  xba
  rep #$20
  pha                            ;push offset_hi
  ; Read size32 (discard — we parse the block header instead)
  sep #$20
  lda.l MSU_DATA
  lda.l MSU_DATA
  lda.l MSU_DATA
  lda.l MSU_DATA
  rep #$20

  ; Stack: [offset_hi] [offset_lo]
  ; Check for null entry (offset == 0)
  lda 3,s
  ora 1,s
  bne _loadRoom.exists

  ; No scripts for this room
  pla
  pla
  clc
  rts

_loadRoom.exists:
  .ACCU 16
  .INDEX 16
  ;--- Seek to room script block ---
  lda 1,s                        ;offset_hi
  tax
  lda 3,s                        ;offset_lo
  phy
  jsr room.msu1Seek
  ply
  pla                            ;discard offset_hi
  pla                            ;discard offset_lo

  ;--- Read block header ---
  ; encd_size (LE16)
  sep #$20
  lda.l MSU_DATA
  xba
  lda.l MSU_DATA
  xba
  rep #$20
  sta.w SCUMM.roomEncdLen

  ; excd_size (LE16)
  sep #$20
  lda.l MSU_DATA
  xba
  lda.l MSU_DATA
  xba
  rep #$20
  sta.w SCUMM.roomExcdLen

  ; lscr_count (u8) + reserved (u8)
  sep #$20
  lda.l MSU_DATA
  rep #$20
  and #$00FF
  sta.w SCUMM.roomLscrCount
  sep #$20
  lda.l MSU_DATA                 ;drain reserved byte
  rep #$20

  ;--- Read per-LSCR header entries ---
  ; For each LSCR: number(u8) + size(LE16) → store in table
  lda.w SCUMM.roomLscrCount
  beq _loadRoom.copyEncd
  pha                            ;push remaining count
_loadRoom.lscrHdr:
  .ACCU 16
  .INDEX 16
  ; Read lscr_number (u8)
  sep #$20
  lda.l MSU_DATA
  rep #$20
  and #$00FF
  sec
  sbc #SCUMM_LSCR_BASE           ; table index (0-55)
  asl a
  asl a                           ; * 4 byte offset
  tax

  ; Read lscr_size (LE16)
  sep #$20
  lda.l MSU_DATA
  xba
  lda.l MSU_DATA
  xba
  rep #$20
  sta.w SCUMM.roomLscrTable.cacheLen,x

  lda 1,s
  dec a
  sta 1,s
  bne _loadRoom.lscrHdr
  pla                            ;discard count

_loadRoom.copyEncd:
  .ACCU 16
  .INDEX 16
  ;--- Copy ENCD from MSU → cache ---
  lda.w SCUMM.roomEncdLen
  beq _loadRoom.copyExcd
  lda.w SCUMM.cacheWritePtr
  sta.w SCUMM.roomEncdPtr
  lda.w SCUMM.roomEncdLen
  jsr _scummvm.copyMsuToCache

_loadRoom.copyExcd:
  .ACCU 16
  .INDEX 16
  ;--- Copy EXCD from MSU → cache ---
  lda.w SCUMM.roomExcdLen
  beq _loadRoom.copyLscr
  lda.w SCUMM.cacheWritePtr
  sta.w SCUMM.roomExcdPtr
  lda.w SCUMM.roomExcdLen
  jsr _scummvm.copyMsuToCache

_loadRoom.copyLscr:
  .ACCU 16
  .INDEX 16
  ;--- Copy LSCR bytecodes from MSU → cache ---
  ; LSCRs are stored in number-ascending order in MSU, matching table iteration
  phx
  ldx #0
_loadRoom.lscrLoop:
  .ACCU 16
  .INDEX 16
  cpx #_sizeof_lscrEntry * SCUMM_LSCR_MAX
  bcs _loadRoom.lscrDone
  lda.w SCUMM.roomLscrTable.cacheLen,x
  beq _loadRoom.lscrNext          ; no entry at this index
  ; Save table offset, copy this LSCR
  phx
  lda.w SCUMM.cacheWritePtr
  sta.w SCUMM.scratch2            ; save cachePtr for this entry
  lda.w SCUMM.roomLscrTable.cacheLen,x
  jsr _scummvm.copyMsuToCache
  ; Write cachePtr back into the table
  plx
  lda.w SCUMM.scratch2
  sta.w SCUMM.roomLscrTable.cachePtr,x
_loadRoom.lscrNext:
  .ACCU 16
  .INDEX 16
  inx
  inx
  inx
  inx                              ; next lscrEntry (4 bytes)
  bra _loadRoom.lscrLoop
_loadRoom.lscrDone:
  .ACCU 16
  .INDEX 16
  plx

  sec                              ; success
  rts


;-------------------------------------------------------------------
; _scummvm.startEncdSlot -- start ENCD script in a new slot
; Uses roomEncdPtr/roomEncdLen. Finds dead slot, inits as ROOM.
;-------------------------------------------------------------------
_scummvm.startEncdSlot:
  rep #$31

  ; Find a dead slot
  ldx #0
  ldy #0
_startEncd.findSlot:
  .ACCU 16
  .INDEX 16
  lda.w SCUMM.slots.status,x
  and #$00FF
  cmp #SCUMM_SLOT_DEAD
  beq _startEncd.found
  txa
  clc
  adc #_sizeof_scummSlot
  tax
  iny
  cpy #SCUMM_MAX_SLOTS
  bcc _startEncd.findSlot
  rts                              ; no free slot

_startEncd.found:
  .ACCU 16
  .INDEX 16
  ; X = slot byte offset
  ; Set up SCUMM.scratch2 = cachePtr, SCUMM.scratch = cacheLen
  lda.w SCUMM.roomEncdPtr
  sta.w SCUMM.scratch2
  lda.w SCUMM.roomEncdLen
  sta.w SCUMM.scratch
  ; A = 0 (ENCD script number), Y = WHERE_ROOM
  lda #0
  ldy #SCUMM_WHERE_ROOM
  jmp _startScript.initSlot


;-------------------------------------------------------------------
; _scummvm.runEncdInline -- run ENCD synchronously + restore brightness
; Called from processRoomChange after startEncdSlot.
; Finds the ENCD slot, executes it, applies tile patches, then
; restores screen brightness. Eliminates the 5-frame blackout.
;-------------------------------------------------------------------
_scummvm.runEncdInline:
  rep #$31
  ; Save current slot context
  lda.w SCUMM.currentSlot
  pha
  lda.w SCUMM.currentSlotPtr
  pha

  ; Find ENCD slot (WHERE_ROOM + status=RUNNING)
  ldx #0
  ldy #0
_rei.find:
  .ACCU 16
  .INDEX 16
  lda.w SCUMM.slots.status,x
  and #$00FF
  cmp #SCUMM_SLOT_RUNNING
  bne _rei.next
  lda.w SCUMM.slots.where,x
  and #$00FF
  cmp #SCUMM_WHERE_ROOM
  beq _rei.found
_rei.next:
  txa
  clc
  adc #_sizeof_scummSlot
  tax
  iny
  cpy #SCUMM_MAX_SLOTS
  bcc _rei.find
  bra _rei.done                   ; no ENCD slot found

_rei.found:
  .ACCU 16
  .INDEX 16
  ; Set current slot to ENCD slot
  sty.w SCUMM.currentSlot
  stx.w SCUMM.currentSlotPtr

  ; Execute ENCD (runs to first breakHere or completion)
  jsl scummvm.executeSlot

  ; ENCD set object states. Apply tile patches so VRAM matches.
  rep #$31
  stz.w GLOBAL.room.nmiTileCount
  stz.w GLOBAL.room.nmiTileStageLen
  jsr room.refreshObjectColumns

  ; --- Fade in after ENCD + tile patches ---
  ; Step brightness up by 3 per frame (~5 frames from $00 to $0F).
_rei.fadeIn:
  sep #$20
  .ACCU 8
  lda.w ScreenBrightness
  cmp #$0F
  bcs _rei.fadeInDone
  clc
  adc #3
  cmp #$0F
  bcc +
    lda #$0F
+
  sta.w ScreenBrightness
  rep #$20
  .ACCU 16
  jsr core.nmi.waitFrame
  bra _rei.fadeIn
_rei.fadeInDone:
  rep #$20
  .ACCU 16

_rei.done:
  .ACCU 16
  .INDEX 16
  ; Restore original slot context
  pla
  sta.w SCUMM.currentSlotPtr
  pla
  sta.w SCUMM.currentSlot
  rts


;-------------------------------------------------------------------
; _scummvm.startExcdSlot -- start EXCD (exit) script in a new slot
; Uses roomExcdPtr/roomExcdLen. Finds dead slot, inits as ROOM.
;-------------------------------------------------------------------
_scummvm.startExcdSlot:
  rep #$31

  ; Find a dead slot
  ldx #0
  ldy #0
_startExcd.findSlot:
  .ACCU 16
  .INDEX 16
  lda.w SCUMM.slots.status,x
  and #$00FF
  cmp #SCUMM_SLOT_DEAD
  beq _startExcd.found
  txa
  clc
  adc #_sizeof_scummSlot
  tax
  iny
  cpy #SCUMM_MAX_SLOTS
  bcc _startExcd.findSlot
  rts                              ; no free slot

_startExcd.found:
  .ACCU 16
  .INDEX 16
  ; X = slot byte offset
  ; Set up SCUMM.scratch2 = cachePtr, SCUMM.scratch = cacheLen
  lda.w SCUMM.roomExcdPtr
  sta.w SCUMM.scratch2
  lda.w SCUMM.roomExcdLen
  sta.w SCUMM.scratch
  ; A = 0 (EXCD script number), Y = WHERE_ROOM
  lda #0
  ldy #SCUMM_WHERE_ROOM
  jmp _startScript.initSlot


;===================================================================
; _scummvm.loadActorCostumes
; Multi-actor: scan actors in current room, assign render slots,
; DMA palettes + stand-frame CHR per slot. Bank 0 handles NMI/brightness;
; superfree impl does slot assignment + DMA.
;===================================================================
_scummvm.loadActorCostumes:
  rep #$31

  ; Save brightness BEFORE core.nmi.stop (which zeros ScreenBrightness)
  lda.w ScreenBrightness
  and #$00FF
  pha

  jsr core.nmi.stop
  sei
  sep #$20
  lda.b #INIDSP_FORCE_BLANK
  sta.l INIDSP
  rep #$20

  jsl scummvm.loadActorCostumes_impl

  ; Restore display + re-enable NMI/IRQ
  rep #$20
  pla
  sep #$20
  sta.l INIDSP
  sta.w ScreenBrightness
  cli
  rep #$20
  jsr core.nmi.start

  rts


;===================================================================
; _scummvm.renderActors
; Write OAM entries for visible actors in current room.
; MVP: only renders actor 1 (Guybrush) using hardcoded costume frame.
; Called at end of ScummVM.play(), after slot scheduler.
;
; Writes to GLOBAL.oamBuffer (Table 0) and GLOBAL.oamTable1 (Table 1).
; Sets GLOBAL.oamUploadFlag so the engine DMAs to OAM during VBlank.
;===================================================================

_scummvm.renderActors:
  jsl scummvm.renderActors_impl
  rts


;-------------------------------------------------------------------
; Long-callable wrappers for cross-bank calls from superfree opcodes
;-------------------------------------------------------------------
scummvm.startScriptSlot_long:
  jsr _scummvm.startScriptSlot
  rtl

scummvm.triggerBadOpcode:
  TRIGGER_ERROR E_ScummVmBadOpcode


  CLASS ScummVM

.ends

;===================================================================
; Walkbox Pathfinding — superfree section
;
; Contains: pointInBox, findBox, getNextBox, getBoxEdgeCrossing,
; buildWalkPath.  All routines use jsr/rts internally.
; Entry points are jsl/rtl wrappers.
;===================================================================
.bank 4 slot 0
.base BSL
.section "ScummVM walkbox pathfinding" free

;-------------------------------------------------------------------
; pointInBox — test if point (px, py) is inside walkbox boxIdx
;
; Walkbox = quadrilateral with vertices UL, UR, LR, LL.
; Uses scanline: check Y in range, then interpolate left/right edges.
;
; @param tmp+0 (word) px
; @param tmp+2 (word) py
; @param tmp+4 (word) boxIdx
; @return carry set if inside, clear if outside
;-------------------------------------------------------------------
scummvm.pointInBox:
  .ACCU 16
  .INDEX 16
  ;compute BOXD entry offset: $7F5002 + boxIdx * 20
  lda.b tmp+4
  ;multiply by 20: n*16 + n*4
  asl a               ;*2
  asl a               ;*4
  sta.b tmp+6
  asl a               ;*8
  asl a               ;*16
  clc
  adc.b tmp+6         ;*20
  clc
  adc #$5002          ;base = $7F5000 + 2 (skip count word)
  tax                 ;X = offset within $7F bank

  ;read Y coords: uly(+2), ury(+6), lry(+10), lly(+14)
  lda.l $7F0002,x     ;uly
  sta.b tmp+6
  lda.l $7F0006,x     ;ury
  sta.b tmp+8

  ;y_top = min(uly, ury)
  lda.b tmp+6
  cmp.b tmp+8
  bcc +               ;uly < ury, uly is min
    lda.b tmp+8
+
  ;check py >= y_top
  cmp.b tmp+2         ;y_top vs py
  beq +
  bcc +               ;y_top <= py OK
    clc               ;py < y_top, outside
    rts
+

  lda.l $7F000A,x     ;lry
  sta.b tmp+10
  lda.l $7F000E,x     ;lly
  sta.b tmp+12

  ;y_bot = max(lry, lly)
  lda.b tmp+10
  cmp.b tmp+12
  bcs +               ;lry >= lly, lry is max
    lda.b tmp+12
+
  ;check py <= y_bot
  sta.b tmp+14        ;y_bot
  lda.b tmp+2         ;py
  cmp.b tmp+14
  beq +
  bcc +               ;py < y_bot OK
    clc               ;py > y_bot, outside
    rts
+

  ;read X coords: ulx(+0), urx(+4), lrx(+8), llx(+12)
  ;interpolate left edge X at py: between UL and LL
  ;left_x = ulx + (py - uly) * (llx - ulx) / (lly - uly)
  ;if lly == uly, left_x = ulx (zero-height edge)

  ;left edge: UL -> LL
  lda.l $7F000E,x     ;lly
  sec
  sbc.b tmp+6         ;lly - uly = dy_left
  beq _pib.leftFlat
  sta.b tmp+16        ;dy_left (denominator)
  lda.b tmp+2         ;py
  sec
  sbc.b tmp+6         ;py - uly
  sta.b tmp+18        ;numerator_y

  lda.l $7F000C,x     ;llx
  sec
  sbc.l $7F0000,x     ;llx - ulx = dx_left
  jsr _pib.signedMul  ;(py-uly) * (llx-ulx) in tmp+20:22
  jsr _pib.signedDiv  ;result / dy_left in tmp+20
  lda.b tmp+20
  clc
  adc.l $7F0000,x     ;+ ulx
  bra _pib.leftDone

_pib.leftFlat:
  .ACCU 16
  .INDEX 16
  lda.l $7F0000,x     ;ulx (flat edge)

_pib.leftDone:
  .ACCU 16
  .INDEX 16
  sta.b tmp+20        ;left_x

  ;check px >= left_x
  lda.b tmp
  cmp.b tmp+20
  bcs +               ;px >= left_x OK (unsigned compare OK for positive coords)
    clc               ;px < left_x, outside
    rts
+

  ;right edge: UR -> LR
  lda.l $7F000A,x     ;lry
  sec
  sbc.b tmp+8         ;lry - ury = dy_right
  beq _pib.rightFlat
  sta.b tmp+16        ;dy_right (denominator)
  lda.b tmp+2         ;py
  sec
  sbc.b tmp+8         ;py - ury
  sta.b tmp+18        ;numerator_y

  lda.l $7F0008,x     ;lrx
  sec
  sbc.l $7F0004,x     ;lrx - urx = dx_right
  jsr _pib.signedMul  ;(py-ury) * (lrx-urx) in tmp+20:22
  jsr _pib.signedDiv  ;result / dy_right in tmp+20
  lda.b tmp+20
  clc
  adc.l $7F0004,x     ;+ urx
  bra _pib.rightDone

_pib.rightFlat:
  .ACCU 16
  .INDEX 16
  lda.l $7F0004,x     ;urx (flat edge)

_pib.rightDone:
  .ACCU 16
  .INDEX 16
  sta.b tmp+22        ;right_x

  ;check px <= right_x
  lda.b tmp           ;px
  cmp.b tmp+22
  beq +
  bcc +               ;px < right_x OK
    clc               ;px > right_x, outside
    rts
+
  sec                 ;inside!
  rts

;--- helper: signed multiply tmp+18 * A -> tmp+20:22 (32-bit result) ---
;uses shift-and-add, handles sign
_pib.signedMul:
  .ACCU 16
  .INDEX 16
  sta.b tmp+24        ;dx
  ;compute sign: XOR of signs of tmp+18 and tmp+24
  stz.b tmp+26        ;result sign (0=positive)
  lda.b tmp+18
  bpl +
    eor #$FFFF
    inc a
    sta.b tmp+18
    lda #1
    sta.b tmp+26
+
  lda.b tmp+24
  bpl +
    eor #$FFFF
    inc a
    sta.b tmp+24
    lda.b tmp+26
    eor #1
    sta.b tmp+26
+
  ;unsigned multiply: tmp+18 * tmp+24 -> tmp+20:22 (shift-right accumulate)
  stz.b tmp+20
  lda.b tmp+18
  beq _pib.mulZero
  lda #0               ;A = partial product high
  ldy #16
_pib.mulLoop:
  .ACCU 16
  .INDEX 16
  lsr.b tmp+24         ;shift multiplier right, bit to carry
  bcc +
    clc
    adc.b tmp+18       ;partial += multiplicand
+
  ror a                ;shift 32-bit result right through carry
  ror.b tmp+20
  dey
  bne _pib.mulLoop
  sta.b tmp+22         ;store high word
  bra _pib.mulDone
_pib.mulZero:
  .ACCU 16
  .INDEX 16
  stz.b tmp+22

_pib.mulDone:
  .ACCU 16
  .INDEX 16
  ;negate if sign flag set
  lda.b tmp+26
  beq +
    lda.b tmp+20
    eor #$FFFF
    clc
    adc #1
    sta.b tmp+20
    lda.b tmp+22
    eor #$FFFF
    adc #0
    sta.b tmp+22
+
  rts

;--- helper: signed divide tmp+20:22 / tmp+16 -> tmp+20 (16-bit quotient) ---
_pib.signedDiv:
  .ACCU 16
  .INDEX 16
  ;handle sign
  stz.b tmp+26
  lda.b tmp+22        ;high word of dividend (sign indicator)
  bpl +
    ;negate 32-bit dividend
    lda.b tmp+20
    eor #$FFFF
    clc
    adc #1
    sta.b tmp+20
    lda.b tmp+22
    eor #$FFFF
    adc #0
    sta.b tmp+22
    lda #1
    sta.b tmp+26
+
  lda.b tmp+16        ;divisor
  bpl +
    eor #$FFFF
    inc a
    sta.b tmp+16
    lda.b tmp+26
    eor #1
    sta.b tmp+26
+
  ;unsigned 32/16 divide: tmp+20:22 / tmp+16 -> tmp+20
  lda.b tmp+16
  beq _pib.divZero
  ldy #16
  lda #0              ;remainder
_pib.divLoop:
  .ACCU 16
  .INDEX 16
  asl.b tmp+20
  rol.b tmp+22
  rol a
  cmp.b tmp+16
  bcc +
    sbc.b tmp+16
    inc.b tmp+20       ;set low bit of quotient
+
  dey
  bne _pib.divLoop

  ;negate quotient if needed
  lda.b tmp+26
  beq +
    lda.b tmp+20
    eor #$FFFF
    inc a
    sta.b tmp+20
+
  rts

_pib.divZero:
  .ACCU 16
  .INDEX 16
  stz.b tmp+20
  rts


;-------------------------------------------------------------------
; findBox — find which walkbox contains point (px, py)
;
; @param tmp+0 (word) px
; @param tmp+2 (word) py
; @return A = boxIdx (0-based), or $FF if not in any box
;-------------------------------------------------------------------
scummvm.findBox:
  .ACCU 16
  .INDEX 16
  lda.w SCUMM.boxCount
  beq _findBox.none
  ;skip box 0 (sentinel), scan boxes 1..boxCount-1
  lda #1
_findBox.loop:
  .ACCU 16
  .INDEX 16
  cmp.w SCUMM.boxCount
  bcs _findBox.none
  pha

  ;--- skip invisible boxes (kBoxInvisible = $80) ---
  and #$00FF
  asl a               ;*2
  asl a               ;*4
  sta.b tmp+4
  asl a               ;*8
  asl a               ;*16
  clc
  adc.b tmp+4         ;*20
  clc
  adc #$5002 + $11    ;base + flags offset
  tax
  sep #$20
  .ACCU 8
  lda.l $7F0000,x
  rep #$20
  .ACCU 16
  and #SCUMM_BOX_INVISIBLE
  bne _findBox.skip    ;box is invisible — skip it

  lda 1,s              ;peek box index from stack
  sta.b tmp+4          ;boxIdx for pointInBox
  jsr scummvm.pointInBox
  pla
  bcs _findBox.found
  inc a
  bra _findBox.loop

_findBox.skip:
  .ACCU 16
  pla
  inc a
  bra _findBox.loop

_findBox.none:
  .ACCU 16
  .INDEX 16
  lda #$00FF
  rts

_findBox.found:
  .ACCU 16
  .INDEX 16
  ;A still has the box index
  rts


;-------------------------------------------------------------------
; getNextBox — routing matrix lookup
;
; @param A = from box
; @param Y = to box
; @return A = next hop box, or $FF if no path
;-------------------------------------------------------------------
scummvm.getNextBox:
  .ACCU 16
  .INDEX 16
  phx
  ;idx = from * boxCount + to
  pha                  ;save from
  ;multiply from * boxCount using repeated addition (boxCount usually < 64)
  ldx.w SCUMM.boxCount
  beq _gnb.noPath
  sta.b tmp+6          ;from
  ;from * boxCount: use shift-add for speed
  ;A = from, need A * boxCount
  phy                  ;save Y (to) — _gnb.mul trashes Y
  jsr _gnb.mul
  ;tmp+6 = from * boxCount
  pla                  ;recover to (was Y, now in A)
  clc
  adc.b tmp+6          ;from * boxCount + to = matrix index
  tax
  pla                  ;discard saved from

  ;read matrix[idx] from $7F bank at boxMatrixPtr + idx
  ;boxMatrixPtr is within $7F
  txa
  clc
  adc.w SCUMM.boxMatrixPtr
  tax
  sep #$20
  lda.l $7F0000,x
  rep #$20
  and #$00FF
  plx
  rts

_gnb.noPath:
  .ACCU 16
  .INDEX 16
  pla
  lda #$00FF
  plx
  rts

;multiply A * SCUMM.boxCount -> tmp+6 (clobbers A)
_gnb.mul:
  .ACCU 16
  .INDEX 16
  ;simple 16x16 multiply via shift-add (boxCount is small)
  sta.b tmp+8          ;multiplicand (from)
  stz.b tmp+6          ;result
  lda.w SCUMM.boxCount ;multiplier
  sta.b tmp+10
  ldy #16
- lsr.b tmp+10
  bcc +
    lda.b tmp+6
    clc
    adc.b tmp+8
    sta.b tmp+6
+
  asl.b tmp+8
  dey
  bne -
  rts


;-------------------------------------------------------------------
; getBoxEdgeCrossing — find crossing waypoint between two adjacent boxes
;
; Finds overlapping Y range of both boxes, picks midpoint Y,
; then averages the X coords of both boxes at that Y.
;
; @param A = boxA index
; @param Y = boxB index
; @return tmp+0 = crossX, tmp+2 = crossY
;-------------------------------------------------------------------
scummvm.getBoxEdgeCrossing:
  .ACCU 16
  .INDEX 16
  ;compute BOXD offset for boxA
  pha
  phy
  jsr _gbe.boxOffset   ;X = BOXD offset for box in A
  stx.b tmp+28

  ;read boxA Y range
  lda.l $7F0002,x      ;uly
  sta.b tmp+6
  lda.l $7F0006,x      ;ury
  cmp.b tmp+6
  bcs +
    sta.b tmp+6         ;y_topA = min(uly, ury)
+
  lda.l $7F000A,x      ;lry
  sta.b tmp+8
  lda.l $7F000E,x      ;lly
  cmp.b tmp+8
  bcc +
    sta.b tmp+8         ;y_botA = max(lry, lly)
+

  ;compute BOXD offset for boxB
  pla                   ;boxB (was pushed as Y)
  jsr _gbe.boxOffset
  stx.b tmp+30

  ;read boxB Y range
  lda.l $7F0002,x      ;uly
  sta.b tmp+10
  lda.l $7F0006,x      ;ury
  cmp.b tmp+10
  bcs +
    sta.b tmp+10        ;y_topB = min(uly, ury)
+
  lda.l $7F000A,x      ;lry
  sta.b tmp+12
  lda.l $7F000E,x      ;lly
  cmp.b tmp+12
  bcc +
    sta.b tmp+12        ;y_botB = max(lry, lly)
+

  pla                   ;discard saved boxA

  ;overlap Y range: y_top = max(y_topA, y_topB), y_bot = min(y_botA, y_botB)
  lda.b tmp+6           ;y_topA
  cmp.b tmp+10          ;y_topB
  bcs +
    lda.b tmp+10         ;max
+
  sta.b tmp+14           ;overlap y_top

  lda.b tmp+8           ;y_botA
  cmp.b tmp+12          ;y_botB
  bcc +
    lda.b tmp+12         ;min
+
  sta.b tmp+16           ;overlap y_bot

  ;crossY = (y_top + y_bot) / 2
  lda.b tmp+14
  clc
  adc.b tmp+16
  lsr a                  ;unsigned divide by 2 (coords are positive screen coords)
  sta.b tmp+2            ;crossY

  ;crossX = midpoint of left and right edges at crossY
  ;for simplicity, average the horizontal midpoints of both boxes at crossY
  ;use the overlapping X range at crossY
  ;simplified: average ulx+urx of both boxes (center X of each) then average
  ldx.b tmp+28           ;boxA BOXD offset
  lda.l $7F0000,x        ;boxA ulx
  clc
  adc.l $7F0004,x        ;boxA urx
  lsr a                  ;boxA center X
  sta.b tmp+18

  ldx.b tmp+30           ;boxB BOXD offset
  lda.l $7F0000,x        ;boxB ulx
  clc
  adc.l $7F0004,x        ;boxB urx
  lsr a                  ;boxB center X
  clc
  adc.b tmp+18
  lsr a                  ;average of both center X
  sta.b tmp             ;crossX

  rts

;helper: compute BOXD offset in $7F bank for box index in A
_gbe.boxOffset:
  .ACCU 16
  .INDEX 16
  ;offset = $5002 + A * 20
  asl a
  asl a
  sta.b tmp+18
  asl a
  asl a
  clc
  adc.b tmp+18          ;*20
  clc
  adc #$5002
  tax
  rts


;-------------------------------------------------------------------
; buildWalkPath — compute waypoints from current pos to target pos
;
; @param A = actor index (0-15)
; @param tmp+0 = startX
; @param tmp+2 = startY
; @param tmp+4 = targetX
; @param tmp+6 = targetY
; @return walk path stored in SCUMM.walkPath* arrays
;-------------------------------------------------------------------
scummvm.buildWalkPath:
  .ACCU 16
  .INDEX 16
  pha                   ;save actor index

  ;save target coords to WRAM before findBox trashes DP tmp
  lda.b tmp+4
  sta.w SCUMM.bwpTargetX
  lda.b tmp+6
  sta.w SCUMM.bwpTargetY

  ;find source box (tmp+0=startX, tmp+2=startY already set)
  jsr scummvm.findBox   ;trashes tmp+4-26; result in A
  sta.w SCUMM.bwpCurBox

  ;find dest box — copy target to tmp+0,+2 for findBox
  lda.w SCUMM.bwpTargetX
  sta.b tmp
  lda.w SCUMM.bwpTargetY
  sta.b tmp+2
  jsr scummvm.findBox   ;trashes tmp+4-26; result in A
  sta.w SCUMM.bwpDestBox

  ;compute walk path array base for this actor
  ;walkPathX base = SCUMM.walkPathX + actor * WALK_MAX_WAYPOINTS * 2
  pla                   ;actor index
  pha
  and #$000F
  asl a                 ;*2
  asl a                 ;*4
  asl a                 ;*8
  asl a                 ;*16 (= WALK_MAX_WAYPOINTS * 2)
  sta.w SCUMM.bwpArrayOfs

  ;pathLen = 0
  stz.w SCUMM.bwpPathLen

  ;if destBox == $FF, target is outside walkboxes — clamp to nearest box
  ;(must come BEFORE curBox check so target is always clamped)
  lda.w SCUMM.bwpDestBox
  cmp #$00FF
  bne +
  jsr _bwp.adjustToBox
  lda.w SCUMM.bwpDestBox
  cmp #$00FF
  bne +
  jmp _bwp.noPath          ;no walkboxes at all — give up
+
  ;if curBox == $FF, actor is outside walkboxes — go direct (target already clamped)
  lda.w SCUMM.bwpCurBox
  cmp #$00FF
  beq _bwp.directPath
  lda.w SCUMM.bwpCurBox
  cmp.w SCUMM.bwpDestBox
  beq _bwp.directPath

  ;routing loop: follow BOXM until we reach destBox
_bwp.routeLoop:
  .ACCU 16
  .INDEX 16
  lda.w SCUMM.bwpPathLen
  cmp #(WALK_MAX_WAYPOINTS - 1) * 2
  bcs _bwp.directPath   ;path full, just go direct

  ;nextBox = getNextBox(curBox, destBox)
  lda.w SCUMM.bwpCurBox
  ldy.w SCUMM.bwpDestBox
  jsr scummvm.getNextBox ;trashes tmp+6-10; result in A
  cmp #$00FF
  beq _bwp.directPath   ;no path
  cmp.w SCUMM.bwpCurBox
  beq _bwp.directPath   ;stuck (self-loop)
  pha                   ;save nextBox on stack

  ;get crossing waypoint between curBox and nextBox
  tay                   ;Y = nextBox
  lda.w SCUMM.bwpCurBox ;A = curBox
  jsr scummvm.getBoxEdgeCrossing ;trashes tmp+0-30; output: tmp+0=crossX, tmp+2=crossY

  ;store waypoint at walkPath[actor][pathLen]
  lda.w SCUMM.bwpPathLen
  clc
  adc.w SCUMM.bwpArrayOfs
  tax
  lda.b tmp             ;crossX
  sta.w SCUMM.walkPathX,x
  lda.b tmp+2           ;crossY
  sta.w SCUMM.walkPathY,x

  ;advance pathLen
  lda.w SCUMM.bwpPathLen
  clc
  adc #2                ;next waypoint slot (2 bytes per entry)
  sta.w SCUMM.bwpPathLen

  ;curBox = nextBox
  pla                   ;pop nextBox
  sta.w SCUMM.bwpCurBox
  cmp.w SCUMM.bwpDestBox
  bne _bwp.routeLoop

_bwp.directPath:
  .ACCU 16
  .INDEX 16
  ;final waypoint = target position
  lda.w SCUMM.bwpPathLen
  clc
  adc.w SCUMM.bwpArrayOfs
  tax
  lda.w SCUMM.bwpTargetX
  sta.w SCUMM.walkPathX,x
  lda.w SCUMM.bwpTargetY
  sta.w SCUMM.walkPathY,x

  ;pathLen = (bwpPathLen / 2) + 1  (convert byte offset to index, add final wp)
  lda.w SCUMM.bwpPathLen
  lsr a
  inc a
  sta.w SCUMM.bwpPathLen

  ;store pathLen and reset pathIdx for this actor
  pla                   ;actor index (pushed at entry)
  and #$000F
  tax
  lda.w SCUMM.bwpPathLen
  sep #$20
  sta.w SCUMM.walkPathLen,x
  lda #0
  sta.w SCUMM.walkPathIdx,x

  ;update actorWalkBox to curBox
  lda.w SCUMM.bwpCurBox
  sta.w SCUMM.actorWalkBox,x
  rep #$20

  rts

;-------------------------------------------------------------------
; _bwp.adjustToBox — clamp target to nearest walkbox AABB
; Called when findBox returns $FF for the target position.
; Scans all walkboxes, finds the one whose bounding rectangle is
; closest to (bwpTargetX, bwpTargetY), clamps target to that AABB,
; and updates bwpDestBox. Uses tmp+0..tmp+26 as scratch.
;-------------------------------------------------------------------
_bwp.adjustToBox:
  .ACCU 16
  .INDEX 16
  lda #$7FFF
  sta.b tmp+24                 ; bestDist = $7FFF
  lda #$00FF
  sta.b tmp+26                 ; bestBox = $FF
  lda #1                       ; start from box 1 (skip sentinel box 0)
_atb.loop:
  .ACCU 16
  .INDEX 16
  cmp.w SCUMM.boxCount
  bcc +
  jmp _atb.done
+
  pha                          ; save box index

  ; Compute BOXD entry offset: $7F5002 + box * 20
  asl a
  asl a
  sta.b tmp+6
  asl a
  asl a
  clc
  adc.b tmp+6                  ; box * 20
  clc
  adc #$5002
  tax                          ; X = BOXD offset in $7F bank

  ; Skip invisible boxes (flags byte at +17)
  sep #$20
  lda.l $7F0011,x              ; flags byte
  rep #$20
  .ACCU 16
  and #SCUMM_BOX_INVISIBLE
  beq +
  jmp _atb.next
+

  ; Compute AABB: minY = min(uly, ury), maxY = max(lly, lry)
  lda.l $7F0002,x              ; uly
  sta.b tmp+8
  lda.l $7F0006,x              ; ury
  cmp.b tmp+8
  bcs +
  sta.b tmp+8                  ; minY = min(uly, ury)
+
  lda.l $7F000A,x              ; lry
  sta.b tmp+10
  lda.l $7F000E,x              ; lly
  cmp.b tmp+10
  bcc +
  sta.b tmp+10                 ; maxY = max(lly, lry)
+

  ; Compute AABB: minX = min(ulx, llx), maxX = max(urx, lrx)
  lda.l $7F0000,x              ; ulx
  sta.b tmp+12
  lda.l $7F000C,x              ; llx
  cmp.b tmp+12
  bcs +
  sta.b tmp+12                 ; minX = min(ulx, llx)
+
  lda.l $7F0004,x              ; urx
  sta.b tmp+14
  lda.l $7F0008,x              ; lrx
  cmp.b tmp+14
  bcc +
  sta.b tmp+14                 ; maxX = max(urx, lrx)
+

  ; clampX = clamp(targetX, minX, maxX)
  lda.w SCUMM.bwpTargetX
  cmp.b tmp+12
  bcs +
  lda.b tmp+12                 ; clamp to minX
+
  cmp.b tmp+14
  bcc +
  lda.b tmp+14                 ; clamp to maxX
+
  sta.b tmp+16                 ; clampX

  ; clampY = clamp(targetY, minY, maxY)
  lda.w SCUMM.bwpTargetY
  cmp.b tmp+8
  bcs +
  lda.b tmp+8                  ; clamp to minY
+
  cmp.b tmp+10
  bcc +
  lda.b tmp+10                 ; clamp to maxY
+
  sta.b tmp+18                 ; clampY

  ; dist = |targetX - clampX| + |targetY - clampY|
  lda.w SCUMM.bwpTargetX
  sec
  sbc.b tmp+16
  bpl +
  eor #$FFFF
  inc a
+
  sta.b tmp+20                 ; |dx|
  lda.w SCUMM.bwpTargetY
  sec
  sbc.b tmp+18
  bpl +
  eor #$FFFF
  inc a
+
  clc
  adc.b tmp+20                 ; dist = |dx| + |dy|

  ; if dist < bestDist → update best
  cmp.b tmp+24
  bcc +                        ; dist < bestDist, update
  jmp _atb.next                ; dist >= bestDist, skip
+
  sta.b tmp+24                 ; bestDist = dist
  pla                          ; box index
  pha
  sta.b tmp+26                 ; bestBox = box
  lda.b tmp+16
  sta.b tmp+28                 ; bestX = clampX (NOT tmp+20 — that's used for |dx|)
  lda.b tmp+18
  sta.b tmp+30                 ; bestY = clampY

_atb.next:
  .ACCU 16
  .INDEX 16
  pla                          ; box index
  inc a
  jmp _atb.loop

_atb.done:
  .ACCU 16
  .INDEX 16
  ; Apply best result
  lda.b tmp+26
  cmp #$00FF
  beq _atb.rts                 ; no valid box found
  sta.w SCUMM.bwpDestBox
  lda.b tmp+28
  sta.w SCUMM.bwpTargetX
  lda.b tmp+30
  sta.w SCUMM.bwpTargetY
_atb.rts:
  .ACCU 16
  .INDEX 16
  rts

_bwp.noPath:
  .ACCU 16
  .INDEX 16
  ;target outside all walkboxes — refuse walk (pathLen=0)
  pla                   ;actor index (pushed at entry)
  and #$000F
  tax
  sep #$20
  stz.w SCUMM.walkPathLen,x
  stz.w SCUMM.walkPathIdx,x
  rep #$20
  rts


;-------------------------------------------------------------------
; jsl/rtl wrappers for external callers
;-------------------------------------------------------------------
scummvm.buildWalkPath_long:
  jsr scummvm.buildWalkPath
  rtl

scummvm.findBox_long:
  jsr scummvm.findBox
  rtl


;-------------------------------------------------------------------
; createBoxMatrix — rebuild routing matrix after box flags change
;
; Derives adjacency from the saved original routing matrix, then
; runs Floyd-Warshall to compute new transitive routes, skipping
; boxes with kBoxLocked ($40) or kBoxInvisible ($80) flags.
;
; Uses bwp scratch area — safe since this is never called during
; an active buildWalkPath.
;
; @clobbers A, X, Y, tmp+0..tmp+10, bwp scratch
;-------------------------------------------------------------------
scummvm.createBoxMatrix:
  .ACCU 16
  .INDEX 16
  lda.w SCUMM.boxCount
  cmp #2
  bcs +
    jmp _cbm.done                  ;0 or 1 boxes — nothing to rebuild
+
  sta.w SCUMM.bwpDestBox           ;N (cached)

  ;=== Phase 1: Initialize routing matrix from original adjacency ===
  ; For each (i,j):
  ;   if i == j: routing[i*N+j] = i
  ;   elif origMatrix[i*N+j] == j: routing[i*N+j] = j (adjacent)
  ;   else: routing[i*N+j] = $FF (no direct path)
  stz.w SCUMM.bwpTargetY          ;i = 0
  stz.w SCUMM.bwpArrayOfs         ;i*N = 0

_cbm.initI:
  .ACCU 16
  .INDEX 16
  lda.w SCUMM.bwpTargetY
  cmp.w SCUMM.bwpDestBox
  bcc +
  jmp _cbm.phase2
+
  stz.w SCUMM.bwpCurBox           ;j = 0

_cbm.initJ:
  .ACCU 16
  .INDEX 16
  lda.w SCUMM.bwpCurBox
  cmp.w SCUMM.bwpDestBox
  bcc +
  jmp _cbm.initNextI
+

  ;--- linear index = i*N + j ---
  lda.w SCUMM.bwpArrayOfs
  clc
  adc.w SCUMM.bwpCurBox
  sta.b tmp                        ;index

  ;--- check i == j (self-route) ---
  lda.w SCUMM.bwpTargetY
  cmp.w SCUMM.bwpCurBox
  bne _cbm.checkAdj

  ;self: routing[idx] = i
  lda.b tmp
  clc
  adc.w SCUMM.boxMatrixPtr
  tax
  lda.w SCUMM.bwpTargetY
  sep #$20
  .ACCU 8
  sta.l $7F0000,x
  rep #$20
  .ACCU 16
  bra _cbm.initNextJ

_cbm.checkAdj:
  .ACCU 16
  .INDEX 16
  ;--- read origMatrix[idx] ---
  lda.b tmp
  clc
  adc.w SCUMM.boxOrigMatrixPtr
  tax
  sep #$20
  .ACCU 8
  lda.l $7F0000,x
  rep #$20
  .ACCU 16
  and #$00FF

  ;--- adjacent if origVal == j ---
  cmp.w SCUMM.bwpCurBox
  bne _cbm.setFF

  ;adjacent: routing[idx] = j
  lda.b tmp
  clc
  adc.w SCUMM.boxMatrixPtr
  tax
  lda.w SCUMM.bwpCurBox
  sep #$20
  .ACCU 8
  sta.l $7F0000,x
  rep #$20
  .ACCU 16
  bra _cbm.initNextJ

_cbm.setFF:
  .ACCU 16
  .INDEX 16
  ;not adjacent: routing[idx] = $FF
  lda.b tmp
  clc
  adc.w SCUMM.boxMatrixPtr
  tax
  sep #$20
  .ACCU 8
  lda #$FF
  sta.l $7F0000,x
  rep #$20
  .ACCU 16

_cbm.initNextJ:
  .ACCU 16
  .INDEX 16
  inc.w SCUMM.bwpCurBox
  bra _cbm.initJ

_cbm.initNextI:
  .ACCU 16
  .INDEX 16
  inc.w SCUMM.bwpTargetY
  ;bwpArrayOfs += N
  lda.w SCUMM.bwpArrayOfs
  clc
  adc.w SCUMM.bwpDestBox
  sta.w SCUMM.bwpArrayOfs
  jmp _cbm.initI

  ;=== Phase 2: Floyd-Warshall ===
_cbm.phase2:
  .ACCU 16
  .INDEX 16
  stz.w SCUMM.bwpTargetX          ;k = 0

_cbm.fwK:
  .ACCU 16
  .INDEX 16
  lda.w SCUMM.bwpTargetX
  cmp.w SCUMM.bwpDestBox
  bcc +
  jmp _cbm.done
+

  ;check box k flags — skip if locked or invisible
  jsr _cbm.getBoxFlags
  and #(SCUMM_BOX_LOCKED | SCUMM_BOX_INVISIBLE)
  beq +
  jmp _cbm.fwNextK
+

  ;compute k*N → bwpPathLen
  lda.w SCUMM.bwpTargetX
  jsr _gnb.mul                     ;A * boxCount → tmp+6
  lda.b tmp+6
  sta.w SCUMM.bwpPathLen           ;k*N

  stz.w SCUMM.bwpTargetY          ;i = 0
  stz.w SCUMM.bwpArrayOfs         ;i*N = 0

_cbm.fwI:
  .ACCU 16
  .INDEX 16
  lda.w SCUMM.bwpTargetY
  cmp.w SCUMM.bwpDestBox
  bcc +
  jmp _cbm.fwNextK
+

  ;check box i flags
  jsr _cbm.getBoxFlags
  and #(SCUMM_BOX_LOCKED | SCUMM_BOX_INVISIBLE)
  beq +
  jmp _cbm.fwNextI
+

  ;--- preload routing[i*N+k] — if $FF, skip entire row ---
  lda.w SCUMM.bwpArrayOfs
  clc
  adc.w SCUMM.bwpTargetX          ;i*N + k
  clc
  adc.w SCUMM.boxMatrixPtr
  tax
  sep #$20
  .ACCU 8
  lda.l $7F0000,x
  rep #$20
  .ACCU 16
  and #$00FF
  cmp #$00FF
  bne +
  jmp _cbm.fwNextI
+
  sta.b tmp+2                      ;cache routing[i*N+k]

  stz.w SCUMM.bwpCurBox           ;j = 0

_cbm.fwJ:
  .ACCU 16
  .INDEX 16
  lda.w SCUMM.bwpCurBox
  cmp.w SCUMM.bwpDestBox
  bcc +
  jmp _cbm.fwNextI
+

  ;check box j flags
  jsr _cbm.getBoxFlags
  and #(SCUMM_BOX_LOCKED | SCUMM_BOX_INVISIBLE)
  bne _cbm.fwNextJ

  ;--- check routing[i*N+j] — skip if not $FF ---
  lda.w SCUMM.bwpArrayOfs
  clc
  adc.w SCUMM.bwpCurBox           ;i*N + j
  sta.b tmp                        ;save index for potential write
  clc
  adc.w SCUMM.boxMatrixPtr
  tax
  sep #$20
  .ACCU 8
  lda.l $7F0000,x
  rep #$20
  .ACCU 16
  and #$00FF
  cmp #$00FF
  bne _cbm.fwNextJ                 ;already has route

  ;--- check routing[k*N+j] — skip if $FF ---
  lda.w SCUMM.bwpPathLen
  clc
  adc.w SCUMM.bwpCurBox           ;k*N + j
  clc
  adc.w SCUMM.boxMatrixPtr
  tax
  sep #$20
  .ACCU 8
  lda.l $7F0000,x
  rep #$20
  .ACCU 16
  and #$00FF
  cmp #$00FF
  beq _cbm.fwNextJ                 ;no route from k to j

  ;--- set routing[i*N+j] = routing[i*N+k] ---
  lda.b tmp                        ;index = i*N + j
  clc
  adc.w SCUMM.boxMatrixPtr
  tax
  lda.b tmp+2                      ;routing[i*N+k]
  sep #$20
  .ACCU 8
  sta.l $7F0000,x
  rep #$20
  .ACCU 16

_cbm.fwNextJ:
  .ACCU 16
  .INDEX 16
  inc.w SCUMM.bwpCurBox
  bra _cbm.fwJ

_cbm.fwNextI:
  .ACCU 16
  .INDEX 16
  inc.w SCUMM.bwpTargetY
  lda.w SCUMM.bwpArrayOfs
  clc
  adc.w SCUMM.bwpDestBox
  sta.w SCUMM.bwpArrayOfs
  jmp _cbm.fwI

_cbm.fwNextK:
  .ACCU 16
  .INDEX 16
  inc.w SCUMM.bwpTargetX
  jmp _cbm.fwK

_cbm.done:
  .ACCU 16
  .INDEX 16
  rts


;-------------------------------------------------------------------
; _cbm.getBoxFlags — read flags byte for a walkbox
;
; @param A = box index
; @return A = flags byte (16-bit, high byte clear)
; @clobbers X, tmp+4
;-------------------------------------------------------------------
_cbm.getBoxFlags:
  .ACCU 16
  .INDEX 16
  and #$00FF
  asl a               ;*2
  asl a               ;*4
  sta.b tmp+4
  asl a               ;*8
  asl a               ;*16
  clc
  adc.b tmp+4         ;*20
  clc
  adc #$5002 + $11    ;BOXD base + flags offset
  tax
  sep #$20
  .ACCU 8
  lda.l $7F0000,x
  rep #$20
  .ACCU 16
  and #$00FF
  rts


;-------------------------------------------------------------------
; jsl/rtl wrapper for createBoxMatrix
;-------------------------------------------------------------------
scummvm.createBoxMatrix_long:
  jsr scummvm.createBoxMatrix
  rtl

.ends

;===================================================================
; SCUMM Opcode Dispatch — superfree section
;
; Contains: executeSlot, fetchLoop, dispatch table, all 106 opcode
; handlers, parameter helpers, math/audio helpers, updateActors.
; Moved from bank 0 to free ~3.5KB.
;===================================================================
.bank 4 slot 0
.base BSL
.section "ScummVM dispatch" free

;-------------------------------------------------------------------
; _scummvm.updateActors entry (jsl wrapper)
; Internal code uses rts to return to this wrapper, which does rtl.
;-------------------------------------------------------------------
scummvm.updateActors:
  jsr _scummvm.updateActors_body
  rtl

;===================================================================
; _scummvm.executeSlot -- run opcodes for current slot until yield
;
; Sets up [tmp] pointing into $7F cache and Y = slot.pc,
; then loops: fetch opcode, dispatch via jsr (table,x).
; Handler returns carry set to yield, carry clear to continue.
;===================================================================
scummvm.executeSlot:
  rep #$31

  ; Set up tmp (ZP) as 24-bit pointer to script bytecode
  ; tmp+0,1 = SCUMM_CACHE_BASE + slot.cachePtr (low 16)
  ; tmp+2   = $7F
  ldx.w SCUMM.currentSlotPtr
  lda.w SCUMM.slots.cachePtr,x
  clc
  adc #SCUMM_CACHE_BASE
  sta.b tmp
  sep #$20
  lda #$7F
  sta.b tmp+2
  rep #$20

  ; Y = slot.pc
  ldx.w SCUMM.currentSlotPtr
  ldy.w SCUMM.slots.pc,x

  ; Per-slot opcode execution limit — prevents tight loops from blocking the engine
  lda #500
  sta.w SCUMM.opcodeLimit

_scummvm.fetchLoop:
  .ACCU 16
  .INDEX 16
  ; --- override check: VAR_OVERRIDE + cutScenePtr[nest-1] → update OWNER slot's PC ---
  ; The owner slot (cutSceneScript[nest-1]) registered the override, not the current slot.
  ; We update its pc to the target and yield; it runs correctly next iteration.
  ldx #5*2
  lda.w SCUMM.globalVars,x           ; VAR_OVERRIDE (var 5)
  beq _floop.noOverride
  lda.w SCUMM.cutsceneNest
  beq _floop.noOverride
  dec a
  asl a
  tax
  lda.w SCUMM.cutScenePtr,x          ; override target PC offset for nest-1
  beq _floop.noOverride              ; no target stored
  pha                                 ; save target PC offset
  ; Get owner slot index from cutSceneScript[nest-1]
  lda.w SCUMM.cutsceneNest
  dec a
  tax
  sep #$20
  .ACCU 8
  lda.w SCUMM.cutSceneScript,x       ; owner slot index (0-24)
  rep #$20
  .ACCU 16
  and #$00FF                          ; zero-extend
  ; ownerSlotPtr = ownerSlotIndex × sizeof(scummSlot) = ownerSlotIndex × 64
  asl a
  asl a
  asl a
  asl a
  asl a
  asl a                               ; × 64
  tax                                 ; X = owner slot struct offset
  pla                                 ; A = override target PC offset
  sta.w SCUMM.slots.pc,x             ; redirect owner slot to override target
  ; If owner IS the current slot, update Y so fetchYield saves the correct PC
  cpx.w SCUMM.currentSlotPtr
  bne _floop.overNotSelf
  tay                                  ; Y = override target (live SCUMM PC)
_floop.overNotSelf:
  ; Decrement owner slot.cutsceneOverride (clamp at 0)
  lda.w SCUMM.slots.cutsceneOverride,x
  and #$00FF
  beq _floop.overOk
    dec a
    sep #$20
    .ACCU 8
    sta.w SCUMM.slots.cutsceneOverride,x
    rep #$20
    .ACCU 16
_floop.overOk:
  .ACCU 16
  .INDEX 16
  ; Unwind one cutscene level
  lda.w SCUMM.cutsceneNest
  dec a
  sta.w SCUMM.cutsceneNest
  asl a
  tax
  stz.w SCUMM.cutScenePtr,x
  stz.w SCUMM.cutSceneData,x
  lda.w SCUMM.cutsceneNest
  tax
  sep #$20
  .ACCU 8
  stz.w SCUMM.cutSceneScript,x
  rep #$20
  .ACCU 16
  ; Clear VAR_OVERRIDE, yield current slot — owner runs with new PC next frame
  ldx #5*2
  stz.w SCUMM.globalVars,x
  sec
  bra _scummvm.fetchYield             ; yield; owner slot gets new PC on next iteration
_floop.noOverride:
  ; Read opcode byte (16-bit load, mask to 8-bit)
  lda [tmp],y
  and #$00FF
  sta.w SCUMM.currentOpcode
  iny                       ; advance PC past opcode byte

  ; Dispatch: opcode * 2 for word-indexed table
  asl a
  tax
  jsr (_scummvm.dispatchTable,x)
  bcs _scummvm.fetchYield     ; handler said yield
  dec.w SCUMM.opcodeLimit
  bne _scummvm.fetchLoop      ; counter not zero, keep going
_scummvm.fetchYield:
  ; Save Y back to slot.pc
  ldx.w SCUMM.currentSlotPtr
  tya
  sta.w SCUMM.slots.pc,x
  rtl


;===================================================================
; Parameter Decoder Helpers
;
; These read parameters from the bytecode stream.
; Y = SCUMM PC (advanced as bytes are consumed).
; [tmp] = bytecode pointer.
;===================================================================

;-------------------------------------------------------------------
; _scummvm.fetchByte -- read next byte, zero-extend to 16-bit
; Returns: A = byte value, Y advanced by 1
;-------------------------------------------------------------------
_scummvm.fetchByte:
  .ACCU 16
  .INDEX 16
  lda [tmp],y
  and #$00FF
  iny
  rts

;-------------------------------------------------------------------
; _scummvm.fetchWord -- read next 16-bit LE word
; Returns: A = word value, Y advanced by 2
;-------------------------------------------------------------------
_scummvm.fetchWord:
  .ACCU 16
  .INDEX 16
  lda [tmp],y
  iny
  iny
  rts

;-------------------------------------------------------------------
; _scummvm.getActorPtr -- convert actor number to table offset
; Input: A = actor number (0-12)
; Output: X = byte offset into SCUMM.actors, carry set if valid
; Clobbers: A
; If actor >= SCUMM_MAX_ACTORS, returns X=0 and carry clear
;-------------------------------------------------------------------
_scummvm.getActorPtr:
  .ACCU 16
  .INDEX 16
  and #$00FF              ; mask to byte
  cmp #SCUMM_MAX_ACTORS
  bcc _getActorPtr.ok
    ldx #0                ; out of bounds → point to actor 0 (unused)
    clc                   ; carry clear = invalid
    rts
_getActorPtr.ok:
  .ACCU 16
  .INDEX 16
  asl a                   ; *2
  asl a                   ; *4
  asl a                   ; *8
  asl a                   ; *16 = _sizeof_scummActor
  tax
  sec                     ; carry set = valid
  rts

;-------------------------------------------------------------------
; _scummvm.getVarOrDirectWord -- decode p16 parameter
; Input: A = flag bitmask to test against currentOpcode
; If flag SET in opcode: FETCH_WORD -> readVariable (var reference)
; If flag CLEAR: FETCH_WORD (literal value)
; Returns: A = resolved value
;-------------------------------------------------------------------
_scummvm.getVarOrDirectWord:
  .ACCU 16
  .INDEX 16
  and.w SCUMM.currentOpcode   ; test flag bit against opcode
  beq +
    ; Flag set: word is a variable reference
    jsr _scummvm.fetchWord
    jmp _scummvm.readVariable
+
  ; Flag clear: word is literal
  jsr _scummvm.fetchWord
  rts

;-------------------------------------------------------------------
; _scummvm.getVarOrDirectByte -- decode p8 parameter
; Input: A = flag bitmask to test against currentOpcode
; If flag SET: FETCH_WORD -> readVariable (2-byte var ref)
; If flag CLEAR: FETCH_BYTE (1-byte literal)
; Returns: A = resolved value
;-------------------------------------------------------------------
_scummvm.getVarOrDirectByte:
  .ACCU 16
  .INDEX 16
  and.w SCUMM.currentOpcode   ; test flag bit against opcode
  beq +
    ; Flag set: read variable reference (2 bytes)
    jsr _scummvm.fetchWord
    jmp _scummvm.readVariable
+
  ; Flag clear: literal byte
  jsr _scummvm.fetchByte
  rts

;-------------------------------------------------------------------
; _scummvm.getResultPos -- read result variable position
; Reads 2-byte variable reference, stores in SCUMM.resultVar
;-------------------------------------------------------------------
_scummvm.getResultPos:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.fetchWord
  bit #$2000                   ; array-indexed variable? (SCUMM v5 bit 0x2000)
  beq _getResultPos.done
  pha                          ; push base var
  jsr _scummvm.fetchWord       ; read index word
  bit #$2000                   ; index is itself a variable ref?
  beq _getResultPos.literal
  and #$DFFF                   ; ~$2000: clear array bit
  jsr _scummvm.readVariable    ; resolve variable → A = index value
  bra _getResultPos.add
_getResultPos.literal:
  .ACCU 16
  and #$0FFF                   ; 12-bit literal index
_getResultPos.add:
  .ACCU 16
  clc
  adc 1,s                     ; add base from stack
  and #$DFFF                  ; clear bit 0x2000
  sta 1,s                     ; store result on stack
  pla                         ; pull final result
_getResultPos.done:
  .ACCU 16
  sta.w SCUMM.resultVar
  rts


;-------------------------------------------------------------------
; _scummvm.skipWordVararg -- skip getWordVararg argument list
; SCUMM v5 format: { sub_opcode_byte, word_arg } ... 0xFF
; Each non-0xFF byte is followed by a 2-byte word (var ref or literal).
; Preserves A on stack (caller typically has script number pushed).
;-------------------------------------------------------------------
_scummvm.skipWordVararg:
  .ACCU 16
  .INDEX 16
-
  jsr _scummvm.fetchByte
  cmp #$00FF
  beq +
  jsr _scummvm.fetchWord          ; skip the 2-byte argument
  bra -
+
  rts


;-------------------------------------------------------------------
; _scummvm.readWordVararg -- read getWordVararg args into SCUMM.argBuffer
; SCUMM v5 format: { sentinel_byte, word_arg } ... 0xFF
; Word encoding (literal vs var ref) controlled by main opcode bit 7.
; Output: SCUMM.argBuffer filled, SCUMM.argCount = byte count of args
; Clobbers: A, X. Preserves: Y (SCUMM PC).
;-------------------------------------------------------------------
_scummvm.readWordVararg:
  .ACCU 16
  .INDEX 16
  ldx #0                               ; X = byte offset into argBuffer
-
  jsr _scummvm.fetchByte
  cmp #$00FF
  beq +
  phx                                  ; save buffer offset (getVarOrDirectWord clobbers X)
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord      ; A = resolved arg value
  plx                                  ; restore buffer offset
  sta.w SCUMM.argBuffer,x
  inx
  inx
  cpx #50                              ; argBuffer bounds check (50 bytes / 25 words)
  bcc -                                ; keep going if X < 50
  ; overflow — drain remaining args without storing
_rwv.drain:
  jsr _scummvm.fetchByte
  cmp #$00FF
  beq +
  phx
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord      ; consume the word arg (result discarded)
  plx
  bra _rwv.drain
+
  stx.w SCUMM.argCount                 ; store byte count (clamped at 50)
  rts


;-------------------------------------------------------------------
; _scummvm.skipP8fromScratch -- skip one p8 param using SCUMM.scratch
; Input: A = flag bitmask to test against SCUMM.scratch
; If flag SET: fetchWord (2-byte var ref), else fetchByte (1-byte literal)
;-------------------------------------------------------------------
_scummvm.skipP8fromScratch:
  .ACCU 16
  .INDEX 16
  and.w SCUMM.scratch
  beq +
  jmp _scummvm.fetchWord
+
  jmp _scummvm.fetchByte


;-------------------------------------------------------------------
; _scummvm.skipNullString -- skip bytes until $00 terminator
;-------------------------------------------------------------------
_scummvm.skipNullString:
  .ACCU 16
  .INDEX 16
-
  jsr _scummvm.fetchByte
  cmp #0
  bne -
  rts


;-------------------------------------------------------------------
; _scummvm.skipPrintString -- skip SCUMM print string
; Bytes $01-$08 are embedded var references (2 extra bytes each).
; $00 terminates the string.
;-------------------------------------------------------------------
_scummvm.skipPrintString:
  .ACCU 16
  .INDEX 16
-
  jsr _scummvm.fetchByte
  cmp #0
  beq +                            ; $00 = end of string
  cmp #$00FF
  beq _sps.escape                  ; $FF = escape code
  cmp #$0009
  bcs -                            ; >= $09 = normal char, loop
  ; $01-$08: embedded var ref, consume 2 extra bytes
  jsr _scummvm.fetchWord
  bra -
+
  rts

_sps.escape:
  .ACCU 16
  .INDEX 16
  ; $FF escape: read sub-code byte
  jsr _scummvm.fetchByte
  ; sub-codes 1, 2, 3, 8: no extra args
  cmp #1
  beq -
  cmp #2
  beq -
  cmp #3
  beq -
  cmp #8
  beq -
  ; all other sub-codes (incl. $0A talkie): skip 2 arg bytes
  jsr _scummvm.fetchWord
  bra -


;===================================================================
; Variable System
;===================================================================

;-------------------------------------------------------------------
; _scummvm.readVariable -- read a SCUMM variable
; Input: A = raw variable encoding (16-bit)
; Returns: A = variable value (16-bit)
;-------------------------------------------------------------------
_scummvm.readVariable:
  .ACCU 16
  .INDEX 16
  bit #$2000                   ; array-indexed? (SCUMM v5 bit 0x2000)
  beq _readVar.dispatch
  pha                          ; push base var
  jsr _scummvm.fetchWord       ; read index word from script stream
  bit #$2000                   ; index is itself a variable ref?
  beq _readVar.idxLiteral
  and #$DFFF                   ; ~$2000: clear array bit
  jsr _scummvm.readVariable    ; resolve variable → A = index value
  bra _readVar.idxAdd
_readVar.idxLiteral:
  .ACCU 16
  and #$0FFF                   ; 12-bit literal index
_readVar.idxAdd:
  .ACCU 16
  clc
  adc 1,s                     ; add base from stack
  and #$DFFF                  ; clear bit 0x2000
  sta 1,s
  pla                         ; A = effective var number
_readVar.dispatch:
  .ACCU 16
  sta.w SCUMM.scratch
  and #SCUMM_VAR_TYPE_MASK
  beq _readVar.global

  cmp #SCUMM_VAR_LOCAL_MASK
  beq _readVar.local

  ; Bit variable ($8000-$BFFF)
  lda.w SCUMM.scratch
  and #SCUMM_VAR_INDEX_MASK
  pha
  lsr a
  lsr a
  lsr a
  tax
  pla
  and #$0007
  pha
  lda #1
  sta.w SCUMM.scratch2
  pla
  beq _readBit.test
_readBit.shift:
  .ACCU 16
  .INDEX 16
  asl.w SCUMM.scratch2
  dec a
  bne _readBit.shift
_readBit.test:
  .ACCU 16
  .INDEX 16
  lda.w SCUMM.bitVars,x
  and #$00FF
  and.w SCUMM.scratch2
  beq +
    lda #1
+
  rts

_readVar.global:
  .ACCU 16
  .INDEX 16
  lda.w SCUMM.scratch
  and #SCUMM_VAR_INDEX_MASK
  asl a
  tax
  lda.w SCUMM.globalVars,x
  rts

_readVar.local:
  .ACCU 16
  .INDEX 16
  lda.w SCUMM.scratch
  and #SCUMM_VAR_INDEX_MASK
  asl a
  clc
  adc.w SCUMM.currentSlotPtr
  tax
  lda.w SCUMM.slots.localVars,x
  rts


;-------------------------------------------------------------------
; _scummvm.writeVariable -- write a SCUMM variable
; Input: A = value to write
;        SCUMM.resultVar = target variable encoding
;-------------------------------------------------------------------
_scummvm.writeVariable:
  .ACCU 16
  .INDEX 16
  sta.w SCUMM.scratch2
  lda.w SCUMM.resultVar
  and #SCUMM_VAR_TYPE_MASK
  beq _writeVar.global

  cmp #SCUMM_VAR_LOCAL_MASK
  beq _writeVar.local

  ; Bit variable
  lda.w SCUMM.resultVar
  and #SCUMM_VAR_INDEX_MASK
  pha
  lsr a
  lsr a
  lsr a
  tax
  pla
  and #$0007
  pha
  lda #1
  sta.w SCUMM.scratch
  pla
  beq _writeBit.apply
_writeBit.shift:
  .ACCU 16
  .INDEX 16
  asl.w SCUMM.scratch
  dec a
  bne _writeBit.shift
_writeBit.apply:
  .ACCU 16
  .INDEX 16
  lda.w SCUMM.scratch2
  beq _writeBit.clear
    sep #$20
    lda.w SCUMM.bitVars,x
    ora.w SCUMM.scratch
    sta.w SCUMM.bitVars,x
    rep #$20
    rts
_writeBit.clear:
  .ACCU 16
  .INDEX 16
    sep #$20
    lda.w SCUMM.scratch
    eor #$FF
    and.w SCUMM.bitVars,x
    sta.w SCUMM.bitVars,x
    rep #$20
    rts

_writeVar.global:
  .ACCU 16
  .INDEX 16
  lda.w SCUMM.resultVar
  and #SCUMM_VAR_INDEX_MASK
  asl a
  tax
  lda.w SCUMM.scratch2
  sta.w SCUMM.globalVars,x
  rts

_writeVar.local:
  .ACCU 16
  .INDEX 16
  lda.w SCUMM.resultVar
  and #SCUMM_VAR_INDEX_MASK
  asl a
  clc
  adc.w SCUMM.currentSlotPtr
  tax
  lda.w SCUMM.scratch2
  sta.w SCUMM.slots.localVars,x
  rts


;-------------------------------------------------------------------
; _scummvm.findSlotByNumber -- find slot running script N
; Input: A = script number
; Output: X = slot byte offset, carry set if found
;-------------------------------------------------------------------
_scummvm.findSlotByNumber:
  .ACCU 16
  .INDEX 16
  sta.w SCUMM.scratch
  ldx #0
  ldy #0
_findSlot.loop:
  .ACCU 16
  .INDEX 16
  lda.w SCUMM.slots.status,x
  and #$00FF
  cmp #SCUMM_SLOT_DEAD
  beq _findSlot.next
  lda.w SCUMM.slots.number,x
  and #$00FF
  cmp.w SCUMM.scratch
  beq _findSlot.found
_findSlot.next:
  .ACCU 16
  .INDEX 16
  txa
  clc
  adc #_sizeof_scummSlot
  tax
  iny
  cpy #SCUMM_MAX_SLOTS
  bcc _findSlot.loop
  clc
  rts
_findSlot.found:
  .ACCU 16
  .INDEX 16
  sec
  rts


;===================================================================
; 256-Entry Dispatch Table
;===================================================================
.include "src/object/scummvm/scummvm_dispatch_table.inc"


;===================================================================
; Opcode Handlers
;
; Register conventions:
;   Y = SCUMM PC (bytecode offset). Advance as bytes consumed.
;   A = scratch. SCUMM.currentOpcode has original byte.
;   X = scratch (not preserved).
;   [tmp] = 24-bit bytecode ptr. Do NOT clobber.
;   Carry on return: clear=continue, set=yield.
;   All handlers assume rep #$31 (16-bit A/X/Y).
;===================================================================

;-------------------------------------------------------------------
; op_stub -- unimplemented opcode, fatal error
;-------------------------------------------------------------------
op_stub:
  .ACCU 16
  .INDEX 16
  ldx.w SCUMM.currentSlotPtr
  tya
  sta.w SCUMM.slots.pc,x
  jml scummvm.triggerBadOpcode


;-------------------------------------------------------------------
; Tier 1 -- Boot critical opcodes
;-------------------------------------------------------------------

; scummvm.killSlotCleanup — kill slot at X with cutscene nest cleanup
; Input: X = slot struct pointer
; ScummVM errors if a script with active cutsceneOverride is stopped.
; We gracefully unwind: decrement global cutsceneNest by the slot's count.
scummvm.killSlotCleanup:
  .ACCU 16
  .INDEX 16
  lda.w SCUMM.slots.cutsceneOverride,x
  and #$00FF
  beq _killSlot.noCutscene
    sta.w SCUMM.scratch            ; scratch = slot's cutscene count
    lda.w SCUMM.cutsceneNest
    sec
    sbc.w SCUMM.scratch            ; nest -= override count
    bpl _killSlot.noClamp
      lda #0                       ; clamp at 0
_killSlot.noClamp:
    sta.w SCUMM.cutsceneNest
    sep #$20
    stz.w SCUMM.slots.cutsceneOverride,x
    rep #$20
_killSlot.noCutscene:
  .ACCU 16
  .INDEX 16
  sep #$20
  lda #SCUMM_SLOT_DEAD
  sta.w SCUMM.slots.status,x
  rep #$20
  rts

; stopObjectCode ($00, $A0)
op_stopObjectCode:
  .ACCU 16
  .INDEX 16
  ldx.w SCUMM.currentSlotPtr
  jsr scummvm.killSlotCleanup
  sec
  rts

; breakHere ($80)
op_breakHere:
  .ACCU 16
  .INDEX 16
  sec
  rts

; jumpRelative ($18) -- 2-byte signed relative offset
op_jumpRelative:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.fetchWord    ; A = signed relative offset, Y past word
  sta.w SCUMM.scratch
  tya
  clc
  adc.w SCUMM.scratch       ; Y' = Y + offset
  tay
  clc
  rts

; move ($1A, $9A)
op_move:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.getResultPos
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord
  jsr _scummvm.writeVariable
  clc
  rts

; startScript ($0A, $2A, $4A, $6A, $8A, $AA, $CA, $EA)
op_startScript:
  .ACCU 16
  .INDEX 16
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte
  pha                             ; push script number
  jsr _scummvm.readWordVararg     ; read args into argBuffer/argCount
  pla                             ; A = script number
  phy                             ; save SCUMM PC
  jsl scummvm.startScriptSlot_long
  bcc _startScript.noArgs         ; slot creation failed
  ; X = new slot byte offset; copy args to slot's localVars
  ldy #0
_startScript.copyArgs:
  .ACCU 16
  .INDEX 16
  cpy.w SCUMM.argCount
  bcs _startScript.argsDone
  lda.w SCUMM.argBuffer,y
  sta.w SCUMM.slots.localVars,x
  inx
  inx
  iny
  iny
  bra _startScript.copyArgs
_startScript.argsDone:
_startScript.noArgs:
  .ACCU 16
  .INDEX 16
  ply                             ; restore SCUMM PC
  ; Refresh tmp — cacheGC during startScriptSlot may have moved our script
  ldx.w SCUMM.currentSlotPtr
  lda.w SCUMM.slots.cachePtr,x
  clc
  adc #SCUMM_CACHE_BASE
  sta.b tmp
  sep #$20
  lda #$7F
  sta.b tmp+2
  rep #$20
  clc
  rts

; stopScript ($62, $E2)
op_stopScript:
  .ACCU 16
  .INDEX 16
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte
  and #$00FF
  beq _stopScript.self
  phy                           ; save SCUMM PC (findSlotByNumber clobbers Y)
  jsr _scummvm.findSlotByNumber
  ply                           ; restore SCUMM PC
  bcc _stopScript.done
  jsr scummvm.killSlotCleanup
_stopScript.done:
  .ACCU 16
  .INDEX 16
  clc
  rts
_stopScript.self:
  .ACCU 16
  .INDEX 16
  ldx.w SCUMM.currentSlotPtr
  jsr scummvm.killSlotCleanup
  sec
  rts


;-------------------------------------------------------------------
; Tier 2 -- Conditional branches
;-------------------------------------------------------------------

; SCUMM v5 conditional convention (from ScummVM source):
;   jumpRelative(cond): if (!cond) scriptPointer += offset
;   Condition name = what makes cond TRUE (skip jump). Jump taken when cond FALSE.
; Jump targets are signed relative offsets from the byte AFTER the target word.

; Helper: apply relative jump from SCUMM.scratch2 to Y
_scummvm.takeRelJump:
  .ACCU 16
  .INDEX 16
  tya
  clc
  adc.w SCUMM.scratch2
  tay
  rts

; isEqual ($48, $C8) -- getVar + p16[7] + jump
; ScummVM: jumpRelative(b == a) → jump when NOT equal (cond FALSE)
op_isEqual:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.getResultPos
  lda.w SCUMM.resultVar
  jsr _scummvm.readVariable
  pha
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord
  sta.w SCUMM.scratch
  jsr _scummvm.fetchWord
  sta.w SCUMM.scratch2
  pla
  cmp.w SCUMM.scratch
  beq +                          ; equal → cond TRUE → skip jump
    jsr _scummvm.takeRelJump     ; not equal → cond FALSE → take jump
+
  clc
  rts

; isNotEqual ($08, $88) -- getVar + p16[7] + jump
; ScummVM: jumpRelative(b != a) → jump when equal (cond FALSE)
op_isNotEqual:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.getResultPos
  lda.w SCUMM.resultVar
  jsr _scummvm.readVariable
  pha
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord
  sta.w SCUMM.scratch
  jsr _scummvm.fetchWord
  sta.w SCUMM.scratch2
  pla
  cmp.w SCUMM.scratch
  bne +                          ; not equal → cond TRUE → skip jump
    jsr _scummvm.takeRelJump     ; equal → cond FALSE → take jump
+
  clc
  rts

; notEqualZero ($A8) -- getVar + jump
; ScummVM: jumpRelative(a != 0) → jump when zero (cond FALSE)
op_notEqualZero:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.fetchWord
  jsr _scummvm.readVariable
  pha
  jsr _scummvm.fetchWord
  sta.w SCUMM.scratch2
  pla
  cmp #0
  bne +                          ; not zero → cond TRUE → skip jump
    jsr _scummvm.takeRelJump     ; zero → cond FALSE → take jump
+
  clc
  rts

; equalZero ($28) -- getVar + jump
; ScummVM: jumpRelative(a == 0) → jump when NOT zero (cond FALSE)
op_equalZero:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.fetchWord
  jsr _scummvm.readVariable
  pha
  jsr _scummvm.fetchWord
  sta.w SCUMM.scratch2
  pla
  cmp #0
  beq +                          ; zero → cond TRUE → skip jump
    jsr _scummvm.takeRelJump     ; not zero → cond FALSE → take jump
+
  clc
  rts

; isGreater ($78, $F8) -- getVar + p16[7] + jump
; ScummVM: jumpRelative(b > a) → jump when b <= a (cond FALSE)
op_isGreater:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.getResultPos
  lda.w SCUMM.resultVar
  jsr _scummvm.readVariable
  pha
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord
  sta.w SCUMM.scratch
  jsr _scummvm.fetchWord
  sta.w SCUMM.scratch2
  pla
  cmp.w SCUMM.scratch
  bcc +                          ; A < scratch → b > a → cond TRUE → skip
    jsr _scummvm.takeRelJump     ; A >= scratch → b <= a → cond FALSE → jump
+
  clc
  rts

; isLess ($44, $C4) -- getVar + p16[7] + jump
; ScummVM: jumpRelative(b < a) → jump when b >= a (cond FALSE)
op_isLess:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.getResultPos
  lda.w SCUMM.resultVar
  jsr _scummvm.readVariable
  pha
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord
  sta.w SCUMM.scratch
  jsr _scummvm.fetchWord
  sta.w SCUMM.scratch2
  pla
  cmp.w SCUMM.scratch
  beq _isL.doJump                ; A == scratch → b == a → b >= a → jump
  bcs +                          ; A > scratch → b < a → cond TRUE → skip
_isL.doJump:
  .ACCU 16
  .INDEX 16
    jsr _scummvm.takeRelJump     ; A <= scratch → b >= a → cond FALSE → jump
+
  clc
  rts

; isLessEqual ($38, $B8) -- getVar + p16[7] + jump
; ScummVM: jumpRelative(b <= a) → jump when b > a (cond FALSE)
op_isLessEqual:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.getResultPos
  lda.w SCUMM.resultVar
  jsr _scummvm.readVariable
  pha
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord
  sta.w SCUMM.scratch
  jsr _scummvm.fetchWord
  sta.w SCUMM.scratch2
  pla
  cmp.w SCUMM.scratch
  bcs +                          ; A >= scratch → b <= a → cond TRUE → skip
    jsr _scummvm.takeRelJump     ; A < scratch → b > a → cond FALSE → jump
+
  clc
  rts

; isGreaterEqual ($04, $84) -- getVar + p16[7] + jump
; ScummVM: jumpRelative(b >= a) → jump when b < a (cond FALSE)
op_isGreaterEqual:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.getResultPos
  lda.w SCUMM.resultVar
  jsr _scummvm.readVariable
  pha
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord
  sta.w SCUMM.scratch
  jsr _scummvm.fetchWord
  sta.w SCUMM.scratch2
  pla
  cmp.w SCUMM.scratch
  beq +                          ; A == scratch → b >= a → cond TRUE → skip
  bcc +                          ; A < scratch → b > a → b >= a → cond TRUE → skip
    jsr _scummvm.takeRelJump     ; A > scratch → b < a → cond FALSE → jump
+
  clc
  rts


;-------------------------------------------------------------------
; Tier 3 -- Arithmetic opcodes
;-------------------------------------------------------------------

; add ($5A, $DA)
op_add:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.getResultPos
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord
  pha
  lda.w SCUMM.resultVar
  jsr _scummvm.readVariable
  clc
  adc 1,s
  sta.w SCUMM.scratch
  pla
  lda.w SCUMM.scratch
  jsr _scummvm.writeVariable
  clc
  rts

; subtract ($3A, $BA)
op_subtract:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.getResultPos
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord
  pha
  lda.w SCUMM.resultVar
  jsr _scummvm.readVariable
  sec
  sbc 1,s
  sta.w SCUMM.scratch
  pla
  lda.w SCUMM.scratch
  jsr _scummvm.writeVariable
  clc
  rts

; increment ($46)
op_increment:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.getResultPos
  lda.w SCUMM.resultVar
  jsr _scummvm.readVariable
  inc a
  jsr _scummvm.writeVariable
  clc
  rts

; decrement ($C6)
op_decrement:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.getResultPos
  lda.w SCUMM.resultVar
  jsr _scummvm.readVariable
  dec a
  jsr _scummvm.writeVariable
  clc
  rts


;-------------------------------------------------------------------
; Misc opcodes for boot path
;-------------------------------------------------------------------

; setVarRange ($26, $A6)
op_setVarRange:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.getResultPos
  jsr _scummvm.fetchByte
  sta.w SCUMM.scratch

  lda.w SCUMM.currentOpcode
  and #SCUMM_FLAG_BIT7
  bne _setVarRange.wordMode

_setVarRange.byteMode:
  .ACCU 16
  .INDEX 16
  lda.w SCUMM.scratch
  beq _setVarRange.done
_setVarRange.byteLoop:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.fetchByte
  jsr _scummvm.writeVariable
  lda.w SCUMM.resultVar
  inc a
  sta.w SCUMM.resultVar
  lda.w SCUMM.scratch
  dec a
  sta.w SCUMM.scratch
  bne _setVarRange.byteLoop
  bra _setVarRange.done

_setVarRange.wordMode:
  .ACCU 16
  .INDEX 16
  lda.w SCUMM.scratch
  beq _setVarRange.done
_setVarRange.wordLoop:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.fetchWord
  jsr _scummvm.writeVariable
  lda.w SCUMM.resultVar
  inc a
  sta.w SCUMM.resultVar
  lda.w SCUMM.scratch
  dec a
  sta.w SCUMM.scratch
  bne _setVarRange.wordLoop

_setVarRange.done:
  .ACCU 16
  .INDEX 16
  clc
  rts

; delay ($2E) -- 3-byte LE delay value
op_delay:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.fetchByte
  sta.w SCUMM.scratch
  jsr _scummvm.fetchByte
  xba
  ora.w SCUMM.scratch
  ldx.w SCUMM.currentSlotPtr
  sta.w SCUMM.slots.delay,x
  jsr _scummvm.fetchByte
  sec
  rts

; delayVariable ($2B)
op_delayVariable:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.fetchWord
  jsr _scummvm.readVariable
  ldx.w SCUMM.currentSlotPtr
  sta.w SCUMM.slots.delay,x
  sec
  rts

; dummy ($A7)
op_dummy:
  .ACCU 16
  .INDEX 16
  clc
  rts

; cutscene ($40) -- read arg list, increment nest level
op_cutscene:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.skipWordVararg
  lda.w SCUMM.cutsceneNest
  cmp #5                              ; max 5 levels (cutScenePtr/Script/Data arrays are 5 entries)
  bcs _op_cutscene.nestFull           ; at cap — skip to avoid WRAM overflow
  inc a
  sta.w SCUMM.cutsceneNest

  ; Zero the cutscene stack at the NEW nesting level (not old).
  ; This preserves any override target pre-registered at the old level
  ; (MI1 intro calls override before cutscene in separate scripts).
  pha                                 ; save nest (already incremented)
  asl a
  tax
  stz.w SCUMM.cutScenePtr,x
  stz.w SCUMM.cutSceneData,x
  pla
  tax
  sep #$20
  .ACCU 8
  stz.w SCUMM.cutSceneScript,x
  rep #$20
  .ACCU 16

  ldx.w SCUMM.currentSlotPtr
  sep #$20
  lda.w SCUMM.slots.cutsceneOverride,x
  inc a
  sta.w SCUMM.slots.cutsceneOverride,x
  rep #$20
  .ACCU 16

  ; --- START abort at cutscene open ---
  ; _play() runs too infrequently to catch cutscenes that open+close within
  ; one iteration. Check here so the override fires immediately.
  lda.w inputDevice.press
  bit.w #JOY_BUTTON_START
  beq _op_cutscene.noAbort
  lda.w SCUMM.cutsceneNest
  beq _op_cutscene.noAbort
  dec a
  asl a
  tax
  lda.w SCUMM.cutScenePtr,x          ; target at nest-1
  beq _op_cutscene.noAbort
  ldx #5*2
  lda #1
  sta.w SCUMM.globalVars,x           ; VAR_OVERRIDE = 1
_op_cutscene.noAbort:
  clc
  rts

_op_cutscene.nestFull:
  clc
  rts

; endCutscene ($C0)
op_endCutscene:
  .ACCU 16
  .INDEX 16

  ; Clear VAR_OVERRIDE (var 5) = 0
  ldx #5*2
  stz.w SCUMM.globalVars,x

  ; Decrement cutsceneNest, clamp at 0
  lda.w SCUMM.cutsceneNest
  beq _ec.nestOk
  dec a
  sta.w SCUMM.cutsceneNest
_ec.nestOk:
  .ACCU 16
  .INDEX 16

  ; Decrement slot cutsceneOverride, clamp at 0
  ldx.w SCUMM.currentSlotPtr
  lda.w SCUMM.slots.cutsceneOverride,x
  and #$00FF
  beq _ec.overOk
  dec a
  sep #$20
  .ACCU 8
  sta.w SCUMM.slots.cutsceneOverride,x
  rep #$20
_ec.overOk:
  .ACCU 16
  .INDEX 16

  ; --- START abort: directly redirect owner slot before target is cleared ---
  ; _play() runs too infrequently and fetchLoop can't fire when csNest=0.
  ; Directly set the owner slot's PC to the override target here.
  lda.w inputDevice.press
  bit.w #JOY_BUTTON_START
  beq _ec.noAbort
  lda.w SCUMM.cutsceneNest             ; already decremented = old level index
  pha                                   ; save level index
  asl a
  tax
  lda.w SCUMM.cutScenePtr,x            ; target at old level
  beq _ec.noAbortPop
  pha                                   ; save target PC
  ; Find owner slot: cutSceneScript[level] (byte array, indexed by level)
  lda 3,s                              ; get level index from stack
  and #$00FF
  tax
  sep #$20
  lda.w SCUMM.cutSceneScript,x         ; A = owner slot number (8-bit)
  rep #$20
  and #$00FF
  ; Convert slot number to struct offset: slot * 64
  .REPEAT 6
    asl a
  .ENDR
  tax                                   ; X = owner slot struct offset
  pla                                   ; A = override target PC
  sta.w SCUMM.slots.pc,x               ; redirect owner to skip point
  ; If owner is current slot, also update Y for fetchYield
  cpx.w SCUMM.currentSlotPtr
  bne _ec.noAbortPop
  tay
_ec.noAbortPop:
  pla                                   ; discard saved level index
  bra _ec.noAbortDone
_ec.noAbort:
_ec.noAbortDone:
  ; Clean up cutScenePtr/Script/Data for the old level
  lda.w SCUMM.cutsceneNest             ; now decremented = old level index
  asl a
  tax
  stz.w SCUMM.cutScenePtr,x
  stz.w SCUMM.cutSceneData,x
  lda.w SCUMM.cutsceneNest
  tax
  sep #$20
  .ACCU 8
  stz.w SCUMM.cutSceneScript,x
  rep #$20
  .ACCU 16

  clc
  rts

; override ($58)
op_override:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.fetchByte             ; flag byte (0=endOverride, nonzero=beginOverride)
  and #$00FF
  beq _override.endOverride

  ; --- beginOverride ---
  ; Read the jump opcode + 2-byte relative offset, compute absolute target
  jsr _scummvm.fetchByte             ; jump opcode byte (0x18)
  jsr _scummvm.fetchWord             ; A = signed offset, Y = PC past offset
  ; Absolute target = current PC (Y) + offset (A)
  sta.w SCUMM.scratch
  tya
  clc
  adc.w SCUMM.scratch                ; A = absolute bytecode target
  pha                                ; save absolute target

  ; Store into cutScenePtr[max(nest-1, 0)]
  ; MI1 intro calls override before cutscene (nest=0); clamp index to 0.
  lda.w SCUMM.cutsceneNest
  dec a                              ; level index (may be -1 if nest=0)
  bpl _override.indexOk
  lda #0                             ; clamp: nest=0 → store at index 0
_override.indexOk:
  asl a
  tax
  pla
  sta.w SCUMM.cutScenePtr,x         ; save the override jump target

  ; Store current slot index into cutSceneScript[max(nest-1, 0)]
  lda.w SCUMM.cutsceneNest
  dec a
  bpl _override.scriptOk
  lda #0
_override.scriptOk:
  tax
  lda.w SCUMM.currentSlot
  sep #$20
  .ACCU 8
  sta.w SCUMM.cutSceneScript,x
  rep #$20
  .ACCU 16

  ; Set VAR_OVERRIDE (var 5) = 0
  ldx #5*2
  stz.w SCUMM.globalVars,x

  clc
  rts

_override.popDone:
  .ACCU 16
  .INDEX 16
  pla                                ; discard saved offset
  clc
  rts

_override.endOverride:
  .ACCU 16
  .INDEX 16
  ; endOverride: clear the stored override pointer
  lda.w SCUMM.cutsceneNest
  beq _override.endDone              ; no active cutscene
  dec a
  asl a
  tax
  stz.w SCUMM.cutScenePtr,x         ; clear override target

  lda.w SCUMM.cutsceneNest
  dec a
  tax
  sep #$20
  .ACCU 8
  stz.w SCUMM.cutSceneScript,x
  rep #$20
  .ACCU 16

  ; Clear VAR_OVERRIDE (var 5) = 0
  ldx #5*2
  stz.w SCUMM.globalVars,x

_override.endDone:
  .ACCU 16
  .INDEX 16
  clc
  rts

; freezeScripts ($60, $E0)
op_freezeScripts:
  .ACCU 16
  .INDEX 16
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte
  sta.w SCUMM.scratch
  ldx #0
  ldy #0
_freeze.loop:
  .ACCU 16
  .INDEX 16
  cpx.w SCUMM.currentSlotPtr
  beq _freeze.next
  lda.w SCUMM.slots.status,x
  and #$00FF
  cmp #SCUMM_SLOT_RUNNING
  bne _freeze.next

  lda.w SCUMM.scratch
  beq _freeze.unfreeze
  lda.w SCUMM.slots.freezeCount,x
  and #$00FF
  inc a
  sep #$20
  sta.w SCUMM.slots.freezeCount,x
  rep #$20
  bra _freeze.next
_freeze.unfreeze:
  .ACCU 16
  .INDEX 16
  lda.w SCUMM.slots.freezeCount,x
  and #$00FF
  beq _freeze.next
  dec a
  sep #$20
  sta.w SCUMM.slots.freezeCount,x
  rep #$20

_freeze.next:
  .ACCU 16
  .INDEX 16
  txa
  clc
  adc #_sizeof_scummSlot
  tax
  iny
  cpy #SCUMM_MAX_SLOTS
  bcc _freeze.loop
  clc
  rts

; stopObjectScript ($6E, $EE)
op_stopObjectScript:
  .ACCU 16
  .INDEX 16
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord
  clc
  rts

; isScriptRunning ($68, $E8)
op_isScriptRunning:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.getResultPos
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte
  phy                           ; save SCUMM PC (findSlotByNumber clobbers Y)
  jsr _scummvm.findSlotByNumber
  ply                           ; restore SCUMM PC
  bcs +
    lda #0
    bra _isScriptRunning.write
+
    lda #1
_isScriptRunning.write:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.writeVariable
  clc
  rts

; debug ($6B, $EB)
op_debug:
  .ACCU 16
  .INDEX 16
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord
  clc
  rts

; and ($17, $97)
op_and:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.getResultPos
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord
  pha
  lda.w SCUMM.resultVar
  jsr _scummvm.readVariable
  and 1,s
  sta.w SCUMM.scratch
  pla
  lda.w SCUMM.scratch
  jsr _scummvm.writeVariable
  clc
  rts

; or ($57, $D7)
op_or:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.getResultPos
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord
  pha
  lda.w SCUMM.resultVar
  jsr _scummvm.readVariable
  ora 1,s
  sta.w SCUMM.scratch
  pla
  lda.w SCUMM.scratch
  jsr _scummvm.writeVariable
  clc
  rts

; expression ($AC) -- stack-based expression evaluator
op_expression:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.getResultPos
_expression.loop:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.fetchByte
  cmp #$FF
  bne _expression.notEnd
  jmp _expression.end
_expression.notEnd:
  .ACCU 16
  .INDEX 16
  sta.w SCUMM.scratch

  lda.w SCUMM.scratch
  and #$001F
  cmp #$01
  beq _expression.number         ; 0x01 = PUSH value
  cmp #$02
  beq _expression.add            ; 0x02 = ADD
  cmp #$03
  beq _expression.sub            ; 0x03 = SUB
  cmp #$04
  beq _expression.mul            ; 0x04 = MUL
  cmp #$05
  beq _expression.div            ; 0x05 = DIV
  cmp #$06
  beq _expression.execOpcode     ; 0x06 = execute embedded opcode, push result
  bra _expression.loop           ; unknown sub-op → skip

_expression.number:
  .ACCU 16
  .INDEX 16
  lda.w SCUMM.currentOpcode
  pha                              ; save real opcode
  lda.w SCUMM.scratch
  sta.w SCUMM.currentOpcode        ; set sub-opcode for flag check
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord
  sta.w SCUMM.scratch2             ; save result
  pla
  sta.w SCUMM.currentOpcode        ; restore real opcode
  lda.w SCUMM.scratch2
  pha                              ; push value onto RPN stack
  jmp _expression.loop

_expression.add:
  .ACCU 16
  .INDEX 16
  pla
  sta.w SCUMM.scratch2
  pla
  clc
  adc.w SCUMM.scratch2
  pha
  jmp _expression.loop

_expression.sub:
  .ACCU 16
  .INDEX 16
  pla
  sta.w SCUMM.scratch2
  pla
  sec
  sbc.w SCUMM.scratch2
  pha
  jmp _expression.loop

_expression.mul:
  .ACCU 16
  .INDEX 16
  pla                              ; B (second operand)
  sta.w SCUMM.scratch2
  pla                              ; A (first operand)
  jsr _scummvm.mul16
  pha
  jmp _expression.loop

_expression.div:
  .ACCU 16
  .INDEX 16
  pla                              ; divisor
  sta.w SCUMM.scratch2
  pla                              ; dividend
  ldx.w SCUMM.scratch2
  beq _expression.divZero
  jsr _scummvm.div16
  pha
  jmp _expression.loop
_expression.divZero:
  .ACCU 16
  .INDEX 16
  lda #0
  pha
  jmp _expression.loop

_expression.execOpcode:
  .ACCU 16
  .INDEX 16
  ; Sub-op 6: fetch next byte as opcode, execute it, push VAR_RESULT
  lda.w SCUMM.currentOpcode
  pha                              ; save expression's outer opcode
  jsr _scummvm.fetchByte           ; fetch embedded opcode byte
  sta.w SCUMM.currentOpcode        ; set for embedded opcode's flag checks
  asl a
  tax
  jsr (_scummvm.dispatchTable,x)   ; execute the embedded opcode
  ; ignore carry (don't yield mid-expression)
  pla
  sta.w SCUMM.currentOpcode        ; restore outer opcode
  lda.w SCUMM.globalVars           ; var[0] = VAR_RESULT
  pha                              ; push result onto RPN stack
  jmp _expression.loop

_expression.end:
  .ACCU 16
  .INDEX 16
  pla
  jsr _scummvm.writeVariable
  clc
  rts

; chainScript ($42, $C2)
op_chainScript:
  .ACCU 16
  .INDEX 16
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte
  pha                             ; push script number
  jsr _scummvm.readWordVararg     ; read args into argBuffer/argCount
  ldx.w SCUMM.currentSlotPtr
  sep #$20
  lda #SCUMM_SLOT_DEAD
  sta.w SCUMM.slots.status,x
  rep #$20
  pla                             ; A = script number
  phy                             ; save SCUMM PC
  jsl scummvm.startScriptSlot_long
  bcc _chainScript.noArgs         ; slot creation failed
  ; X = new slot byte offset; copy args to slot's localVars
  ldy #0
_chainScript.copyArgs:
  .ACCU 16
  .INDEX 16
  cpy.w SCUMM.argCount
  bcs _chainScript.argsDone
  lda.w SCUMM.argBuffer,y
  sta.w SCUMM.slots.localVars,x
  inx
  inx
  iny
  iny
  bra _chainScript.copyArgs
_chainScript.argsDone:
_chainScript.noArgs:
  .ACCU 16
  .INDEX 16
  ply                             ; restore SCUMM PC
  sec
  rts

; cursorCommand ($2C) -- subop-based, consume parameters + apply cursor state
; Fixes: fetchByte (not fetchWord), currentOpcode for flag bits, 3 params for
;   hotspot, getWordVararg for charsetColor, userput sub-ops 3/4/8, soft on/off
;   counters, VAR_CURSORSTATE=52/VAR_USERPUT=53, epilogue sync
op_cursorCommand:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.fetchByte            ; BUG1: was fetchWord
  sta.w SCUMM.scratch               ; save full sub-opcode byte
  sta.w SCUMM.currentOpcode         ; BUG2: needed for getVarOrDirectByte flag bits
  and #$001F                        ; mask to sub-op number
  ; Dispatch on sub-op
  cmp #1
  beq _cc.cursorOn
  cmp #2
  beq _cc.cursorOff
  cmp #3
  beq _cc.userputOn
  cmp #4
  beq _cc.userputOff
  cmp #5
  beq _cc.cursorSoftOn
  cmp #6
  beq _cc.cursorSoftOff
  cmp #7
  beq _cc.userputSoftOn
  cmp #8
  beq _cc.userputSoftOff
  cmp #10
  beq _cc.cursorImage
  cmp #11
  beq _cc.cursorHotspot
  cmp #12
  beq _cc.oneParam
  cmp #13
  beq _cc.oneParam
  cmp #14
  beq _cc.charsetColor
  bra _cc.epilogue                  ; unknown sub-op, skip
; --- No-param sub-ops ---
_cc.cursorOn:
  .ACCU 16
  lda #1
  sta.w SCUMM.cursorEnabled
  bra _cc.epilogue
_cc.cursorOff:
  .ACCU 16
  stz.w SCUMM.cursorEnabled
  bra _cc.epilogue
_cc.userputOn:
  .ACCU 16
  lda #1
  sta.w SCUMM.userPut
  bra _cc.epilogue
_cc.userputOff:
  .ACCU 16
  stz.w SCUMM.userPut
  bra _cc.epilogue
_cc.cursorSoftOn:
  .ACCU 16
  lda.w SCUMM.cursorEnabled
  inc a
  sta.w SCUMM.cursorEnabled
  bra _cc.epilogue
_cc.cursorSoftOff:
  .ACCU 16
  lda.w SCUMM.cursorEnabled
  dec a
  sta.w SCUMM.cursorEnabled
  bra _cc.epilogue
_cc.userputSoftOn:
  .ACCU 16
  lda.w SCUMM.userPut
  inc a
  sta.w SCUMM.userPut
  bra _cc.epilogue
_cc.userputSoftOff:
  .ACCU 16
  lda.w SCUMM.userPut
  dec a
  sta.w SCUMM.userPut
  bra _cc.epilogue
; --- Param-consuming stubs ---
_cc.cursorImage:
  .ACCU 16
  .INDEX 16
  ; getVarOrDirectByte(0x80), getVarOrDirectByte(0x40) — 2 params
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte
  lda #SCUMM_FLAG_BIT6
  jsr _scummvm.getVarOrDirectByte
  bra _cc.epilogue
_cc.cursorHotspot:
  .ACCU 16
  .INDEX 16
  ; BUG3: 3 params not 2
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte
  lda #SCUMM_FLAG_BIT6
  jsr _scummvm.getVarOrDirectByte
  lda #SCUMM_FLAG_BIT5
  jsr _scummvm.getVarOrDirectByte
  bra _cc.epilogue
_cc.oneParam:
  .ACCU 16
  .INDEX 16
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte
  bra _cc.epilogue
_cc.charsetColor:
  .ACCU 16
  .INDEX 16
  ; BUG4: getWordVararg — {byte, getVarOrDirectWord(0x80)}* terminated by byte==0xFF
_cc.charsetColorLoop:
  jsr _scummvm.fetchByte
  cmp #$00FF
  beq _cc.epilogue
  ; byte has flag bits for the following word param
  sta.w SCUMM.currentOpcode         ; store for getVarOrDirectWord flag check
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord
  bra _cc.charsetColorLoop
; --- Epilogue: sync cursorState + userPut to SCUMM global vars ---
_cc.epilogue:
  .ACCU 16
  .INDEX 16
  lda.w SCUMM.cursorEnabled
  ldx #52*2                         ; VAR_CURSORSTATE (BUG7: was 48)
  sta.w SCUMM.globalVars,x
  lda.w SCUMM.userPut
  ldx #53*2                         ; VAR_USERPUT
  sta.w SCUMM.globalVars,x
  clc
  rts

; systemOps ($98)
op_systemOps:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.fetchByte
  clc
  rts

;-------------------------------------------------------------------
; Actor / resource stubs -- consume params correctly, no-op for now
;-------------------------------------------------------------------

; resourceRoutines ($0C, $8C) -- resource preload/cache management
; Sub-opcode byte controls flag bits, not the main opcode.
; All are no-ops for MSU-1 on-demand loading; just skip params.
op_resourceRoutines:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.fetchByte     ; read sub-opcode byte
  sta.w SCUMM.scratch        ; save full sub-opcode

  and #$003F                 ; mask to get key
  cmp #$11
  beq _resRoutines.done      ; clearHeap: no params
  cmp #$14
  beq _resRoutines.flObject  ; loadFlObject: p8 + p16

  ; Default: one p8 parameter (flag = bit 7 of SUB-OPCODE byte)
  lda.w SCUMM.scratch                ; sub-opcode byte
  sta.w SCUMM.currentOpcode          ; set as current for flag check
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte
  bra _resRoutines.done

_resRoutines.flObject:
  .ACCU 16
  .INDEX 16
  ; loadFlObject: p8[7] room + p16 object (per ScummVM)
  lda.w SCUMM.scratch                ; sub-opcode byte
  sta.w SCUMM.currentOpcode          ; set as current for flag check
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte   ; room
  jsr _scummvm.fetchWord            ; object ID (always p16)

_resRoutines.done:
  .ACCU 16
  .INDEX 16
  clc
  rts

; putActorInRoom ($2D, $6D, $AD, $ED)
; Params: p8[7]=actor, p8[6]=room
op_putActorInRoom:
  .ACCU 16
  .INDEX 16
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte    ; actor number
  pha                                ; save actor number
  jsr _scummvm.getActorPtr           ; X = actor table offset
  stx.w SCUMM.scratch2              ; save actor offset

  lda #SCUMM_FLAG_BIT6
  jsr _scummvm.getVarOrDirectByte    ; room number
  sta.w SCUMM.scratch3              ; save room number
  ldx.w SCUMM.scratch2
  sep #$20
  sta.w SCUMM.actors.room,x
  ; room=0 means "remove from room" → clear visible; otherwise set visible
  cmp #0
  beq +
    lda #1
    sta.w SCUMM.actors.visible,x
    bra ++
+
    stz.w SCUMM.actors.visible,x
++
  rep #$20

  ; If ego actor (actor 1) → trigger room change (ScummVM: VAR_NEW_ROOM)
  pla                                ; recover actor number
  and #$00FF
  cmp #1
  bne +
  lda.w SCUMM.scratch3              ; room number
  and #$00FF
  beq +                              ; room 0 = remove actor, not room change
  sta.w SCUMM.newRoom
+
  clc
  rts

; getActorMoving ($56, $D6)
; Params: result + p8[7]=actor
; Returns actor's moving field (0=stationary, non-zero=moving)
op_getActorMoving:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.getResultPos
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte    ; actor number
  jsr _scummvm.getActorPtr           ; X = actor table offset
  lda.w SCUMM.actors.moving,x
  and #$00FF                         ; db field — mask high byte
  jsr _scummvm.writeVariable
  clc
  rts

; getObjectState ($0F, $8F) -- result + p16[7], return 0
op_getObjectState:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.getResultPos
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord    ; object ID
  tax
  cpx #SCUMM_MAX_OBJECTS
  bcs _getObjState.zero              ; out of bounds → return 0
    lda.w SCUMM.objectState,x
    and #$00FF                       ; byte field → mask high
    jsr _scummvm.writeVariable
    clc
    rts
_getObjState.zero:
  .ACCU 16
  .INDEX 16
  lda #0
  jsr _scummvm.writeVariable
  clc
  rts

; getObjectOwner ($10, $90) -- result + p16[7], return objectOwner[obj]
op_getObjectOwner:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.getResultPos
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord    ; object ID
  cmp #SCUMM_MAX_OBJECTS
  bcs _getObjOwner.zero
    tax
    lda.w SCUMM.objectOwner,x
    and #$00FF
    jsr _scummvm.writeVariable
    clc
    rts
_getObjOwner.zero:
  .ACCU 16
  .INDEX 16
  lda #0
  jsr _scummvm.writeVariable
  clc
  rts

; setState ($07, $47, $87, $C7) -- getVarOrDirectWord[7]=obj + getVarOrDirectByte[6]=state
op_setState:
  .ACCU 16
  .INDEX 16
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord    ; object ID (p16 with BIT7)
  sta.w SCUMM.scratch                ; save object ID
  lda #SCUMM_FLAG_BIT6
  jsr _scummvm.getVarOrDirectByte    ; state (p8 with BIT6)
  sta.w SCUMM.scratch2               ; save state
  ; Bounds check object ID
  ldx.w SCUMM.scratch
  cpx #SCUMM_MAX_OBJECTS
  bcs +                              ; out of bounds → skip
    ; Save script pointer (tmp+0..tmp+2) and Y (script PC)
    phy                              ; save Y (script PC)
    lda.b tmp
    pha                              ; save tmp+0,1
    lda.b tmp+2
    pha                              ; save tmp+2,3
    ; Call drawObjectSetStateN: SCUMM.scratch=obj_id (already set), A=state
    lda.w SCUMM.scratch2
    and #$00FF
    jsl scummvm.drawObjectSetStateN
    ; Restore script pointer and Y
    pla
    sta.b tmp+2
    pla
    sta.b tmp
    ply                              ; restore Y (script PC)
+
  clc
  rts

; putActor ($01, $21, $41, $61, $81, $A1, $C1, $E1) -- p8[7]=actor, p16[6]=x, p16[5]=y
op_putActor:
  .ACCU 16
  .INDEX 16
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte    ; actor number
  jsr _scummvm.getActorPtr           ; X = actor table offset (clamped if invalid)
  stx.w SCUMM.scratch2              ; save actor offset

  lda #SCUMM_FLAG_BIT6
  jsr _scummvm.getVarOrDirectWord    ; x coordinate
  ldx.w SCUMM.scratch2
  sta.w SCUMM.actors.x,x

  lda #SCUMM_FLAG_BIT5
  jsr _scummvm.getVarOrDirectWord    ; y coordinate
  ldx.w SCUMM.scratch2
  sta.w SCUMM.actors.y,x

  ; ScummVM: putActor(x,y) does NOT change actor's room or visible flag.
  ; Only clears moving. Room is set by putActorInRoom, not putActor.
  sep #$20
  stz.w SCUMM.actors.moving,x       ; ScummVM: putActor clears moving
  rep #$20

  ; Assign walkbox from position (ScummVM: adjustActorPos)
  ; Save SCUMM PC (Y) + fetchLoop bytecode pointer (tmp) — findBox clobbers both
  phy                                ; save Y = SCUMM PC
  lda.b tmp
  pha
  lda.b tmp+2
  pha
  ; Set findBox args
  lda.w SCUMM.actors.x,x
  sta.b tmp
  lda.w SCUMM.actors.y,x
  sta.b tmp+2
  jsr scummvm.findBox                ; A = boxIdx or $FF
  ; Restore fetchLoop bytecode pointer + SCUMM PC
  pha                                ; save findBox result
  lda 3,s                            ; saved tmp+2 (stack: result, tmp+2, tmp, Y)
  sta.b tmp+2
  lda 5,s                            ; saved tmp
  sta.b tmp
  pla                                ; A = findBox result
  plx                                ; discard saved tmp+2
  plx                                ; discard saved tmp
  ply                                ; restore Y = SCUMM PC
  cmp #$00FF
  beq +
  pha                                ; save boxIdx
  ldx.w SCUMM.scratch2              ; actor struct offset
  txa
  lsr a
  lsr a
  lsr a
  lsr a                              ; / 16 = actor number
  tax
  pla                                ; recover boxIdx
  sep #$20
  .ACCU 8
  sta.w SCUMM.actorWalkBox,x
  rep #$20
  .ACCU 16
+
  clc
  rts

; getActorRoom ($03, $83) -- result + p8[7], return actor's room
op_getActorRoom:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.getResultPos
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte    ; actor number
  jsr _scummvm.getActorPtr
  lda.w SCUMM.actors.room,x
  and #$00FF                        ; byte field → 16-bit
  jsr _scummvm.writeVariable
  clc
  rts

; panCameraTo ($12, $92) -- p16[7] — set camera pan target
op_panCameraTo:
  .ACCU 16
  .INDEX 16
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord    ; A = target X (center)
  sta.w SCUMM.cameraDest
  clc
  rts

; setCameraAt ($32, $B2) -- p16[7] — instant camera snap
; Snaps camera to target position. If jump > 8px, calls
; room.reloadViewport to refresh all visible tile columns.
op_setCameraAt:
  .ACCU 16
  .INDEX 16
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord    ; A = target X (center)
  phy                                ; save SCUMM PC
  jsl scummvm.setCameraAtImpl        ; snap camera instantly
  ply                                ; restore SCUMM PC
  rts

; lights ($70, $F0) -- p8[7]=value + byte + byte → store to VAR_CURRENT_LIGHTS (var 9)
op_lights:
  .ACCU 16
  .INDEX 16
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte    ; luminance
  ldx #9 * 2                        ; VAR(9) = VAR_CURRENT_LIGHTS (SCUMM v5)
  sta.w SCUMM.globalVars,x
  jsr _scummvm.fetchByte             ; color1
  jsr _scummvm.fetchByte             ; color2
  clc
  rts

; loadRoom ($72, $F2) -- p8[7]=room
; Room 0 is applied IMMEDIATELY (ScummVM: startScene(0) is synchronous).
; Non-zero rooms are deferred to the scheduler via SCUMM.newRoom.
op_loadRoom:
  .ACCU 16
  .INDEX 16
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte    ; room number
  and #$00FF
  bne _loadRoom.nonZero

  ; Room 0: apply immediately so consecutive loadRoom(0)+loadRoom(N)
  ; works correctly (credits script 152: loadRoom(0) then loadRoom(10))
  stz.w SCUMM.currentRoom
  ldx #4*2                            ; VAR_ROOM
  stz.w SCUMM.globalVars,x
  stz.w SCUMM.newRoom                 ; clear any stale pending change
  sep #$20
  stz.w ScreenBrightness              ; blank screen (hides stale tiles)
  rep #$20
  clc
  rts

_loadRoom.nonZero:
  sta.w SCUMM.newRoom                  ; request room change (deferred)
  clc
  rts

; setOwnerOf ($29, $69, $A9, $E9) -- p16[7]=object + p8[6]=owner
; Triggers inventory rebuild when ownership changes to/from ego (1).
op_setOwnerOf:
  .ACCU 16
  .INDEX 16
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord    ; object ID
  pha                                ; save object ID
  lda #SCUMM_FLAG_BIT6
  jsr _scummvm.getVarOrDirectByte    ; owner
  sta.w SCUMM.scratch               ; save new owner
  pla                                ; object ID
  cmp #SCUMM_MAX_OBJECTS
  bcs _soo.skip                      ; out of range → skip
    tax
    ; Check if old or new owner is ego (1)
    lda.w SCUMM.objectOwner,x
    and #$00FF
    sta.w SCUMM.scratch2             ; save old owner
    lda.w SCUMM.scratch
    sep #$20
    sta.w SCUMM.objectOwner,x       ; store new owner
    rep #$20
    ; Rebuild if old or new owner is ego
    lda.w SCUMM.scratch2
    cmp #1
    beq _soo.rebuild
    lda.w SCUMM.scratch
    and #$00FF
    cmp #1
    bne _soo.skip
_soo.rebuild:
  .ACCU 16
  .INDEX 16
    phy
    ; Cache inventory name if new owner is ego
    lda.w SCUMM.scratch
    and #$00FF
    cmp #1
    bne _soo.skipCache
      txa                            ; A = obj_id
      jsl scummvm.cacheInventoryName
_soo.skipCache:
  .ACCU 16
  .INDEX 16
    jsl scummvm.rebuildInventory
    ply
_soo.skip:
  .ACCU 16
  .INDEX 16
  clc
  rts

; getActorX ($43, $C3) -- result + p16[7], return actor's X
op_getActorX:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.getResultPos
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord    ; actor number (p16 format)
  jsr _scummvm.getActorPtr
  lda.w SCUMM.actors.x,x
  jsr _scummvm.writeVariable
  clc
  rts

; getActorY ($23, $A3) -- result + p16[7], return actor's Y
op_getActorY:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.getResultPos
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord    ; actor number (p16 format)
  jsr _scummvm.getActorPtr
  lda.w SCUMM.actors.y,x
  jsr _scummvm.writeVariable
  clc
  rts

; actorOps ($13, $93) -- p8[7]=actor + sub-opcode sequence terminated by $FF
op_actorOps:
  .ACCU 16
  .INDEX 16
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte    ; actor number
  jsr _scummvm.getActorPtr           ; X = actor table offset
  ; Save actor table offset on stack (preserved across sub-opcode loop)
  phx

_actorOps.subLoop:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.fetchByte
  cmp #$FF
  bne _actorOps.dispatch
  plx                                ; clean up actor offset from stack
  jmp _actorOps.done
_actorOps.dispatch:
  .ACCU 16
  .INDEX 16
  sta.w SCUMM.scratch                ; save full sub-opcode byte (flags in upper bits)
  and #$001F                         ; sub-opcode key (ScummVM: _opcode & 0x1F)
  ; ScummVM v5 actorOps sub-opcodes (1-based):
  ;   0x01=setCostume(p8), 0x02=walkSpeed(2xp8), 0x03=sound(p8),
  ;   0x04=walkAnimNr(p8), 0x05=talkAnimNr(2xp8), 0x06=standFrame(p8),
  ;   0x07=palette(3xp8), 0x08=init(0), 0x09=elevation(p16),
  ;   0x0A=animDefault(0), 0x0B=palette2(2xp8), 0x0C=talkColor(p8),
  ;   0x0D=actorName(string), 0x0E=initFrame(p8), 0x10=width(p8),
  ;   0x11=scale(2xp8), 0x12=neverZClip(0), 0x13=setZClip(p8),
  ;   0x14=ignoreBoxes(0), 0x15=followBoxes(0), 0x16=animSpeed(p8),
  ;   0x17=shadow(p8)
  ;--- Sub 0x01: setCostume — wire to actor table
  cmp #$01
  bne +
    jmp _actorOps.sub_setCostume
+
  ;--- Sub 0x02: walkSpeed (2 params: p8[7]=speedX + p8[6]=speedY)
  cmp #$02
  bne +
    jmp _actorOps.sub_setWalkSpeed
+
  ;--- Sub 0x05: talkAnimNr (2 params: p8[7]=start + p8[6]=end)
  cmp #$05
  bne +
    jmp _actorOps.sub_setTalkAnim
+
  ;--- Sub 0x07: palette (3 params: p8[7] + p8[6] + p8[5])
  cmp #$07
  bne +
    jmp _actorOps.sub_3param
+
  ;--- Sub 0x0B: palette2 (2 params: p8[7] + p8[6])
  cmp #$0B
  bne +
    jmp _actorOps.jmp_2param
+
  ;--- Sub 0x11: scale (2 params: p8[7]=scaleX + p8[6]=scaleY)
  cmp #$11
  bne +
    jmp _actorOps.sub_setScale
+
  ;--- Sub 0x0D: actorName (null-terminated string)
  cmp #$0D
  bne +
    jmp _actorOps.sub_string
+
  ;--- Sub 0x09: elevation (1 param: p16[7] — WORD)
  cmp #$09
  bne +
    jmp _actorOps.sub_p16
+
  ;--- Sub 0x08: init (0 params) — set facing=180 (south), per ScummVM initActor
  cmp #$08
  bne +
    phy                              ; save script PC
    lda 3,s                          ; actor struct offset (adjusted for pushed Y)
    clc
    adc #6                           ; +6 = facing field
    tay
    lda #180                         ; south
    sta.w SCUMM.actors,y
    ply                              ; restore script PC
    jmp _actorOps.subLoop
+
  ;--- Sub 0x0A: animDefault (0 params)
  cmp #$0A
  beq _actorOps.jmp_none
  ;--- Sub 0x12: neverZClip (0 params)
  cmp #$12
  beq _actorOps.jmp_none
  ;--- Sub 0x14: ignoreBoxes (0 params) — set actorIgnoreBoxes[actor]=1
  cmp #$14
  bne +
    lda 1,s                          ; actor struct offset from stack
    lsr a
    lsr a
    lsr a
    lsr a                            ; /16 = actor number
    and #$000F
    tax
    sep #$20
    lda #1
    sta.w SCUMM.actorIgnoreBoxes,x
    rep #$20
    jmp _actorOps.subLoop
+
  ;--- Sub 0x15: followBoxes (0 params) — set actorIgnoreBoxes[actor]=0
  cmp #$15
  bne +
    lda 1,s                          ; actor struct offset from stack
    lsr a
    lsr a
    lsr a
    lsr a                            ; /16 = actor number
    and #$000F
    tax
    sep #$20
    stz.w SCUMM.actorIgnoreBoxes,x
    rep #$20
    jmp _actorOps.subLoop
+
  ;--- Sub 0x0E: initFrame — wire to actor table
  cmp #$0E
  bne +
    jmp _actorOps.sub_initFrame
+
  ;--- Sub 0x0C: talkColor — wire to actor table
  cmp #$0C
  bne +
    jmp _actorOps.sub_talkColor
+
  ;--- Sub 0x10: width (1 param: p8[7])
  cmp #$10
  bne +
    jmp _actorOps.sub_setWidth
+
  ;--- Sub 0x16: animSpeed (1 param: p8[7])
  cmp #$16
  bne +
    jmp _actorOps.sub_setAnimSpeed
+
  ;--- Sub 0x04: walkAnimNr (1 param: p8[7])
  cmp #$04
  bne +
    jmp _actorOps.sub_setWalkAnimNr
+
  ;--- Sub 0x06: standFrame (1 param: p8[7])
  cmp #$06
  bne +
    jmp _actorOps.sub_setStandFrame
+
  ;--- Sub 0x13: setZClip (1 param: p8[7])
  cmp #$13
  bne +
    jmp _actorOps.sub_setZClip
+
  ;--- Everything else: 1 param p8[7]
  ; (0x03=sound, 0x17=shadow + unknown)
  bra _actorOps.sub_1param

_actorOps.jmp_none:
  .ACCU 16
  .INDEX 16
  jmp _actorOps.sub_none

_actorOps.jmp_2param:
  .ACCU 16
  .INDEX 16
  jmp _actorOps.sub_2param

_actorOps.sub_1param:
  .ACCU 16
  .INDEX 16
  lda.w SCUMM.scratch
  and #$0080
  beq +
  jsr _scummvm.fetchWord
  jmp _actorOps.subLoop
+
  jsr _scummvm.fetchByte
  jmp _actorOps.subLoop

_actorOps.sub_setCostume:
  .ACCU 16
  .INDEX 16
  ; Sub 0x00: p8[7] — store costume to actor table
  lda.w SCUMM.scratch
  and #$0080
  beq +
    jsr _scummvm.fetchWord
    jsr _scummvm.readVariable
    bra ++
+
    jsr _scummvm.fetchByte
++
  pha                                ; save costume value
  lda 3,s                           ; actor offset (past pushed costume)
  tax
  pla
  sep #$20
  sta.w SCUMM.actors.costume,x
  ; Mark render slot dirty if this actor is in a slot
  ; Push order: phx first (2B, 16-bit X), then pha (1B, 8-bit A)
  ; so costume is on TOP of stack for correct pla in foundSlot path
  phx                                ; save actor offset (2 bytes, X is 16-bit)
  pha                                ; save costume (1 byte, A is 8-bit)
  ; Compute actor number from struct offset: offset / 16
  txa
  lsr a
  lsr a
  lsr a
  lsr a                              ; A = actor number (8-bit)
  ldx #0
_asc.findSlot:
  .ACCU 8
  .INDEX 16
  cmp.w SCUMM.renderSlotActor,x
  beq _asc.foundSlot
  inx
  cpx #SCUMM_MAX_RENDER_SLOTS
  bcc _asc.findSlot
  bra _asc.noSlot
_asc.foundSlot:
  .ACCU 8
  .INDEX 16
  pla                                ; costume (1 byte from top of stack)
  sta.w SCUMM.renderSlotCostume,x
  lda #$FF
  sta.w SCUMM.renderSlotLastPic,x
  lda #1
  sta.w SCUMM.renderSlotDirty,x
  pha                                ; re-push to match stack
_asc.noSlot:
  .ACCU 8
  .INDEX 16
  pla                                ; pop costume (1 byte)
  plx                                ; pop actor offset (2 bytes)
  rep #$20
  jmp _actorOps.subLoop

_actorOps.sub_initFrame:
  .ACCU 16
  .INDEX 16
  ; Sub 0x08: p8[7] — store initFrame to actor table
  lda.w SCUMM.scratch
  and #$0080
  beq +
    jsr _scummvm.fetchWord
    jsr _scummvm.readVariable
    bra ++
+
    jsr _scummvm.fetchByte
++
  pha
  lda 3,s
  tax
  pla
  sep #$20
  sta.w SCUMM.actors.initFrame,x
  rep #$20
  jmp _actorOps.subLoop

_actorOps.sub_setScale:
  .ACCU 16
  .INDEX 16
  ; Sub 0x11: p8[7]=scaleX, p8[6]=scaleY — store scaleX to actor struct
  lda.w SCUMM.scratch
  and #$0080
  beq +
    jsr _scummvm.fetchWord
    jsr _scummvm.readVariable
    bra ++
+
    jsr _scummvm.fetchByte
++
  pha                                ; save scaleX
  lda 3,s                           ; actor offset from stack (past pushed value)
  tax
  pla
  sep #$20
  sta.w SCUMM.actors.scalex,x
  rep #$20
  ; Consume and discard scaleY (param 2)
  lda.w SCUMM.scratch
  and #$0040
  beq +
  jsr _scummvm.fetchWord
  jmp _actorOps.subLoop
+
  jsr _scummvm.fetchByte
  jmp _actorOps.subLoop

_actorOps.sub_setWidth:
  .ACCU 16
  .INDEX 16
  ; Sub 0x10: p8[7]=width — store to actorWidth parallel array
  lda.w SCUMM.scratch
  and #$0080
  beq +
    jsr _scummvm.fetchWord
    jsr _scummvm.readVariable
    bra ++
+
    jsr _scummvm.fetchByte
++
  pha
  lda 3,s                           ; actor struct offset
  lsr a
  lsr a
  lsr a
  lsr a                             ; /16 = actor number
  and #$000F
  tax
  pla
  sep #$20
  sta.w SCUMM.actorWidth,x
  rep #$20
  jmp _actorOps.subLoop

_actorOps.sub_setAnimSpeed:
  .ACCU 16
  .INDEX 16
  ; Sub 0x16: p8[7]=animSpeed — store to actorAnimSpeed parallel array
  lda.w SCUMM.scratch
  and #$0080
  beq +
    jsr _scummvm.fetchWord
    jsr _scummvm.readVariable
    bra ++
+
    jsr _scummvm.fetchByte
++
  pha
  lda 3,s                           ; actor struct offset
  lsr a
  lsr a
  lsr a
  lsr a                             ; /16 = actor number
  and #$000F
  tax
  pla
  sep #$20
  sta.w SCUMM.actorAnimSpeed,x
  rep #$20
  jmp _actorOps.subLoop

_actorOps.sub_setWalkSpeed:
  .ACCU 16
  .INDEX 16
  ; Sub 0x02: p8[7]=speedX, p8[6]=speedY — store to parallel arrays
  lda.w SCUMM.scratch
  and #$0080
  beq +
    jsr _scummvm.fetchWord
    jsr _scummvm.readVariable
    bra ++
+
    jsr _scummvm.fetchByte
++
  pha                                ; save speedX
  lda 3,s                           ; actor struct offset
  lsr a
  lsr a
  lsr a
  lsr a                             ; /16 = actor number
  and #$000F
  tax
  pla
  sep #$20
  sta.w SCUMM.actorWalkSpeedX,x
  rep #$20
  ; Read speedY (param 2)
  lda.w SCUMM.scratch
  and #$0040
  beq +
    jsr _scummvm.fetchWord
    jsr _scummvm.readVariable
    bra ++
+
    jsr _scummvm.fetchByte
++
  pha
  lda 3,s
  lsr a
  lsr a
  lsr a
  lsr a
  and #$000F
  tax
  pla
  sep #$20
  sta.w SCUMM.actorWalkSpeedY,x
  rep #$20
  jmp _actorOps.subLoop

_actorOps.sub_setWalkAnimNr:
  .ACCU 16
  .INDEX 16
  ; Sub 0x04: p8[7]=walkAnimNr — store to parallel array
  lda.w SCUMM.scratch
  and #$0080
  beq +
    jsr _scummvm.fetchWord
    jsr _scummvm.readVariable
    bra ++
+
    jsr _scummvm.fetchByte
++
  pha
  lda 3,s
  lsr a
  lsr a
  lsr a
  lsr a
  and #$000F
  tax
  pla
  sep #$20
  sta.w SCUMM.actorWalkAnimNr,x
  rep #$20
  jmp _actorOps.subLoop

_actorOps.sub_setStandFrame:
  .ACCU 16
  .INDEX 16
  ; Sub 0x06: p8[7]=standFrame — store to parallel array
  lda.w SCUMM.scratch
  and #$0080
  beq +
    jsr _scummvm.fetchWord
    jsr _scummvm.readVariable
    bra ++
+
    jsr _scummvm.fetchByte
++
  pha
  lda 3,s
  lsr a
  lsr a
  lsr a
  lsr a
  and #$000F
  tax
  pla
  sep #$20
  sta.w SCUMM.actorStandFrame,x
  rep #$20
  jmp _actorOps.subLoop

_actorOps.sub_setZClip:
  .ACCU 16
  .INDEX 16
  ; Sub 0x13: p8[7]=zClip — store to parallel array
  lda.w SCUMM.scratch
  and #$0080
  beq +
    jsr _scummvm.fetchWord
    jsr _scummvm.readVariable
    bra ++
+
    jsr _scummvm.fetchByte
++
  pha
  lda 3,s
  lsr a
  lsr a
  lsr a
  lsr a
  and #$000F
  tax
  pla
  sep #$20
  sta.w SCUMM.actorZClip,x
  rep #$20
  jmp _actorOps.subLoop

_actorOps.sub_setTalkAnim:
  .ACCU 16
  .INDEX 16
  ; Sub 0x05: p8[7]=talkAnimStart, p8[6]=talkAnimEnd — store to parallel arrays
  lda.w SCUMM.scratch
  and #$0080
  beq +
    jsr _scummvm.fetchWord
    jsr _scummvm.readVariable
    bra ++
+
    jsr _scummvm.fetchByte
++
  pha
  lda 3,s
  lsr a
  lsr a
  lsr a
  lsr a
  and #$000F
  tax
  pla
  sep #$20
  sta.w SCUMM.actorTalkAnimStart,x
  rep #$20
  ; Read talkAnimEnd (param 2)
  lda.w SCUMM.scratch
  and #$0040
  beq +
    jsr _scummvm.fetchWord
    jsr _scummvm.readVariable
    bra ++
+
    jsr _scummvm.fetchByte
++
  pha
  lda 3,s
  lsr a
  lsr a
  lsr a
  lsr a
  and #$000F
  tax
  pla
  sep #$20
  sta.w SCUMM.actorTalkAnimEnd,x
  rep #$20
  jmp _actorOps.subLoop

_actorOps.sub_none:
  .ACCU 16
  .INDEX 16
  jmp _actorOps.subLoop

_actorOps.sub_2param:
  .ACCU 16
  .INDEX 16
  lda.w SCUMM.scratch
  and #$0080
  beq +
  jsr _scummvm.fetchWord
  bra ++
+
  jsr _scummvm.fetchByte
++
  lda.w SCUMM.scratch
  and #$0040
  beq +
  jsr _scummvm.fetchWord
  jmp _actorOps.subLoop
+
  jsr _scummvm.fetchByte
  jmp _actorOps.subLoop

_actorOps.sub_2word:
  ; Sub 0x14 textOffset: p16[7] + p16[6] (word params)
  lda.w SCUMM.scratch
  and #$0080
  beq +
  jsr _scummvm.fetchWord
  jsr _scummvm.readVariable
  bra ++
+
  jsr _scummvm.fetchWord
++
  lda.w SCUMM.scratch
  and #$0040
  beq +
  jsr _scummvm.fetchWord
  jsr _scummvm.readVariable
  jmp _actorOps.subLoop
+
  jsr _scummvm.fetchWord
  jmp _actorOps.subLoop

_actorOps.sub_p16:
  .ACCU 16
  .INDEX 16
  ; Sub 0x09 elevation: p16[7] (word param) — store to actor struct
  lda.w SCUMM.scratch
  and #$0080
  beq +
  jsr _scummvm.fetchWord
  jsr _scummvm.readVariable
  bra _actorOps.storeElevation
+
  jsr _scummvm.fetchWord
_actorOps.storeElevation:
  .ACCU 16
  .INDEX 16
  pha
  lda 3,s                           ; actor offset (past pushed value)
  tax
  pla
  sta.w SCUMM.actors.elevation,x
  jmp _actorOps.subLoop

_actorOps.sub_3param:
  .ACCU 16
  .INDEX 16
  ; Sub 0x07 palette: 3 params — p8[7] + p8[6] + p8[5]
  lda.w SCUMM.scratch
  and #$0080
  beq +
  jsr _scummvm.fetchWord
  bra ++
+
  jsr _scummvm.fetchByte
++
  lda.w SCUMM.scratch
  and #$0040
  beq +
  jsr _scummvm.fetchWord
  bra ++
+
  jsr _scummvm.fetchByte
++
  lda.w SCUMM.scratch
  and #$0020
  beq +
  jsr _scummvm.fetchWord
  jmp _actorOps.subLoop
+
  jsr _scummvm.fetchByte
  jmp _actorOps.subLoop

_actorOps.sub_talkColor:
  .ACCU 16
  .INDEX 16
  ; Sub 0x0C: p8[7] — store talkColor to actor table
  lda.w SCUMM.scratch
  and #$0080
  beq +
    jsr _scummvm.fetchWord
    jsr _scummvm.readVariable
    bra ++
+
    jsr _scummvm.fetchByte
++
  pha
  lda 3,s                            ; actor offset from stack
  tax
  pla
  sep #$20
  sta.w SCUMM.actors.talkColor,x
  rep #$20
  jmp _actorOps.subLoop

_actorOps.sub_string:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.fetchByte
  cmp #0
  bne _actorOps.sub_string
  jmp _actorOps.subLoop

_actorOps.done:
  .ACCU 16
  .INDEX 16
  clc
  rts

;===================================================================
; Batch stub opcodes — consume params correctly, no-op behavior
; These allow ENCD and LSCR scripts to run without crashing.
;===================================================================

;-------------------------------------------------------------------
; Sound opcodes — wired to Terrific Audio Driver (TAD)
;-------------------------------------------------------------------

; stopSound ($3C, $BC) -- p8[7] sound ID → stop all SFX
op_stopSound:
  .ACCU 16
  .INDEX 16
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte
  ; Stop all sound effects via TAD
  phy
  sep #$20
  lda.b #TadCommand_STOP_SOUND_EFFECTS
  ldx #0
  ldy #0
  jsl Tad_QueueCommand
  rep #$31
  ply
  clc
  rts

; startSound ($1C, $9C) -- p8[7] sound ID → queue SFX
op_startSound:
  .ACCU 16
  .INDEX 16
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte
  ; Queue sound effect via TAD (A = sfx id)
  phy
  sep #$20
  jsl Tad_QueueSoundEffect
  rep #$31
  ply
  clc
  rts

; startMusic ($02, $82) -- p8[7] song ID → load song
op_startMusic:
  .ACCU 16
  .INDEX 16
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte
  phy
  pha                               ; save song ID
  lda.w SCUMM.musicMode
  bne _startMusic.msu1
  ; TAD path
  pla
  sep #$20
  jsl Tad_LoadSongIfChanged
  rep #$31
  ply
  clc
  rts
_startMusic.msu1:
  .ACCU 16
  .INDEX 16
  pla                               ; A = song ID
  jsr _scummvm.msu1PlayTrack
  ply
  clc
  rts

; stopMusic ($20) -- no params → pause music
op_stopMusic:
  .ACCU 16
  .INDEX 16
  phy
  lda.w SCUMM.musicMode
  bne _stopMusic.msu1
  ; TAD path
  sep #$20
  lda.b #TadCommand_PAUSE
  ldx #0
  ldy #0
  jsl Tad_QueueCommand
  rep #$31
  ply
  clc
  rts
_stopMusic.msu1:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.msu1StopTrack
  ply
  clc
  rts

; isSoundRunning ($7C, $FC) -- result + p8[7] → check TAD state
op_isSoundRunning:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.getResultPos
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte    ; consume sound ID param
  ; Stub: return 0 (sound not playing)
  ; Scripts busy-wait on isSoundRunning==0 to proceed; returning 1 causes infinite loops
  ; TODO: replace with real TAD/MSU-1 state when audio is wired
  lda #0
  jsr _scummvm.writeVariable
  clc
  rts

; soundKludge ($4C, $CC) -- iMUSE vararg, consume params (stub)
op_soundKludge:
  .ACCU 16
  .INDEX 16
  ldx #16                          ; max 16 args (ScummVM limit)
-
  jsr _scummvm.fetchByte
  cmp #$00FF
  beq +
  dex
  beq +                            ; safety: stop after 16 args
  jsr _scummvm.fetchWord
  bra -
+
  clc
  rts


;-------------------------------------------------------------------
; MSU-1 Audio Helpers — used when musicMode = MSU-1
;-------------------------------------------------------------------

; Play MSU-1 audio track (A = track number, 16-bit)
_scummvm.msu1PlayTrack:
  .ACCU 16
  .INDEX 16
  sep #$20
  sta.l MSU_TRACK
  lda.b #0
  sta.l MSU_TRACK+1
  ; Wait for audio busy to clear
- lda.l MSU_STATUS
  and.b #MSU_STATUS_AUDIO_BUSY
  bne -
  ; Start playing with repeat (music loops)
  lda.b #MSU_CONTROL_PLAY | MSU_CONTROL_REPEAT
  sta.l MSU_CONTROL
  ; Check for audio error (missing PCM file → graceful silence)
  lda.l MSU_STATUS
  and.b #MSU_STATUS_AUDIO_ERROR
  beq +
    lda.b #MSU_VOLUME_MUTE
    sta.l MSU_VOLUME
    lda.b #0
    sta.l MSU_CONTROL
    rep #$20
    rts
+
  ; Set volume to full (after play start, prevents DC offset click)
  lda.b #MSU_VOLUME_FULL
  sta.l MSU_VOLUME
  rep #$20
  rts

; Stop MSU-1 audio track
_scummvm.msu1StopTrack:
  .ACCU 16
  .INDEX 16
  sep #$20
  lda.b #MSU_VOLUME_MUTE
  sta.l MSU_VOLUME
  lda.b #0
  sta.l MSU_CONTROL
  rep #$20
  rts

; Check if MSU-1 audio is playing (carry set = playing)
_scummvm.msu1IsPlaying:
  sep #$20
  lda.l MSU_STATUS
  and.b #MSU_STATUS_AUDIO_PLAY
  rep #$20
  beq +
    sec
    rts
+
  clc
  rts


;-------------------------------------------------------------------
; setClass ($5D, $DD) -- p16[7] object + vararg class list
; Each class arg: bit 7 = set flag, bits 6-0 = class number
; Class 0 = clear all classes for this object
;-------------------------------------------------------------------
op_setClass:
  .ACCU 16
  .INDEX 16
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord    ; object ID
  sta.w SCUMM.scratch3               ; save obj ID
_setClass.loop:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.fetchByte             ; aux byte (flag for next arg)
  and #$00FF
  cmp #$00FF
  beq _setClass.done
  sta.w SCUMM.currentOpcode          ; treat aux byte as opcode for getVarOrDirectWord
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord    ; class value
  ; A = class value. Bit 7 = set. Bits 6-0 = class number.
  sta.w SCUMM.scratch                ; save class value
  and #$00FF
  beq _setClass.clearAll             ; cls == 0 → clear all
  ; Compute class bit: class_number = (cls & $1F) — ScummVM uses cls &= 0x1F
  and #$001F                         ; class number (0-31)
  cmp #16
  bcs _setClass.loop                 ; class > 15, unsupported in 16-bit storage
  asl a                              ; x2 for word table lookup
  tax
  lda.l scummvm.classBitLut,x               ; bit mask for this class position
  sta.w SCUMM.scratch2               ; save bit mask
  ; Compute object word offset
  ldx.w SCUMM.scratch3               ; obj ID
  cpx #SCUMM_MAX_OBJECTS
  bcs _setClass.loop                 ; out of bounds
  txa
  asl a                              ; obj * 2
  tax
  ; Check set/clear flag (bit 7 of class value)
  lda.w SCUMM.scratch
  and #$0080
  beq _setClass.clearBit
  ; Set bit
  lda.w SCUMM.objectClass,x
  ora.w SCUMM.scratch2
  sta.w SCUMM.objectClass,x
  bra _setClass.loop
_setClass.clearBit:
  .ACCU 16
  .INDEX 16
  lda.w SCUMM.scratch2
  eor #$FFFF                         ; invert mask
  and.w SCUMM.objectClass,x
  sta.w SCUMM.objectClass,x
  bra _setClass.loop
_setClass.clearAll:
  .ACCU 16
  .INDEX 16
  ldx.w SCUMM.scratch3
  cpx #SCUMM_MAX_OBJECTS
  bcs _setClass.loop
  txa
  asl a
  tax
  stz.w SCUMM.objectClass,x
  bra _setClass.loop
_setClass.done:
  .ACCU 16
  .INDEX 16
  clc
  rts


;-------------------------------------------------------------------
; matrixOps ($30, $B0) -- walkbox runtime modification
; Sub-ops: 0x01=setBoxFlags, 0x02=setBoxScale, 0x03=setBoxSlot,
;          0x04=createBoxMatrix
;-------------------------------------------------------------------
op_matrixOps:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.fetchByte             ; sub-opcode byte
  pha                                ; save for flag bit checks
  and #$001F                         ; extract key
  cmp #$04
  bne +
  jmp _matrixOps.create              ; createBoxMatrix: no params
+
  cmp #$01
  beq _matrixOps.setFlags
  cmp #$02
  beq _matrixOps.setScale
  cmp #$03
  beq _matrixOps.setSlot
  pla                                ; pop sub-opcode (unknown)
  jmp _matrixOps.done

_matrixOps.setFlags:
  .ACCU 16
  .INDEX 16
  lda #$11                           ; flags offset in scummBoxEntry
  bra _matrixOps.writeField

_matrixOps.setScale:
  .ACCU 16
  .INDEX 16
  jmp _matrixOps.setScaleImpl

_matrixOps.setSlot:
  .ACCU 16
  .INDEX 16
  jmp _matrixOps.setSlotImpl

_matrixOps.writeField:
  .ACCU 16
  .INDEX 16
  sta.w SCUMM.scratch2               ; field offset within box entry

  ;--- decode param 1: box number (p8, flag bit $80 of sub-opcode) ---
  pla                                ; pull sub-opcode byte
  pha                                ; save again for param 2
  and #$0080
  beq +
    jsr _scummvm.fetchWord           ; 2-byte variable reference
    jsr _scummvm.readVariable        ; resolve to value
    bra ++
+
    jsr _scummvm.fetchByte           ; 1-byte literal
++
  and #$00FF
  sta.w SCUMM.scratch3               ; box number

  ;--- decode param 2: value (p8, flag bit $40 of sub-opcode) ---
  pla                                ; pull sub-opcode byte (final pop)
  and #$0040
  beq +
    jsr _scummvm.fetchWord
    jsr _scummvm.readVariable
    bra ++
+
    jsr _scummvm.fetchByte
++
  and #$00FF                         ; value to write (byte)
  pha                                ; save value

  ;--- compute BOXD entry address: $7F5002 + box*20 + fieldOffset ---
  lda.w SCUMM.scratch3              ; box number
  asl a                              ;*2
  asl a                              ;*4
  sta.w SCUMM.scratch3
  asl a                              ;*8
  asl a                              ;*16
  clc
  adc.w SCUMM.scratch3              ;*20
  clc
  adc #$5002                         ;skip count word
  clc
  adc.w SCUMM.scratch2              ;+ field offset
  tax                                ;X = byte offset in $7F

  pla                                ;A = value
  sep #$20
  .ACCU 8
  sta.l $7F0000,x                    ;write field byte
  rep #$20
  .ACCU 16
  jmp _matrixOps.done

_matrixOps.setScaleImpl:
  .ACCU 16
  .INDEX 16
  ;--- decode param 1: box number (p8, flag bit $80 of sub-opcode) ---
  pla                                ; pull sub-opcode byte
  pha                                ; save again for param 2
  and #$0080
  beq +
    jsr _scummvm.fetchWord
    jsr _scummvm.readVariable
    bra ++
+
    jsr _scummvm.fetchByte
++
  and #$00FF
  sta.w SCUMM.scratch3               ; box number

  ;--- decode param 2: scale value (p8, flag bit $40 of sub-opcode) ---
  pla                                ; pull sub-opcode byte (final pop)
  and #$0040
  beq +
    jsr _scummvm.fetchWord
    jsr _scummvm.readVariable
    bra ++
+
    jsr _scummvm.fetchByte
++
  and #$00FF                         ; scale value (high byte = 0)
  pha                                ; save value

  ;--- compute BOXD entry address: $5002 + box*20 + $12 ---
  lda.w SCUMM.scratch3
  asl a                              ;*2
  asl a                              ;*4
  sta.w SCUMM.scratch3
  asl a                              ;*8
  asl a                              ;*16
  clc
  adc.w SCUMM.scratch3              ;*20
  clc
  adc #$5002 + $12                   ;skip count word + scale offset
  tax

  pla                                ;A = scale value (16-bit, high byte = 0)
  sta.l $7F0000,x                    ;write 16-bit to BOXD scale field
  bra _matrixOps.done

_matrixOps.setSlotImpl:
  .ACCU 16
  .INDEX 16
  ;--- decode param 1: box number (p8, flag bit $80 of sub-opcode) ---
  pla                                ; pull sub-opcode byte
  pha                                ; save again for param 2
  and #$0080
  beq +
    jsr _scummvm.fetchWord
    jsr _scummvm.readVariable
    bra ++
+
    jsr _scummvm.fetchByte
++
  and #$00FF
  pha                                ; save box number

  ;--- decode param 2: slot value (p8, flag bit $40 of sub-opcode) ---
  lda 3,s                            ; peek sub-opcode from under box number
  and #$0040
  beq +
    jsr _scummvm.fetchWord
    jsr _scummvm.readVariable
    bra ++
+
    jsr _scummvm.fetchByte
++
  and #$00FF
  dec a                              ; value - 1
  ora #$8000                         ; (value-1) | $8000
  pha                                ; save transformed value

  ;--- compute BOXD entry address: $5002 + box*20 + $12 ---
  lda 3,s                            ; peek box number (under value on stack)
  asl a                              ;*2
  asl a                              ;*4
  sta.w SCUMM.scratch3
  asl a                              ;*8
  asl a                              ;*16
  clc
  adc.w SCUMM.scratch3              ;*20
  clc
  adc #$5002 + $12                   ;skip count word + scale offset
  tax

  pla                                ;A = transformed value
  sta.l $7F0000,x                    ;write 16-bit to BOXD scale field
  pla                                ; discard box number
  pla                                ; discard sub-opcode byte
  bra _matrixOps.done

_matrixOps.create:
  .ACCU 16
  .INDEX 16
  pla                                ; pop sub-opcode
  phy                                ; save SCUMM PC
  jsl scummvm.createBoxMatrix_long
  ply                                ; restore SCUMM PC
  bra _matrixOps.done

_matrixOps.done:
  .ACCU 16
  .INDEX 16
  clc
  rts


;-------------------------------------------------------------------
; roomOps ($33, $B3) -- sub-opcode with variable params, no-op
; Only sub-opcodes actually used by MI1 need full param decode.
;-------------------------------------------------------------------
op_roomOps:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.fetchByte             ; sub-opcode byte
  sta.w SCUMM.scratch
  and #$001F

  cmp #$01
  bne +
  jmp _roomOps.scroll                ; scroll: 2x p16
+
  cmp #$03
  bne +
  jmp _roomOps.setScreen             ; setScreen: 2x p16
+
  cmp #$04
  bne +
  jmp _roomOps.palColor              ; setPalColor: 3x p16 + aux + p8
+
  cmp #$05
  bne +
  jmp _roomOps.shakeOn               ; shakeOn: no params
+
  cmp #$06
  bne +
  jmp _roomOps.shakeOff              ; shakeOff: no params
+
  cmp #$07
  bne +
  jmp _roomOps.scale                 ; roomScale v5: complex
+
  cmp #$08
  bne +
  jmp _roomOps.scaleSimple           ; roomScale simple: 3x p8
+
  cmp #$09
  bne +
  jmp _roomOps.saveGame              ; saveGame: 2x p8
+
  cmp #$0A
  bne +
  jmp _roomOps.fade                  ; roomFade: 1x p16
+
  cmp #$0B
  bne +
  jmp _roomOps.intensity             ; rgbRoomIntensity: 3x p16 + aux + 2x p8
+
  cmp #$0C
  bne +
  jmp _roomOps.roomShadow            ; roomShadow (same format, consume-only)
+
  cmp #$0D
  bne +
  jmp _roomOps.saveString            ; saveString: p8[7] + null-terminated string
+
  cmp #$0E
  bne +
  jmp _roomOps.saveString            ; loadString: same format (p8[7] + null-terminated)
+
  cmp #$0F
  bne +
  jmp _roomOps.palManipulate         ; palManipulate: complex params
+
  ; Default: no params
  clc
  rts

_roomOps.scroll:
  .ACCU 16
  .INDEX 16
  ; roomScroll: minX, maxX (2x fetchWord)
  jsr _scummvm.fetchWord             ; minX
  pha
  jsr _scummvm.fetchWord             ; maxX
  ; Clamp maxX: if < 128, set to 128
  cmp #128
  bcs +
    lda #128
+
  ldx #SCUMM_VAR_CAMERA_MAX_X*2
  sta.w SCUMM.globalVars,x
  ; Clamp minX: if < 128, set to 128
  pla
  cmp #128
  bcs +
    lda #128
+
  ldx #SCUMM_VAR_CAMERA_MIN_X*2
  sta.w SCUMM.globalVars,x
  clc
  rts

_roomOps.setScreen:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.fetchWord
  jsr _scummvm.fetchWord
  clc
  rts

_roomOps.palColor:
  .ACCU 16
  .INDEX 16
  ; sub-op 4: 3x p16(r,g,b) + fetchByte(aux) + p8(palette index)
  ; ScummVM: getVarOrDirectWord(0x80) x3, fetchScriptByte, getVarOrDirectByte(0x80)
  jsr _scummvm.fetchWord             ; r (VGA 0-63)
  sta.l BWRAM_PALETTE_SCRATCH        ; +0 = r
  jsr _scummvm.fetchWord             ; g
  sta.l BWRAM_PALETTE_SCRATCH+2      ; +2 = g
  jsr _scummvm.fetchWord             ; b
  sta.l BWRAM_PALETTE_SCRATCH+4      ; +4 = b
  jsr _scummvm.fetchByte             ; aux opcode
  sta.w SCUMM.scratch
  lda.w SCUMM.scratch
  and #$0080
  beq +
  jsr _scummvm.fetchWord
  bra ++
+
  jsr _scummvm.fetchByte
++
  sta.l BWRAM_PALETTE_SCRATCH+6      ; +6 = palette index
  phy                                ; save SCUMM PC
  jsl scummvm.setPalColor_impl
  ply                                ; restore SCUMM PC
  clc
  rts

_roomOps.saveGame:
  .ACCU 16
  .INDEX 16
  ; sub-op 9: getVarOrDirectByte(0x80) + getVarOrDirectByte(0x40)
  ; Only 1 invocation (room 77) — consume params and discard
  lda #$0080
  jsr _scummvm.skipP8fromScratch     ; save/load slot
  lda #$0040
  jsr _scummvm.skipP8fromScratch     ; save/load flag
  clc
  rts

_roomOps.shakeOn:
  .ACCU 16
  .INDEX 16
  ; sub-op 5: no parameters — just set shake flag
  sep #$20
  .ACCU 8
  lda #1
  sta.w SCUMM.shakeEnabled
  rep #$20
  .ACCU 16
  clc
  rts

_roomOps.shakeOff:
  .ACCU 16
  .INDEX 16
  ; sub-op 6: no parameters — just clear shake flag
  sep #$20
  .ACCU 8
  stz.w SCUMM.shakeEnabled
  rep #$20
  .ACCU 16
  clc
  rts

_roomOps.scale:
  .ACCU 16
  .INDEX 16
  ; scale1: p8[7]
  lda.w SCUMM.scratch
  and #$0080
  beq +
  jsr _scummvm.fetchWord
  jsr _scummvm.readVariable
  bra ++
+
  jsr _scummvm.fetchByte
++
  and #$00FF
  pha                                ; [SP+10] = scale1

  ; y1: p8[6]
  lda.w SCUMM.scratch
  and #$0040
  beq +
  jsr _scummvm.fetchWord
  jsr _scummvm.readVariable
  bra ++
+
  jsr _scummvm.fetchByte
++
  and #$00FF
  pha                                ; [SP+8] = y1

  ; aux1 byte — new flags for next params
  jsr _scummvm.fetchByte
  sta.w SCUMM.scratch

  ; scale2: p8[7] of aux1
  lda.w SCUMM.scratch
  and #$0080
  beq +
  jsr _scummvm.fetchWord
  jsr _scummvm.readVariable
  bra ++
+
  jsr _scummvm.fetchByte
++
  and #$00FF
  pha                                ; [SP+6] = scale2

  ; y2: p8[6] of aux1
  lda.w SCUMM.scratch
  and #$0040
  beq +
  jsr _scummvm.fetchWord
  jsr _scummvm.readVariable
  bra ++
+
  jsr _scummvm.fetchByte
++
  and #$00FF
  pha                                ; [SP+4] = y2

  ; aux2 byte — new flags for slot param
  jsr _scummvm.fetchByte
  sta.w SCUMM.scratch

  ; slot: p8[7] of aux2
  lda.w SCUMM.scratch
  and #$0080
  beq +
  jsr _scummvm.fetchWord
  jsr _scummvm.readVariable
  bra ++
+
  jsr _scummvm.fetchByte
++
  and #$00FF                         ; slot number (1-based from script)

  ; Compute WRAM offset: (slot - 2) * 8
  ; Script slot e -> setScaleSlot(e-1) -> _scaleSlots[(e-1)-1] = WRAM slot (e-2)
  sec
  sbc #2
  asl a                              ; *2
  asl a                              ; *4
  asl a                              ; *8
  tax

  ; Write params to SCAL slot WRAM
  ; Stack: y2 [SP+2], scale2 [SP+4], y1 [SP+6], scale1 [SP+8]
  ; (stack grew by 4 pushes = 8 bytes, but slot calc didn't push)
  lda 7,s                            ; scale1
  sta.w SCUMM.scalSlot0_s1,x
  lda 5,s                            ; y1
  sta.w SCUMM.scalSlot0_y1,x
  lda 3,s                            ; scale2
  sta.w SCUMM.scalSlot0_s2,x
  lda 1,s                            ; y2
  sta.w SCUMM.scalSlot0_y2,x

  ; Clean up stack (4 words = 8 bytes)
  pla
  pla
  pla
  pla

  clc
  rts

_roomOps.scaleSimple:
  .ACCU 16
  .INDEX 16
  ; scale: p8[7], startcolor: p8[6], endcolor: p8[5]
  lda.w SCUMM.scratch
  and #$0080
  beq +
  jsr _scummvm.fetchWord
  bra ++
+
  jsr _scummvm.fetchByte
++
  lda.w SCUMM.scratch
  and #$0040
  beq +
  jsr _scummvm.fetchWord
  bra ++
+
  jsr _scummvm.fetchByte
++
  lda.w SCUMM.scratch
  and #$0020
  beq +
  jsr _scummvm.fetchWord
  clc
  rts
+
  jsr _scummvm.fetchByte
  clc
  rts

_roomOps.intensity:
  .ACCU 16
  .INDEX 16
  ; sub-op $0B: rgbRoomIntensity
  ; r, g, b scales (0-255), aux byte, startColor (p8), endColor (p8)
  jsr _scummvm.fetchWord
  sta.l BWRAM_PALETTE_SCRATCH        ; +0 = redScale
  jsr _scummvm.fetchWord
  sta.l BWRAM_PALETTE_SCRATCH+2      ; +2 = greenScale
  jsr _scummvm.fetchWord
  sta.l BWRAM_PALETTE_SCRATCH+4      ; +4 = blueScale
  ; aux byte, then startcolor: p8[7], endcolor: p8[6]
  jsr _scummvm.fetchByte
  sta.w SCUMM.scratch
  lda.w SCUMM.scratch
  and #$0080
  beq +
  jsr _scummvm.fetchWord
  bra ++
+
  jsr _scummvm.fetchByte
++
  sta.l BWRAM_PALETTE_SCRATCH+6      ; +6 = startColor
  lda.w SCUMM.scratch
  and #$0040
  beq +
  jsr _scummvm.fetchWord
  bra ++
+
  jsr _scummvm.fetchByte
++
  sta.l BWRAM_PALETTE_SCRATCH+8      ; +8 = endColor
  phy                                ; save SCUMM PC
  jsl scummvm.darkenPalette_impl
  ply                                ; restore SCUMM PC
  clc
  rts

_roomOps.roomShadow:
  .ACCU 16
  .INDEX 16
  ; sub-op $0C: roomShadow — software renderer feature, consume params only
  jsr _scummvm.fetchWord
  jsr _scummvm.fetchWord
  jsr _scummvm.fetchWord
  jsr _scummvm.fetchByte
  sta.w SCUMM.scratch
  lda.w SCUMM.scratch
  and #$0080
  beq +
  jsr _scummvm.fetchWord
  bra ++
+
  jsr _scummvm.fetchByte
++
  lda.w SCUMM.scratch
  and #$0040
  beq +
  jsr _scummvm.fetchWord
  clc
  rts
+
  jsr _scummvm.fetchByte
  clc
  rts

_roomOps.fade:
  .ACCU 16
  .INDEX 16
  ; roomFade/screenEffect: 1x p16[7]
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord    ; A = fade param (16-bit)
  and #$FFFF
  beq _roomOps.fade.doFadeIn
  ; A != 0: store deferred effect params
  sep #$20
  .ACCU 8
  sta.w SCUMM.switchRoomEffect       ; low byte = fadeIn effect
  xba
  sta.w SCUMM.switchRoomEffect2      ; high byte = fadeOut effect
  rep #$20
  .ACCU 16
  clc
  rts

_roomOps.fade.doFadeIn:
  .ACCU 16
  ; Immediate fadeIn: restore full brightness
  sep #$20
  .ACCU 8
  lda #$0F
  sta.w ScreenBrightness
  lda #1
  sta.w SCUMM.screenEffectFlag
  rep #$20
  .ACCU 16
  clc
  rts

_roomOps.saveString:
  .ACCU 16
  .INDEX 16
  ; sub-op 13: getVarOrDirectByte(0x80) + null-terminated string
  lda #$0080
  jsr _scummvm.skipP8fromScratch     ; string resource ID
  jsr _scummvm.skipNullString        ; filename
  clc
  rts

_roomOps.palManipulate:
  .ACCU 16
  .INDEX 16
  ; sub-op 15: resID p8[7] + aux + start p8[7] + end p8[6] + aux + time p8[7]
  lda #$0080
  jsr _scummvm.skipP8fromScratch     ; resID
  jsr _scummvm.fetchByte             ; aux opcode 1
  sta.w SCUMM.scratch
  lda #$0080
  jsr _scummvm.skipP8fromScratch     ; start
  lda #$0040
  jsr _scummvm.skipP8fromScratch     ; end
  jsr _scummvm.fetchByte             ; aux opcode 2
  sta.w SCUMM.scratch
  lda #$0080
  jsr _scummvm.skipP8fromScratch     ; time
  clc
  rts


;-------------------------------------------------------------------
; loadRoomWithEgo ($24, $64, $A4, $E4) -- p16 + p8[6] + word + word
; Sets newRoom and yields (no-op for actor placement)
;-------------------------------------------------------------------
op_loadRoomWithEgo:
  .ACCU 16
  .INDEX 16
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord    ; object (p16[7])
  lda #SCUMM_FLAG_BIT6
  jsr _scummvm.getVarOrDirectByte    ; room number
  and #$00FF
  beq +                              ; room 0 = no-op (ScummVM: skip startScene)
  sta.w SCUMM.newRoom                ; request room change
+
  ; Place ego actor at (x, y) from bytecode (ScummVM: a->putActor(x, y, room))
  jsr _scummvm.fetchWord             ; x
  sta.w SCUMM.scratch                ; save x
  jsr _scummvm.fetchWord             ; y
  sta.w SCUMM.scratch2               ; save y
  ; Check x != -1 (ScummVM skips putActor if x == -1)
  lda.w SCUMM.scratch
  cmp #$FFFF
  beq _loadRoomEgo.done
  ; Get ego actor pointer (VAR_EGO = global[1] = actor number)
  lda #1                             ; global var 1 = VAR_EGO
  jsr _scummvm.readVariable          ; A = ego actor number
  jsr _scummvm.getActorPtr           ; X = actor table offset
  bcc _loadRoomEgo.done              ; invalid actor → skip
  ; Write position + room
  lda.w SCUMM.scratch
  sta.w SCUMM.actors.x,x
  lda.w SCUMM.scratch2
  sta.w SCUMM.actors.y,x
  lda.w SCUMM.newRoom
  sep #$20
  sta.w SCUMM.actors.room,x
  lda #1
  sta.w SCUMM.actors.visible,x
  stz.w SCUMM.actors.moving,x       ; ScummVM: putActor clears moving
  rep #$20
  ; ScummVM: camera._follows = a->_number (ego actor)
  ldx #1*2                           ; VAR_EGO = globalVar[1]
  lda.w SCUMM.globalVars,x           ; ego actor number
  and #$00FF
  sta.w SCUMM.cameraFollows
_loadRoomEgo.done:
  .ACCU 16
  .INDEX 16
  clc
  rts


; ifState ($4F, $CF) / ifNotState ($2F, $6F, $AF, $EF)
; p16[7] + p8[6] + jump(2) — always skip branch (stub)
; ifState ($0F variant) — jumpRelative(state == expected) → jump when match
op_ifState:
  .ACCU 16
  .INDEX 16
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord    ; object ID
  sta.w SCUMM.scratch                ; save obj ID
  lda #SCUMM_FLAG_BIT6
  jsr _scummvm.getVarOrDirectByte    ; expected state
  pha                                ; save expected state on stack
  jsr _scummvm.fetchWord             ; jump offset
  sta.w SCUMM.scratch2               ; save jump offset
  pla                                ; restore expected state
  sta.w SCUMM.scratch3               ; save for comparison
  ; Look up actual state
  ldx.w SCUMM.scratch
  cpx #SCUMM_MAX_OBJECTS
  bcs +                              ; out of bounds -> skip
  lda.w SCUMM.objectState,x
  and #$00FF
  cmp.w SCUMM.scratch3
  bne +                              ; no match -> skip jump
    jsr _scummvm.takeRelJump         ; match -> take jump
+
  clc
  rts

; ifNotState ($2F variant) — jumpRelative(state != expected) → jump when no match
op_ifNotState:
  .ACCU 16
  .INDEX 16
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord    ; object ID
  sta.w SCUMM.scratch
  lda #SCUMM_FLAG_BIT6
  jsr _scummvm.getVarOrDirectByte    ; expected state
  pha                                ; save expected state
  jsr _scummvm.fetchWord             ; jump offset
  sta.w SCUMM.scratch2               ; save jump offset
  pla                                ; restore expected state
  sta.w SCUMM.scratch3               ; for comparison
  ldx.w SCUMM.scratch
  cpx #SCUMM_MAX_OBJECTS
  bcs _ifNotState.doJump             ; out of bounds -> jump
  lda.w SCUMM.objectState,x
  and #$00FF
  cmp.w SCUMM.scratch3
  beq +                              ; equal -> skip jump
_ifNotState.doJump:
  .ACCU 16
  .INDEX 16
    jsr _scummvm.takeRelJump         ; not equal -> take jump
+
  clc
  rts


;-------------------------------------------------------------------
; Actor stubs — consume params, no-op
;-------------------------------------------------------------------

; animateActor ($11, $51, $91, $D1) -- p8[7]=actor, p8[6]=frame
op_animateActor:
  .ACCU 16
  .INDEX 16
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte    ; actor number
  jsr _scummvm.getActorPtr
  stx.w SCUMM.scratch2

  lda #SCUMM_FLAG_BIT6
  jsr _scummvm.getVarOrDirectByte    ; animation frame
  ldx.w SCUMM.scratch2
  sep #$20
  sta.w SCUMM.actors.initFrame,x
  rep #$20
  clc
  rts

; faceActor ($09, $49, $89, $C9) -- p8[7]=actor, p16[6]=direction
op_faceActor:
  .ACCU 16
  .INDEX 16
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte    ; actor number
  jsr _scummvm.getActorPtr
  stx.w SCUMM.scratch2

  lda #SCUMM_FLAG_BIT6
  jsr _scummvm.getVarOrDirectWord    ; direction
  ldx.w SCUMM.scratch2
  sta.w SCUMM.actors.facing,x
  clc
  rts

; walkActorToActor ($0D, $4D, $8D, $CD) -- p8[7]=actor, p8[6]=target, byte=dist
op_walkActorToActor:
  .ACCU 16
  .INDEX 16
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte    ; actor number
  jsr _scummvm.getActorPtr
  stx.w SCUMM.scratch2              ; save actor struct offset

  lda #SCUMM_FLAG_BIT6
  jsr _scummvm.getVarOrDirectByte    ; target actor number
  jsr _scummvm.getActorPtr           ; X = target actor struct offset
  lda.w SCUMM.actors.x,x            ; target X
  pha
  lda.w SCUMM.actors.y,x            ; target Y
  sta.w SCUMM.scratch               ; target y

  jsr _scummvm.fetchByte             ; distance byte (ignored for now)

  ; Derive actor number from struct offset
  lda.w SCUMM.scratch2
  lsr a
  lsr a
  lsr a
  lsr a
  sta.w SCUMM.scratch3              ; actor index

  ; Store walk targets
  asl a                              ; x2 for word index
  tax
  pla                                ; target x
  sta.w SCUMM.actorTargetX,x
  lda.w SCUMM.scratch               ; target y
  sta.w SCUMM.actorTargetY,x

  ; Save SCUMM PC (Y) — walkActorTo body destroys Y
  phy
  ; Reuse walkActorTo path-building logic
  jmp _walkActorTo.checkBoxes

; walkActorTo ($1E, $3E, $5E, $7E, $9E, $BE, $DE, $FE) -- p8[7]=actor, p16[6]=x, p16[5]=y
; MVP: instantly teleport actor to target position (no walking animation)
op_walkActorTo:
  .ACCU 16
  .INDEX 16
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte    ; actor number
  jsr _scummvm.getActorPtr
  stx.w SCUMM.scratch2              ; save actor struct offset

  lda #SCUMM_FLAG_BIT6
  jsr _scummvm.getVarOrDirectWord    ; x
  pha                                ; save target x

  lda #SCUMM_FLAG_BIT5
  jsr _scummvm.getVarOrDirectWord    ; y
  sta.w SCUMM.scratch               ; target y

  ; Save SCUMM PC (Y) — walkActorTo body destroys Y via buildWalkPath/direct path
  phy

  ; Derive actor number from struct offset (offset / 16)
  lda.w SCUMM.scratch2
  lsr a
  lsr a
  lsr a
  lsr a                              ; actor number (0-255)
  sta.w SCUMM.scratch3               ; save actor index

  ; Store walk targets in parallel arrays (word index = actor * 2)
  asl a                              ; × 2 for word index
  tax
  pla                                ; target x
  sta.w SCUMM.actorTargetX,x
  lda.w SCUMM.scratch               ; target y
  sta.w SCUMM.actorTargetY,x

  ; Build walk path using walkbox routing
_walkActorTo.checkBoxes:
  .ACCU 16
  .INDEX 16
  ; Check if actor should ignore boxes
  lda.w SCUMM.scratch3              ; actor index
  and #$000F
  tax
  sep #$20
  lda.w SCUMM.actorIgnoreBoxes,x
  rep #$20
  and #$00FF
  bne _walkActorTo.direct           ; skip pathfinding

  ; Check if walkboxes are loaded
  lda.w SCUMM.boxCount
  beq _walkActorTo.direct           ; no boxes, straight-line

  ; Set up buildWalkPath params
  ldx.w SCUMM.scratch2              ; actor struct offset
  lda.w SCUMM.actors.x,x           ; startX
  sta.b tmp
  lda.w SCUMM.actors.y,x           ; startY
  sta.b tmp+2
  lda.w SCUMM.scratch3
  asl a                             ; word index
  tax
  lda.w SCUMM.actorTargetX,x       ; targetX
  sta.b tmp+4
  lda.w SCUMM.actorTargetY,x       ; targetY
  sta.b tmp+6
  ; Save scratch2/scratch3 — buildWalkPath clobbers them via findBox
  lda.w SCUMM.scratch2
  pha
  lda.w SCUMM.scratch3             ; actor index (also the param for buildWalkPath)
  pha
  jsl scummvm.buildWalkPath_long
  pla
  sta.w SCUMM.scratch3
  pla
  sta.w SCUMM.scratch2
  bra _walkActorTo.anim

_walkActorTo.direct:
  .ACCU 16
  .INDEX 16
  ; Direct path: single waypoint = target
  lda.w SCUMM.scratch3             ; actor index
  and #$000F
  tax
  sep #$20
  lda #1
  sta.w SCUMM.walkPathLen,x
  lda #0
  sta.w SCUMM.walkPathIdx,x
  rep #$20

  ; Copy target to walkPathX/Y[actor][0]
  txa
  asl a                             ; *2
  asl a                             ; *4
  asl a                             ; *8
  asl a                             ; *16 (WALK_MAX_WAYPOINTS * 2)
  tax
  lda.w SCUMM.scratch3
  asl a                             ; word index for target arrays
  tay
  lda.w SCUMM.actorTargetX,y
  sta.w SCUMM.walkPathX,x
  lda.w SCUMM.actorTargetY,y
  sta.w SCUMM.walkPathY,x

_walkActorTo.anim:
  .ACCU 16
  .INDEX 16
  ; Initialize animation state for this actor
  lda.w SCUMM.scratch3
  and #$000F
  tax
  lda #COSTUME_WALK_ANIM_SPEED
  sep #$20
  sta.w SCUMM.actorAnimTimer,x
  lda #0
  sta.w SCUMM.actorAnimFrame,x

  ; Set actor.moving = 1
  ldx.w SCUMM.scratch2
  lda #1
  sta.w SCUMM.actors.moving,x
  rep #$20

  ; Restore SCUMM PC (Y) saved before walkActorTo body
  ply
  clc
  rts

; isActorInBox ($1F, $5F, $9F, $DF) -- p8[7] + p8[6] + jump, return false
op_isActorInBox:
  .ACCU 16
  .INDEX 16
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte    ; actor number
  jsr _scummvm.getActorPtr           ; X = actor struct offset
  stx.w SCUMM.scratch3              ; save actor struct ptr

  lda #SCUMM_FLAG_BIT6
  jsr _scummvm.getVarOrDirectByte    ; box index
  sta.w SCUMM.scratch               ; save box

  jsr _scummvm.fetchWord             ; jump offset
  sta.w SCUMM.scratch2

  ; Get actor position
  ; Save SCUMM PC (Y) + fetchLoop bytecode pointer (tmp) — findBox clobbers both
  phy                                  ; save Y = SCUMM PC
  lda.b tmp
  pha
  lda.b tmp+2
  pha
  ; Set findBox args
  ldx.w SCUMM.scratch3
  lda.w SCUMM.actors.x,x
  sta.b tmp
  lda.w SCUMM.actors.y,x
  sta.b tmp+2
  lda.w SCUMM.scratch               ; box index
  sta.b tmp+4

  ; Check if walkboxes loaded
  lda.w SCUMM.boxCount
  beq _isActorInBox.restore         ; no boxes → not in any box

  jsl scummvm.findBox_long           ; tmp+0/+2 = point, returns A=boxIdx
  cmp.w SCUMM.scratch               ; found box == requested box?
  bne _isActorInBox.restore

  ; IN box → take jump (ScummVM: jumpRelative(true) when in box)
  ; Restore Y before takeRelJump (it reads SCUMM.scratch2, doesn't need Y)
  ; Actually takeRelJump uses Y for PC, so restore first
  pla
  sta.b tmp+2
  pla
  sta.b tmp
  ply                                ; restore Y = SCUMM PC
  jsr _scummvm.takeRelJump
  clc
  rts

_isActorInBox.restore:
  .ACCU 16
  .INDEX 16
  ; Restore fetchLoop bytecode pointer + SCUMM PC
  pla
  sta.b tmp+2
  pla
  sta.b tmp
  ply                                ; restore Y = SCUMM PC
  clc
  rts


;-------------------------------------------------------------------
; wait ($AE) -- sub-opcode with conditional waits
; Yields (sec;rts) with PC rewound to opcode if condition not met.
;-------------------------------------------------------------------
op_wait:
  .ACCU 16
  .INDEX 16
  tya
  dec a
  sta.w SCUMM.scratch3
  jsr _scummvm.fetchByte
  sta.w SCUMM.scratch
  and #$001F
  cmp #$01
  beq _wait.forActor
  cmp #$02
  beq _wait.forMessage
  cmp #$03
  beq _wait.forCamera
  clc
  rts

_wait.forActor:
  .ACCU 16
  .INDEX 16
  lda.w SCUMM.scratch
  and #$0080
  beq +
    jsr _scummvm.fetchWord
    jsr _scummvm.readVariable
    bra ++
+
    jsr _scummvm.fetchByte
++
  and #$00FF
  jsr _scummvm.getActorPtr
  lda.w SCUMM.actors.moving,x
  and #$00FF
  beq _wait.done
  bra _wait.yield

_wait.forMessage:
  .ACCU 16
  .INDEX 16
  lda.w SCUMM.dialogActive
  beq _wait.done
  bra _wait.yield

_wait.forCamera:
  .ACCU 16
  .INDEX 16
  ldx #SCUMM_VAR_CAMERA_POS_X*2
  lda.w SCUMM.globalVars,x
  cmp.w SCUMM.cameraDest
  beq _wait.done

_wait.yield:
  .ACCU 16
  .INDEX 16
  ldy.w SCUMM.scratch3
  sec
  rts

_wait.done:
  .ACCU 16
  .INDEX 16
  clc
  rts


;-------------------------------------------------------------------
; drawObject ($05, $25, $45, $65, $85, $A5, $C5, $E5)
; p16 object + sub-opcode + sub params, no-op
;-------------------------------------------------------------------
op_drawObject:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.fetchWord             ; object ID (always p16)
  sta.w SCUMM.scratch                ; save obj_id
  jsr _scummvm.fetchByte             ; sub-opcode byte
  and #$001F
  cmp #$01
  beq _drawObj.setXY
  cmp #$02
  beq _drawObj.setState
  ; $1F or default: set state=1 (make visible)
  phy
  lda.b tmp
  pha
  lda.b tmp+2
  pha
  jsl scummvm.drawObjectSetState1
  pla
  sta.b tmp+2
  pla
  sta.b tmp
  ply
  clc
  rts

_drawObj.setXY:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.fetchWord             ; xpos
  jsr _scummvm.fetchWord             ; ypos
  clc
  rts

_drawObj.setState:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.fetchWord             ; state value
  phy
  lda.b tmp
  pha
  lda.b tmp+2
  pha
  jsl scummvm.drawObjectSetStateN
  pla
  sta.b tmp+2
  pla
  sta.b tmp
  ply
  clc
  rts


;===================================================================
; Print / Verb / Sentence / Object / String opcode stubs
; Correctly consume all bytecode parameters without behavior.
;===================================================================

;-------------------------------------------------------------------
; print ($14, $94) -- actor + sub-opcode loop, no-op
; Format: getVarOrDirectByte(BIT7) actor, then sub-opcode loop
;-------------------------------------------------------------------
op_print:
  .ACCU 16
  .INDEX 16
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte    ; actor
  sta.w SCUMM.dialogActor            ; save for positioning
  stz.w SCUMM.dialogX                ; reset explicit position
  stz.w SCUMM.dialogY
_print.subLoop:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.fetchByte
  cmp #$00FF
  beq _print.done
  sta.w SCUMM.scratch                ; save sub-opcode for flag testing
  and #$000F                         ; sub-key is low 4 bits
  cmp #$00
  beq _print.pos                     ; $00: pos (2x p16)
  cmp #$01
  beq _print.color                   ; $01: color (p8[7])
  cmp #$02
  beq _print.clipping                ; $02: clipping (p16)
  cmp #$0F
  beq _print.text                    ; $0F: text (print string)
  ; $03,$04,$06,$07,$08: no params
  jmp _print.subLoop

_print.pos:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.fetchWord             ; x
  sta.w SCUMM.dialogX
  jsr _scummvm.fetchWord             ; y
  sta.w SCUMM.dialogY
  jmp _print.subLoop

_print.color:
  .ACCU 16
  .INDEX 16
  lda.w SCUMM.scratch
  and #$0080
  beq +
    jsr _scummvm.fetchWord
    jsr _scummvm.readVariable
    bra ++
+
    jsr _scummvm.fetchByte
++
  sta.w SCUMM.dialogColor
  jmp _print.subLoop

_print.clipping:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.fetchWord             ; right
  jmp _print.subLoop

_print.text:
  .ACCU 16
  .INDEX 16
  phy                                    ; save SCUMM PC
  jsl scummvm.extractAndRenderString
  ply                                    ; restore SCUMM PC
  jmp _print.done                      ; SO_TEXTSTRING is terminal — ScummVM returns, no $FF follows

_print.done:
  .ACCU 16
  .INDEX 16
  clc
  rts


;-------------------------------------------------------------------
; printEgo ($D8) -- same sub-opcode loop as print, no actor param
;-------------------------------------------------------------------
op_printEgo:
  .ACCU 16
  .INDEX 16
  lda #1                              ; VAR_EGO = global var 1
  jsr _scummvm.readVariable
  sta.w SCUMM.dialogActor
  stz.w SCUMM.dialogX
  stz.w SCUMM.dialogY
  jmp _print.subLoop


;-------------------------------------------------------------------
; verbOps ($7A, $FA) -- verb setup: store verb data for display
; Delegates to superfree section to avoid bank 0 overflow
;-------------------------------------------------------------------
op_verbOps:
  .ACCU 16
  .INDEX 16
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte    ; A = verb ID, Y = advanced PC
  and #$00FF
  sta.w SCUMM.resultVar              ; save verb ID
  phy                                ; save SCUMM PC
  jsl scummvm.verbOps_impl
  ply                                ; restore SCUMM PC
  clc
  rts


;-------------------------------------------------------------------
; doSentence ($19,$39,$59,$79,$99,$B9,$D9,$F9)
; verb + objectA + objectB, with special sentinels $FE/$FC
; Executes the verb script on objectA if a handler exists.
;-------------------------------------------------------------------
op_doSentence:
  .ACCU 16
  .INDEX 16
  lda.w SCUMM.currentOpcode
  and #$0080
  bne _doSentence.verbVar
  ; bit7 clear: verb is literal byte
  jsr _scummvm.fetchByte
  cmp #$00FE
  beq _doSentence.done               ; $FE = stop sentence, no more params
  cmp #$00FC
  beq _doSentence.done               ; $FC = stop sentence (v5 alt)
  bra _doSentence.readObjects

_doSentence.verbVar:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.fetchWord             ; verb as variable reference
  jsr _scummvm.readVariable

_doSentence.readObjects:
  .ACCU 16
  .INDEX 16
  pha                                  ; push verb ID
  lda #SCUMM_FLAG_BIT6
  jsr _scummvm.getVarOrDirectWord    ; objectA
  pha                                  ; push objectA
  lda #SCUMM_FLAG_BIT5
  jsr _scummvm.getVarOrDirectWord    ; objectB (consumed, not used yet)

  ;--- Look up verb entrypoint for objectA ---
  lda 1,s                             ; objectA
  sta.w SCUMM.scratch2                 ; scratch2 = obj_id for helper
  lda 3,s                             ; verb ID
  sta.w SCUMM.scratch                  ; scratch = verb_id
  lda 1,s                             ; A = objectA
  phy                                  ; save SCUMM PC
  jsl scummvm.getVerbEntrypoint_impl   ; A = entry offset (0 = none)
  ply                                  ; restore SCUMM PC
  cmp #0
  beq _doSentence.noHandler

  ;--- Start the object script at this entry point ---
  sta.w SCUMM.scratch                  ; scratch = entry offset
  lda 1,s                             ; objectA
  phy                                  ; save SCUMM PC
  jsl scummvm.startObjectScript
  ply                                  ; restore SCUMM PC

_doSentence.noHandler:
  .ACCU 16
  .INDEX 16
  pla                                  ; discard objectA
  pla                                  ; discard verb ID

_doSentence.done:
  .ACCU 16
  .INDEX 16
  clc
  rts


;-------------------------------------------------------------------
; startObject ($37,$77,$B7,$F7) -- p16 object + p8[6] entry + varargs
; Starts an object's verb script at the given entry point.
;-------------------------------------------------------------------
op_startObject:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.fetchWord             ; object ID (always p16)
  pha                                  ; push object ID
  lda #SCUMM_FLAG_BIT6
  jsr _scummvm.getVarOrDirectByte    ; entry point (verb number)
  sta.w SCUMM.scratch3                 ; save entry/verb for lookup
  jsr _scummvm.skipWordVararg        ; variable args (consumed, not used)

  ;--- Look up verb entrypoint ---
  lda.w SCUMM.scratch3                ; verb/entry number
  sta.w SCUMM.scratch                  ; scratch = verb_id
  lda 1,s                             ; object ID
  phy                                  ; save SCUMM PC
  jsl scummvm.getVerbEntrypoint_impl   ; A = entry offset
  ply                                  ; restore SCUMM PC
  cmp #0
  beq _startObj.noHandler

  ;--- Start the object script ---
  sta.w SCUMM.scratch                  ; scratch = entry offset
  lda 1,s                             ; object ID
  phy                                  ; save SCUMM PC
  jsl scummvm.startObjectScript
  ply                                  ; restore SCUMM PC

_startObj.noHandler:
  .ACCU 16
  .INDEX 16
  pla                                  ; discard object ID
  clc
  rts


;-------------------------------------------------------------------
; stringOps ($27) -- real string table operations
; SCUMM.stringTable: 16 slots x 128 bytes (raw byte buffers)
;-------------------------------------------------------------------
op_stringOps:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.fetchByte             ; sub-opcode byte
  sta.w SCUMM.currentOpcode          ; SET ONCE — getVarOrDirectByte reads this, does NOT clobber it
  and #$001F

  cmp #$01
  bne +
  jmp _stringOps.putCode
+
  .ACCU 16
  .INDEX 16
  cmp #$02
  bne +
  jmp _stringOps.copyString
+
  .ACCU 16
  .INDEX 16
  cmp #$03
  bne +
  jmp _stringOps.setChar
+
  .ACCU 16
  .INDEX 16
  cmp #$04
  bne +
  jmp _stringOps.getChar
+
  .ACCU 16
  .INDEX 16
  cmp #$05
  bne +
  jmp _stringOps.createString
+
  .ACCU 16
  .INDEX 16
  ; unknown sub-op — consume 2 p8 params as fallback
  jmp _stringOps.fallbackTwoP8

;--- Sub-op 5: createString(stringId, size) ---
; Zero-fills the 128-byte slot. Size param consumed but ignored (fixed slots).
_stringOps.createString:
  .ACCU 16
  .INDEX 16
  lda #$0080
  jsr _scummvm.getVarOrDirectByte    ; stringId
  pha                                ; save stringId
  lda #$0040
  jsr _scummvm.getVarOrDirectByte    ; size (consumed, ignored)
  pla                                ; restore stringId
  and #$000F                         ; clamp to 0-15
  xba                                ; *256
  lsr a                              ; /2 = net *128
  clc
  adc #SCUMM.stringTable             ; A = slot base WRAM address
  tax                                ; X = slot address
  lda #$0000
  phy                                ; save script PC (Y = bytecode offset)
  ldy #0
_stringOps.createLoop:
  .ACCU 16
  .INDEX 16
  sta.w $0000,x                      ; zero 2 bytes
  inx
  inx
  iny
  iny
  cpy #128
  bcc _stringOps.createLoop
  ply                                ; restore script PC
  clc
  rts

;--- Sub-op 1: putCodeInString(stringId, null-terminated string from script) ---
; Reads bytes from script stream into slot until $00 terminator.
_stringOps.putCode:
  .ACCU 16
  .INDEX 16
  lda #$0080
  jsr _scummvm.getVarOrDirectByte    ; stringId
  and #$000F                         ; clamp to 0-15
  xba                                ; *256
  lsr a                              ; /2 = net *128
  clc
  adc #SCUMM.stringTable             ; A = slot base WRAM address
  sta.w SCUMM.scratch3               ; scratch3 = dest slot base
  ldx #0                             ; X = write offset into slot
_stringOps.putCodeLoop:
  .ACCU 16
  .INDEX 16
  phx                                ; save write offset
  jsr _scummvm.fetchByte             ; read byte from script stream
  plx                                ; restore write offset
  and #$00FF
  bne +                              ; not $00 — continue
  jmp _stringOps.putCodeDone         ; $00 terminator — done
+
  cmp #$00FF
  bne +                              ; not $FF — continue
  jmp _stringOps.putCodeFF           ; $FF escape — handle specially
+
  cpx #SCUMM_STRING_MAX_LEN
  bcs _stringOps.putCodeDrain        ; slot full — drain remaining bytes
  ; Store char at slot[X]: compute dest = scratch3 + X
  phy                                ; save script PC
  pha                                ; save char value
  txa                                ; A = offset
  clc
  adc.w SCUMM.scratch3               ; A = slot base + offset
  tay                                ; Y = target WRAM address
  pla                                ; A = char value
  sep #$20                           ; 8-bit A for byte store
  .ACCU 8
  sta.w $0000,y                      ; store char byte
  rep #$20                           ; back to 16-bit A
  .ACCU 16
  ply                                ; restore script PC
  inx                                ; advance write offset
  bra _stringOps.putCodeLoop

_stringOps.putCodeFF:
  .ACCU 16
  .INDEX 16
  ; Store $FF in slot, then read sub-code
  lda #$00FF
  jsr _stringOps.putCodeStoreByte    ; store $FF at slot[X], inc X
  phx
  jsr _scummvm.fetchByte             ; read sub-code
  plx
  and #$00FF
  pha                                ; save sub-code
  jsr _stringOps.putCodeStoreByte    ; store sub-code at slot[X], inc X
  pla                                ; restore sub-code
  ; sub-codes 1, 2, 3, 8: no extra args
  cmp #1
  beq _stringOps.putCodeLoop
  cmp #2
  beq _stringOps.putCodeLoop
  cmp #3
  beq _stringOps.putCodeLoop
  cmp #8
  beq _stringOps.putCodeLoop
  ; all other sub-codes: 2 extra arg bytes
  phx
  jsr _scummvm.fetchByte
  plx
  and #$00FF
  jsr _stringOps.putCodeStoreByte
  phx
  jsr _scummvm.fetchByte
  plx
  and #$00FF
  jsr _stringOps.putCodeStoreByte
  bra _stringOps.putCodeLoop

_stringOps.putCodeStoreByte:
  .ACCU 16
  .INDEX 16
  ; A = byte to store (16-bit, only low byte used), X = write offset
  cpx #SCUMM_STRING_MAX_LEN
  bcs +                              ; slot full, skip store
  phy                                ; save script PC
  pha
  txa
  clc
  adc.w SCUMM.scratch3
  tay
  pla
  sep #$20
  .ACCU 8
  sta.w $0000,y
  rep #$20
  .ACCU 16
  ply                                ; restore script PC
  inx
+
  rts

_stringOps.putCodeDrain:
  .ACCU 16
  .INDEX 16
  ; Slot is full — keep consuming script bytes until null terminator
  phx
  jsr _scummvm.fetchByte
  plx
  and #$00FF
  beq _stringOps.putCodeDone         ; $00 = done, fall through to terminator
  cmp #$00FF
  bne _stringOps.putCodeDrain        ; normal byte, keep draining
  ; $FF escape in drain mode: skip sub-code + args
  phx
  jsr _scummvm.fetchByte             ; sub-code
  plx
  and #$00FF
  cmp #1
  beq _stringOps.putCodeDrain
  cmp #2
  beq _stringOps.putCodeDrain
  cmp #3
  beq _stringOps.putCodeDrain
  cmp #8
  beq _stringOps.putCodeDrain
  ; 2 extra arg bytes
  phx
  jsr _scummvm.fetchWord
  plx
  bra _stringOps.putCodeDrain

_stringOps.putCodeDone:
  .ACCU 16
  .INDEX 16
  ; Write null terminator at slot[X]
  phy                                ; save script PC
  txa                                ; A = offset
  clc
  adc.w SCUMM.scratch3               ; A = slot base + offset
  tay                                ; Y = target address
  sep #$20
  .ACCU 8
  lda #$00
  sta.w $0000,y                      ; null terminator
  rep #$20
  .ACCU 16
  ply                                ; restore script PC
  clc
  rts

;--- Sub-op 3: setStringChar(stringId, index, char) ---
_stringOps.setChar:
  .ACCU 16
  .INDEX 16
  lda #$0080
  jsr _scummvm.getVarOrDirectByte    ; stringId
  pha                                ; [stack +2] save stringId
  lda #$0040
  jsr _scummvm.getVarOrDirectByte    ; index
  pha                                ; [stack +4] save index
  lda #$0020
  jsr _scummvm.getVarOrDirectByte    ; char value
  pha                                ; [stack +6] save char
  ; Stack (top→bottom): char[2], index[2], stringId[2]
  ;   1,s = char, 3,s = index, 5,s = stringId
  lda 5,s                            ; stringId
  and #$000F
  xba                                ; *256
  lsr a                              ; /2 = net *128
  clc
  adc #SCUMM.stringTable             ; A = slot base
  sta.w SCUMM.scratch3               ; save slot base
  lda 3,s                            ; index
  and #$007F                         ; clamp to 0-127
  cmp #SCUMM_STRING_MAX_LEN
  bcc _stringOps.setCharOk
  lda #SCUMM_STRING_MAX_LEN
_stringOps.setCharOk:
  .ACCU 16
  .INDEX 16
  clc
  adc.w SCUMM.scratch3               ; A = slot base + index
  tax                                ; X = target WRAM address (preserve Y = script PC)
  lda 1,s                            ; char
  sep #$20
  .ACCU 8
  sta.w $0000,x                      ; store byte
  rep #$20
  .ACCU 16
  pla                                ; discard char
  pla                                ; discard index
  pla                                ; discard stringId
  clc
  rts

;--- Sub-op 4: getStringChar(stringId, index) -> result ---
_stringOps.getChar:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.getResultPos          ; sets SCUMM.resultVar
  lda #$0080
  jsr _scummvm.getVarOrDirectByte    ; stringId
  pha                                ; [stack +2] save stringId
  lda #$0040
  jsr _scummvm.getVarOrDirectByte    ; index
  pha                                ; [stack +4] save index
  ; Stack: index[2], stringId[2]
  ;   1,s = index, 3,s = stringId
  lda 3,s                            ; stringId
  and #$000F
  xba                                ; *256
  lsr a                              ; /2 = net *128
  clc
  adc #SCUMM.stringTable             ; A = slot base
  sta.w SCUMM.scratch3               ; save slot base
  pla                                ; A = index
  and #$007F                         ; clamp to 0-127
  cmp #SCUMM_STRING_MAX_LEN
  bcc _stringOps.getCharOk
  lda #SCUMM_STRING_MAX_LEN
_stringOps.getCharOk:
  .ACCU 16
  .INDEX 16
  clc
  adc.w SCUMM.scratch3               ; A = slot base + index
  tax                                ; X = source WRAM address (preserve Y = script PC)
  pla                                ; discard stringId from stack
  lda.w $0000,x                      ; load 16-bit
  and #$00FF                         ; byte only
  jsr _scummvm.writeVariable         ; write A to SCUMM.resultVar
  clc
  rts

;--- Sub-op 2: copyString(destId, srcId) ---
; Copies 128 bytes from src slot to dest slot.
_stringOps.copyString:
  .ACCU 16
  .INDEX 16
  lda #$0080
  jsr _scummvm.getVarOrDirectByte    ; dest stringId
  pha                                ; save dest
  lda #$0040
  jsr _scummvm.getVarOrDirectByte    ; src stringId
  ; A = src id
  and #$000F
  xba                                ; *256
  lsr a                              ; /2 = net *128
  clc
  adc #SCUMM.stringTable             ; A = src slot base
  sta.w SCUMM.scratch3               ; scratch3 = src base
  pla                                ; dest id
  and #$000F
  xba                                ; *256
  lsr a                              ; /2 = net *128
  clc
  adc #SCUMM.stringTable             ; A = dest slot base
  tax                                ; X = dest base address
  phy                                ; save script PC (Y = bytecode offset)
  ldy #0                             ; Y = byte counter (0, 2, 4, ... 126)
_stringOps.copyLoop:
  .ACCU 16
  .INDEX 16
  ; Compute src address: A = scratch3 + Y
  tya                                ; A = offset
  clc
  adc.w SCUMM.scratch3               ; A = src base + offset
  phy                                ; save counter (need Y for src addressing)
  tay                                ; Y = src address
  lda.w $0000,y                      ; load 16-bit from src
  sta.w $0000,x                      ; store 16-bit to dest
  ply                                ; restore counter
  inx
  inx
  iny
  iny
  cpy #128
  bcc _stringOps.copyLoop
  ply                                ; restore script PC
  clc
  rts

;--- Fallback: consume 2x p8 for unknown sub-ops ---
_stringOps.fallbackTwoP8:
  .ACCU 16
  .INDEX 16
  lda #$0080
  jsr _scummvm.getVarOrDirectByte    ; param1 (discarded)
  lda #$0040
  jsr _scummvm.getVarOrDirectByte    ; param2 (discarded)
  clc
  rts


;-------------------------------------------------------------------
; saveRestoreVerbs ($AB) -- 3x p8 params for all sub-ops
;-------------------------------------------------------------------
op_saveRestoreVerbs:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.fetchByte             ; sub-opcode byte
  sta.w SCUMM.scratch                ; save for flag testing
  ; Read 3 params: begin_verb p8[7], end_verb p8[6], mode p8[5]
  lda #$0080
  and.w SCUMM.scratch
  beq +
  jsr _scummvm.fetchWord
  jsr _scummvm.readVariable
  bra ++
+
  jsr _scummvm.fetchByte
++
  .ACCU 16
  pha                                 ; push begin_verb
  lda #$0040
  and.w SCUMM.scratch
  beq +
  jsr _scummvm.fetchWord
  jsr _scummvm.readVariable
  bra ++
+
  jsr _scummvm.fetchByte
++
  .ACCU 16
  pha                                 ; push end_verb
  lda #$0020
  and.w SCUMM.scratch
  beq +
  jsr _scummvm.fetchWord
  jsr _scummvm.readVariable
  bra ++
+
  jsr _scummvm.fetchByte
++
  .ACCU 16
  pha                                 ; push mode (unused, but consume param)
  ; Stack: mode (top), end_verb, begin_verb
  ; Pass sub-opcode in scratch, params on stack
  phy                                 ; save SCUMM PC
  jsl saveRestoreVerbs_impl
  ply                                 ; restore SCUMM PC
  pla                                 ; clean mode
  pla                                 ; clean end_verb
  pla                                 ; clean begin_verb
  clc
  rts


;===================================================================
; Remaining opcode stubs — batch implementation
; All consume params correctly and return safe defaults.
;===================================================================

;-------------------------------------------------------------------
; getActorWalkBox — result + p8[7]=actor → SCUMM.actorWalkBox[actor]
;-------------------------------------------------------------------
op_getActorWalkBox:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.getResultPos
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte    ; actor number
  and #$000F                         ; clamp to 0-15
  tax
  lda.w SCUMM.actorWalkBox,x
  and #$00FF
  jsr _scummvm.writeVariable
  clc
  rts

;-------------------------------------------------------------------
; getActorCostume — result + p8[7]=actor → actors.costume (byte)
;-------------------------------------------------------------------
op_getActorCostume:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.getResultPos
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte
  jsr _scummvm.getActorPtr
  lda.w SCUMM.actors.costume,x
  and #$00FF
  jsr _scummvm.writeVariable
  clc
  rts

;-------------------------------------------------------------------
; getActorFacing — result + p8[7]=actor → actors.facing (word)
;-------------------------------------------------------------------
op_getActorFacing:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.getResultPos
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte
  jsr _scummvm.getActorPtr
  lda.w SCUMM.actors.facing,x
  jsr _scummvm.writeVariable
  clc
  rts

;-------------------------------------------------------------------
; getActorElevation — result + p8[7]=actor → actors.elevation (word)
;-------------------------------------------------------------------
op_getActorElevation:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.getResultPos
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte
  jsr _scummvm.getActorPtr
  lda.w SCUMM.actors.elevation,x
  jsr _scummvm.writeVariable
  clc
  rts

;-------------------------------------------------------------------
; getActorScale — result + p8[7]=actor → actors.scalex (byte, 255=full)
;-------------------------------------------------------------------
op_getActorScale:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.getResultPos
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte
  jsr _scummvm.getActorPtr
  lda.w SCUMM.actors.scalex,x
  and #$00FF
  jsr _scummvm.writeVariable
  clc
  rts

;-------------------------------------------------------------------
; getAnimCounter — result + p8[7]=actor → 0 (no backing data)
;-------------------------------------------------------------------
op_getAnimCounter:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.getResultPos
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte    ; consume actor param
  lda #0
  jsr _scummvm.writeVariable
  clc
  rts

;-------------------------------------------------------------------
; getActorWidth — result + p8[7]=actor → actorWidth (default 24 if 0)
;-------------------------------------------------------------------
op_getActorWidth:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.getResultPos
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte    ; A = actor number
  and #$000F
  tax
  lda.w SCUMM.actorWidth,x
  and #$00FF
  bne +
    lda #24                          ; default width if not set
+
  jsr _scummvm.writeVariable
  clc
  rts

op_getInventoryCount:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.getResultPos
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte    ; actor
  and #$00FF
  phy
  jsl scummvm.getInventoryCount_impl ; A = count
  ply
  jsr _scummvm.writeVariable
  clc
  rts

op_getStringWidth:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.getResultPos
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte    ; A = string slot ID
  and #$000F                         ; clamp to 0-15
  phy                                ; save SCUMM PC
  jsl scummvm.getStringWidth_impl    ; A = pixel width
  ply                                ; restore SCUMM PC
  jsr _scummvm.writeVariable
  clc
  rts

;-------------------------------------------------------------------
; getRandomNr ($16, $96) -- result + p8[7]=range
; Returns random value in [0, range] inclusive.
; Inlines the RNG to avoid bank 0 wrapper overhead.
;-------------------------------------------------------------------
op_getRandomNr:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.getResultPos
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte
  and #$00FF
  inc a
  pha
  sep #$20
  .ACCU 8
  lda.w GLOBAL.random3
  sta.w GLOBAL.random4
  lda.w GLOBAL.random2
  sta.w GLOBAL.random3
  lda.w GLOBAL.random1
  sta.w GLOBAL.random2
  cmp.w GLOBAL.random3
  bmi _rng.alt
  lda.w GLOBAL.random3
  clc
  adc.w GLOBAL.random4
  bra _rng.store
_rng.alt:
  .ACCU 8
  .INDEX 16
  clc
  adc.w GLOBAL.random4
  clc
  eor.w FrameCounter
_rng.store:
  .ACCU 8
  .INDEX 16
  sta.w GLOBAL.random1
  rep #$20
  .ACCU 16
  and #$00FF
  pla
  sta.w SCUMM.scratch2
  lda.w GLOBAL.random1
  and #$00FF
  jsr _scummvm.mul16
  xba
  and #$00FF
  jsr _scummvm.writeVariable
  clc
  rts

;-------------------------------------------------------------------
; result + p16 → return 0  (getClosestObjActor)
;-------------------------------------------------------------------
op_getClosestObjActor:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.getResultPos
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord    ; A = reference actor/object ID
  phy                                ; save SCUMM PC
  jsl scummvm.getClosestObjActor_impl ; A = closest actor/obj ID
  ply                                ; restore SCUMM PC
  jsr _scummvm.writeVariable
  clc
  rts

;-------------------------------------------------------------------
; getDist ($34, $B4) — result + p16[7] + p16[6] → return 0 (stub)
; actorFromPos ($15, $55, $95, $D5) — result + p16[7] + p16[6] → 0
;-------------------------------------------------------------------
op_getDist:
  .ACCU 16
  .INDEX 16
op_actorFromPos:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.getResultPos
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord
  lda #SCUMM_FLAG_BIT6
  jsr _scummvm.getVarOrDirectWord
  lda #0
  jsr _scummvm.writeVariable
  clc
  rts

;-------------------------------------------------------------------
; getVerbEntrypoint ($0B, $4B, $8B, $CB)
; result = getVerbEntrypoint(object, verb)
; Returns offset into object's VERB data (>0 = has handler, 0 = none)
;-------------------------------------------------------------------
op_getVerbEntrypoint:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.getResultPos
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord
  pha                                    ; push object ID
  lda #SCUMM_FLAG_BIT6
  jsr _scummvm.getVarOrDirectWord
  sta.w SCUMM.scratch                   ; scratch = verb ID
  pla                                    ; A = object ID
  phy                                    ; save SCUMM PC
  jsl scummvm.getVerbEntrypoint_impl
  ply                                    ; restore SCUMM PC
  jsr _scummvm.writeVariable
  clc
  rts

;-------------------------------------------------------------------
; findObject ($35, $B5) — result + p8[7] screenX + p8[6] screenY
;-------------------------------------------------------------------
op_findObject:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.getResultPos
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte        ;param1 = screenX
  pha
  lda #SCUMM_FLAG_BIT6
  jsr _scummvm.getVarOrDirectByte        ;param2 = screenY
  sta.w SCUMM.scratch                    ;scratch = screenY
  pla                                    ;A = screenX
  phy                                    ;save SCUMM PC (Y)
  jsl room.findObject                    ;camera+AABB → A=objId (clobbers Y)
  ply                                    ;restore SCUMM PC
  jsr _scummvm.writeVariable
  clc
  rts

;-------------------------------------------------------------------
; findInventory ($3D, $7D, $BD, $FD) — result + p8[7]=owner + p8[6]=index
; Returns the Nth object owned by the given actor (1-based index).
;-------------------------------------------------------------------
op_findInventory:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.getResultPos
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte        ;owner actor
  pha
  lda #SCUMM_FLAG_BIT6
  jsr _scummvm.getVarOrDirectByte        ;index (1-based)
  sta.w SCUMM.scratch                    ;scratch = index
  pla
  and #$00FF                             ;A = owner
  phy
  jsl scummvm.findInventory_impl         ;A = obj_id (0 if not found)
  ply
  jsr _scummvm.writeVariable
  clc
  rts

;-------------------------------------------------------------------
; actorFollowCamera ($52, $D2) — p8[7] — follow actor with camera
;-------------------------------------------------------------------
op_actorFollowCamera:
  .ACCU 16
  .INDEX 16
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte
  and #$00FF
  sta.w SCUMM.cameraFollows
  beq _afc.done
  ; Immediately set cameraDest to actor's X
  asl a
  asl a
  asl a
  asl a                              ; * 16
  clc
  adc #2                             ; .x offset
  tax
  lda.w SCUMM.actors,x              ; actor X position
  sta.w SCUMM.cameraDest
_afc.done:
  .ACCU 16
  .INDEX 16
  clc
  rts

;-------------------------------------------------------------------
; putActorAtObject ($0E, $4E, $8E, $CE) — p8[7] actor + p16[6] object
; Teleports actor to object's walk-to point.
;-------------------------------------------------------------------
op_putActorAtObject:
  .ACCU 16
  .INDEX 16
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte    ; actor
  and #$00FF
  pha                                ; push actor number
  lda #SCUMM_FLAG_BIT6
  jsr _scummvm.getVarOrDirectWord    ; object
  sta.w SCUMM.scratch3               ; scratch3 = object ID
  pla                                ; actor number
  asl a
  asl a
  asl a
  asl a                              ; * 16 = actor struct offset
  sta.w SCUMM.scratch2               ; scratch2 = actor struct offset
  lda.w SCUMM.scratch3               ; A = object ID
  phy                                ; save SCUMM PC
  sec                                ; carry set = PUT (teleport)
  jsl scummvm.actorAtObj_impl
  ply                                ; restore SCUMM PC
  clc
  rts

;-------------------------------------------------------------------
; walkActorToObject ($36, $76, $B6, $F6) — p8[7] actor + p16[6] object
; Walks actor to object's walk-to point via pathfinding.
;-------------------------------------------------------------------
op_walkActorToObject:
  .ACCU 16
  .INDEX 16
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte    ; actor
  and #$00FF
  pha                                ; push actor number
  lda #SCUMM_FLAG_BIT6
  jsr _scummvm.getVarOrDirectWord    ; object
  sta.w SCUMM.scratch3               ; scratch3 = object ID
  pla                                ; actor number
  asl a
  asl a
  asl a
  asl a                              ; * 16 = actor struct offset
  sta.w SCUMM.scratch2               ; scratch2 = actor struct offset
  lda.w SCUMM.scratch3               ; A = object ID
  phy                                ; save SCUMM PC
  clc                                ; carry clear = WALK (pathfind)
  jsl scummvm.actorAtObj_impl
  ply                                ; restore SCUMM PC
  clc
  rts

;-------------------------------------------------------------------
; pickupObject ($25, $65, $A5, $E5) — p16[7]=obj + p8[6]=room
; Sets owner to ego (1), hides from room, caches name, rebuilds list.
;-------------------------------------------------------------------
op_pickupObject:
  .ACCU 16
  .INDEX 16
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord    ; object id
  pha                                ; save obj_id (scratch gets clobbered)
  lda #SCUMM_FLAG_BIT6
  jsr _scummvm.getVarOrDirectByte    ; room (consumed, not used in MVP)
  pla                                ; restore obj_id
  tax
  cpx #SCUMM_MAX_OBJECTS
  bcs _pickupObj.done
  sep #$20
  lda #1
  sta.w SCUMM.objectOwner,x          ; owner = ego (actor 1)
  lda #1
  sta.w SCUMM.objectState,x          ; state=1 (picked up, per ScummVM putState)
  rep #$20
  ; Remove OCHR tiles if object had a visual patch
  ; Save tmp (bytecode pointer) — removeObjectPatch clobbers tmp+0..tmp+22
  lda.b tmp+2
  pha
  lda.b tmp
  pha
  phx                                ; save obj_id on stack
  txa                                ; A = obj_id
  phy                                ; save SCUMM PC
  jsl room.removeObjectPatch
  ply                                ; restore SCUMM PC
  plx                                ; restore obj_id
  pla
  sta.b tmp                          ; restore bytecode pointer low word
  pla
  sta.b tmp+2                        ; restore bytecode pointer bank byte
  txa                                ; A = obj_id
  phy                                ; save SCUMM PC
  jsl scummvm.cacheInventoryName
  jsl scummvm.rebuildInventory
  ply                                ; restore SCUMM PC
_pickupObj.done:
  .ACCU 16
  .INDEX 16
  clc
  rts

;-------------------------------------------------------------------
; pickupObjectOld ($50, $D0) — p16[7]=obj only
; Same as pickupObject but without room parameter.
;-------------------------------------------------------------------
op_pickupObjectOld:
  .ACCU 16
  .INDEX 16
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord    ; object id
  sta.w SCUMM.scratch
  ldx.w SCUMM.scratch
  cpx #SCUMM_MAX_OBJECTS
  bcs _pickupObjOld.done
  sep #$20
  lda #1
  sta.w SCUMM.objectOwner,x
  lda #1
  sta.w SCUMM.objectState,x          ; state=1 (picked up, per ScummVM putState)
  rep #$20
  ; Save tmp (bytecode pointer) — removeObjectPatch clobbers tmp+0..tmp+22
  lda.b tmp+2
  pha
  lda.b tmp
  pha
  phx                                ; save obj_id on stack
  txa                                ; A = obj_id
  phy                                ; save SCUMM PC
  jsl room.removeObjectPatch
  ply                                ; restore SCUMM PC
  plx                                ; restore obj_id
  pla
  sta.b tmp                          ; restore bytecode pointer low word
  pla
  sta.b tmp+2                        ; restore bytecode pointer bank byte
  txa                                ; A = obj_id
  phy                                ; save SCUMM PC
  jsl scummvm.cacheInventoryName
  jsl scummvm.rebuildInventory
  ply                                ; restore SCUMM PC
_pickupObjOld.done:
  .ACCU 16
  .INDEX 16
  clc
  rts

;-------------------------------------------------------------------
; multiply ($1B, $9B) — result + p16[7]
; result = readVar(resultVar) * operand
;-------------------------------------------------------------------
op_multiply:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.getResultPos
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord
  pha
  lda.w SCUMM.resultVar
  jsr _scummvm.readVariable
  sta.w SCUMM.scratch2
  pla
  jsr _scummvm.mul16
  jsr _scummvm.writeVariable
  clc
  rts

;-------------------------------------------------------------------
; divide ($5B, $DB) — result + p16[7]
; result = readVar(resultVar) / operand
;-------------------------------------------------------------------
op_divide:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.getResultPos
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord
  pha
  beq _op_div.zero_stk
  lda.w SCUMM.resultVar
  jsr _scummvm.readVariable
  plx
  stx.w SCUMM.scratch2
  jsr _scummvm.div16
  jsr _scummvm.writeVariable
  clc
  rts
_op_div.zero_stk:
  .ACCU 16
  .INDEX 16
  pla
  lda #0
  jsr _scummvm.writeVariable
  clc
  rts

;-------------------------------------------------------------------
; ifClassOfIs ($1D, $9D) — p16[7] + varargs(word until $FF) + jump(2)
; Checks all class conditions; if ALL match → skip jump, else → take jump
;-------------------------------------------------------------------
op_ifClassOfIs:
  .ACCU 16
  .INDEX 16
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord    ; object ID
  sta.w SCUMM.scratch3               ; save obj ID
  ; Load object class word
  cmp #SCUMM_MAX_OBJECTS
  bcs _icoi.objOOB
  asl a                              ; obj * 2
  tax
  lda.w SCUMM.objectClass,x
  sta.w SCUMM.actorOamCount          ; borrow as temp: obj class bits
  lda #1
  bra _icoi.loopStart
_icoi.objOOB:
  .ACCU 16
  .INDEX 16
  ; Out-of-bounds object: class bits = 0
  stz.w SCUMM.actorOamCount
  lda #1                             ; cond = true initially
_icoi.loopStart:
  .ACCU 16
  .INDEX 16
  sta.w SCUMM.scratch                ; cond flag (1=true, 0=false)
_icoi.loop:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.fetchByte             ; aux byte
  and #$00FF
  cmp #$00FF
  beq _icoi.loopDone
  sta.w SCUMM.currentOpcode          ; set as opcode for getVarOrDirectWord
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord    ; class value
  ; A = class value
  and #$00FF
  beq _icoi.clsZero                  ; cls == 0: check if ANY class set
  ; Extract class number and check/negate flag
  pha                                ; save full cls
  and #$001F                         ; ScummVM: cls &= 0x1F
  cmp #16
  bcs _icoi.skipCls                  ; class > 15, unsupported in 16-bit → skip
  asl a
  tax
  lda.l scummvm.classBitLut,x               ; bit mask
  sta.w SCUMM.scratch2               ; save mask
  pla                                ; recover full cls
  and #$0080                         ; test set flag (bit 7)
  beq _icoi.clsClear
  ; cls & 0x80: condition fails if class NOT set
  lda.w SCUMM.actorOamCount          ; obj class bits
  and.w SCUMM.scratch2
  bne _icoi.loop                     ; class IS set → condition holds
  stz.w SCUMM.scratch                ; cond = false
  bra _icoi.loop
_icoi.clsClear:
  .ACCU 16
  .INDEX 16
  ; !(cls & 0x80): condition fails if class IS set
  lda.w SCUMM.actorOamCount          ; obj class bits
  and.w SCUMM.scratch2
  beq _icoi.loop                     ; class NOT set → condition holds
  stz.w SCUMM.scratch                ; cond = false
  bra _icoi.loop
_icoi.skipCls:
  .ACCU 16
  .INDEX 16
  pla                                ; discard saved cls
  bra _icoi.loop
_icoi.clsZero:
  .ACCU 16
  .INDEX 16
  ; cls == 0: condition fails if object has ANY class bits set
  lda.w SCUMM.actorOamCount
  beq _icoi.loop                     ; no classes → condition holds
  stz.w SCUMM.scratch                ; cond = false
  bra _icoi.loop
_icoi.loopDone:
  .ACCU 16
  .INDEX 16
  ; Read jump offset
  jsr _scummvm.fetchWord
  sta.w SCUMM.scratch2               ; jump offset
  ; ScummVM: jumpRelative(cond) → jump when cond FALSE
  lda.w SCUMM.scratch
  bne +                              ; cond=true → skip (don't jump)
  jsr _scummvm.takeRelJump           ; cond=false → take jump
+
  clc
  rts

;-------------------------------------------------------------------
; setObjectName ($54, $D4) — p16[7] + null-terminated string, no-op
;-------------------------------------------------------------------
op_setObjectName:
  .ACCU 16
  .INDEX 16
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord    ; object
  jsr _scummvm.skipNullString        ; name string
  clc
  rts

;-------------------------------------------------------------------
; drawBox ($3F, $7F, $BF, $FF) — x(p16[7]) + y(p16[6]) + aux(1) + x2(p16[7]') + y2(p16[6]') + color(p8[5]')
; ScummVM re-reads _opcode from the aux byte for x2/y2/color flag bits
;-------------------------------------------------------------------
op_drawBox:
  .ACCU 16
  .INDEX 16
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord    ; x (main opcode bit 7)
  lda #SCUMM_FLAG_BIT6
  jsr _scummvm.getVarOrDirectWord    ; y (main opcode bit 6)
  jsr _scummvm.fetchByte             ; aux opcode byte
  sta.w SCUMM.currentOpcode          ; aux byte becomes new opcode for flag checks
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord    ; x2 (aux bit 7)
  lda #SCUMM_FLAG_BIT6
  jsr _scummvm.getVarOrDirectWord    ; y2 (aux bit 6)
  lda #SCUMM_FLAG_BIT5
  jsr _scummvm.getVarOrDirectByte    ; color (aux bit 5)
_drawBox.done:
  .ACCU 16
  .INDEX 16
  clc
  rts

;-------------------------------------------------------------------
; oldRoomEffect ($5C, $DC) — sub-opcode + optional p16, no-op
;-------------------------------------------------------------------
op_oldRoomEffect:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.fetchByte             ; sub-opcode byte
  and #$001F
  cmp #$03
  bne _oldRoomEffect.done
  jsr _scummvm.fetchWord             ; setScreen: p16
_oldRoomEffect.done:
  .ACCU 16
  .INDEX 16
  clc
  rts

;-------------------------------------------------------------------
; pseudoRoom ($CC) — ScummVM v5 format:
;   fetchByte → real_room (i), then loop fetchByte → j:
;     j == 0 → done
;     j >= 0x80 → resourceMapper[j & 0x7F] = real_room
;-------------------------------------------------------------------
op_pseudoRoom:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.fetchByte             ; i = real room number
  and #$00FF
  sta.w SCUMM.scratch                ; save real_room in scratch
_pseudoRoom.loop:
  .ACCU 16
  .INDEX 16
  jsr _scummvm.fetchByte             ; j = pseudo-room byte
  and #$00FF
  beq _pseudoRoom.done               ; j == 0 → terminator
  cmp #$0080
  bcc _pseudoRoom.loop               ; j < 0x80 → skip (shouldn't happen)
  and #$007F                         ; j & 0x7F → index
  tax
  lda.w SCUMM.scratch                ; A = real_room
  sep #$20
  .ACCU 8
  sta.w SCUMM.resourceMapper,x
  rep #$20
  .ACCU 16
  bra _pseudoRoom.loop
_pseudoRoom.done:
  .ACCU 16
  .INDEX 16
  clc
  rts


;-------------------------------------------------------------------
; _scummvm.mul16 -- signed 16x16 → 16 multiply (truncated)
; Input: A = multiplicand, SCUMM.scratch2 = multiplier
; Output: A = product (low 16 bits, signed)
; Clobbers: SCUMM.scratch, SCUMM.scratch2
;-------------------------------------------------------------------
_scummvm.mul16:
  .ACCU 16
  .INDEX 16
  phx
  ; Sign = (A ^ scratch2) bit 15
  sta.w SCUMM.scratch              ; save multiplicand
  eor.w SCUMM.scratch2
  and #$8000
  tax                              ; X = sign flag (0 or $8000)
  ; |multiplicand|
  lda.w SCUMM.scratch
  bpl _mul16.mndPos
  eor #$FFFF
  inc a
_mul16.mndPos:
  .ACCU 16
  .INDEX 16
  pha                              ; push |multiplicand| on stack
  ; |multiplier|
  lda.w SCUMM.scratch2
  bpl _mul16.mplPos
  eor #$FFFF
  inc a
_mul16.mplPos:
  .ACCU 16
  .INDEX 16
  sta.w SCUMM.scratch2             ; scratch2 = |multiplier| (shifts right)
  ; result = 0
  stz.w SCUMM.scratch              ; scratch = result accumulator
  ; Shift-and-add loop
_mul16.loop:
  .ACCU 16
  .INDEX 16
  lda.w SCUMM.scratch2
  beq _mul16.done                  ; multiplier == 0, done
  lsr a
  sta.w SCUMM.scratch2             ; multiplier >>= 1, carry = old bit 0
  bcc _mul16.noadd                 ; bit was 0, skip addition
  lda.w SCUMM.scratch              ; result
  clc
  adc 1,s                          ; + multiplicand (on stack)
  sta.w SCUMM.scratch
_mul16.noadd:
  .ACCU 16
  .INDEX 16
  lda 1,s                          ; multiplicand
  asl a
  sta 1,s                          ; multiplicand <<= 1
  bra _mul16.loop
_mul16.done:
  .ACCU 16
  .INDEX 16
  pla                              ; discard multiplicand from stack
  lda.w SCUMM.scratch              ; A = |result|
  ; Apply sign
  cpx #0
  beq _mul16.pos
  eor #$FFFF
  inc a
_mul16.pos:
  .ACCU 16
  .INDEX 16
  plx
  rts

;-------------------------------------------------------------------
; _scummvm.div16 -- signed 16÷16 → 16 divide (truncated toward zero)
; Input: A = dividend, SCUMM.scratch2 = divisor (non-zero)
; Output: A = quotient
; Clobbers: Y, SCUMM.scratch, SCUMM.scratch2
;-------------------------------------------------------------------
_scummvm.div16:
  .ACCU 16
  .INDEX 16
  phx
  phy
  ; Sign = (A ^ scratch2) bit 15
  sta.w SCUMM.scratch              ; save dividend
  eor.w SCUMM.scratch2
  and #$8000
  tax                              ; X = sign flag
  ; |dividend|
  lda.w SCUMM.scratch
  bpl _div16.dvdPos
  eor #$FFFF
  inc a
_div16.dvdPos:
  .ACCU 16
  .INDEX 16
  sta.w SCUMM.scratch              ; scratch = |dividend| (shifts left, becomes quotient)
  ; |divisor|
  lda.w SCUMM.scratch2
  bpl _div16.dvsPos
  eor #$FFFF
  inc a
_div16.dvsPos:
  .ACCU 16
  .INDEX 16
  sta.w SCUMM.scratch2             ; scratch2 = |divisor|
  ; Restoring division: 16 iterations
  ; scratch = dividend/quotient, scratch2 = divisor, stack = remainder
  lda #0
  pha                              ; push remainder (0)
  ldy #16                          ; loop counter
_div16.loop:
  .ACCU 16
  .INDEX 16
  ; remainder = (remainder << 1) | bit 15 of dividend
  lda.w SCUMM.scratch
  asl a
  sta.w SCUMM.scratch              ; dividend <<= 1, carry = old bit 15
  lda 1,s                          ; remainder
  rol a                            ; (remainder << 1) | carry
  ; if remainder >= divisor
  cmp.w SCUMM.scratch2
  bcc _div16.less
  ; remainder -= divisor, set quotient bit
  sec
  sbc.w SCUMM.scratch2
  sta 1,s                          ; update remainder
  lda.w SCUMM.scratch
  ora #$0001                       ; set bit 0 of quotient
  sta.w SCUMM.scratch
  bra _div16.next
_div16.less:
  .ACCU 16
  .INDEX 16
  sta 1,s                          ; update remainder (shifted only)
_div16.next:
  .ACCU 16
  .INDEX 16
  dey
  bne _div16.loop
  pla                              ; discard remainder
  lda.w SCUMM.scratch              ; A = |quotient|
  ; Apply sign
  cpx #0
  beq _div16.pos
  eor #$FFFF
  inc a
_div16.pos:
  .ACCU 16
  .INDEX 16
  ply
  plx
  rts


;===================================================================
; _scummvm.updateActors
; Per-frame walk movement + animation with waypoint following.
; Loops over all 16 walk slots. Each slot index = actor number.
;===================================================================
.define WALK_SPEED 2

_scummvm.updateActors_body:
  .ACCU 16
  .INDEX 16
  rep #$31
  stz.w SCUMM.scratch3               ; slot = 0

_ua.slotLoop:
  .ACCU 16
  .INDEX 16
  ; Compute actor struct offset: slot * 16
  lda.w SCUMM.scratch3
  and #$00FF
  asl a
  asl a
  asl a
  asl a                               ; * 16 = sizeof(scummActor)
  sta.w SCUMM.uaActorStructOfs
  tax

  ; Skip if actor not placed in a room (room=0)
  lda.w SCUMM.actors.room,x
  and #$00FF
  beq _ua.skipSlot

  ; Check if this actor is in the current room
  cmp.w SCUMM.currentRoom
  bne _ua.skipSlot

  ; Check if actor is moving
  lda.w SCUMM.actors.moving,x
  and #$00FF
  beq _ua.skipSlot

  ; Check if walk path is valid (pathLen > 0)
  ldx.w SCUMM.scratch3
  lda.w SCUMM.walkPathLen,x
  and #$00FF
  bne +
_ua.skipSlot:
  .ACCU 16
  .INDEX 16
  jmp _ua.nextSlot
+

  ; Get current waypoint from walk path
  ; waypointArrayOfs = slot * WALK_MAX_WAYPOINTS * 2 + waypointIdx * 2
  lda.w SCUMM.walkPathIdx,x
  and #$00FF
  asl a                               ; * 2 for word index
  sta.w SCUMM.actorOamCount           ; save waypointIdx * 2
  lda.w SCUMM.scratch3
  and #$00FF
  ; slot * WALK_MAX_WAYPOINTS * 2 = slot * 8 * 2 = slot * 16
  asl a
  asl a
  asl a
  asl a                               ; slot * 16
  clc
  adc.w SCUMM.actorOamCount           ; + waypointIdx * 2
  tax

  ; dx = waypointX - actor.x
  lda.w SCUMM.walkPathX,x
  pha                                 ; save waypointX
  ldx.w SCUMM.uaActorStructOfs
  sec
  sbc.w SCUMM.actors.x,x
  sta.w SCUMM.scratch                 ; dx

  ; dy = waypointY - actor.y
  ; Recompute waypoint X offset for Y array
  ldx.w SCUMM.scratch3
  lda.w SCUMM.walkPathIdx,x
  and #$00FF
  asl a
  sta.w SCUMM.actorOamCount
  lda.w SCUMM.scratch3
  and #$00FF
  asl a
  asl a
  asl a
  asl a
  clc
  adc.w SCUMM.actorOamCount
  tax
  lda.w SCUMM.walkPathY,x
  pha                                 ; save waypointY
  ldx.w SCUMM.uaActorStructOfs
  sec
  sbc.w SCUMM.actors.y,x
  sta.w SCUMM.scratch2                ; dy

  ; |dx|
  lda.w SCUMM.scratch
  bpl +
  eor #$FFFF
  inc a
+
  sta.w SCUMM.actorOamCount           ; |dx| temp

  ; Compute scaled walk speed: max(1, walkSpeed * actorScale / 256)
  ldx.w SCUMM.uaActorStructOfs
  sep #$20
  .ACCU 8
  lda.w SCUMM.actors.scalex,x        ; actor's current scale (0-255)
  sta.l $4202                         ; WRMPYA
  ldx.w SCUMM.scratch3               ; walk slot index
  lda.w SCUMM.actorWalkSpeedX,x      ; per-actor walk speed
  bne _ua.hasWalkSpeed
  lda #WALK_SPEED                     ; default if 0
_ua.hasWalkSpeed:
  .ACCU 8
  sta.l $4203                         ; WRMPYB — start multiply
  nop
  nop
  nop
  nop                                 ; 8 cycle wait for hardware multiply
  lda.l $4217                         ; high byte = (scale * speed) >> 8
  bne _ua.walkSpeedOk
  lda #1                              ; minimum 1 pixel/frame
_ua.walkSpeedOk:
  .ACCU 8
  sta.w SCUMM.chrDmaPending          ; effective speed temp
  rep #$20
  .ACCU 16

  ; Update facing ALWAYS (before arrival check so standing frame is correct)
  lda.w SCUMM.scratch2
  bpl +
  eor #$FFFF
  inc a
+
  cmp.w SCUMM.actorOamCount           ; |dy| vs |dx|
  bcs _ua.faceVertical
  lda.w SCUMM.scratch
  bmi _ua.faceWest
  lda #90
  bra _ua.setFacing
_ua.faceWest:
  .ACCU 16
  .INDEX 16
  lda #270
  bra _ua.setFacing
_ua.faceVertical:
  .ACCU 16
  .INDEX 16
  lda.w SCUMM.scratch2
  bmi _ua.faceNorth
  lda #180
  bra _ua.setFacing
_ua.faceNorth:
  .ACCU 16
  .INDEX 16
  lda #0
_ua.setFacing:
  .ACCU 16
  .INDEX 16
  ldx.w SCUMM.uaActorStructOfs
  sta.w SCUMM.actors.facing,x

  ; |dy| for distance check
  lda.w SCUMM.scratch2
  bpl +
  eor #$FFFF
  inc a
+
  ; A = |dy|
  clc
  adc.w SCUMM.actorOamCount           ; A = |dx|+|dy|
  ; Compare sum with effective speed: if sum > speed, not arrived
  sep #$20
  .ACCU 8
  cmp.w SCUMM.chrDmaPending          ; sum vs effective speed
  rep #$20
  .ACCU 16
  beq _ua.notArrived                  ; sum == speed → not arrived (still moving)
  bcs _ua.notArrived                  ; sum > speed → not arrived

  ; --- Arrived at waypoint: snap position ---
  pla                                 ; waypointY
  ldx.w SCUMM.uaActorStructOfs
  sta.w SCUMM.actors.y,x
  pla                                 ; waypointX
  sta.w SCUMM.actors.x,x

  ; Advance to next waypoint
  sep #$20
  ldx.w SCUMM.scratch3
  lda.w SCUMM.walkPathIdx,x
  inc a
  cmp.w SCUMM.walkPathLen,x
  bcs _ua.fullyArrived
  sta.w SCUMM.walkPathIdx,x
  rep #$20
  jmp _ua.nextSlot                    ; keep moving=1, next frame targets new waypoint

_ua.fullyArrived:
  .ACCU 8
  .INDEX 16
  ldx.w SCUMM.uaActorStructOfs
  stz.w SCUMM.actors.moving,x
  ldx.w SCUMM.scratch3
  stz.w SCUMM.actorAnimFrame,x
  lda #$FF
  sta.w SCUMM.actorLastFrame,x
  rep #$20
  .ACCU 16
  jmp _ua.nextSlot

_ua.notArrived:
  .ACCU 16
  .INDEX 16
  pla                                 ; discard saved waypointY
  pla                                 ; discard saved waypointX

  ; Move X toward current waypoint (effective speed already in chrDmaPending)
  lda.w SCUMM.actorOamCount           ; |dx|
  sep #$20
  .ACCU 8
  cmp.w SCUMM.chrDmaPending
  rep #$20
  .ACCU 16
  bcc +
  lda.w SCUMM.chrDmaPending
  and #$00FF
+
  ldx.w SCUMM.scratch                 ; dx sign
  bpl _ua.dxPos
  eor #$FFFF
  inc a
_ua.dxPos:
  .ACCU 16
  .INDEX 16
  ldx.w SCUMM.uaActorStructOfs
  clc
  adc.w SCUMM.actors.x,x
  sta.w SCUMM.actors.x,x

  ; Move Y toward current waypoint
  lda.w SCUMM.scratch2
  bpl +
  eor #$FFFF
  inc a
+
  sep #$20
  .ACCU 8
  cmp.w SCUMM.chrDmaPending
  rep #$20
  .ACCU 16
  bcc +
  lda.w SCUMM.chrDmaPending
  and #$00FF
+
  ldx.w SCUMM.scratch2                ; dy sign
  bpl _ua.dyPos
  eor #$FFFF
  inc a
_ua.dyPos:
  .ACCU 16
  .INDEX 16
  ldx.w SCUMM.uaActorStructOfs
  clc
  adc.w SCUMM.actors.y,x
  sta.w SCUMM.actors.y,x

  ; Advance walk animation
  sep #$20
  ldx.w SCUMM.scratch3
  lda.w SCUMM.actorAnimTimer,x
  dec a
  sta.w SCUMM.actorAnimTimer,x
  bne _ua.animDone
  lda #COSTUME_WALK_ANIM_SPEED
  sta.w SCUMM.actorAnimTimer,x
  lda.w SCUMM.actorAnimFrame,x
  inc a
  cmp #COSTUME_WALK_CYCLE_LEN
  bcc +
  lda #1                              ; wrap to walk start (skip stand at 0)
+
  sta.w SCUMM.actorAnimFrame,x
_ua.animDone:
  .ACCU 8
  .INDEX 16
  rep #$20

_ua.nextSlot:
  .ACCU 16
  .INDEX 16
  ; Advance to next slot
  sep #$20
  lda.w SCUMM.scratch3
  inc a
  sta.w SCUMM.scratch3
  cmp #SCUMM_WALK_ACTORS
  rep #$20
  .ACCU 16
  bcs +
  jmp _ua.slotLoop
+
  rts

.ends


;===================================================================
; Class bit lookup table (16 entries, superfree)
;===================================================================
.bank 5 slot 0
.base BSL
.section "ClassBitLut" free
scummvm.classBitLut:
  .dw $0001, $0002, $0004, $0008, $0010, $0020, $0040, $0080
  .dw $0100, $0200, $0400, $0800, $1000, $2000, $4000, $8000
.ends


;===================================================================
; scummvm.zeroExtraWram — Zero WRAM not covered by existing init loops.
; Eliminates Mesen testrunner uninit-read warnings for render slots,
; room objects, actor arrays, scroll staging, and OAM scratch.
; Called via jsl from ScummVM.init. DBR=$7E. A/XY=16-bit on entry.
;===================================================================
.section "scummvm zero extra wram" superfree
.base BSL

scummvm.zeroExtraWram:
  .ACCU 16
  .INDEX 16
  php
  rep #$31

  ;render slot arrays: NOT zeroed here — partial zeroing causes stale
  ;dirty flags to trigger DMA with length=0 (=64KB). Properly initialized
  ;by loadActorCostumes on first room load.

  ;zero room object table header + all entries (96 x 16B + 4B)
  lda #0
  ldx #0
_zew.roomObj:
  .ACCU 16
  .INDEX 16
  sta.w SCUMM.roomObjCount,x
  inx
  inx
  cpx #16 * SCUMM_MAX_ROOM_OBJECTS + 4
  bcc _zew.roomObj

  ;zero inventory count
  stz.w SCUMM.invNameCount

  ;zero actor parallel arrays (16 actors)
  sep #$20
  .ACCU 8
  lda #0
  ldx #0
_zew.actorArrays:
  .ACCU 8
  .INDEX 16
  sta.w SCUMM.actorWidth,x
  sta.w SCUMM.actorWalkSpeedX,x
  sta.w SCUMM.actorWalkSpeedY,x
  sta.w SCUMM.actorAnimSpeed,x
  sta.w SCUMM.actorWalkAnimNr,x
  sta.w SCUMM.actorStandFrame,x
  sta.w SCUMM.actorTalkAnimStart,x
  sta.w SCUMM.actorTalkAnimEnd,x
  sta.w SCUMM.actorZClip,x
  sta.w SCUMM.actorWalkBox,x
  sta.w SCUMM.actorIgnoreBoxes,x
  inx
  cpx #SCUMM_WALK_ACTORS
  bcc _zew.actorArrays
  rep #$20
  .ACCU 16

  ;zero room scroll staging buffer
  lda #0
  ldx #0
_zew.colStaging:
  .ACCU 16
  .INDEX 16
  sta.w GLOBAL.room.colStaging,x
  inx
  inx
  cpx #GLOBAL.room.cacheNextSlot - GLOBAL.room.colStaging
  bcc _zew.colStaging

  ;zero OAM scratch buffer (80 bytes)
  lda #0
  ldx #0
_zew.oamScratch:
  .ACCU 16
  .INDEX 16
  sta.w SCUMM.oamScratch,x
  inx
  inx
  cpx #80
  bcc _zew.oamScratch

  ;zero string buffer (896 bytes = 28 lines x 32 cols)
  lda #0
  ldx #0
_zew.stringBuf:
  .ACCU 16
  .INDEX 16
  sta.w GLOBAL.CORE.STRING.buffer,x
  inx
  inx
  cpx #GLOBAL.CORE.STRING.buffer.length
  bcc _zew.stringBuf

  ;zero inventory names buffer (512 bytes)
  lda #0
  ldx #0
_zew.invNames:
  .ACCU 16
  .INDEX 16
  sta.w SCUMM.invNames,x
  inx
  inx
  cpx #512
  bcc _zew.invNames

  plp
  rtl

.ends


;===================================================================
; loadActorCostumes_impl — superfree bank
; Scans actors in current room, assigns render slots (5 max),
; DMAs palettes + stand-frame CHR per slot during force-blank.
; Called via jsl from bank 0 wrapper.
;===================================================================
.section "scummvm loadCostumes impl" superfree
.base BSL

scummvm.loadActorCostumes_impl:
  rep #$31

  ; Set ObjSel so sprites read tiles from VRAM word $6000
  sep #$20
  lda.b #$03
  sta.w ObjSel
  rep #$20

  ; --- Clear all render slots ---
  sep #$20
  ldx #SCUMM_MAX_RENDER_SLOTS - 1
  lda #0
_lac.clearLoop:
  sta.w SCUMM.renderSlotActor,x
  sta.w SCUMM.renderSlotCostume,x
  sta.w SCUMM.renderSlotDirty,x
  sta.w SCUMM.renderSlotHeadDirty,x
  sta.w SCUMM.slotScalePending,x
  sta.w SCUMM.renderSlotComposite,x
  lda #$FF
  sta.w SCUMM.renderSlotLastPic,x
  sta.w SCUMM.renderSlotLastHead,x
  lda #0
  dex
  bpl _lac.clearLoop
  rep #$20

  ; Store VRAM base addresses and palette slot numbers for each render slot
  ; Use X-indexed stores to avoid WRAM+offset overflow
  ldx #0
  lda #ACTOR_VRAM_SLOT0
  sta.w SCUMM.renderSlotTileBase,x
  ldx #2
  lda #ACTOR_VRAM_SLOT1
  sta.w SCUMM.renderSlotTileBase,x
  ldx #4
  lda #ACTOR_VRAM_SLOT2
  sta.w SCUMM.renderSlotTileBase,x
  ldx #6
  lda #ACTOR_VRAM_SLOT3
  sta.w SCUMM.renderSlotTileBase,x
  ldx #8
  lda #ACTOR_VRAM_SLOT4
  sta.w SCUMM.renderSlotTileBase,x
  sep #$20
  ldx #0
  lda #0
  sta.w SCUMM.renderSlotPalSlot,x
  inx
  lda #1
  sta.w SCUMM.renderSlotPalSlot,x
  inx
  lda #2
  sta.w SCUMM.renderSlotPalSlot,x
  inx
  lda #3
  sta.w SCUMM.renderSlotPalSlot,x
  inx
  lda #4
  sta.w SCUMM.renderSlotPalSlot,x
  rep #$20

  ; --- Assign slot 0 = actor 1 (ego) always ---
  sep #$20
  lda #1
  sta.w SCUMM.renderSlotActor
  ; Read costume number from actor struct (16B per actor, costume at offset 1)
  rep #$20
  ldx #17                             ; actor 1: struct offset 16 + costume field 1
  lda.w SCUMM.actors,x
  and #$00FF
  sep #$20
  sta.w SCUMM.renderSlotCostume
  rep #$20

  ; --- Scan actors 2-15 for others in current room ---
  ; scratch = next free render slot (1-4)
  lda #1
  sta.w SCUMM.scratch2                ; next free slot index

  ldx #2                              ; start scanning at actor 2
_lac.scanLoop:
  ; Compute actor struct offset: actor_num * 16
  txa
  asl a
  asl a
  asl a
  asl a
  tay                                 ; Y = struct offset (room at +0)

  ; Check room == currentRoom
  lda.w SCUMM.actors,y               ; room byte at offset 0
  and #$00FF
  cmp.w SCUMM.currentRoom
  bne _lac.scanNext

  ; Check visible: add 11 to Y for visible field
  phy                                 ; save base struct offset
  tya
  clc
  adc #11
  tay
  lda.w SCUMM.actors,y               ; visible at offset 11
  and #$00FF
  ply                                 ; restore base offset
  beq _lac.scanNext

  ; Check costume != 0: offset 1
  phy
  iny                                 ; Y = struct offset + 1 (costume)
  lda.w SCUMM.actors,y               ; costume at offset 1
  and #$00FF
  ply                                 ; restore base offset
  beq _lac.scanNext

  ; Assign this actor to next free render slot
  phx
  phy
  ldx.w SCUMM.scratch2               ; slot index
  cpx #SCUMM_MAX_RENDER_SLOTS
  bcs _lac.scanFull                   ; no more slots

  sep #$20
  .ACCU 8
  ; Get actor number from stack: pushed X (2B) then Y (2B)
  ; Stack: 1,s=Y_lo, 2,s=Y_hi, 3,s=X_lo, 4,s=X_hi
  lda 3,s                            ; original X = actor number
  sta.w SCUMM.renderSlotActor,x
  ; Read costume: struct base is in Y on stack, need +1
  ply                                 ; Y = struct base offset
  iny                                 ; Y = struct + 1 (costume)
  phy                                 ; re-push for later ply
  lda.w SCUMM.actors,y               ; costume
  sta.w SCUMM.renderSlotCostume,x
  rep #$20
  .ACCU 16

  ; Advance slot index
  lda.w SCUMM.scratch2
  inc a
  sta.w SCUMM.scratch2

_lac.scanFull:
  ply
  plx

_lac.scanNext:
  inx
  cpx #16
  bcc _lac.scanLoop

  ; --- DMA palettes + stand-frame CHR for each occupied render slot ---
  stz.w SCUMM.scratch3                ; render slot index (0-4)

_lac.dmaLoop:
  ldx.w SCUMM.scratch3
  cpx #SCUMM_MAX_RENDER_SLOTS
  bcc +
  jmp _lac.dmaDone
+
  sep #$20
  .ACCU 8
  lda.w SCUMM.renderSlotActor,x
  rep #$20
  .ACCU 16
  and #$00FF
  bne +
  jmp _lac.dmaNext                    ; empty slot
+

  ; Look up costume in CostumeDirTable (8 bytes per entry)
  lda.w SCUMM.renderSlotCostume,x
  and #$00FF
  asl a
  asl a
  asl a                               ; costume * 8
  tax                                 ; X = dir table offset

  ; --- DMA palette: 32 bytes from CostumeDirTable[costume].pal ---
  sep #$20
  .ACCU 8
  ; CGRAM target: color index = 128 + palSlot*16
  phy
  ldy.w SCUMM.scratch3               ; render slot index
  lda.w SCUMM.renderSlotPalSlot,y
  ply
  asl a
  asl a
  asl a
  asl a                               ; palSlot * 16
  clc
  adc #128                            ; OBJ palette base
  sta.l CGADD

  lda.b #$00
  sta.l $4360
  lda.b #$22
  sta.l $4361
  rep #$20
  .ACCU 16
  lda.l CostumeDirTable,x             ; palette addr low
  sta.l $4362
  sep #$20
  .ACCU 8
  lda.l CostumeDirTable + 2,x         ; palette bank
  sta.l $4364
  rep #$20
  .ACCU 16
  lda #32
  sta.l $4365
  sep #$20
  .ACCU 8
  lda.b #$40
  sta.l MDMAEN

  ; --- DMA stand frame CHR (pic 0) ---
  rep #$20
  .ACCU 16
  lda.l CostumeDirTable + 4,x         ; ChrLo table addr
  sta.b _costDirPtr
  sep #$20
  .ACCU 8
  lda.l CostumeDirTable + 6,x         ; ChrLo table bank
  sta.b _costDirPtr + 2
  rep #$20
  .ACCU 16

  ; Get numPics from CostumeDirTable+3
  lda.l CostumeDirTable + 3,x
  and #$00FF
  sta.w SCUMM.scratch                 ; numPics

  ; Read pic 0 CHR address from ChrLo[0]
  ldy #0
  lda [_costDirPtr],y
  sta.w SCUMM.scratch2                ; save CHR addr

  ; ChrHi = ChrLo_base + numPics*2
  lda.w SCUMM.scratch
  asl a
  clc
  adc.b _costDirPtr
  sta.b _costDirPtr                   ; -> ChrHi table
  ; Read ChrHi[0]
  lda [_costDirPtr],y
  and #$00FF
  sta.w SCUMM.actorOamCount           ; temp: CHR bank

  ; ChrLen = ChrHi_base + numPics
  lda.w SCUMM.scratch                 ; numPics
  clc
  adc.b _costDirPtr
  sta.b _costDirPtr                   ; -> ChrLen table
  ; Read ChrLen[0]
  lda [_costDirPtr],y
  pha                                 ; save CHR length on stack

  ; Set up VRAM target
  sep #$20
  .ACCU 8
  lda.b #VMAIN_INCREMENT_MODE
  sta.l VMAIN
  rep #$20
  .ACCU 16
  ; Get VRAM addr from renderSlotTileBase (word array at slot*2)
  lda.w SCUMM.scratch3                ; render slot
  asl a
  tax
  lda.w SCUMM.renderSlotTileBase,x
  lsr a                               ; byte -> word addr
  sta.l VMADDL

  ; DMA channel 7: CHR -> VRAM
  sep #$20
  .ACCU 8
  lda.b #$01
  sta.l $4370
  lda.b #$18
  sta.l $4371
  rep #$20
  .ACCU 16
  lda.w SCUMM.scratch2                ; CHR source addr
  sta.l $4372
  sep #$20
  .ACCU 8
  lda.w SCUMM.actorOamCount           ; CHR bank
  sta.l $4374
  rep #$20
  .ACCU 16
  pla                                 ; CHR length
  sta.l $4375
  sep #$20
  .ACCU 8
  lda.b #$80
  sta.l MDMAEN
  rep #$20
  .ACCU 16

  ; Init animation state for this actor
  ldx.w SCUMM.scratch3
  sep #$20
  .ACCU 8
  lda.w SCUMM.renderSlotActor,x
  rep #$20
  .ACCU 16
  and #$00FF
  tax
  sep #$20
  .ACCU 8
  lda #$FF
  sta.w SCUMM.actorLastFrame,x
  lda #0
  sta.w SCUMM.actorAnimFrame,x
  sta.w SCUMM.actorAnimTimer,x
  rep #$20
  .ACCU 16

_lac.dmaNext:
  inc.w SCUMM.scratch3
  jmp _lac.dmaLoop

_lac.dmaDone:
  rtl

.ends




;===================================================================
; renderActors_impl — superfree bank
; Multi-actor OAM renderer. Loops over render slots, computes screen
; position, looks up current pic via CostumeDirTable, writes OAM.
; D register = ScummVM object ZP. DBR = $7E.
;===================================================================
.section "scummvm render impl" superfree
.base BSL

; VRAM tile base table (word per slot: tile_id_base * 2 for quick lookup)
_ri.tileBaseLut:
  .db $00, $30, $60, $90, $C0

; Palette OAM bits table: (palSlot << 1) for OAM attr byte bits 1-3
_ri.palBitsLut:
  .db $00, $02, $04, $06, $08

scummvm.renderActors_impl:
  rep #$31

  ; --- Clear OAM Table 1 (hi bits) for first 80 sprites (20 bytes) ---
  sep #$20
  lda #0
  ldx #19
- sta.w GLOBAL.oamTable1,x
  dex
  bpl -
  rep #$20

  ; --- Loop over render slots ---
  stz.w SCUMM.scratch3                ; scratch3 = current render slot index (0-4)

_ri.slotLoop:
  ldx.w SCUMM.scratch3
  sep #$20
  lda.w SCUMM.renderSlotActor,x
  rep #$20
  and #$00FF
  bne +
  jmp _ri.nextSlot
+
  sta.w SCUMM.actorOamCount           ; temporarily store actor number

  ; Compute actor struct offset: actor_number * 16
  asl a
  asl a
  asl a
  asl a
  tay                                 ; Y = actor struct offset

  ; Check room == currentRoom (room at struct offset 0)
  lda.w SCUMM.actors,y
  and #$00FF
  cmp.w SCUMM.currentRoom
  beq +
  jmp _ri.nextSlot
+

  ; Check visible (struct offset 11)
  phy
  tya
  clc
  adc #11
  tay
  lda.w SCUMM.actors,y
  and #$00FF
  ply                                 ; restore Y = struct base
  bne +
  jmp _ri.nextSlot
+

  ; Read facing from actor struct (offset +6) for direction-aware walk cycle
  phy                                 ; save struct base
  tya
  clc
  adc #6
  tay
  lda.w SCUMM.actors,y               ; facing (word: 0/90/180/270)
  sta.w SCUMM.scratch2                ; save for walk cycle + flip
  ply                                 ; restore Y = struct base

  ; --- Determine current pic index from walk cycle ---
  ; Get actor number for walk array indexing
  lda.w SCUMM.actorOamCount           ; actor number
  and #$00FF
  tax
  sep #$20
  .ACCU 8
  lda.w SCUMM.actorAnimFrame,x       ; walk cycle step (0-6)
  rep #$20
  .ACCU 16
  and #$00FF
  phx                                 ; save actor number
  tax
  ; Select walk cycle table based on facing direction
  lda.w SCUMM.scratch2               ; facing (0=N, 90=E, 180=S, 270=W)
  beq _ri.northCycle                  ; facing=0 → north
  cmp #180
  beq _ri.southCycle
  lda.l CostumeWalkCycleSide,x       ; east/west: side view
  bra _ri.gotPic
_ri.northCycle:
  .ACCU 16
  lda.l CostumeWalkCycleNorth,x      ; north: rear view
  bra _ri.gotPic
_ri.southCycle:
  .ACCU 16
  lda.l CostumeWalkCycleFront,x      ; south: front view
_ri.gotPic:
  .ACCU 16
  and #$00FF
  sta.w SCUMM.scratch                 ; body pic index

  ; --- Head pic lookup (X = animFrame, scratch2 = facing) ---
  lda.w SCUMM.scratch2               ; facing (0=N, 90=E, 180=S, 270=W)
  beq _ri.headNorth
  cmp #180
  beq _ri.headSouth
  lda.l CostumeHeadCycleSide,x       ; east/west: side head
  bra _ri.headGot
_ri.headNorth:
  .ACCU 16
  lda.l CostumeHeadCycleNorth,x      ; north: rear head
  bra _ri.headGot
_ri.headSouth:
  .ACCU 16
  lda.l CostumeHeadCycleFront,x      ; south: front head
_ri.headGot:
  .ACCU 16
  and #$00FF
  sep #$20
  .ACCU 8
  sta.w SCUMM.actorHeadPicCur        ; store head pic ($FF=none)
  rep #$20
  .ACCU 16

  plx                                 ; restore actor number

  ; --- Check if frame changed -> stage CHR DMA for this slot ---
  sep #$20
  .ACCU 8
  lda.w SCUMM.actorLastFrame,x
  rep #$20
  .ACCU 16
  and #$00FF
  cmp.w SCUMM.scratch
  bne _ri.frameChanged
  jmp _ri.chrReady                    ; frame same -> skip
_ri.frameChanged:

  ; Store new lastFrame
  lda.w SCUMM.scratch
  sep #$20
  .ACCU 8
  sta.w SCUMM.actorLastFrame,x
  rep #$20
  .ACCU 16

  ; Look up costume in CostumeDirTable to find CHR source
  phx                                 ; save actor number
  phy                                 ; save struct offset
  ldx.w SCUMM.scratch3                ; render slot
  lda.w SCUMM.renderSlotCostume,x
  and #$00FF
  asl a
  asl a
  asl a                               ; costume * 8
  tax                                 ; X = CostumeDirTable offset

  ; Get ChrLo table pointer
  lda.l CostumeDirTable + 4,x         ; ChrLo table addr
  sta.b _costDirPtr
  sep #$20
  lda.l CostumeDirTable + 6,x         ; ChrLo table bank
  sta.b _costDirPtr + 2
  rep #$20

  ; Get numPics for computing ChrHi/ChrLen offsets
  lda.l CostumeDirTable + 3,x
  and #$00FF
  sta.w SCUMM.scratch2                ; numPics

  ; Read ChrLo[pic]
  lda.w SCUMM.scratch                 ; pic index
  asl a                               ; x2 for word table
  tay
  lda [_costDirPtr],y                 ; ChrLo[pic] = CHR source addr
  pha                                 ; save CHR addr

  ; Compute ChrHi = ChrLo_base + numPics*2
  lda.w SCUMM.scratch2                ; numPics
  asl a
  clc
  adc.b _costDirPtr
  sta.b _costDirPtr                   ; -> ChrHi table

  ; Read ChrHi[pic] (byte table)
  lda.w SCUMM.scratch                 ; pic index
  and #$00FF
  tay
  lda [_costDirPtr],y
  and #$00FF
  pha                                 ; save CHR bank

  ; Compute ChrLen = ChrHi_base + numPics
  lda.w SCUMM.scratch2                ; numPics
  clc
  adc.b _costDirPtr
  sta.b _costDirPtr                   ; -> ChrLen table

  ; Read ChrLen[pic] (word table)
  lda.w SCUMM.scratch                 ; pic index
  asl a
  tay
  lda [_costDirPtr],y                 ; CHR length
  sta.w SCUMM.scratch2                ; save CHR length

  ; Store per-slot DMA params (and original ROM copies for SA-1 re-reads)
  ldx.w SCUMM.scratch3                ; render slot
  pla                                 ; CHR bank
  sep #$20
  .ACCU 8
  sta.w SCUMM.slotChrSrcHi,x
  sta.w SCUMM.slotOrigChrSrcHi,x     ; preserve original ROM bank
  stz.w SCUMM.slotScalePending,x     ; clear pending flag on new costume load
  stz.w SCUMM.renderSlotComposite,x  ; composite output stale on frame change
  rep #$20
  .ACCU 16
  ; Slot arrays use word-per-slot indexing for word fields
  txa
  asl a                               ; slot * 2
  tax
  pla                                 ; CHR addr
  sta.w SCUMM.slotChrSrcLo,x
  sta.w SCUMM.slotOrigChrSrcLo,x     ; preserve original ROM addr
  lda.w SCUMM.scratch2                ; CHR length
  sta.w SCUMM.slotChrLen,x
  sta.w SCUMM.slotOrigChrLen,x       ; preserve original ROM length
  ; renderSlotTileBase is word-per-slot (slot*2)
  lda.w SCUMM.scratch3
  asl a
  tax
  lda.w SCUMM.renderSlotTileBase,x
  sta.w SCUMM.slotChrVram,x           ; VRAM byte addr target
  ldx.w SCUMM.scratch3

  ; Mark slot dirty
  sep #$20
  .ACCU 8
  lda #1
  sta.w SCUMM.renderSlotDirty,x
  rep #$20
  .ACCU 16

  ply                                 ; restore struct offset
  plx                                 ; restore actor number

_ri.chrReady:
  .ACCU 16
  .INDEX 16
  ; --- Set up OAM source pointer for current frame ---
  ; Look up OAM data from CostumeDirOamTable
  phx                                 ; save actor number
  phy                                 ; save struct offset

  ldx.w SCUMM.scratch3                ; render slot
  lda.w SCUMM.renderSlotCostume,x
  and #$00FF
  asl a
  asl a
  asl a                               ; costume * 8
  tax                                 ; X = OAM dir table offset

  ; OamLo table pointer
  lda.l CostumeDirOamTable,x
  sta.b _costDirPtr
  sep #$20
  lda.l CostumeDirOamTable + 2,x
  sta.b _costDirPtr + 2
  rep #$20

  ; Read OamLo[pic] (word table)
  lda.w SCUMM.scratch                 ; pic index
  asl a
  tay
  lda [_costDirPtr],y
  sta.b _oamSrcPtr                    ; OAM data addr low 16

  ; OamHi table pointer
  lda.l CostumeDirOamTable + 4,x      ; OamHi addr
  sta.b _costDirPtr
  sep #$20
  lda.l CostumeDirOamTable + 6,x      ; OamHi bank
  sta.b _costDirPtr + 2
  rep #$20

  ; Read OamHi[pic] (byte table)
  lda.w SCUMM.scratch                 ; pic index
  and #$00FF
  tay
  lda [_costDirPtr],y
  sep #$20
  .ACCU 8
  sta.b _oamSrcPtr + 2               ; OAM bank byte
  rep #$20
  .ACCU 16

  ply                                 ; restore struct offset (Y)
  plx                                 ; restore actor number

  ; Read entry count from OAM header byte 0
  phy
  ldy #0
  lda [_oamSrcPtr],y
  and #$00FF
  sta.w SCUMM.actorOamCount
  ply

  ; Compute screen X = actor.x - cameraX (x at struct offset +2)
  phy                                 ; save base struct offset
  iny
  iny                                 ; Y = struct + 2
  lda.w SCUMM.actors,y               ; actor.x
  sec
  sbc.w GLOBAL.room.cameraX
  sta.w SCUMM.actorScreenX

  ; Screen Y = actor.y (struct offset +4)
  iny
  iny                                 ; Y = struct + 4
  lda.w SCUMM.actors,y               ; actor.y
  sta.w SCUMM.actorScreenY

  ; Read facing (struct offset +6)
  iny
  iny                                 ; Y = struct + 6
  lda.w SCUMM.actors,y               ; facing
  sta.w SCUMM.scratch2                ; save facing for later
  ply                                 ; restore Y = struct base

  ; Skip if position is (0,0) — actor not placed yet
  lda.w SCUMM.actorScreenX
  ora.w SCUMM.actorScreenY
  bne _ri.posReady
  jmp _ri.nextSlot
_ri.posReady:

  ; =================================================================
  ; ACTOR SCALE COMPUTATION (from walkbox SCAL data)
  ; =================================================================
  ; Per-slot composite flag persists across frames (cleared on frame change/scale change)
  sep #$20
  .ACCU 8
  ; Default scale = 255 (full size)
  .ACCU 8
  lda #$FF
  sta.w SCUMM.actorCurScale
  rep #$20
  .ACCU 16

  ; Get actor's walkbox index (re-read from renderSlotActor, actorOamCount was overwritten)
  ldx.w SCUMM.scratch3                ; current render slot
  sep #$20
  .ACCU 8
  lda.w SCUMM.renderSlotActor,x
  tax
  lda.w SCUMM.actorWalkBox,x
  rep #$20
  .ACCU 16
  and #$00FF
  beq _ri.scaleInvalid
  cmp #$00FF
  bne +
_ri.scaleInvalid:
  jmp _ri.scaleDone                   ; box 0 or $FF = invalid, keep scale 255
+

  ; Read box.scale from BOXD: $7F:5002 + box*20 + $12
  ; box * 20 = box * 16 + box * 4
  sta.w SCUMM.scratch                 ; save box number
  asl a
  asl a
  sta.w SCUMM.actorOamCount           ; box * 4
  asl a
  asl a                               ; box * 16
  clc
  adc.w SCUMM.actorOamCount           ; box * 20
  clc
  adc #$5002 + $12                    ; + BOXD base + scale offset
  tax
  lda.l $7F0000,x                     ; box.scale (16-bit)

  ; Check bit 15: if set, use SCAL interpolation
  bmi _ri.scaleInterp

  ; Direct scale value (0-255)
  and #$00FF
  bne +
  jmp _ri.scaleDone                   ; 0 = no scale info, keep 255
+
  sep #$20
  .ACCU 8
  sta.w SCUMM.actorCurScale
  rep #$20
  .ACCU 16
  jmp _ri.scaleDone

_ri.scaleInterp:
  .ACCU 16
  ; Box scale bit 15 set: use SCAL slot (bits 0-14 = slot index)
  and #$7FFF                          ; slot index (usually 0)
  asl a
  asl a
  asl a
  tax                                 ; X = SCAL slot byte offset

  ; Read SCAL params into tmp: s1, y1, s2, y2
  lda.w SCUMM.scalSlot0_s1,x
  sta.b tmp                           ; tmp+0 = s1
  lda.w SCUMM.scalSlot0_y1,x
  sta.b tmp+2                         ; tmp+2 = y1
  lda.w SCUMM.scalSlot0_s2,x
  sta.b tmp+4                         ; tmp+4 = s2
  lda.w SCUMM.scalSlot0_y2,x
  sta.b tmp+6                         ; tmp+6 = y2

  ; Check if SCAL slot is empty
  lda.b tmp
  ora.b tmp+2
  bne +
  jmp _ri.scaleDone
+

  ; Check y1 == y2 (avoid div by zero)
  lda.b tmp+2
  cmp.b tmp+6
  bne +
  jmp _ri.scaleDone
+

  ; Compute: scale = s1 + (s2-s1) * (actorY - y1) / (y2 - y1)
  ; All values fit in 8-bit unsigned after abs (MI1 ranges)

  ; delta_s = s2 - s1 (signed)
  lda.b tmp+4                         ; s2
  sec
  sbc.b tmp                           ; delta_s
  pha                                 ; stack: [delta_s]

  ; offset_y = actorY - y1 (signed)
  lda.w SCUMM.actorScreenY
  sec
  sbc.b tmp+2                         ; offset_y
  pha                                 ; stack: [offset_y, delta_s]

  ; range_y = y2 - y1 (signed)
  lda.b tmp+6
  sec
  sbc.b tmp+2                         ; range_y
  pha                                 ; stack: [range_y, offset_y, delta_s]

  ; Compute sign: XOR of signs of all 3 values
  ; sign = (delta_s < 0) ^ (offset_y < 0) ^ (range_y < 0)
  stz.b tmp+4                         ; sign accumulator (0=positive)

  ; abs(range_y) — currently in A and on top of stack
  bpl +
  eor #$FFFF
  inc a
  inc.b tmp+4
+
  sta.b tmp+6                         ; tmp+6 = |range_y|

  ; abs(offset_y)
  lda 3,s                             ; offset_y from stack
  bpl +
  eor #$FFFF
  inc a
  inc.b tmp+4
+
  sta.b tmp+2                         ; tmp+2 = |offset_y| (clobbers y1, no longer needed)

  ; abs(delta_s)
  lda 5,s                             ; delta_s from stack
  bpl +
  eor #$FFFF
  inc a
  inc.b tmp+4
+
  ; A = |delta_s|

  ; Hardware multiply: |delta_s| * |offset_y| → 16-bit product
  sep #$20
  .ACCU 8
  sta.l $4202                         ; WRMPYA = |delta_s| (low byte)
  lda.b tmp+2                         ; |offset_y| (low byte)
  sta.l $4203                         ; WRMPYB = |offset_y|
  ; 8 machine cycle wait
  nop
  nop
  nop
  nop
  rep #$20
  .ACCU 16
  lda.l $4216                         ; product = |delta_s * offset_y|

  ; Hardware divide: product / |range_y|
  sta.l $4204                         ; WRDIVL/H = dividend (16-bit)
  sep #$20
  .ACCU 8
  lda.b tmp+6                         ; |range_y| (low byte)
  sta.l $4206                         ; WRDIVB = divisor (8-bit)
  rep #$20
  .ACCU 16
  ; 16 machine cycle wait for division
  nop
  nop
  nop
  nop
  nop
  nop
  nop
  nop

  ; Read quotient
  lda.l $4214                         ; RDDIVL/H = quotient

  ; Apply sign
  lda.b tmp+4                         ; sign accumulator
  and #$0001                          ; odd = negative
  beq _ri.scalePos
  lda.l $4214
  eor #$FFFF
  inc a                               ; negate quotient
  bra _ri.scaleApply
_ri.scalePos:
  lda.l $4214
_ri.scaleApply:
  ; scale = s1 + signed_quotient
  clc
  adc.b tmp                           ; + s1

  ; Clean up stack (remove 3 pushed words)
  ; NOTE: ply clobbers N/Z flags, so re-test A afterwards
  ply
  ply
  ply

  ; Re-establish flags from A (ply clobbered N/Z)
  cmp #0

  ; Clamp to 1..255
  bmi _ri.scaleClampLo                ; negative → clamp to 1
  beq _ri.scaleClampLo                ; zero → clamp to 1
  cmp #256
  bcc +
  lda #255                            ; > 255 → clamp to 255
+
  sep #$20
  .ACCU 8
  sta.w SCUMM.actorCurScale
  rep #$20
  .ACCU 16
  bra _ri.scaleDone

_ri.scaleClampLo:
  sep #$20
  .ACCU 8
  lda #1
  sta.w SCUMM.actorCurScale
  rep #$20
  .ACCU 16

_ri.scaleDone:
  .ACCU 16
  .INDEX 16
  ; Write computed scale back to actor struct's scalex field
  ldx.w SCUMM.scratch3               ; render slot index
  lda.w SCUMM.renderSlotActor,x
  and #$00FF                          ; actor number
  asl a
  asl a
  asl a
  asl a                               ; * 16 = struct offset
  tax
  sep #$20
  .ACCU 8
  lda.w SCUMM.actorCurScale
  sta.w SCUMM.actors.scalex,x

  ; --- Apply elevation: screenY -= (elevation * scale) / 256 ---
  ; X = actor struct offset, actorCurScale already computed
  rep #$20
  .ACCU 16
  lda.w SCUMM.actors.elevation,x
  beq _ri.elevDone                        ; elevation 0 = skip (common case)
  sep #$20
  .ACCU 8
  sta.l $4202                             ; WRMPYA = elevation low byte
  lda.w SCUMM.actorCurScale
  sta.l $4203                             ; WRMPYB = scale -> start multiply
  nop
  nop
  nop
  nop
  lda.l $4217                             ; high byte = (elev * scale) >> 8
  rep #$20
  .ACCU 16
  and #$00FF
  sta.w SCUMM.scratch                     ; scaled elevation
  lda.w SCUMM.actorScreenY
  sec
  sbc.w SCUMM.scratch
  sta.w SCUMM.actorScreenY
_ri.elevDone:
  rep #$20
  .ACCU 16

  ; --- SA-1 sprite scaling hook (non-blocking) ---
  ; Phase 1: Harvest — check if a previous frame's CMD=2 completed
  ; Phase 2: Submit — fire new CMD=2 if needed, return immediately
  sep #$20
  .ACCU 8
  ldx.w SCUMM.scratch3                ; render slot

  ; --- Phase 1: Harvest previous request ---
  lda.w SCUMM.slotScalePending,x
  beq _ri.scaleNoHarvest              ; nothing pending -> skip harvest

  ; Check SA-1 status
  lda.l SA1_MBOX_STATUS
  cmp #1
  bne _ri.scaleNoHarvest              ; not done yet -> skip (will check next frame)

  ; SA-1 finished! Harvest results.
  stz.w SCUMM.slotScalePending,x     ; clear pending

  ; Read output tile count
  lda.l SA1_MBOX_OUTTILES
  beq _ri.scaleNoHarvest              ; 0 tiles = nothing usable

  ; Redirect slot CHR source to I-RAM ($00:3100)
  rep #$20
  .ACCU 16
  and #$00FF
  asl a
  asl a
  asl a
  asl a
  asl a                                ; outTiles * 32 = CHR length
  pha                                  ; save CHR length
  ldx.w SCUMM.scratch3
  txa
  asl a
  tax                                  ; slot * 2
  pla
  sta.w SCUMM.slotChrLen,x
  lda #SA1_TILE_BUF
  sta.w SCUMM.slotChrSrcLo,x          ; I-RAM addr = $3100
  ldx.w SCUMM.scratch3
  sep #$20
  .ACCU 8
  lda #$00
  sta.w SCUMM.slotChrSrcHi,x          ; bank $00 (I-RAM)

  ; Mark slot dirty so DMA transfers I-RAM tiles
  lda #1
  sta.w SCUMM.renderSlotDirty,x

  ; Cache grid metadata from I-RAM into per-slot arrays
  lda.l SA1_OUTPUT_META                ; outTilesWide
  sta.w SCUMM.slotGridTilesWide,x
  lda.l SA1_OUTPUT_META + 1            ; outTilesTall
  sta.w SCUMM.slotGridTilesTall,x
  lda.l SA1_OUTPUT_META + 2            ; scaledRelX (signed)
  sta.w SCUMM.slotGridRelX,x
  lda.l SA1_OUTPUT_META + 3            ; scaledRelY (signed)
  sta.w SCUMM.slotGridRelY,x

  ; Set per-slot composite flag (persists until frame/scale change)
  lda #1
  sta.w SCUMM.renderSlotComposite,x
  lda.w SCUMM.actorCurScale
  sta.w SCUMM.renderSlotLastScale,x
  rep #$20
  .ACCU 16
  jmp _ri.buildOam                     ; go build OAM with scaled output

_ri.scaleNoHarvest:
  .ACCU 8

  ; --- Phase 2: Decide whether to submit a new request ---
  lda.w SCUMM.actorCurScale
  cmp #$FF
  beq _ri.scaleExitRange              ; 255 = no scaling needed
  cmp #64
  bcc _ri.scaleExitRange              ; < 64 = extreme downscale, skip
  bra _ri.scaleInRange

_ri.scaleExitRange:
  ; Scale outside composite range: clear composite flag if it was set
  ldx.w SCUMM.scratch3
  lda.w SCUMM.renderSlotComposite,x
  beq _ri.scaleHookDone               ; wasn't composite -> done
  stz.w SCUMM.renderSlotComposite,x   ; clear composite
  ; Restore original ROM CHR source so DMA reads ROM tiles again
  lda.w SCUMM.slotOrigChrSrcHi,x
  sta.w SCUMM.slotChrSrcHi,x
  rep #$20
  .ACCU 16
  txa
  asl a
  tax
  lda.w SCUMM.slotOrigChrSrcLo,x
  sta.w SCUMM.slotChrSrcLo,x
  lda.w SCUMM.slotOrigChrLen,x
  sta.w SCUMM.slotChrLen,x
  sep #$20
  .ACCU 8
  ldx.w SCUMM.scratch3
  lda #1
  sta.w SCUMM.renderSlotDirty,x       ; force re-DMA from ROM
  bra _ri.scaleHookDone

_ri.scaleInRange:
  ldx.w SCUMM.scratch3                ; render slot

  ; Don't submit if a request is already in flight
  lda.w SCUMM.slotScalePending,x
  bne _ri.scaleHookDone               ; still pending -> wait

  ; Path A: slot is dirty (frame changed) -> always scale
  lda.w SCUMM.renderSlotDirty,x
  bne _ri.scaleSubmit

  ; Path B: scale changed since last frame?
  lda.w SCUMM.actorCurScale
  cmp.w SCUMM.renderSlotLastScale,x
  beq _ri.scaleHookDone               ; scale unchanged -> skip

  ; Scale changed: invalidate stale composite output
  stz.w SCUMM.renderSlotComposite,x

  ; Verify slot has been loaded at least once (slotOrigChrSrcLo != 0)
  rep #$20
  .ACCU 16
  txa
  asl a                                ; slot * 2 for word arrays
  tax
  lda.w SCUMM.slotOrigChrSrcLo,x
  beq _ri.scaleHookDoneFrom16         ; no CHR staged yet -> skip
  sep #$20
  .ACCU 8
  ldx.w SCUMM.scratch3                ; restore byte slot index

_ri.scaleSubmit:
  .ACCU 8
  ; Check SA-1 is idle before submitting (only one CMD at a time)
  lda.l SA1_MBOX_CMD
  bne _ri.scaleHookDone               ; SA-1 still processing -> skip
  ; Fire-and-forget: submit CMD=2 to SA-1 (non-blocking)
  jsl scummvm.requestCompositeScale
  ; requestCompositeScale now returns immediately after writing mailbox.
  ; Mark slot as pending — harvest will happen next frame.
  ldx.w SCUMM.scratch3
  lda #1
  sta.w SCUMM.slotScalePending,x
  lda.w SCUMM.actorCurScale
  sta.w SCUMM.renderSlotLastScale,x
  bra _ri.scaleHookDone

_ri.scaleHookDoneFrom16:
  .ACCU 16
  sep #$20
  .ACCU 8
_ri.scaleHookDone:
  .ACCU 8
  .INDEX 16
  ; Not scaling or waiting: update lastScale to current
  ldx.w SCUMM.scratch3
  lda.w SCUMM.actorCurScale
  sta.w SCUMM.renderSlotLastScale,x
  rep #$20
  .ACCU 16

_ri.buildOam:
  .ACCU 16
  .INDEX 16
  ; Compute flip mask: priority 3 + palette bits + optional H-flip
  ; OAM attr: VHOOPPPc (V=vflip, H=hflip, OO=priority, PPP=palette, c=nametable)
  sep #$20
  .ACCU 8
  ldx.w SCUMM.scratch3               ; render slot
  lda.l _ri.palBitsLut,x             ; palette bits (PPP << 1)
  ora #$30                            ; priority 3
  sta.w SCUMM.actorFlipMask

  ; Check facing: 270 = west = H-flip
  rep #$20
  .ACCU 16
  lda.w SCUMM.scratch2                ; facing (saved above)
  cmp #270
  bne +
  sep #$20
  .ACCU 8
  lda.w SCUMM.actorFlipMask
  ora #$40                            ; H-flip
  sta.w SCUMM.actorFlipMask
  rep #$20
  .ACCU 16
+

  ; Get tile base for this slot
  sep #$20
  .ACCU 8
  ldx.w SCUMM.scratch3
  lda.l _ri.tileBaseLut,x
  sta.w SCUMM.scratch2                ; tile base (byte, low 8 bits of scratch2)

  ; Check if this slot uses composite grid OAM (per-slot persistent flag)
  lda.w SCUMM.renderSlotComposite,x
  beq _ri.usePerEntry
  ; Defense-in-depth: CHR source must be I-RAM (bank $00) for grid OAM
  lda.w SCUMM.slotChrSrcHi,x
  bne _ri.fixStaleComposite            ; CHR is ROM, not I-RAM -> flag is stale
  rep #$20
  .ACCU 16
  jmp _ri.buildGridOam

_ri.fixStaleComposite:
  stz.w SCUMM.renderSlotComposite,x   ; clear stale composite flag
_ri.usePerEntry:
  rep #$20
  .ACCU 16

  ; --- OAM render loop ---
  ldx.w GLOBAL.currentOamSlot
  cpx #$0200
  bcc _ri.entryOamOk
  ldx #$0200
  stx.w GLOBAL.currentOamSlot
  jmp _ri.headRender
_ri.entryOamOk:
  ; Read OAM entry count from header
  ldy #0
  lda [_oamSrcPtr],y
  and #$00FF
  sta.w SCUMM.actorOamCount
  ldy #6                              ; skip 6-byte OAM header

_ri.entryLoop:
  cpx #$0200
  bcc _ri.entryInBounds
  stx.w GLOBAL.currentOamSlot
  jmp _ri.headRender
_ri.entryInBounds:
  rep #$20
  .ACCU 16
  lda [_oamSrcPtr],y                  ; dx byte
  iny
  and #$00FF
  cmp #$0080
  bcc +
  ora #$FF00
+
  ; If facing west, mirror dx: new_dx = -(dx + 8)
  pha
  sep #$20
  .ACCU 8
  lda.w SCUMM.actorFlipMask
  rep #$20
  .ACCU 16
  and #$0040
  beq _ri.noFlipDx
  pla
  clc
  adc #8
  eor #$FFFF
  inc a
  bra _ri.applyDx
_ri.noFlipDx:
  pla
_ri.applyDx:
  ; --- Scale dx by actorCurScale/256 if needed ---
  pha                                 ; save dx
  sep #$20
  .ACCU 8
  lda.w SCUMM.actorCurScale
  cmp #$FF
  rep #$20
  .ACCU 16
  beq _ri.dxNoScale
  pla                                 ; signed dx
  bpl _ri.dxAbsPos
  eor #$FFFF
  inc a                               ; |dx|
  sep #$20
  .ACCU 8
  sta.l $4202                         ; WRMPYA = |dx|
  lda.w SCUMM.actorCurScale
  sta.l $4203                         ; WRMPYB = scale
  nop
  nop
  nop
  nop
  lda.l $4217                         ; high byte = (|dx|*scale)>>8
  rep #$20
  .ACCU 16
  and #$00FF
  eor #$FFFF
  inc a                               ; restore negative sign
  bra _ri.dxScaled
_ri.dxAbsPos:
  .ACCU 16
  sep #$20
  .ACCU 8
  sta.l $4202
  lda.w SCUMM.actorCurScale
  sta.l $4203
  nop
  nop
  nop
  nop
  lda.l $4217
  rep #$20
  .ACCU 16
  and #$00FF
_ri.dxScaled:
  clc
  adc.w SCUMM.actorScreenX
  sta.w SCUMM.scratch
  bra _ri.dxDone
_ri.dxNoScale:
  pla
  clc
  adc.w SCUMM.actorScreenX
  sta.w SCUMM.scratch
_ri.dxDone:

  lda [_oamSrcPtr],y                  ; dy byte
  iny
  and #$00FF
  cmp #$0080
  bcc +
  ora #$FF00
+
  ; --- Scale dy by actorCurScale/256 if needed ---
  pha                                 ; save dy
  sep #$20
  .ACCU 8
  lda.w SCUMM.actorCurScale
  cmp #$FF
  rep #$20
  .ACCU 16
  beq _ri.dyNoScale
  pla                                 ; signed dy
  bpl _ri.dyAbsPos
  eor #$FFFF
  inc a                               ; |dy|
  sep #$20
  .ACCU 8
  sta.l $4202
  lda.w SCUMM.actorCurScale
  sta.l $4203
  nop
  nop
  nop
  nop
  lda.l $4217
  rep #$20
  .ACCU 16
  and #$00FF
  eor #$FFFF
  inc a
  bra _ri.dyScaled
_ri.dyAbsPos:
  .ACCU 16
  sep #$20
  .ACCU 8
  sta.l $4202
  lda.w SCUMM.actorCurScale
  sta.l $4203
  nop
  nop
  nop
  nop
  lda.l $4217
  rep #$20
  .ACCU 16
  and #$00FF
_ri.dyScaled:
  clc
  adc.w SCUMM.actorScreenY
  bra _ri.dyDone
_ri.dyNoScale:
  pla
  clc
  adc.w SCUMM.actorScreenY
_ri.dyDone:
  pha                                 ; save computed Y on stack

  ; Bounds check X
  lda.w SCUMM.scratch
  bmi _ri.hideEntry
  cmp #$0100
  bcs _ri.hideEntry
  ; Bounds check Y
  pla
  pha
  bmi _ri.hideEntry
  cmp #144                      ; during cutscenes, clip sprites at verb bar boundary
  bcc +
  lda.w SCUMM.cutsceneNest
  bne _ri.hideEntry             ; cutscene active + Y >= 144 → hide
  pla
  pha
+
  cmp #$00E0
  bcs _ri.hideEntry

  ; Write visible OAM entry
  pla                                 ; computed Y (16-bit pull matches 16-bit push)
  sep #$20
  .ACCU 8
  pha                                 ; re-push Y low byte (8-bit, 1 byte)
  lda.w SCUMM.scratch                 ; screen X
  sta.w GLOBAL.oamBuffer,x
  inx
  pla                                 ; pull Y low byte (8-bit, 1 byte)
  sta.w GLOBAL.oamBuffer,x
  inx
  lda [_oamSrcPtr],y                  ; tile_id
  clc
  adc.w SCUMM.scratch2               ; + tile base for this slot
  sta.w GLOBAL.oamBuffer,x
  iny
  inx
  lda [_oamSrcPtr],y                  ; flags from OAM data
  ora.w SCUMM.actorFlipMask           ; priority + palette + flip
  sta.w GLOBAL.oamBuffer,x
  iny
  inx
  rep #$20
  .ACCU 16
  bra _ri.nextEntry

_ri.hideEntry:
  pla                                 ; discard saved Y
  sep #$20
  .ACCU 8
  lda #0
  sta.w GLOBAL.oamBuffer,x
  inx
  lda #$F0                            ; off-screen Y
  sta.w GLOBAL.oamBuffer,x
  inx
  lda #0
  sta.w GLOBAL.oamBuffer,x
  iny                                 ; skip tile_id
  inx
  sta.w GLOBAL.oamBuffer,x
  iny                                 ; skip flags
  inx
  rep #$20
  .ACCU 16

_ri.nextEntry:
  dec.w SCUMM.actorOamCount
  beq +
  jmp _ri.entryLoop
+
  stx.w GLOBAL.currentOamSlot
  jmp _ri.headRender                     ; per-entry OAM done, proceed to head

  ; =================================================================
  ; GRID OAM BUILDER — for composite-scaled actors
  ; Reads SA-1 output metadata from I-RAM $30F0-$30F3:
  ;   $30F0: outTilesWide, $30F1: outTilesTall
  ;   $30F2: scaledRelX (signed), $30F3: scaledRelY (signed)
  ; Builds a grid of 8x8 OAM entries, row-major, using tile IDs
  ; starting from the slot's tile base.
  ; =================================================================
_ri.buildGridOam:
  .ACCU 16
  .INDEX 16

  ; Read per-slot grid metadata into temps (X will be OAM index for the loop)
  sep #$20
  .ACCU 8
  ldx.w SCUMM.scratch3                ; render slot
  lda.w SCUMM.slotGridTilesWide,x
  sta.w SCUMM.actorOamCount           ; tilesWide temp
  lda.w SCUMM.slotGridRelX,x          ; scaledRelX (signed byte)
  sta.w SCUMM.chrDmaSrcLo             ; temp storage
  lda.w SCUMM.slotGridRelY,x
  sta.w SCUMM.chrDmaSrcHi             ; temp storage
  lda.w SCUMM.slotGridTilesTall,x

  ; Now switch X to OAM slot for the rest of the grid builder
  ldx.w GLOBAL.currentOamSlot
  cpx #$0200
  bcc _ri.gridOamOk
  ldx #$0200
  stx.w GLOBAL.currentOamSlot
  jmp _ri.noHead
_ri.gridOamOk:
  pha                                  ; save outTilesTall on stack

  ; Compute screen anchor for scaled sprite:
  ; screenX + scaledRelX, screenY + scaledRelY
  lda.w SCUMM.chrDmaSrcLo             ; scaledRelX (signed byte)
  rep #$20
  .ACCU 16
  and #$00FF
  cmp #$0080
  bcc +
  ora #$FF00                           ; sign-extend
+
  ; If facing west, mirror: scaledX = screenX - scaledRelX - outW*8
  pha                                  ; save scaledRelX extended
  sep #$20
  .ACCU 8
  lda.w SCUMM.actorFlipMask
  rep #$20
  .ACCU 16
  and #$0040
  beq _ri.gridNoFlipX

  ; West facing: anchorX = screenX - scaledRelX - outTilesWide*8
  pla                                  ; scaledRelX extended
  eor #$FFFF
  inc a                                ; -scaledRelX
  clc
  adc.w SCUMM.actorScreenX
  pha                                  ; save partial
  sep #$20
  .ACCU 8
  lda.w SCUMM.actorOamCount            ; outTilesWide
  rep #$20
  .ACCU 16
  and #$00FF
  asl a
  asl a
  asl a                                ; * 8
  sta.w SCUMM.scratch                  ; outW pixels
  pla
  sec
  sbc.w SCUMM.scratch                  ; - outW
  sta.w SCUMM.scratch                  ; gridBaseX
  bra _ri.gridXDone

_ri.gridNoFlipX:
  pla                                  ; scaledRelX extended
  clc
  adc.w SCUMM.actorScreenX
  sta.w SCUMM.scratch                  ; gridBaseX

_ri.gridXDone:
  sep #$20
  .ACCU 8
  lda.w SCUMM.chrDmaSrcHi              ; scaledRelY (from per-slot cache)
  rep #$20
  .ACCU 16
  and #$00FF
  cmp #$0080
  bcc +
  ora #$FF00
+
  clc
  adc.w SCUMM.actorScreenY
  pha                                  ; stack: [gridBaseY, outTilesTall]

  ; --- Grid tile loop: row-major ---
  ; Stack layout: SP+1 = gridBaseY(2), SP+3 = outTilesTall(1)
  ; SCUMM.scratch = gridBaseX
  ; SCUMM.actorOamCount = outTilesWide
  ; SCUMM.scratch2 low byte = tile base for slot
  sep #$20
  .ACCU 8
  lda #0
  pha                                  ; push tileRow counter (1 byte)
  pha                                  ; push tileIdx counter (1 byte)
  ; Stack: SP+1=tileIdx, SP+2=tileRow, SP+3..4=gridBaseY, SP+5=outTilesTall

_ri.gridRowLoop:
  sep #$20
  .ACCU 8
  lda 2,s                             ; tileRow
  cmp 5,s                             ; outTilesTall
  bcc +
  jmp _ri.gridDone
+
  ; tileCol = 0
  lda #0
  pha                                  ; push tileCol (1 byte)
  ; Stack: SP+1=tileCol, SP+2=tileIdx, SP+3=tileRow, SP+4..5=gridBaseY, SP+6=outTilesTall

_ri.gridColLoop:
  cpx #$0200
  bcc _ri.gridColInBounds
  ; OAM full — bail out, clean up tileCol then let gridDone handle rest
  sep #$20
  .ACCU 8
  pla                                  ; discard tileCol (1 byte)
  rep #$30
  .ACCU 16
  .INDEX 16
  stx.w GLOBAL.currentOamSlot
  jmp _ri.gridDone
_ri.gridColInBounds:
  sep #$20
  .ACCU 8
  lda 1,s                             ; tileCol
  cmp.w SCUMM.actorOamCount            ; outTilesWide
  bcc +
  jmp _ri.gridColDone
+

  ; Compute screen X for this tile: gridBaseX + tileCol * 8
  rep #$20
  .ACCU 16
  lda 1,s                             ; tileCol
  and #$00FF
  asl a
  asl a
  asl a                                ; * 8
  clc
  adc.w SCUMM.scratch                  ; + gridBaseX
  ; Bounds check X
  bmi _ri.gridHide
  cmp #$0100
  bcs _ri.gridHide

  ; Save tileScreenX for OAM write
  pha                                  ; push screenX

  ; Compute screen Y: gridBaseY + tileRow * 8
  sep #$20
  .ACCU 8
  lda 5,s                             ; tileRow (stack shifted by push)
  rep #$20
  .ACCU 16
  and #$00FF
  asl a
  asl a
  asl a                                ; * 8
  clc
  adc 6,s                             ; + gridBaseY (shifted)
  ; Bounds check Y
  bmi _ri.gridHidePopX
  cmp #144                      ; during cutscenes, clip crowd sprites at verb bar boundary
  bcc +
  pha
  lda.w SCUMM.cutsceneNest
  beq _ri.gridRestoreY
  pla
  bra _ri.gridHidePopX
_ri.gridRestoreY:
  pla
+
  cmp #$00E0
  bcs _ri.gridHidePopX

  ; Write visible OAM entry
  ; Stack: SP+1..2=screenX, SP+3=tileCol, SP+4=tileIdx, SP+5=tileRow, SP+6..7=gridBaseY, SP+8=outTilesTall
  sep #$20
  .ACCU 8
  pha                                  ; push screenY low byte
  lda 2,s                             ; screenX low byte (shifted by 1)
  sta.w GLOBAL.oamBuffer,x
  inx
  pla                                  ; screenY low byte
  sta.w GLOBAL.oamBuffer,x
  inx
  ; tile_id = tileIdx + tileBase
  lda 4,s                             ; tileIdx (shifted: was SP+4, now +2 from pla+pla... let me recalculate)

  ; Actually let me simplify the stack. After the pla of screenY, we popped it.
  ; The push of screenX is still on stack.
  ; Stack: SP+1..2=screenX, SP+3=tileCol, SP+4=tileIdx, SP+5=tileRow, SP+6..7=gridBaseY, SP+8=outTilesTall
  lda 4,s                             ; tileIdx
  clc
  adc.w SCUMM.scratch2                ; + tile base
  sta.w GLOBAL.oamBuffer,x
  inx
  lda.w SCUMM.actorFlipMask           ; priority + palette + flip
  sta.w GLOBAL.oamBuffer,x
  inx
  rep #$20
  .ACCU 16
  pla                                  ; discard screenX

  ; Advance tileIdx
  sep #$20
  .ACCU 8
  lda 2,s                             ; tileIdx
  inc a
  sta 2,s
  ; Advance tileCol
  lda 1,s                             ; tileCol
  inc a
  sta 1,s
  jmp _ri.gridColLoop

_ri.gridHidePopX:
  rep #$20
  .ACCU 16
  pla                                  ; discard saved screenX

_ri.gridHide:
  ; Write hidden OAM entry (off-screen)
  sep #$20
  .ACCU 8
  lda #0
  sta.w GLOBAL.oamBuffer,x
  inx
  lda #$F0                            ; off-screen Y
  sta.w GLOBAL.oamBuffer,x
  inx
  lda #0
  sta.w GLOBAL.oamBuffer,x
  inx
  sta.w GLOBAL.oamBuffer,x
  inx
  rep #$20
  .ACCU 16

  ; Advance tileIdx + tileCol
  sep #$20
  .ACCU 8
  lda 2,s                             ; tileIdx
  inc a
  sta 2,s
  lda 1,s                             ; tileCol
  inc a
  sta 1,s
  jmp _ri.gridColLoop

_ri.gridColDone:
  pla                                  ; discard tileCol
  ; Advance tileRow
  sep #$20
  .ACCU 8
  lda 2,s                             ; tileRow
  inc a
  sta 2,s
  jmp _ri.gridRowLoop

_ri.gridDone:
  ; Stack cleanup: tileIdx(1) + tileRow(1) + gridBaseY(2) + outTilesTall(1) = 5 bytes
  ; Adjust SP directly to avoid mixed-width pla confusion
  rep #$30
  .ACCU 16
  .INDEX 16
  tsc
  clc
  adc #5
  tcs

  stx.w GLOBAL.currentOamSlot
  jmp _ri.noHead                       ; skip head — SA-1 already composited it

  ; =================================================================
  ; HEAD OAM RENDERING (limb 1, composited on top of body)
  ; =================================================================
_ri.headRender:
  rep #$20
  .ACCU 16

  ; Skip head if SA-1 already composited it (per-slot persistent flag)
  sep #$20
  .ACCU 8
  ldx.w SCUMM.scratch3
  lda.w SCUMM.renderSlotComposite,x
  beq +
  jmp _ri.noHead
+
  rep #$20
  .ACCU 16

  ; Check if head pic is $FF (no head needed for this frame)
  sep #$20
  .ACCU 8
  lda.w SCUMM.actorHeadPicCur
  rep #$20
  .ACCU 16
  and #$00FF
  cmp #$00FF
  bne +
  jmp _ri.noHead
+

  ; --- Check if this costume has head data (CostumeHeadDirTable) ---
  ldx.w SCUMM.scratch3                ; render slot
  lda.w SCUMM.renderSlotCostume,x
  and #$00FF
  asl a
  asl a                               ; costume * 4 (HeadDirTable = 4 bytes/entry)
  tax
  lda.l CostumeHeadDirTable,x         ; headBasePtr
  bne +
  jmp _ri.noHead                      ; 0 = no head data for this costume
+
  sta.b _costDirPtr                   ; head table base pointer
  sep #$20
  .ACCU 8
  lda.l CostumeHeadDirTable + 2,x     ; headBaseBank
  sta.b _costDirPtr + 2
  lda.l CostumeHeadDirTable + 3,x     ; numHeadPics
  rep #$20
  .ACCU 16
  and #$00FF
  sta.w SCUMM.actorOamCount           ; temp: numHeadPics

  ; --- Check if head pic changed -> stage head CHR DMA ---
  ldx.w SCUMM.scratch3                ; render slot
  sep #$20
  .ACCU 8
  lda.w SCUMM.actorHeadPicCur
  cmp.w SCUMM.renderSlotLastHead,x
  beq _ri.headChrReady
  sta.w SCUMM.renderSlotLastHead,x    ; update last head

  ; --- Stage head CHR DMA params ---
  rep #$20
  .ACCU 16
  ; _costDirPtr = HeadChrLo table base
  ; actorOamCount = numHeadPics
  ; Look up ChrLo[headPic]
  lda.w SCUMM.actorHeadPicCur
  and #$00FF
  asl a                               ; x2 for word table
  tay
  lda [_costDirPtr],y                 ; ChrLo[headPic] = CHR source addr
  pha                                 ; save CHR addr

  ; Compute ChrHi = base + numHeadPics * 2
  lda.w SCUMM.actorOamCount           ; numHeadPics
  asl a
  clc
  adc.b _costDirPtr
  sta.b _costDirPtr                   ; -> ChrHi table

  ; Read ChrHi[headPic]
  lda.w SCUMM.actorHeadPicCur
  and #$00FF
  tay
  lda [_costDirPtr],y
  and #$00FF
  pha                                 ; save CHR bank

  ; Compute ChrLen = ChrHi + numHeadPics
  lda.w SCUMM.actorOamCount
  clc
  adc.b _costDirPtr
  sta.b _costDirPtr                   ; -> ChrLen table

  ; Read ChrLen[headPic]
  lda.w SCUMM.actorHeadPicCur
  and #$00FF
  asl a
  tay
  lda [_costDirPtr],y                 ; CHR length
  sta.w SCUMM.scratch2                ; save CHR length

  ; Store per-slot head DMA params
  ldx.w SCUMM.scratch3                ; render slot
  pla                                 ; CHR bank
  sep #$20
  .ACCU 8
  sta.w SCUMM.slotHeadChrSrcHi,x
  rep #$20
  .ACCU 16
  txa
  asl a                               ; slot * 2
  tax
  pla                                 ; CHR addr
  sta.w SCUMM.slotHeadChrSrcLo,x
  lda.w SCUMM.scratch2                ; CHR length
  sta.w SCUMM.slotHeadChrLen,x
  ldx.w SCUMM.scratch3                ; render slot (byte index)

  ; Mark head dirty
  sep #$20
  .ACCU 8
  lda #1
  sta.w SCUMM.renderSlotHeadDirty,x
  rep #$20
  .ACCU 16

_ri.headChrReady:
  .ACCU 16

  ; Skip head OAM if CHR DMA is still pending (avoids rendering un-DMA'd VRAM)
  ldx.w SCUMM.scratch3
  sep #$20
  .ACCU 8
  lda.w SCUMM.renderSlotHeadDirty,x
  rep #$20
  .ACCU 16
  and #$00FF
  beq +
  jmp _ri.noHead
+

  ; --- Reload head table base for OAM lookup ---
  ; Need to re-read CostumeHeadDirTable since _costDirPtr was modified
  ldx.w SCUMM.scratch3
  lda.w SCUMM.renderSlotCostume,x
  and #$00FF
  asl a
  asl a                               ; costume * 4
  tax
  lda.l CostumeHeadDirTable,x
  sta.b _costDirPtr
  sep #$20
  .ACCU 8
  lda.l CostumeHeadDirTable + 2,x
  sta.b _costDirPtr + 2
  lda.l CostumeHeadDirTable + 3,x     ; numHeadPics
  rep #$20
  .ACCU 16
  and #$00FF
  sta.w SCUMM.actorOamCount           ; numHeadPics

  ; Compute OamLo = base + nHP*5
  ; Layout: ChrLo(nHP*2) + ChrHi(nHP) + ChrLen(nHP*2) = nHP*5 bytes
  lda.w SCUMM.actorOamCount           ; nHP
  asl a                               ; nHP * 2
  asl a                               ; nHP * 4
  clc
  adc.w SCUMM.actorOamCount           ; nHP * 5
  clc
  adc.b _costDirPtr
  sta.b _oamSrcPtr                    ; -> OamLo table

  ; Read OamLo[headPic]
  lda.w SCUMM.actorHeadPicCur
  and #$00FF
  asl a
  tay
  ; Need bank for OamLo table
  sep #$20
  .ACCU 8
  lda.b _costDirPtr + 2               ; same bank as head table base
  sta.b _oamSrcPtr + 2
  rep #$20
  .ACCU 16
  lda [_oamSrcPtr],y                  ; OamLo[headPic] = OAM data addr
  pha                                 ; save OAM addr

  ; Compute OamHi = OamLo + nHP * 2
  lda.w SCUMM.actorOamCount           ; nHP
  asl a                               ; nHP * 2
  clc
  adc.b _oamSrcPtr
  sta.b _oamSrcPtr                    ; -> OamHi table

  ; Read OamHi[headPic]
  lda.w SCUMM.actorHeadPicCur
  and #$00FF
  tay
  lda [_oamSrcPtr],y
  sep #$20
  .ACCU 8
  sta.b _oamSrcPtr + 2               ; OAM bank
  rep #$20
  .ACCU 16

  pla                                 ; OAM addr
  sta.b _oamSrcPtr                    ; set up _oamSrcPtr for head OAM data

  ; --- Read head OAM entry count from header ---
  ldy #0
  lda [_oamSrcPtr],y
  and #$00FF
  sta.w SCUMM.actorOamCount           ; head OAM entry count
  bne +
  jmp _ri.noHead
+

  ; --- Compute head tile base = body tile base + $18 ---
  sep #$20
  .ACCU 8
  ldx.w SCUMM.scratch3                ; render slot
  lda.l _ri.tileBaseLut,x
  clc
  adc #COSTUME_HEAD_TILE_OFFSET       ; + $18
  sta.w SCUMM.scratch2                ; head tile base (low byte of scratch2)
  rep #$20
  .ACCU 16

  ; --- Head OAM entry loop ---
  ldx.w GLOBAL.currentOamSlot
  cpx #$0200
  bcc _ri.headOamOk
  ldx #$0200
  stx.w GLOBAL.currentOamSlot
  jmp _ri.noHead
_ri.headOamOk:
  ldy #6                              ; skip 6-byte OAM header

_ri.headEntryLoop:
  cpx #$0200
  bcc _ri.headEntryInBounds
  stx.w GLOBAL.currentOamSlot
  jmp _ri.noHead
_ri.headEntryInBounds:
  rep #$20
  .ACCU 16
  lda [_oamSrcPtr],y                  ; dx byte
  iny
  and #$00FF
  cmp #$0080
  bcc +
  ora #$FF00
+
  ; If facing west, mirror dx: new_dx = -(dx + 8)
  pha
  sep #$20
  .ACCU 8
  lda.w SCUMM.actorFlipMask
  rep #$20
  .ACCU 16
  and #$0040
  beq _ri.headNoFlipDx
  pla
  clc
  adc #8
  eor #$FFFF
  inc a
  bra _ri.headApplyDx
_ri.headNoFlipDx:
  pla
_ri.headApplyDx:
  ; Scale head dx by actorCurScale/256 (same as body)
  pha
  sep #$20
  .ACCU 8
  lda.w SCUMM.actorCurScale
  cmp #$FF
  rep #$20
  .ACCU 16
  beq _ri.headDxNoScale
  pla
  bpl _ri.headDxPos
  eor #$FFFF
  inc a
  sep #$20
  .ACCU 8
  sta.l $4202
  lda.w SCUMM.actorCurScale
  sta.l $4203
  nop
  nop
  nop
  nop
  lda.l $4217
  rep #$20
  .ACCU 16
  and #$00FF
  eor #$FFFF
  inc a
  bra _ri.headDxAdd
_ri.headDxPos:
  .ACCU 16
  sep #$20
  .ACCU 8
  sta.l $4202
  lda.w SCUMM.actorCurScale
  sta.l $4203
  nop
  nop
  nop
  nop
  lda.l $4217
  rep #$20
  .ACCU 16
  and #$00FF
  bra _ri.headDxAdd
_ri.headDxNoScale:
  pla
_ri.headDxAdd:
  clc
  adc.w SCUMM.actorScreenX
  sta.w SCUMM.scratch

  lda [_oamSrcPtr],y                  ; dy byte
  iny
  and #$00FF
  cmp #$0080
  bcc +
  ora #$FF00
+
  ; Scale head dy by actorCurScale/256
  pha
  sep #$20
  .ACCU 8
  lda.w SCUMM.actorCurScale
  cmp #$FF
  rep #$20
  .ACCU 16
  beq _ri.headDyNoScale
  pla
  bpl _ri.headDyPos
  eor #$FFFF
  inc a
  sep #$20
  .ACCU 8
  sta.l $4202
  lda.w SCUMM.actorCurScale
  sta.l $4203
  nop
  nop
  nop
  nop
  lda.l $4217
  rep #$20
  .ACCU 16
  and #$00FF
  eor #$FFFF
  inc a
  bra _ri.headDyAdd
_ri.headDyPos:
  .ACCU 16
  sep #$20
  .ACCU 8
  sta.l $4202
  lda.w SCUMM.actorCurScale
  sta.l $4203
  nop
  nop
  nop
  nop
  lda.l $4217
  rep #$20
  .ACCU 16
  and #$00FF
  bra _ri.headDyAdd
_ri.headDyNoScale:
  pla
_ri.headDyAdd:
  clc
  adc.w SCUMM.actorScreenY
  pha                                 ; save computed Y

  ; Bounds check X
  lda.w SCUMM.scratch
  bmi _ri.headHide
  cmp #$0100
  bcs _ri.headHide
  ; Bounds check Y
  pla
  pha
  bmi _ri.headHide
  cmp #144                      ; during cutscenes, clip head sprites at verb bar boundary
  bcc +
  lda.w SCUMM.cutsceneNest
  bne _ri.headHide              ; cutscene active + Y >= 144 → hide
  pla
  pha
+
  cmp #$00E0
  bcs _ri.headHide

  ; Write visible head OAM entry
  pla                                 ; computed Y
  sep #$20
  .ACCU 8
  pha                                 ; re-push Y low byte
  lda.w SCUMM.scratch                 ; screen X
  sta.w GLOBAL.oamBuffer,x
  inx
  pla                                 ; Y low byte
  sta.w GLOBAL.oamBuffer,x
  inx
  lda [_oamSrcPtr],y                  ; tile_id
  clc
  adc.w SCUMM.scratch2               ; + head tile base
  sta.w GLOBAL.oamBuffer,x
  iny
  inx
  lda [_oamSrcPtr],y                  ; flags
  ora.w SCUMM.actorFlipMask           ; priority + palette + flip
  sta.w GLOBAL.oamBuffer,x
  iny
  inx
  rep #$20
  .ACCU 16
  bra _ri.headNext

_ri.headHide:
  pla                                 ; discard saved Y
  sep #$20
  .ACCU 8
  lda #0
  sta.w GLOBAL.oamBuffer,x
  inx
  lda #$F0                            ; off-screen Y
  sta.w GLOBAL.oamBuffer,x
  inx
  lda #0
  sta.w GLOBAL.oamBuffer,x
  iny                                 ; skip tile_id
  inx
  sta.w GLOBAL.oamBuffer,x
  iny                                 ; skip flags
  inx
  rep #$20
  .ACCU 16

_ri.headNext:
  dec.w SCUMM.actorOamCount
  beq +
  jmp _ri.headEntryLoop
+
  stx.w GLOBAL.currentOamSlot
  bra _ri.noHead

_ri.noHead:

_ri.nextSlot:
  rep #$20
  .ACCU 16
  lda.w SCUMM.scratch3
  inc a
  sta.w SCUMM.scratch3
  cmp #SCUMM_MAX_RENDER_SLOTS
  bcc +
  jmp _ri.skipActors
+
  jmp _ri.slotLoop

_ri.skipActors:
  ; --- Cursor OAM entry (appended after all actor sprites) ---
  rep #$20
  lda.w SCUMM.cursorEnabled
  beq _ri.noCursor

  ldx.w GLOBAL.currentOamSlot
  cpx #$0200
  bcs _ri.noCursor
  sep #$20
  .ACCU 8
  lda.w SCUMM.cursorX
  sta.w GLOBAL.oamBuffer,x
  inx
  lda.w SCUMM.cursorY
  sta.w GLOBAL.oamBuffer,x
  inx
  lda.b #CURSOR_TILE_ID
  sta.w GLOBAL.oamBuffer,x
  inx
  lda.b #CURSOR_OAM_FLAGS
  sta.w GLOBAL.oamBuffer,x
  inx
  rep #$20
  .ACCU 16
  stx.w GLOBAL.currentOamSlot
_ri.noCursor:

  ; Signal engine to upload OAM buffer during next VBlank
  sep #$20
  .ACCU 8
  lda #1
  sta.w GLOBAL.oamUploadFlag
  rep #$20
  .ACCU 16

  rtl

.ends

;===========================================================================
; requestScaledTiles — Send CHR data to SA-1 for nearest-neighbor scaling
;
; Input:
;   A (16-bit) = scale factor (1-254)
;   SCUMM.scratch3 = render slot index
;   slotChrSrcLo/Hi/Len = ROM source (already populated)
;   _oamSrcPtr (ZP) = OAM header pointer (for width/height)
; Output:
;   slotChrSrcLo/Hi/Len redirected to I-RAM on success
;   Carry set = success, carry clear = timeout/failure
; Clobbers: A, X, Y
;===========================================================================
.section "scummvm SA1 scale request" superfree
.base BSL

scummvm.requestScaledTiles:
  php
  rep #$20
  .ACCU 16

  ; --- Write mailbox parameters to I-RAM ---
  ; Clear status first
  sep #$20
  .ACCU 8
  lda #0
  sta.l SA1_MBOX_STATUS             ; 0 = busy

  ; Scale factor from WRAM (A was clobbered by DBR setup)
  lda.w SCUMM.actorCurScale
  sta.l SA1_MBOX_SCALE
  ; Source ROM address from slot arrays
  ldx.w SCUMM.scratch3                ; render slot (byte index)
  lda.w SCUMM.slotChrSrcHi,x         ; bank byte
  sta.l SA1_MBOX_SRC+2

  rep #$20
  .ACCU 16
  txa
  asl a                                ; slot * 2 for word arrays
  tax
  lda.w SCUMM.slotChrSrcLo,x         ; addr lo/hi
  sta.l SA1_MBOX_SRC

  ; Tile count = ChrLen / 32
  lda.w SCUMM.slotChrLen,x
  lsr a
  lsr a
  lsr a
  lsr a
  lsr a                                ; / 32
  sta.l SA1_MBOX_TILES

  ; Width/height from OAM header (bytes 1,2 = pixel dimensions)
  ; Read width, convert pixels to tiles, write as 16-bit word
  sep #$20
  .ACCU 8
  ldy #1
  lda [_oamSrcPtr],y                  ; width in pixels
  clc
  adc #7
  lsr a
  lsr a
  lsr a                                ; ceil(widthPx / 8) = tiles wide
  rep #$20
  .ACCU 16
  and #$00FF                           ; zero-extend to 16-bit
  sta.l SA1_MBOX_WIDTH                 ; write full word

  ; Read height, convert pixels to tiles, write as 16-bit word
  sep #$20
  .ACCU 8
  ldy #2
  lda [_oamSrcPtr],y                  ; height in pixels
  clc
  adc #7
  lsr a
  lsr a
  lsr a                                ; ceil(heightPx / 8) = tiles tall
  rep #$20
  .ACCU 16
  and #$00FF
  sta.l SA1_MBOX_HEIGHT                ; write full word

  ; Write OAM data ROM pointer for SA-1 pixel reconstruction
  rep #$20
  .ACCU 16
  lda.b _oamSrcPtr                       ; OAM addr lo/hi
  sta.l SA1_MBOX_OAM
  sep #$20
  .ACCU 8
  lda.b _oamSrcPtr + 2                   ; OAM bank
  sta.l SA1_MBOX_OAM + 2

  ; Set command = 1 (triggers SA-1 processing)
  lda #1
  sta.l SA1_MBOX_CMD

  ; --- Poll for completion ---
  ; SA-1 runs at 10.74 MHz; a 27-tile scale takes ~50K SA-1 cycles
  ; = ~5K SNES cycles. Timeout after ~32K iterations (generous).
  rep #$20
  .ACCU 16
  ldx #$7FFF                           ; timeout counter
_srt.poll:
  sep #$20
  .ACCU 8
  lda.l SA1_MBOX_STATUS
  cmp #1
  beq _srt.done
  rep #$20
  .ACCU 16
  dex
  bne _srt.poll

  ; Timeout — leave CHR source pointing at ROM (fallback)
  plp
  clc                                  ; carry clear = failure
  rtl

_srt.done:
  ; --- Read output tile count, redirect DMA source to I-RAM ---
  rep #$20
  .ACCU 16
  lda.l SA1_MBOX_OUTTILES
  and #$00FF
  beq _srt.zeroOut                     ; 0 output tiles = bail

  ; Compute output CHR length = outTiles * 32
  asl a
  asl a
  asl a
  asl a
  asl a                                ; * 32
  pha                                  ; save output length

  ; Redirect slot CHR source to I-RAM ($00:3100)
  ldx.w SCUMM.scratch3                ; render slot
  txa
  asl a
  tax                                  ; slot * 2

  pla                                  ; output length
  sta.w SCUMM.slotChrLen,x            ; update CHR length

  lda #SA1_TILE_BUF
  sta.w SCUMM.slotChrSrcLo,x          ; I-RAM addr = $3100

  ldx.w SCUMM.scratch3
  sep #$20
  .ACCU 8
  lda #$00                             ; bank $00 (I-RAM lives at $00:3000)
  sta.w SCUMM.slotChrSrcHi,x

  plp
  sec                                  ; carry set = success
  rtl

_srt.zeroOut:
  plp
  clc                                  ; carry clear = no output
  rtl

.ends

;===========================================================================
; requestCompositeScale — Submit body+head CHR/OAM to SA-1 CMD=2
;
; NON-BLOCKING: writes mailbox and returns immediately. Caller checks
; SA1_MBOX_STATUS next frame to harvest results.
;
; Input:
;   SCUMM.scratch3 = render slot index
;   SCUMM.actorCurScale = scale factor (64-254)
;   slotOrigChrSrcLo/Hi = body CHR ROM source (never poisoned)
;   _oamSrcPtr (ZP) = body OAM header pointer
;   SCUMM.actorHeadPicCur = head pic index ($FF = no head)
;   renderSlotCostume = costume number (for head lookup)
; Output:
;   Returns after writing CMD=2. No CHR redirect — caller harvests.
; Clobbers: A, X, Y, _costDirPtr
;===========================================================================
.section "scummvm SA1 composite request" superfree
.base BSL

scummvm.requestCompositeScale:
  php
  sep #$20
  .ACCU 8

  ; --- Clear mailbox status ---
  lda #0
  sta.l SA1_MBOX_STATUS                ; 0 = busy

  ; --- Write scale ---
  lda.w SCUMM.actorCurScale
  sta.l SA1_MBOX_SCALE

  ; --- Write body CHR source from ORIGINAL ROM addresses (3 bytes) ---
  ldx.w SCUMM.scratch3                ; render slot (byte index)
  lda.w SCUMM.slotOrigChrSrcHi,x     ; body CHR bank (original ROM)
  sta.l SA1_MBOX_BODYCHR + 2

  rep #$20
  .ACCU 16
  txa
  asl a                                ; slot * 2 for word arrays
  tax
  lda.w SCUMM.slotOrigChrSrcLo,x     ; body CHR addr (original ROM)
  sta.l SA1_MBOX_BODYCHR

  ; --- Write body OAM pointer (3 bytes) ---
  lda.b _oamSrcPtr                    ; body OAM addr lo/hi
  sta.l SA1_MBOX_BODYOAM
  sep #$20
  .ACCU 8
  lda.b _oamSrcPtr + 2               ; body OAM bank
  sta.l SA1_MBOX_BODYOAM + 2

  ; --- Look up head CHR + OAM and write to mailbox ---
  lda.w SCUMM.actorHeadPicCur
  cmp #$FF
  bne _rcs.hasHead

  ; No head: write zero pointers
  rep #$20
  .ACCU 16
  lda #0
  sta.l SA1_MBOX_HEADCHR
  sta.l SA1_MBOX_HEADOAM
  sep #$20
  .ACCU 8
  lda #0
  sta.l SA1_MBOX_HEADCHR + 2
  sta.l SA1_MBOX_HEADOAM + 2
  jmp _rcs.sendCmd

_rcs.hasHead:
  ; Look up head data from CostumeHeadDirTable
  rep #$20
  .ACCU 16
  ldx.w SCUMM.scratch3
  lda.w SCUMM.renderSlotCostume,x
  and #$00FF
  asl a
  asl a                                ; costume * 4
  tax
  lda.l CostumeHeadDirTable,x         ; headBasePtr
  bne +
  jml _rcs.noHeadData                 ; 0 = no head for this costume
+
  sta.b _costDirPtr
  sep #$20
  .ACCU 8
  lda.l CostumeHeadDirTable + 2,x     ; headBaseBank
  sta.b _costDirPtr + 2
  lda.l CostumeHeadDirTable + 3,x     ; numHeadPics
  rep #$20
  .ACCU 16
  and #$00FF
  sta.w SCUMM.actorOamCount           ; numHeadPics (nHP)

  ; --- Head CHR: ChrLo[headPic] ---
  lda.w SCUMM.actorHeadPicCur
  and #$00FF
  asl a                                ; x2 for word table
  tay
  lda [_costDirPtr],y                 ; head CHR addr
  sta.w SCUMM.chrDmaSrcLo             ; scratch

  ; Advance _costDirPtr to ChrHi table: base + nHP*2
  lda.w SCUMM.actorOamCount
  asl a
  clc
  adc.b _costDirPtr
  sta.b _costDirPtr

  ; ChrHi[headPic] (byte table, read via 16-bit and mask)
  lda.w SCUMM.actorHeadPicCur
  and #$00FF
  tay
  lda [_costDirPtr],y
  and #$00FF
  sep #$20
  .ACCU 8
  sta.w SCUMM.chrDmaSrcHi             ; head CHR bank

  ; Write head CHR to mailbox
  rep #$20
  .ACCU 16
  lda.w SCUMM.chrDmaSrcLo
  sta.l SA1_MBOX_HEADCHR
  sep #$20
  .ACCU 8
  lda.w SCUMM.chrDmaSrcHi
  sta.l SA1_MBOX_HEADCHR + 2

  ; --- Head OAM lookup ---
  ; From current _costDirPtr (=ChrHi base):
  ; Skip ChrHi(nHP bytes) + ChrLen(nHP*2 bytes) = nHP*3 to reach OamLo
  rep #$20
  .ACCU 16
  lda.w SCUMM.actorOamCount           ; nHP
  asl a                                ; nHP*2
  clc
  adc.w SCUMM.actorOamCount           ; nHP*3
  clc
  adc.b _costDirPtr
  sta.b _costDirPtr                   ; -> OamLo table

  ; OamLo[headPic]
  lda.w SCUMM.actorHeadPicCur
  and #$00FF
  asl a
  tay
  lda [_costDirPtr],y                 ; head OAM addr
  sta.w SCUMM.chrDmaSrcLo

  ; Advance to OamHi: OamLo + nHP*2
  lda.w SCUMM.actorOamCount
  asl a
  clc
  adc.b _costDirPtr
  sta.b _costDirPtr                   ; -> OamHi table

  lda.w SCUMM.actorHeadPicCur
  and #$00FF
  tay
  lda [_costDirPtr],y                 ; head OAM bank
  sep #$20
  .ACCU 8
  sta.w SCUMM.chrDmaSrcHi

  ; Write head OAM to mailbox
  rep #$20
  .ACCU 16
  lda.w SCUMM.chrDmaSrcLo
  sta.l SA1_MBOX_HEADOAM
  sep #$20
  .ACCU 8
  lda.w SCUMM.chrDmaSrcHi
  sta.l SA1_MBOX_HEADOAM + 2

  jmp _rcs.sendCmd

_rcs.noHeadData:
  ; Costume has no head data: zero head pointers
  rep #$20
  .ACCU 16
  lda #0
  sta.l SA1_MBOX_HEADCHR
  sta.l SA1_MBOX_HEADOAM
  sep #$20
  .ACCU 8
  lda #0
  sta.l SA1_MBOX_HEADCHR + 2
  sta.l SA1_MBOX_HEADOAM + 2

_rcs.sendCmd:
  ; Fire CMD=2 and return immediately (non-blocking)
  sep #$20
  .ACCU 8
  lda #2
  sta.l SA1_MBOX_CMD

  plp
  rtl

.ends

;===========================================================================
; verbOps implementation — superfree section (bank 0 too full)
; Called via jsl from op_verbOps. Y = SCUMM PC, [tmp] = script base.
; SCUMM.resultVar = verb ID. All sub-opcodes handled here.
;===========================================================================
.bank 5 slot 0
.base BSL
.section "scummvm verbOps impl" free

scummvm.verbOps_impl:
  ; Set data bank to $7E for WRAM access
  phb
  sep #$20
  lda #$7E
  pha
  plb
  rep #$20

  ; Find existing slot with this verb ID, or first empty slot
  phy                                ; save Y (SCUMM PC)
  ldx #0
  ldy #$FFFF                         ; Y = first empty slot
_voi.findSlot:
  .ACCU 16
  .INDEX 16
  sep #$20
  lda.w SCUMM.verbs.1.id,x
  beq _voi.findEmpty
  cmp.w SCUMM.resultVar
  beq _voi.foundExact
  bra _voi.findAdvance
_voi.findEmpty:
  .ACCU 16
  .INDEX 16
  rep #$20
  cpy #$FFFF
  bne _voi.findAdvance
  txy
_voi.findAdvance:
  .ACCU 16
  .INDEX 16
  rep #$20
  txa
  clc
  adc #_sizeof_scummVerb
  tax
  cpx #_sizeof_scummVerb * SCUMM_MAX_VERBS
  bcc _voi.findSlot
  tyx                                ; X = empty slot (or $FFFF)
  bra _voi.foundDone
_voi.foundExact:
  .ACCU 16
  .INDEX 16
  rep #$20
_voi.foundDone:
  .ACCU 16
  .INDEX 16
  txa
  sta.w SCUMM.scratch2
  ply                                ; restore Y (SCUMM PC)

; --- Sub-opcode loop ---
_voi.subLoop:
  .ACCU 16
  .INDEX 16
  jsr _voi.fetchByte
  cmp #$00FF
  bne +
  plb                                ; restore DB
  rtl
+
  sta.w SCUMM.scratch
  and #$001F

  cmp #$01
  beq _voi.p16
  cmp #$02
  bne +
  jmp _voi.doName
+
  cmp #$03
  bne +
  jmp _voi.doColor
+
  cmp #$04
  bne +
  jmp _voi.doHiColor
+
  cmp #$05
  bne +
  jmp _voi.doSetXY
+
  cmp #$06
  bne +
  jmp _voi.doOn
+
  cmp #$07
  bne +
  jmp _voi.doOff
+
  cmp #$08
  bne +
  jmp _voi.doDelete
+
  cmp #$09
  bne +
  jmp _voi.doNew
+
  cmp #$0A
  bcc _voi.subLoop
  cmp #$10
  bne +
  jmp _voi.doDimColor
+
  cmp #$11
  beq _voi.subLoop                     ; dim: no params
  cmp #$13
  beq _voi.subLoop                     ; center: no params
  cmp #$14
  beq _voi.p16
  cmp #$16
  beq _voi.p16_p8
  cmp #$17
  beq _voi.doP8                        ; bkcolor: p8 (not p16)
  bra _voi.doP8

; --- Skip helpers ---
_voi.p16:
  .ACCU 16
  .INDEX 16
  jsr _voi.fetchWord
  jmp _voi.subLoop

_voi.doP8:
  .ACCU 16
  .INDEX 16
  lda.w SCUMM.scratch
  and #$0080
  beq +
  jsr _voi.fetchWord
  jmp _voi.subLoop
+
  jsr _voi.fetchByte
  jmp _voi.subLoop

_voi.p16_p8:
  .ACCU 16
  .INDEX 16
  jsr _voi.fetchWord
  jmp _voi.doP8

; --- Fetch helpers (duplicate of bank 0 routines for cross-bank use) ---
_voi.fetchByte:
  .ACCU 16
  .INDEX 16
  lda [tmp],y
  and #$00FF
  iny
  rts

_voi.fetchWord:
  .ACCU 16
  .INDEX 16
  lda [tmp],y
  iny
  iny
  rts

; Read p8 param resolving variable refs via SCUMM.scratch flags
_voi.readP8:
  .ACCU 16
  .INDEX 16
  lda.w SCUMM.scratch
  and #$0080
  beq +
  jsr _voi.fetchWord
  jmp _voi.readVar
+
  jmp _voi.fetchByte

; Minimal readVariable (inline for superfree)
; Input: A = variable index (encoded). Output: A = value.
_voi.readVar:
  .ACCU 16
  .INDEX 16
  pha
  and #SCUMM_VAR_TYPE_MASK
  beq _voi.readGlobal
  cmp #SCUMM_VAR_LOCAL_MASK
  beq _voi.readLocal
  ; bit variable — return 0/1
  pla
  and #SCUMM_VAR_INDEX_MASK
  ; index in A, divide by 8 for byte offset, bit within byte
  pha
  lsr a
  lsr a
  lsr a
  tax
  pla
  and #$0007
  phx
  tax
  lda.l _voi.bitTable,x
  plx
  and.w SCUMM.bitVars,x
  beq +
  lda #1
+
  rts

_voi.readGlobal:
  .ACCU 16
  .INDEX 16
  pla
  and #SCUMM_VAR_INDEX_MASK
  asl a                              ; *2 for word index
  tax
  lda.w SCUMM.globalVars,x
  rts

_voi.readLocal:
  .ACCU 16
  .INDEX 16
  pla
  and #SCUMM_VAR_INDEX_MASK
  asl a
  clc
  adc.w SCUMM.currentSlotPtr
  tax
  lda.w SCUMM.slots.1.localVars,x
  rts

_voi.bitTable:
  .db $01, $02, $04, $08, $10, $20, $40, $80

; --- Storage handlers ---

_voi.doNew:
  .ACCU 16
  .INDEX 16
  ldx.w SCUMM.scratch2
  cpx #$FFFF
  bne +
  jmp _voi.subLoop
+
  lda.w SCUMM.resultVar
  sep #$20
  sta.w SCUMM.verbs.1.id,x
  rep #$20
  jmp _voi.subLoop

_voi.doOn:
  .ACCU 16
  .INDEX 16
  ldx.w SCUMM.scratch2
  cpx #$FFFF
  bne +
  jmp _voi.subLoop
+
  sep #$20
  lda.w SCUMM.verbs.1.flags,x
  ora #SCUMM_VERB_FLAG_ON
  sta.w SCUMM.verbs.1.flags,x
  rep #$20
  lda #1
  sta.w SCUMM.verbDirty
  jmp _voi.subLoop

_voi.doOff:
  .ACCU 16
  .INDEX 16
  ldx.w SCUMM.scratch2
  cpx #$FFFF
  bne +
  jmp _voi.subLoop
+
  sep #$20
  lda.w SCUMM.verbs.1.flags,x
  and #$FE
  sta.w SCUMM.verbs.1.flags,x
  rep #$20
  lda #1
  sta.w SCUMM.verbDirty
  jmp _voi.subLoop

_voi.doDelete:
  .ACCU 16
  .INDEX 16
  ldx.w SCUMM.scratch2
  cpx #$FFFF
  bne +
  jmp _voi.subLoop
+
  stz.w SCUMM.verbs.1.id,x
  stz.w SCUMM.verbs.1.flags,x
  lda #1
  sta.w SCUMM.verbDirty
  jmp _voi.subLoop

_voi.doName:
  .ACCU 16
  .INDEX 16
  ldx.w SCUMM.scratch2
  cpx #$FFFF
  bne _voi.doName.store
  ; skip null string
-
  jsr _voi.fetchByte
  cmp #0
  bne -
  jmp _voi.subLoop
_voi.doName.store:
  .ACCU 16
  .INDEX 16
  lda.w SCUMM.verbNamesPtr
  sta.w SCUMM.verbs.1.namePtr,x
  ldx.w SCUMM.verbNamesPtr
  lda #0
  sta.w SCUMM.scratch                ; char count
_voi.nameChar:
  .ACCU 16
  .INDEX 16
  jsr _voi.fetchByte
  cmp #0
  beq _voi.nameDone
  sep #$20
  sta.w SCUMM.verbNames,x
  rep #$20
  inx
  inc.w SCUMM.scratch
  bra _voi.nameChar
_voi.nameDone:
  .ACCU 16
  .INDEX 16
  txa
  sta.w SCUMM.verbNamesPtr
  ldx.w SCUMM.scratch2
  lda.w SCUMM.scratch
  sep #$20
  sta.w SCUMM.verbs.1.nameLen,x
  rep #$20
  lda #1
  sta.w SCUMM.verbDirty
  jmp _voi.subLoop

_voi.doColor:
  .ACCU 16
  .INDEX 16
  jsr _voi.readP8
  ldx.w SCUMM.scratch2
  cpx #$FFFF
  beq _voi.doColor.skip
  sep #$20
  sta.w SCUMM.verbs.1.color,x
  rep #$20
_voi.doColor.skip:
  .ACCU 16
  .INDEX 16
  jmp _voi.subLoop

_voi.doHiColor:
  .ACCU 16
  .INDEX 16
  jsr _voi.readP8
  ldx.w SCUMM.scratch2
  cpx #$FFFF
  beq _voi.doHiColor.skip
  sep #$20
  sta.w SCUMM.verbs.1.hiColor,x
  rep #$20
_voi.doHiColor.skip:
  .ACCU 16
  .INDEX 16
  jmp _voi.subLoop

_voi.doDimColor:
  .ACCU 16
  .INDEX 16
  jsr _voi.readP8
  ldx.w SCUMM.scratch2
  cpx #$FFFF
  beq _voi.doDimColor.skip
  sep #$20
  sta.w SCUMM.verbs.1.dimColor,x
  rep #$20
_voi.doDimColor.skip:
  .ACCU 16
  .INDEX 16
  jmp _voi.subLoop

_voi.doKey:
  .ACCU 16
  .INDEX 16
  jsr _voi.readP8
  ldx.w SCUMM.scratch2
  cpx #$FFFF
  beq _voi.doKey.skip
  sep #$20
  sta.w SCUMM.verbs.1.key,x
  rep #$20
_voi.doKey.skip:
  .ACCU 16
  .INDEX 16
  jmp _voi.subLoop

_voi.doSetXY:
  .ACCU 16
  .INDEX 16
  ; Read X param: test SCUMM.scratch bit 7
  lda.w SCUMM.scratch
  and #$0080
  beq +
  jsr _voi.fetchWord
  jsr _voi.readVar
  bra _voi.xyGotX
+
  jsr _voi.fetchWord
_voi.xyGotX:
  .ACCU 16
  .INDEX 16
  pha
  ; Read Y param: test SCUMM.scratch bit 6
  lda.w SCUMM.scratch
  and #$0040
  beq +
  jsr _voi.fetchWord
  jsr _voi.readVar
  bra _voi.xyGotY
+
  jsr _voi.fetchWord
_voi.xyGotY:
  .ACCU 16
  .INDEX 16
  sta.w SCUMM.scratch
  pla
  ldx.w SCUMM.scratch2
  cpx #$FFFF
  beq _voi.xySkip
  ; Store raw SCUMM pixel coordinates (renderer handles conversion)
  sep #$20
  sta.w SCUMM.verbs.1.x,x
  lda.w SCUMM.scratch
  sta.w SCUMM.verbs.1.y,x
  rep #$20
  lda #1
  sta.w SCUMM.verbDirty
_voi.xySkip:
  .ACCU 16
  .INDEX 16
  jmp _voi.subLoop

.ends


;===================================================================
; Default verb initializer (superfree — called via jsl from init)
; Hardcodes MI1's standard 10 verbs until proper boot flow runs.
; Table format: 8 bytes per entry (fixed size, no variable-length names)
;   id(1), x_pixel(1), y_pixel(1), nameLen(1), nameOffset(2), pad(2)
; Names stored separately for easy addressing.
;===================================================================
.bank 5 slot 0
.base BSL
.section "ScummVMDefaultVerbs" free

scummvm.initDefaultVerbs:
  phb
  sep #$20
  lda #$7E
  pha
  plb
  rep #$31

  lda #0
  sta.w SCUMM.verbNamesPtr             ; reset name write pointer

  ; Process 10 verb entries
  ldx #0                               ; X = table index (0..9) * 4
  ldy #0                               ; Y = verb slot offset

_idv.loop:
  .ACCU 16
  .INDEX 16
  cpx #_idv.tableEnd - _idv.table
  bcs _idv.done

  ; Read id
  sep #$20
  lda.l _idv.table,x
  beq _idv.done
  sta.w SCUMM.verbs.1.id,y

  ; Read x, y pixel coords
  lda.l _idv.table+1,x
  sta.w SCUMM.verbs.1.x,y

  lda.l _idv.table+2,x
  sta.w SCUMM.verbs.1.y,y

  ; Set flags = ON
  lda #SCUMM_VERB_FLAG_ON
  sta.w SCUMM.verbs.1.flags,y

  ; Read name length
  lda.l _idv.table+3,x
  sta.w SCUMM.verbs.1.nameLen,y
  rep #$20
  and #$00FF
  sta.w SCUMM.scratch                  ; name length

  ; Set name pointer = current verbNamesPtr
  lda.w SCUMM.verbNamesPtr
  sta.w SCUMM.verbs.1.namePtr,y

  ; Copy name: read offset from table entry bytes 4-5
  phx
  phy
  lda.l _idv.table+4,x                ; name ROM offset (relative to _idv.names)
  and #$00FF
  tax                                  ; X = name source offset
  ldy.w SCUMM.verbNamesPtr            ; Y = dest offset in verbNames
  lda.w SCUMM.scratch                  ; char count
  sta.w SCUMM.scratch2

_idv.copy:
  .ACCU 16
  .INDEX 16
  sep #$20
  lda.l _idv.names,x
  sta.w SCUMM.verbNames,y
  rep #$20
  inx
  iny
  dec.w SCUMM.scratch2
  bne _idv.copy

  tya
  sta.w SCUMM.verbNamesPtr
  ply                                  ; restore verb slot offset
  plx                                  ; restore table index

  ; Advance to next entry (6 bytes per table row)
  rep #$20
  txa
  clc
  adc #6
  tax

  ; Advance verb slot
  tya
  clc
  adc #_sizeof_scummVerb
  tay

  bra _idv.loop

_idv.done:
  .ACCU 16
  .INDEX 16
  lda #1
  sta.w SCUMM.verbDirty
  plb
  rtl

; Table: id, x_pixel, y_pixel, nameLen, nameOffset (1 byte into _idv.names)
_idv.table:
  ;     id   x    y   len  nameOff
  .db  $0B,   0, 152,   7, _idv.n0 - _idv.names, 0
  .db  $09,  80, 152,   7, _idv.n4 - _idv.names, 0
  .db  $07, 168, 152,   3, _idv.n7 - _idv.names, 0
  .db  $04,   0, 160,   4, _idv.n1 - _idv.names, 0
  .db  $08,  80, 160,   7, _idv.n5 - _idv.names, 0
  .db  $05, 168, 160,   4, _idv.n8 - _idv.names, 0
  .db  $02,   0, 168,   4, _idv.n2 - _idv.names, 0
  .db  $0A,  80, 168,   7, _idv.n6 - _idv.names, 0
  .db  $06, 168, 168,   4, _idv.n9 - _idv.names, 0
  .db  $03,   0, 176,   5, _idv.n3 - _idv.names, 0
_idv.tableEnd:

_idv.names:
_idv.n0: .db "Walk to"
_idv.n1: .db "Give"
_idv.n2: .db "Open"
_idv.n3: .db "Close"
_idv.n4: .db "Pick up"
_idv.n5: .db "Look at"
_idv.n6: .db "Talk to"
_idv.n7: .db "Use"
_idv.n8: .db "Push"
_idv.n9: .db "Pull"

.ends


;===================================================================
; Verb bar renderer (superfree — called via jsl from play method)
; Builds BG2 tilemap from verb table, then DMA uploads it.
;===================================================================
.bank 5 slot 0
.base BSL
.section "ScummVMVerbBarChecked" free

;-------------------------------------------------------------------
; scummvm.renderVerbBarChecked — guard verb rendering with userPut
; If userPut <= 0, clear verbDirty instead of rendering.
; Otherwise render normally when verbDirty is set.
; JSL/RTL.
;-------------------------------------------------------------------
scummvm.renderVerbBarChecked:
  rep #$31
  lda.w SCUMM.userPut
  beq _rvbc.skip
  bmi _rvbc.skip
  lda.w SCUMM.cutsceneNest
  bne _rvbc.skip
  lda.w SCUMM.verbDirty
  beq _rvbc.done
  sta.w SCUMM.sentenceDirty
  ; Ensure BG2 is enabled for verb bar display
  sep #$20
  lda.w MainScreen
  ora #T_BG2_ENABLE
  sta.w MainScreen
  rep #$20
  jsl scummvm.renderVerbBar
_rvbc.done:
  ; Restore normal HDMA table (verb area shows BG2+BG3+OBJ)
  rep #$31
  ldy.w #VerbHdmaTable
  jsr _rvbc.switchHdma
  rtl

_rvbc.skip:
  stz.w SCUMM.verbDirty
  ; Hide verb bar by disabling BG2 on main screen
  sep #$20
  lda.w MainScreen
  and #T_BG2_ENABLE ~$ff
  sta.w MainScreen
  ; Switch HDMA to cutscene table (disable all layers in verb area)
  rep #$31
  ldy.w #CutsceneHdmaTable
  jsr _rvbc.switchHdma
  rtl

; Helper: point verb HDMA channel source to table address in Y
; Both tables share the same bank. Expects 16-bit index.
_rvbc.switchHdma:
  sep #$20
  lda.w SCUMM.hdmaChannel
  rep #$31
  and #$00FF
  asl a
  asl a
  asl a
  asl a
  tax
  sep #$20
  lda.b #:VerbHdmaTable
  sta.l DMASRC0B,x
  rep #$20
  tya
  sta.l DMASRC0L,x
  rts

.ends

.bank 5 slot 0
.base BSL
.section "ScummVMVerbRenderer" free

scummvm.renderVerbBar:
  phb
  sep #$20
  lda #$7E
  pha
  plb
  rep #$31

  ; Clear verb tilemap buffer (2048 bytes = 1024 words)
  ldx #0
  lda #0
-
  sta.w SCUMM.verbTilemap,x
  inx
  inx
  cpx #VERB_TILEMAP_SIZE
  bcc -

  ; Iterate verb slots
  ldx #0                                ; X = verb slot offset

_rvb.verbLoop:
  .ACCU 16
  .INDEX 16
  ; Check if slot is active (id != 0 and flags & ON)
  sep #$20
  lda.w SCUMM.verbs.1.id,x
  bne +
  jmp _rvb.nextVerb
+
  lda.w SCUMM.verbs.1.flags,x
  and #SCUMM_VERB_FLAG_ON
  bne +
  jmp _rvb.nextVerb
+
  rep #$20

  ; Get verb name length
  lda.w SCUMM.verbs.1.nameLen,x
  and #$00FF
  bne +
  jmp _rvb.nextVerb
+

  ; Compute tilemap offset: (y * 32 + x) * 2
  ; X pos: scale 320->256 by *4/5, then /8 for tiles
  ; For simplicity: tile_x = scumm_x * 4 / 5 / 8 = scumm_x * 4 / 40
  ; Y pos: scumm_y is relative to 144, divide by 8
  ; tile_y = (scumm_y - 144) / 8
  lda.w SCUMM.verbs.1.x,x
  and #$00FF
  ; X is SCUMM pixel coordinate; convert to tile column: x / 8
  lsr a
  lsr a
  lsr a
  sta.w SCUMM.scratch

  lda.w SCUMM.verbs.1.y,x
  and #$00FF
  ; Y is stored as SCUMM pixel coord; convert to tile row in verb area
  ; verb area starts at SCUMM y=144, BG2 tilemap row 0 = screen y=144
  ; tile_y = (y - 144) / 8
  sec
  sbc #144
  lsr a
  lsr a
  lsr a
  ; tilemap offset = (tile_y * 32 + tile_x) * 2
  asl a
  asl a
  asl a
  asl a
  asl a                                 ; tile_y * 32
  clc
  adc.w SCUMM.scratch                   ; + tile_x
  asl a                                 ; * 2 (word entries)
  sta.w SCUMM.scratch                   ; tilemap byte offset

  ; Get name pointer and length
  phx                                   ; save verb slot offset
  lda.w SCUMM.verbs.1.nameLen,x
  and #$00FF
  sta.w SCUMM.scratch2                  ; char count
  lda.w SCUMM.verbs.1.namePtr,x
  tay                                   ; Y = offset into verbNames

  ; Write tile indices for each character
  ; tile index = char - $20 (ASCII space = tile 0)
  ; Choose palette based on highlight state (X = verb slot offset)
  rep #$20
  cpx.w SCUMM.highlightVerb
  bne +
  lda #$3800                            ; palette 6 = highlight (yellow)
  bra _rvb.paletteSet
+
  lda #$3C00                            ; palette 7 = normal (white)
_rvb.paletteSet:
  .ACCU 16
  .INDEX 16
  sta.w SCUMM.actorOamCount            ; reuse as palette word

_rvb.charLoop:
  .ACCU 16
  .INDEX 16
  sep #$20
  lda.w SCUMM.verbNames,y
  rep #$20
  and #$00FF
  sec
  sbc #$20                              ; tile index = ASCII - 0x20
  ora.w SCUMM.actorOamCount            ; priority + palette bits
  phx
  ldx.w SCUMM.scratch                   ; X = tilemap byte offset
  sta.w SCUMM.verbTilemap,x
  plx
  ; advance tilemap offset by 2 (next tile word)
  inc.w SCUMM.scratch
  inc.w SCUMM.scratch
  ; advance name pointer
  iny
  ; decrement char count
  dec.w SCUMM.scratch2
  bne _rvb.charLoop

  plx                                   ; restore verb slot offset

_rvb.nextVerb:
  .ACCU 16
  .INDEX 16
  rep #$20
  txa
  clc
  adc #_sizeof_scummVerb
  tax
  cpx #_sizeof_scummVerb * SCUMM_MAX_VERBS
  bcs +
  jmp _rvb.verbLoop
+

  ;--- Render inventory items on row 5 (Y=184, tile row 5) ---
  lda.w SCUMM.inventoryCount
  bne +
  jmp _rvb.noInventory
+

  lda.w SCUMM.inventoryScroll
  asl a                                 ; scroll * 2 = byte offset into list
  tax
  ldy #0                                ; Y = visible item counter

_rvb.invLoop:
  .ACCU 16
  .INDEX 16
  cpy #INV_VISIBLE_ITEMS
  bcc _rvb.invContinue
  jmp _rvb.noInventory
_rvb.invContinue:
  .ACCU 16
  .INDEX 16
  lda.w SCUMM.inventoryList,x
  bne _rvb.invHasItem
  jmp _rvb.noInventory                  ; 0 = end of list
_rvb.invHasItem:
  .ACCU 16
  .INDEX 16

  ; Look up name from cache for this obj_id
  sta.w SCUMM.scratch3                  ; scratch3 = obj_id to find
  phx                                   ; save inventory list offset
  phy                                   ; save visible counter

  ; Compute tilemap start for this item: row 5, column = visibleIndex * 8
  ; tilemap offset = (5 * 32 + visibleIndex * 8) * 2
  tya
  asl a
  asl a
  asl a                                 ; visibleIndex * 8
  clc
  adc #160                              ; + 5*32 = 160
  asl a                                 ; * 2 = byte offset
  sta.w SCUMM.actorOamCount             ; reuse as tilemap write ptr

  ; Search invNameObjIds for matching obj_id
  ldx #0
  lda.w SCUMM.invNameCount
  beq _rvb.invNameDone
  sta.w SCUMM.scratch2                  ; search count

_rvb.invNameSearch:
  .ACCU 16
  .INDEX 16
  lda.w SCUMM.invNameObjIds,x
  cmp.w SCUMM.scratch3
  beq _rvb.invNameFound
  inx
  inx
  dec.w SCUMM.scratch2
  bne _rvb.invNameSearch
  bra _rvb.invNameDone                  ; not found

_rvb.invNameFound:
  .ACCU 16
  .INDEX 16
  ; X = name slot * 2; compute name data offset = (slot * 16)
  txa
  lsr a                                 ; slot index
  sta.w SCUMM.scratch2                  ; save slot index

  ; Get name length
  tax
  lda.w SCUMM.invNameLens,x
  and #$00FF
  beq _rvb.invNameDone
  pha                                   ; push char count

  ; Name data offset = slot * 16
  lda.w SCUMM.scratch2
  asl a
  asl a
  asl a
  asl a                                 ; * 16
  tax                                   ; X = name data offset

  ; Compute palette: highlight if this item is the hovered cursor object
  phx
  lda.w SCUMM.scratch3                  ; current item obj_id
  cmp.w SCUMM.cursorObject
  bne _rvb.invNormalPal
  lda #$3800                            ; palette 6 = highlight yellow
  bra _rvb.invPalDone
_rvb.invNormalPal:
  .ACCU 16
  lda #$3C00                            ; palette 7 = normal white
_rvb.invPalDone:
  .ACCU 16
  sta.w SCUMM.scratch2                  ; store palette word
  plx

  ldy.w SCUMM.actorOamCount             ; Y = tilemap byte offset

  ; Write name characters
_rvb.invCharLoop:
  .ACCU 16
  .INDEX 16
  sep #$20
.ACCU 8
  lda.w SCUMM.invNames,x
  rep #$20
.ACCU 16
  and #$00FF
  sec
  sbc #$20                              ; ASCII to tile index
  ora.w SCUMM.scratch2                  ; priority + palette (highlight or normal)
  sta.w SCUMM.verbTilemap,y
  inx
  iny
  iny
  pla
  dec a
  beq _rvb.invNameDone
  pha
  bra _rvb.invCharLoop

_rvb.invNameDone:
  .ACCU 16
  .INDEX 16
  ply                                   ; restore visible counter
  plx                                   ; restore list offset
  iny                                   ; next visible slot
  inx
  inx                                   ; next list entry
  jmp _rvb.invLoop

_rvb.noInventory:
  .ACCU 16
  .INDEX 16

  ; Clear dirty flag, set DMA pending flag, mark bar visible
  stz.w SCUMM.verbDirty
  stz.w SCUMM.inventoryDirty
  lda #1
  sta.w SCUMM.verbDmaPending

  plb
  rtl

.ends

;-------------------------------------------------------------------
; scummvm.buildCgramHdmaTable -- fill WRAM CGRAM HDMA table
; Briefly enters force blank to read room's palette 7 colors 1-3
; from CGRAM, then writes the full table to SCUMM.cgramHdmaTable.
; Table restores room colors at scanline 0, sets verb colors at 140.
; JSL/RTL. DBR=$7E assumed for absolute addressing.
;-------------------------------------------------------------------
.bank 5 slot 0
.base BSL
.section "ScummVMBuildCgramHdma" free

scummvm.buildCgramHdmaTable:
  php
  rep #$31
  lda.w #SCUMM.cgramHdmaTable & $FFFF
  tax

  ; Enter force blank and disable HDMA to safely read CGRAM.
  ; Zero GLOBAL.HDMA.CHANNEL.ENABLE so NMI cannot re-enable HDMA
  ; (NMI is non-maskable — sei doesn't block it).
  sep #$20
  lda.w GLOBAL.HDMA.CHANNEL.ENABLE
  pha
  lda #0
  sta.w GLOBAL.HDMA.CHANNEL.ENABLE
  sta.l HDMAEN
  lda.b #INIDSP_FORCE_BLANK
  sta.l INIDSP

  ; --- Read palette 7 colors 1-3 from CGRAM $71 ---
  lda #$71
  sta.l $2121

  ; -- Per-line 8 entries at scanlines 0-7: restore pal7 c1-c3 + pal6 c1-c3 + pal1 c12-c13 --
  lda #$88
  sta.w 0,x
  ; Entry 0: CGRAM[$71] = room pal7 c1
  lda #$71
  sta.w 1,x
  sta.w 2,x
  lda.l $213B
  sta.w 3,x
  lda.l $213B
  sta.w 4,x
  ; Entry 1: CGRAM[$72] = room pal7 c2
  lda #$72
  sta.w 5,x
  sta.w 6,x
  lda.l $213B
  sta.w 7,x
  lda.l $213B
  sta.w 8,x
  ; Entry 2: CGRAM[$73] = room pal7 c3
  lda #$73
  sta.w 9,x
  sta.w 10,x
  lda.l $213B
  sta.w 11,x
  lda.l $213B
  sta.w 12,x

  ; --- Read palette 6 colors 1-3 from CGRAM $61 ---
  lda #$61
  sta.l $2121
  ; Entry 3: CGRAM[$61] = room pal6 c1
  lda #$61
  sta.w 13,x
  sta.w 14,x
  lda.l $213B
  sta.w 15,x
  lda.l $213B
  sta.w 16,x
  ; Entry 4: CGRAM[$62] = room pal6 c2
  lda #$62
  sta.w 17,x
  sta.w 18,x
  lda.l $213B
  sta.w 19,x
  lda.l $213B
  sta.w 20,x
  ; Entry 5: CGRAM[$63] = room pal6 c3
  lda #$63
  sta.w 21,x
  sta.w 22,x
  lda.l $213B
  sta.w 23,x
  lda.l $213B
  sta.w 24,x

  ; --- Read palette 1 colors 12-13 from CGRAM $1C (= 2bpp pal7 c0-c1) ---
  lda #$1C
  sta.l $2121
  ; Entry 6: CGRAM[$1C] = room pal1 c12 (= 2bpp pal7 c0)
  lda #$1C
  sta.w 25,x
  sta.w 26,x
  lda.l $213B
  sta.w 27,x
  lda.l $213B
  sta.w 28,x
  ; Entry 7: CGRAM[$1D] = room pal1 c13 (= 2bpp pal7 c1)
  lda #$1D
  sta.w 29,x
  sta.w 30,x
  lda.l $213B
  sta.w 31,x
  lda.l $213B
  sta.w 32,x

  ; NOTE: HDMA stays disabled until entire table is built.
  ; Re-enabling HDMA here would process a partially-written table,
  ; causing the HDMA to read stale WRAM as bogus count bytes/data
  ; and corrupt CGRAM entries (pal0[1], [5], [7] zeroed).

  ; -- Scanlines 8-127: 120 lines, harmless CGRAM[$70] = $0000 --
  lda #120
  sta.w 33,x
  lda #$70
  sta.w 34,x
  sta.w 35,x
  stz.w 36,x
  stz.w 37,x

  ; -- Scanlines 128-134: 7 lines, harmless CGRAM[$70] = $0000 --
  lda #7
  sta.w 38,x
  lda #$70
  sta.w 39,x
  sta.w 40,x
  stz.w 41,x
  stz.w 42,x

  ; -- Scanlines 135-136: per-line 2, sentence palette (default harmless) --
  lda #$82
  sta.w 43,x
  ; Entry 0: default harmless CGRAM[$70] = $0000
  lda #$70
  sta.w 44,x
  sta.w 45,x
  stz.w 46,x
  stz.w 47,x
  ; Entry 1: default harmless CGRAM[$70] = $0000
  sta.w 48,x
  sta.w 49,x
  stz.w 50,x
  stz.w 51,x

  ; -- Scanlines 137-143: per-line 7, set verb + highlight colors --
  lda #$87
  sta.w 52,x
  ; Entry 0: CGRAM[$00] = $0000 (backdrop = black)
  stz.w 53,x
  stz.w 54,x
  stz.w 55,x
  stz.w 56,x
  ; Entry 1: CGRAM[$73] = $7FFF (white body — normal verb text)
  ; Placed first so it's written earliest (scanline 138), maximizing
  ; margin before sentence text at scanline 146.
  lda #$73
  sta.w 57,x
  sta.w 58,x
  lda #$FF
  sta.w 59,x
  lda #$7F
  sta.w 60,x
  ; Entry 2: CGRAM[$71] = $6318 (light grey fill — normal)
  lda #$71
  sta.w 61,x
  sta.w 62,x
  lda #$18
  sta.w 63,x
  lda #$63
  sta.w 64,x
  ; Entry 3: CGRAM[$72] = $294A (dark shadow — normal)
  lda #$72
  sta.w 65,x
  sta.w 66,x
  lda #$4A
  sta.w 67,x
  lda #$29
  sta.w 68,x
  ; Entry 4: CGRAM[$61] = $6318 (light grey fill — highlight)
  lda #$61
  sta.w 69,x
  sta.w 70,x
  lda #$18
  sta.w 71,x
  lda #$63
  sta.w 72,x
  ; Entry 5: CGRAM[$62] = $294A (dark shadow — highlight)
  lda #$62
  sta.w 73,x
  sta.w 74,x
  lda #$4A
  sta.w 75,x
  lda #$29
  sta.w 76,x
  ; Entry 6: CGRAM[$63] = $03FF (bright yellow body — highlight)
  lda #$63
  sta.w 77,x
  sta.w 78,x
  lda #$FF
  sta.w 79,x
  lda #$03
  sta.w 80,x

  ; -- Scanlines 144-223: 80 lines, harmless CGRAM[$70] = $0000 --
  lda #80
  sta.w 81,x
  lda #$70
  sta.w 82,x
  sta.w 83,x
  stz.w 84,x
  stz.w 85,x

  ; Terminator
  stz.w 86,x

  ; Restore HDMA enable flag + display AFTER entire table is built.
  ; Only set GLOBAL.HDMA.CHANNEL.ENABLE — do NOT write HDMAEN directly.
  ; Mid-frame HDMA enable corrupts CGRAM. NMI enables HDMA at next VBlank.
  pla
  sta.w GLOBAL.HDMA.CHANNEL.ENABLE
  lda.w ScreenBrightness
  sta.l INIDSP

  plp
  rtl

.ends


;===================================================================
; Cursor tile data — 8x8 4bpp arrow sprite (32 bytes)
; Hardcoded arrow pointing upper-left
;===================================================================
.bank 5 slot 0
.base BSL
.section "CursorTileData" free

CursorTileData:
; 8x8 4bpp tile: 2 bitplanes interleaved per row (planes 0-1), then planes 2-3
; Arrow shape (1=outline black, 2=fill white):
; Row 0: 1 0 0 0 0 0 0 0
; Row 1: 1 1 0 0 0 0 0 0
; Row 2: 1 2 1 0 0 0 0 0
; Row 3: 1 2 2 1 0 0 0 0
; Row 4: 1 2 2 2 1 0 0 0
; Row 5: 1 2 2 2 2 1 0 0
; Row 6: 1 2 1 1 0 0 0 0
; Row 7: 1 1 0 1 1 0 0 0
; Palette: index 0=transparent, index 1=black (outline), index 2=white (fill)
; Bitplanes 0-1 (interleaved rows):
; Color = BP0 + BP1*2.  Color 1 (outline): BP0=1,BP1=0.  Color 2 (fill): BP0=0,BP1=1.
  .db %10000000, %00000000   ; row 0: 1 0 0 0 0 0 0 0
  .db %11000000, %00000000   ; row 1: 1 1 0 0 0 0 0 0
  .db %10100000, %01000000   ; row 2: 1 2 1 0 0 0 0 0
  .db %10010000, %01100000   ; row 3: 1 2 2 1 0 0 0 0
  .db %10001000, %01110000   ; row 4: 1 2 2 2 1 0 0 0
  .db %10000100, %01111000   ; row 5: 1 2 2 2 2 1 0 0
  .db %10110000, %01000000   ; row 6: 1 2 1 1 0 0 0 0
  .db %11011000, %00000000   ; row 7: 1 1 0 1 1 0 0 0
; Bitplanes 2-3 (all zero — indices 0-3 only need planes 0-1):
  .db $00, $00, $00, $00, $00, $00, $00, $00
  .db $00, $00, $00, $00, $00, $00, $00, $00
CursorTileDataEnd:

.ends


;===================================================================
; Cursor update — superfree (called via jsl from play method)
; Reads joypad, moves cursor, writes SCUMM vars, handles A-button
; click for walk and verb selection.
;===================================================================
.bank 5 slot 0
.base BSL
.section "ScummVMCursorUpdate" free

scummvm.updateCursor:
  phb
  sep #$20
  lda #$7E
  pha
  plb
  rep #$31

  ;--- Refresh cursor palette buffer every frame (guards against WRAM corruption) ---
  sep #$20
  stz.w SCUMM.cursorPalBuf
  stz.w SCUMM.cursorPalC1Hi
  lda #$FF
  sta.w SCUMM.cursorPalC2Lo
  lda #$7F
  sta.w SCUMM.cursorPalC2Hi
  rep #$20

  lda.w SCUMM.cursorTileDone
  bne _uc.tileDone
_uc.tileDone:
  .ACCU 16
  .INDEX 16

  ;--- Mouse delta application ---
  lda.w mouseDetected
  sta.w SCUMM.mouseActive             ; copy detection flag
  beq _uc.mouseDone

  ; Apply Y delta (clamp 0-223)
  lda.w SCUMM.cursorY
  clc
  adc.w mouseDeltaY
  bmi _uc.clampYzero
  cmp #224
  bcc _uc.storeY
  lda #223
  bra _uc.storeY
_uc.clampYzero:
  .ACCU 16
  .INDEX 16
  lda #0
_uc.storeY:
  .ACCU 16
  .INDEX 16
  sta.w SCUMM.cursorY

  ; Apply X delta (clamp 0-255)
  lda.w SCUMM.cursorX
  clc
  adc.w mouseDeltaX
  bmi _uc.clampXzero
  cmp #256
  bcc _uc.storeX
  lda #255
  bra _uc.storeX
_uc.clampXzero:
  .ACCU 16
  .INDEX 16
  lda #0
_uc.storeX:
  .ACCU 16
  .INDEX 16
  sta.w SCUMM.cursorX

  ; Clear deltas (consumed)
  stz.w mouseDeltaX
  stz.w mouseDeltaY

_uc.mouseDone:
  .ACCU 16
  .INDEX 16

  ;--- Read joypad state (direct WRAM access — can't jsr bank 0 from superfree) ---
  lda.w inputDevice.press
  sta.w SCUMM.scratch                 ; current press state
  lda.w inputDevice.trigger
  sta.w SCUMM.scratch2                ; newly triggered buttons

  ;--- D-pad movement ---
  lda.w SCUMM.scratch
  bit.w #JOY_DIR_UP
  beq _uc.noUp
  lda.w SCUMM.cursorY
  sec
  sbc #CURSOR_SPEED
  bpl +
  lda #0
+
  sta.w SCUMM.cursorY
_uc.noUp:
  .ACCU 16
  .INDEX 16

  lda.w SCUMM.scratch
  bit.w #JOY_DIR_DOWN
  beq _uc.noDown
  lda.w SCUMM.cursorY
  clc
  adc #CURSOR_SPEED
  cmp #224
  bcc +
  lda #223
+
  sta.w SCUMM.cursorY
_uc.noDown:
  .ACCU 16
  .INDEX 16

  lda.w SCUMM.scratch
  bit.w #JOY_DIR_LEFT
  beq _uc.noLeft
  lda.w SCUMM.cursorX
  sec
  sbc #CURSOR_SPEED
  bpl +
  lda #0
+
  sta.w SCUMM.cursorX
_uc.noLeft:
  .ACCU 16
  .INDEX 16

  lda.w SCUMM.scratch
  bit.w #JOY_DIR_RIGHT
  beq _uc.noRight
  lda.w SCUMM.cursorX
  clc
  adc #CURSOR_SPEED
  cmp #256
  bcc +
  lda #255
+
  sta.w SCUMM.cursorX
_uc.noRight:
  .ACCU 16
  .INDEX 16

  ;--- Write SCUMM mouse variables ---
  lda.w SCUMM.cursorX
  ldx #44*2
  sta.w SCUMM.globalVars,x            ; VAR(44) = VAR_MOUSE_X
  ldx #20*2
  sta.w SCUMM.globalVars,x            ; VAR(20) = VAR_VIRT_MOUSE_X

  lda.w SCUMM.cursorY
  ldx #45*2
  sta.w SCUMM.globalVars,x            ; VAR(45) = VAR_MOUSE_Y
  ldx #21*2
  sta.w SCUMM.globalVars,x            ; VAR(21) = VAR_VIRT_MOUSE_Y

  ;--- Per-frame object hover detection ---
  jsl scummvm.updateObjectHover

  ;--- Handle A button click ---
  lda.w SCUMM.scratch2
  bit.w #JOY_BUTTON_A
  bne +
  jmp _uc.noClick
+
  lda.w SCUMM.cursorEnabled
  bne +
  jmp _uc.noClick
+
  ; Check if cursor is in room area (Y < 144)
  lda.w SCUMM.cursorY
  cmp #144
  bcc +
  jmp _uc.verbAreaClick
+

  ;--- Click-to-walk: initialize position if actor at (0,0) ---
  ; Scripts may call putActorInRoom (sets room+visible) without putActor (sets x/y).
  ; If x=0 and y=0, snap to the renderActors fallback position before walking.
  lda.w SCUMM.actors.2.x
  ora.w SCUMM.actors.2.y
  bne _uc.posOk
  lda.w GLOBAL.room.cameraX
  clc
  adc #128
  sta.w SCUMM.actors.2.x
  lda #110
  sta.w SCUMM.actors.2.y
_uc.posOk:
  .ACCU 16
  .INDEX 16

  ; --- runInputScript(clickArea=2, verb, code=0) for scene click ---
  ldx #0
  lda #2
  sta.w SCUMM.argBuffer,x               ; arg[0] = clickArea 2 (scene click)
  lda.w SCUMM.sentenceVerb
  bne _uc.hasVerb2
  lda #$0B                              ; default "Walk to"
_uc.hasVerb2:
  ldx #2
  sta.w SCUMM.argBuffer,x               ; arg[1] = verb ID
  ldx #4
  stz.w SCUMM.argBuffer,x               ; arg[2] = button code 0
  lda #6
  sta.w SCUMM.argCount
  jsl scummvm.runInputScript_impl

  ;--- Resolve click target (object walk-to or cursor room pos) ---
  jsl scummvm.resolveClickTarget      ;A = targetX, scratch = targetY
  pha                                  ;save target X

  ; Set walk target for actor 1 (Guybrush)
  ; actor 1 word index = 2 (actor*2)
  ldx #2
  pla
  sta.w SCUMM.actorTargetX,x          ; target X
  pha                                  ; re-save target X for buildWalkPath
  lda.w SCUMM.scratch
  sta.w SCUMM.actorTargetY,x          ; target Y

  ; Build walk path with walkbox routing (guarded by boxCount)
  lda.w SCUMM.boxCount
  beq _uc.directWalk

  lda.w SCUMM.actors.2.x             ; startX
  sta.b tmp
  lda.w SCUMM.actors.2.y             ; startY
  sta.b tmp+2
  pla                                 ; targetX
  sta.b tmp+4
  lda.w SCUMM.scratch                ; targetY
  sta.b tmp+6
  lda #1                              ; actor index = 1 (Guybrush)
  jsl scummvm.buildWalkPath_long

  ; Check if path was built (pathLen > 0) — if not, target was outside walkboxes
  ldx #1                              ; actor 1 byte index
  sep #$20
  lda.w SCUMM.walkPathLen,x
  rep #$20
  and #$00FF
  bne _uc.walkDone
  jmp _uc.noClick                     ; refuse walk — target not in any walkbox

_uc.directWalk:
  .ACCU 16
  .INDEX 16
  pla                                 ; consume saved targetX
_uc.walkDone:
  .ACCU 16
  .INDEX 16

  ; Init walk animation
  ldx #1                              ; actor 1 byte index
  sep #$20
  lda #COSTUME_WALK_ANIM_SPEED
  sta.w SCUMM.actorAnimTimer,x
  lda #0
  sta.w SCUMM.actorAnimFrame,x
  rep #$20

  ; Set actor.moving = 1
  sep #$20
  lda #1
  sta.w SCUMM.actors.2.moving
  rep #$20

  ; Store pending verb+object for execution on arrival
  lda.w SCUMM.cursorObject
  beq _uc.noPending

  ; Check if this is a two-noun action (sentenceObjectA already set)
  lda.w SCUMM.sentenceObjectA
  beq _uc.firstNoun

  ; Second noun: execute verb with both objects
  lda.w SCUMM.cursorObject
  sta.w SCUMM.sentenceObjectB
  lda.w SCUMM.sentenceObjectA
  sta.w SCUMM.pendingObject           ; first noun is the main object
  lda.w SCUMM.sentenceVerb
  sta.w SCUMM.pendingVerb
  bra _uc.clickDone

_uc.firstNoun:
  .ACCU 16
  .INDEX 16
  lda.w SCUMM.cursorObject
  sta.w SCUMM.pendingObject
  lda.w SCUMM.sentenceVerb
  bne +
  lda #$0B                            ; default "Walk to" verb = $0B (MI1)
+
  sta.w SCUMM.pendingVerb
  bra _uc.clickDone
_uc.noPending:
  .ACCU 16
  .INDEX 16
  stz.w SCUMM.pendingVerb             ; no object = just walking
  stz.w SCUMM.pendingObject
  stz.w SCUMM.sentenceVerb            ; reset to default "Walk to"
  stz.w SCUMM.sentenceObjectA         ; clear first noun
  stz.w SCUMM.sentenceObjectB
  lda #1
  sta.w SCUMM.sentenceDirty           ; redraw sentence line
_uc.clickDone:
  .ACCU 16
  .INDEX 16

  jmp _uc.noClick

_uc.verbAreaClick:
  .ACCU 16
  .INDEX 16
  ;--- Verb area click: hit-test against verb entries ---
  ldx #0                              ; X = verb slot offset
  lda.w SCUMM.cursorX                 ; cursor X in screen pixels
  sta.w SCUMM.actorScreenX            ; reuse scratch (screen X)
  lda.w SCUMM.cursorY
  sta.w SCUMM.actorScreenY            ; screen Y

_uc.verbHitLoop:
  .ACCU 16
  .INDEX 16
  sep #$20
  lda.w SCUMM.verbs.1.id,x
  bne _uc.vhIdOk
  jmp _uc.verbHitNext
_uc.vhIdOk:
  lda.w SCUMM.verbs.1.flags,x
  and #SCUMM_VERB_FLAG_ON
  bne _uc.vhFlagOk
  jmp _uc.verbHitNext
_uc.vhFlagOk:
  rep #$20

  ; Check Y: verb.y <= cursorY < verb.y + 8
  lda.w SCUMM.verbs.1.y,x
  and #$00FF
  cmp.w SCUMM.actorScreenY
  beq _uc.vhYge
  bcc _uc.vhYge
  jmp _uc.verbHitNext                 ; verb.y > cursorY
_uc.vhYge:
  .ACCU 16
  clc
  adc #8
  cmp.w SCUMM.actorScreenY
  bcs _uc.vhYok
  jmp _uc.verbHitNext                 ; verb.y + 8 <= cursorY
_uc.vhYok:
  .ACCU 16
  cmp.w SCUMM.actorScreenY
  bne _uc.vhYnotEq
  jmp _uc.verbHitNext
_uc.vhYnotEq:

  ; Check X: verb.x <= cursorX < verb.x + nameLen*8
  lda.w SCUMM.verbs.1.x,x
  and #$00FF
  cmp.w SCUMM.actorScreenX
  beq _uc.vhXge
  bcc _uc.vhXge
  jmp _uc.verbHitNext                 ; verb.x > cursorX
_uc.vhXge:
  .ACCU 16
  pha
  lda.w SCUMM.verbs.1.nameLen,x
  and #$00FF
  asl a
  asl a
  asl a                               ; nameLen * 8
  clc
  adc 1,s                             ; verb.x + nameLen*8
  sta 1,s
  pla
  cmp.w SCUMM.actorScreenX
  bcs _uc.vhXhit
  jmp _uc.verbHitNext                 ; right edge <= cursorX
_uc.vhXhit:
  .ACCU 16
  cmp.w SCUMM.actorScreenX
  bne _uc.vhXnotEq
  jmp _uc.verbHitNext
_uc.vhXnotEq:

  ; Hit! Store verb ID as sentenceVerb
  sep #$20
  lda.w SCUMM.verbs.1.id,x
  rep #$20
  and #$00FF
  sta.w SCUMM.sentenceVerb
  stz.w SCUMM.sentenceObjectA
  stz.w SCUMM.sentenceObjectB
  lda #1
  sta.w SCUMM.sentenceDirty

  ; --- runInputScript(clickArea=1, verb, code=0) ---
  ldx #0
  lda #1
  sta.w SCUMM.argBuffer,x               ; arg[0] = clickArea 1 (verb click)
  lda.w SCUMM.sentenceVerb
  ldx #2
  sta.w SCUMM.argBuffer,x               ; arg[1] = verb ID
  ldx #4
  stz.w SCUMM.argBuffer,x               ; arg[2] = button code 0
  lda #6
  sta.w SCUMM.argCount
  jsl scummvm.runInputScript_impl

  jmp _uc.noClick

_uc.verbHitNext:
  .ACCU 16
  .INDEX 16
  rep #$20
  txa
  clc
  adc #_sizeof_scummVerb
  tax
  cpx #_sizeof_scummVerb * SCUMM_MAX_VERBS
  bcs +
  jmp _uc.verbHitLoop
+
  ;--- No verb hit: check for inventory item click ---
  lda.w SCUMM.cursorObject
  beq _uc.noClick                      ; no object under cursor
  lda.w SCUMM.sentenceVerb
  beq _uc.noClick                      ; no verb selected

  ; Verb selected + object under cursor (inventory item)
  lda.w SCUMM.sentenceObjectA
  bne _uc.invSecondNoun

  ; First noun from inventory
  lda.w SCUMM.cursorObject
  sta.w SCUMM.sentenceObjectA
  lda #1
  sta.w SCUMM.sentenceDirty
  jmp _uc.noClick

_uc.invSecondNoun:
  .ACCU 16
  .INDEX 16
  ; Second noun from inventory: execute immediately (no walking)
  lda.w SCUMM.cursorObject
  sta.w SCUMM.sentenceObjectB
  lda.w SCUMM.sentenceObjectA
  sta.w SCUMM.pendingObject
  lda.w SCUMM.sentenceVerb
  sta.w SCUMM.pendingVerb

_uc.noClick:
  .ACCU 16
  .INDEX 16
  ;--- Verb hover highlight ---
  ; Check if cursor is in verb area for highlight tracking
  rep #$20
  lda.w SCUMM.cursorY
  cmp #144
  bcc _uc.clearHighlight

  ; Hit-test for hover (same logic as click)
  ldx #0
_uc.hoverLoop:
  .ACCU 16
  .INDEX 16
  sep #$20
  lda.w SCUMM.verbs.1.id,x
  beq _uc.hoverNext
  lda.w SCUMM.verbs.1.flags,x
  and #SCUMM_VERB_FLAG_ON
  beq _uc.hoverNext
  rep #$20

  ; Check Y bounds
  lda.w SCUMM.verbs.1.y,x
  and #$00FF
  cmp.w SCUMM.cursorY
  beq +
  bcs _uc.hoverNext
+
  clc
  adc #8
  cmp.w SCUMM.cursorY
  bcc _uc.hoverNext
  beq _uc.hoverNext

  ; Check X bounds
  lda.w SCUMM.verbs.1.x,x
  and #$00FF
  cmp.w SCUMM.cursorX
  beq +
  bcs _uc.hoverNext
+
  pha
  lda.w SCUMM.verbs.1.nameLen,x
  and #$00FF
  asl a
  asl a
  asl a
  clc
  adc 1,s
  sta 1,s
  pla
  cmp.w SCUMM.cursorX
  bcc _uc.hoverNext
  beq _uc.hoverNext

  ; Hover match — check if changed
  cpx.w SCUMM.highlightVerb
  beq _uc.highlightDone               ; same as before, skip redraw
  stx.w SCUMM.highlightVerb
  lda #1
  sta.w SCUMM.verbDirty               ; force verb redraw with highlight
  jmp _uc.highlightDone

_uc.hoverNext:
  .ACCU 16
  .INDEX 16
  rep #$20
  txa
  clc
  adc #_sizeof_scummVerb
  tax
  cpx #_sizeof_scummVerb * SCUMM_MAX_VERBS
  bcs +
  jmp _uc.hoverLoop
+

_uc.clearHighlight:
  .ACCU 16
  .INDEX 16
  lda.w SCUMM.highlightVerb
  cmp #$FFFF
  beq _uc.highlightDone
  lda #$FFFF
  sta.w SCUMM.highlightVerb
  lda #1
  sta.w SCUMM.verbDirty               ; force redraw without highlight

_uc.highlightDone:
  .ACCU 16
  .INDEX 16

  ;--- L/R shoulder: inventory scroll ---
  lda.w inputDevice.trigger
  bit.w #JOY_BUTTON_L
  beq _uc.noL
  ; L pressed: scroll left (decrement)
  lda.w SCUMM.inventoryScroll
  beq _uc.noL                          ; already at 0
  dec a
  sta.w SCUMM.inventoryScroll
  lda #1
  sta.w SCUMM.inventoryDirty
  sta.w SCUMM.verbDirty
_uc.noL:
  .ACCU 16
  .INDEX 16
  lda.w inputDevice.trigger
  bit.w #JOY_BUTTON_R
  beq _uc.noR
  ; R pressed: scroll right (increment)
  lda.w SCUMM.inventoryCount
  sec
  sbc #INV_VISIBLE_ITEMS               ; max scroll = count - visible
  bmi _uc.noR                          ; fewer items than visible
  beq _uc.noR                          ; exactly visible, no scroll
  sta.w SCUMM.scratch                  ; max scroll value
  lda.w SCUMM.inventoryScroll
  cmp.w SCUMM.scratch
  bcs _uc.noR                          ; already at max
  inc a
  sta.w SCUMM.inventoryScroll
  lda #1
  sta.w SCUMM.inventoryDirty
  sta.w SCUMM.verbDirty
_uc.noR:
  .ACCU 16
  .INDEX 16

  plb
  rtl

.ends


;===================================================================
; DMA registration helper — superfree (called via jsl from play)
; Directly writes DMA queue entries for pending CHR/cursor/verb
; transfers. Avoids bank 0 bloat from inline registerTransfer calls.
;===================================================================
.bank 5 slot 0
.base BSL
.section "ScummVMDmaRegistration" free

scummvm.registerPendingDma:
  php
  rep #$31
  phx
  phy
  sei

  ;--- Per-slot CHR DMA (costume animation frame changes) ---
  ; Process up to 2 dirty render slots per frame
  rep #$20
  stz.w SCUMM.scratch                 ; DMA count this frame
  stz.w SCUMM.scratch2                ; render slot scan index

_rpd.chrSlotLoop:
  .ACCU 16
  .INDEX 16
  ldx.w SCUMM.scratch2
  cpx #SCUMM_MAX_RENDER_SLOTS
  bcc +
  jmp _rpd.noChr
+
  sep #$20
  .ACCU 8
  lda.w SCUMM.renderSlotDirty,x
  rep #$20
  .ACCU 16
  and #$00FF
  bne +
  jmp _rpd.chrSlotNext
+

  ; This slot is dirty — try to register DMA (keep flag until success)
  jsr _rpd.findSlot                   ; X = free DMA queue slot offset
  bcs +
  jmp _rpd.chrSlotNext                ; queue full, keep dirty for retry
+
  ; DMA slot found — NOW clear the dirty flag
  phx                                 ; save DMA queue slot
  ldx.w SCUMM.scratch2                ; render slot index
  sep #$20
  .ACCU 8
  stz.w SCUMM.renderSlotDirty,x
  rep #$20
  .ACCU 16
  plx                                 ; restore DMA queue slot

  ; Read per-slot DMA params using scratch2 as render slot index
  ; Word arrays: slotChrSrcLo, slotChrLen, slotChrVram indexed by slot*2
  ; Byte array: slotChrSrcHi indexed by slot
  phy                                 ; save Y
  ldy.w SCUMM.scratch2                ; render slot index
  phy                                 ; save render slot on stack
  tya
  asl a                               ; slot * 2
  tay                                 ; Y = word index

  lda.w SCUMM.slotChrLen,y
  sta.w GLOBAL.dmaQueue.1.transferLength,x
  lda.w SCUMM.slotChrVram,y
  sta.w GLOBAL.dmaQueue.1.targetAdress,x
  lda.w SCUMM.slotChrSrcLo,y
  sta.w GLOBAL.dmaQueue.1.sourceAdress,x

  ply                                 ; render slot (byte index)
  sep #$20
  .ACCU 8
  lda.w SCUMM.slotChrSrcHi,y
  sta.w (GLOBAL.dmaQueue.1.sourceAdress & $FFFF) + 2,x
  lda #$40                            ; VRAM | ACTIVE
  sta.w GLOBAL.dmaQueue.1.transferType,x
  rep #$20
  .ACCU 16
  ply                                 ; restore original Y

  ; --- Also queue CGRAM DMA for costume palette (32 bytes) ---
  jsr _rpd.findSlot
  bcc _rpd.chrPalDone
  phy                                 ; save Y
  phx                                 ; save DMA queue slot offset
  ; Look up palette from CostumeDirTable using renderSlotCostume[slot]
  ldx.w SCUMM.scratch2                ; render slot index
  lda.w SCUMM.renderSlotCostume,x
  and #$00FF
  asl a
  asl a
  asl a                               ; costume * 8
  tax                                 ; X = CostumeDirTable offset
  lda.l CostumeDirTable,x             ; palette source addr
  sta.w SCUMM.actorScreenX            ; temp store palette addr
  sep #$20
  .ACCU 8
  lda.l CostumeDirTable + 2,x         ; palette source bank
  sta.w SCUMM.actorScreenY            ; temp store palette bank
  rep #$20
  .ACCU 16
  plx                                 ; restore DMA queue slot offset
  lda.w SCUMM.actorScreenX
  sta.w GLOBAL.dmaQueue.1.sourceAdress,x
  sep #$20
  .ACCU 8
  lda.w SCUMM.actorScreenY
  sta.w (GLOBAL.dmaQueue.1.sourceAdress & $FFFF) + 2,x
  rep #$20
  .ACCU 16
  lda #32                             ; 16 colors x 2 bytes
  sta.w GLOBAL.dmaQueue.1.transferLength,x
  ; CGRAM target: OBJ palette area + palSlot*32
  ; OBJ palettes start at CGRAM byte $100
  ldy.w SCUMM.scratch2                ; render slot
  lda.w SCUMM.renderSlotPalSlot,y
  and #$00FF
  asl a
  asl a
  asl a
  asl a
  asl a                               ; palSlot * 32
  clc
  adc #$0100                          ; OBJ palette base
  sta.w GLOBAL.dmaQueue.1.targetAdress,x
  sep #$20
  .ACCU 8
  lda #$42                            ; CGRAM | ACTIVE
  sta.w GLOBAL.dmaQueue.1.transferType,x
  rep #$20
  .ACCU 16
  ply                                 ; restore Y
_rpd.chrPalDone:
  .ACCU 16
  .INDEX 16

  ; Count DMAs, stop at 2 per frame
  inc.w SCUMM.scratch
  lda.w SCUMM.scratch
  cmp #2
  bcs _rpd.noChr

_rpd.chrSlotNext:
  .ACCU 16
  .INDEX 16
  rep #$20
  .ACCU 16
  inc.w SCUMM.scratch2
  jmp _rpd.chrSlotLoop
_rpd.noChr:
  .ACCU 16
  .INDEX 16

  ;--- Per-slot HEAD CHR DMA (head pic changes) ---
  rep #$20
  .ACCU 16
  stz.w SCUMM.scratch2                ; render slot scan index

_rpd.headSlotLoop:
  .ACCU 16
  .INDEX 16
  ldx.w SCUMM.scratch2
  cpx #SCUMM_MAX_RENDER_SLOTS
  bcs _rpd.noHead
  sep #$20
  .ACCU 8
  lda.w SCUMM.renderSlotHeadDirty,x
  rep #$20
  .ACCU 16
  and #$00FF
  beq _rpd.headSlotNext

  ; This slot has dirty head — queue DMA
  jsr _rpd.findSlot                   ; X = free DMA queue slot offset
  bcc _rpd.headSlotNext               ; queue full, keep dirty for retry

  ; DMA slot found — clear dirty
  phx                                 ; save DMA queue slot
  ldx.w SCUMM.scratch2                ; render slot index
  sep #$20
  .ACCU 8
  stz.w SCUMM.renderSlotHeadDirty,x
  rep #$20
  .ACCU 16
  plx                                 ; restore DMA queue slot

  ; Read head DMA params from slot arrays
  phy
  ldy.w SCUMM.scratch2                ; render slot
  phy                                 ; save render slot on stack
  tya
  asl a                               ; slot * 2
  tay                                 ; Y = word index

  lda.w SCUMM.slotHeadChrLen,y
  sta.w GLOBAL.dmaQueue.1.transferLength,x
  lda.w SCUMM.slotHeadChrSrcLo,y
  sta.w GLOBAL.dmaQueue.1.sourceAdress,x

  ; VRAM target = renderSlotTileBase[slot] + $300
  lda.w SCUMM.renderSlotTileBase,y
  clc
  adc #COSTUME_HEAD_VRAM_OFFSET
  sta.w GLOBAL.dmaQueue.1.targetAdress,x

  ply                                 ; render slot (byte index)
  sep #$20
  .ACCU 8
  lda.w SCUMM.slotHeadChrSrcHi,y
  sta.w (GLOBAL.dmaQueue.1.sourceAdress & $FFFF) + 2,x
  lda #$40                            ; VRAM | ACTIVE
  sta.w GLOBAL.dmaQueue.1.transferType,x
  rep #$20
  .ACCU 16
  ply                                 ; restore original Y

_rpd.headSlotNext:
  .ACCU 16
  .INDEX 16
  rep #$20
  .ACCU 16
  inc.w SCUMM.scratch2
  jmp _rpd.headSlotLoop
_rpd.noHead:
  .ACCU 16
  .INDEX 16

  ;--- Cursor tile DMA (one-time init) ---
  rep #$20
  lda.w SCUMM.cursorTileDone
  bne _rpd.cursorTileReady

  ; Mark done so we only DMA tile once
  lda #1
  sta.w SCUMM.cursorTileDone

  ; Cursor tile CHR → VRAM
  jsr _rpd.findSlot
  bcc _rpd.noCursor
  lda #CursorTileDataEnd - CursorTileData
  sta.w GLOBAL.dmaQueue.1.transferLength,x
  lda #CURSOR_TILE_VRAM_WORD * 2
  sta.w GLOBAL.dmaQueue.1.targetAdress,x
  lda.w #CursorTileData
  sta.w GLOBAL.dmaQueue.1.sourceAdress,x
  sep #$20
  lda.b #:CursorTileData
  sta.w (GLOBAL.dmaQueue.1.sourceAdress & $FFFF) + 2,x
  lda #$40                           ; VRAM | ACTIVE
  sta.w GLOBAL.dmaQueue.1.transferType,x
  rep #$20

_rpd.cursorTileReady:
  .ACCU 16
  .INDEX 16
  ;--- Cursor palette DMA (every frame — guards against CGRAM corruption) ---
  lda.w SCUMM.cursorEnabled
  beq _rpd.noCursor
  jsr _rpd.findSlot
  bcc _rpd.noCursor
  lda #4
  sta.w GLOBAL.dmaQueue.1.transferLength,x
  lda #$01A2                         ; CGRAM byte addr: OBJ palette 5, color 1
  sta.w GLOBAL.dmaQueue.1.targetAdress,x
  lda.w #SCUMM.cursorPalBuf & $FFFF
  sta.w GLOBAL.dmaQueue.1.sourceAdress,x
  sep #$20
  lda #$7E
  sta.w (GLOBAL.dmaQueue.1.sourceAdress & $FFFF) + 2,x
  lda #$42                           ; CGRAM | ACTIVE
  sta.w GLOBAL.dmaQueue.1.transferType,x
_rpd.noCursor:
  .ACCU 16
  .INDEX 16

  ;--- Verb tilemap DMA → VRAM $4800 (NMI pending flag, same pattern as dialog tilemap) ---
  rep #$20
  lda.w SCUMM.verbDmaPending
  beq _rpd.noVerb
  stz.w SCUMM.verbDmaPending
  sep #$20
  lda #1
  sta.w SCUMM.verbTilemapNmiPending  ; hand off to NMI direct DMA
  rep #$20
_rpd.noVerb:
  .ACCU 16
  .INDEX 16

  ;--- Dialog font DMA now handled by NMI (SCUMM.dialogFontNmiPending) ---
  .ACCU 16
  .INDEX 16

  ;--- Dialog tilemap DMA -> VRAM $9800 ---
  rep #$20
  lda.w SCUMM.dialogBootSuppress
  beq _rpd.bootOk
  dec.w SCUMM.dialogBootSuppress
  stz.w SCUMM.dialogDmaPending    ; eat the DMA request silently
  stz.w SCUMM.dialogActive        ; kill the dialog state too
  bra _rpd.noDialog
_rpd.bootOk:
  .ACCU 16
  .INDEX 16
  lda.w SCUMM.dialogDmaPending
  beq _rpd.noDialog
  stz.w SCUMM.dialogDmaPending
  sep #$20
  lda #1
  sta.w SCUMM.dialogTilemapNmiPending  ; hand off to NMI direct DMA
  rep #$20
_rpd.noDialog:
  .ACCU 16
  .INDEX 16

  ;--- Dialog palette DMA (every frame while dialog active) ---
  rep #$20
  lda.w SCUMM.dialogActive
  beq _rpd.noDialogPal
  ; Build dynamic palette from dialogColor (or default white)
  lda.w SCUMM.dialogActive
  beq _rpd.palWhite
  lda.w SCUMM.dialogColor
  and #$000F
  bne _rpd.palLookup
_rpd.palWhite:
  .ACCU 16
  .INDEX 16
  lda #15                            ; default = white
_rpd.palLookup:
  .ACCU 16
  .INDEX 16
  asl a
  tax
  lda.l _scummTalkColorLUT,x
  sta.w SCUMM.dialogPalColor         ; color 1 = talk color
  stz.w SCUMM.dialogPalTrans         ; color 0 = transparent
  ; Palette written to SCUMM.dialogPalColor above; NMI writes CGRAM directly.
_rpd.noDialogPal:
  .ACCU 16
  .INDEX 16

  rep #$31
  ply
  plx
  plp
  rtl


; Find free DMA queue slot.
; Assumes 16-bit A+X. Returns X = slot byte offset, carry set.
; If queue full, returns carry clear.
_rpd.findSlot:
  .ACCU 16
  .INDEX 16
  lda.w GLOBAL.currentDmaQueueSlot
  and.w #$78                          ; (16-1) * 8 = 120
  tax
  ldy #16                             ; DMA_QUEUE_SLOTS
-
  lda.w GLOBAL.dmaQueue.1.transferType,x
  bit.w #$0040                        ; ACTIVE bit
  beq +
  txa
  clc
  adc #8                              ; sizeof dmaQueue
  and.w #$78
  tax
  dey
  bne -
  clc
  rts
+
  sec
  rts

; SCUMM color index → BGR555 lookup table (EGA-standard approximation)
; BGR555: B[14:10] G[9:5] R[4:0]
_scummTalkColorLUT:
  .dw $0000             ; 0: black
  .dw $5400             ; 1: blue        (R=0,  G=0,  B=21)
  .dw $02A0             ; 2: green       (R=0,  G=21, B=0)
  .dw $56A0             ; 3: cyan        (R=0,  G=21, B=21)
  .dw $0015             ; 4: red         (R=21, G=0,  B=0)
  .dw $5415             ; 5: magenta     (R=21, G=0,  B=21)
  .dw $0155             ; 6: brown       (R=21, G=10, B=0)
  .dw $56B5             ; 7: light gray  (R=21, G=21, B=21)
  .dw $294A             ; 8: dark gray   (R=10, G=10, B=10)
  .dw $7D4A             ; 9: light blue  (R=10, G=10, B=31)
  .dw $2BEA             ; 10: light green (R=10, G=31, B=10)
  .dw $7FEA             ; 11: light cyan  (R=10, G=31, B=31)
  .dw $295F             ; 12: light red   (R=31, G=10, B=10)
  .dw $7D5F             ; 13: light magenta (R=31, G=10, B=31)
  .dw $03FF             ; 14: yellow     (R=31, G=31, B=0)
  .dw $7FFF             ; 15: white      (R=31, G=31, B=31)

.ends


;===================================================================
; Dialog text renderer — superfree
; extractAndRenderString: reads SCUMM string from bytecode,
; renders to BG3 tilemap buffer, sets dialog state.
; clearDialogTilemap: fills tilemap with $0000, flags DMA.
;===================================================================
.bank 5 slot 0
.base BSL
.section "ScummVMDialogRenderer" free

scummvm.extractAndRenderString:
  php
  phx
  phb
  sep #$20
  lda #$7E
  pha
  plb
  rep #$31

  ; --- Clear dialog tilemap buffer (fill with $0000) ---
  phx
  ldx #0
  lda #0
_ears.clearLoop:
  .ACCU 16
  .INDEX 16
  sta.w SCUMM.dialogTilemap,x
  inx
  inx
  cpx #DIALOG_TILEMAP_SIZE
  bcc _ears.clearLoop
  plx

  ; --- Pre-scan: count printable chars for centering + timer ---
  phy                                  ; save Y (bytecode PC)
  lda #0
  sta.w SCUMM.dialogCharCount         ; reset count
_ears.scanLoop:
  .ACCU 16
  .INDEX 16
  lda [tmp],y
  and #$00FF
  beq _ears.scanDone                   ; $00 = end
  iny
  cmp #$00FF
  beq _ears.scanFF                     ; $FF = escape prefix (CD talkie)
  cmp #$0009
  bcs _ears.scanPrintable              ; >= $09 = printable char
  ; $01-$08: escape code, skip 2-byte arg
  iny
  iny
  bra _ears.scanLoop
_ears.scanFF:
  .ACCU 16
  .INDEX 16
  ; $FF escape: read sub-code byte
  lda [tmp],y
  and #$00FF
  iny                                  ; skip sub-code
  ; sub-codes 1, 2, 3, 8: no extra args
  cmp #1
  beq _ears.scanDone                   ; newline — stop counting (first line only)
  cmp #2
  beq _ears.scanLoop
  cmp #3
  beq _ears.scanLoop
  cmp #8
  beq _ears.scanDone                   ; newline — stop counting (first line only)
  ; all other sub-codes (incl. $0A talkie): skip 2 arg bytes
  iny
  iny
  bra _ears.scanLoop
_ears.scanPrintable:
  .ACCU 16
  .INDEX 16
  inc.w SCUMM.dialogCharCount
  bra _ears.scanLoop
_ears.scanDone:
  .ACCU 16
  .INDEX 16
  ply                                  ; restore Y to start of string

  ; --- Determine text position ---
  ; If dialogY != 0: use explicit position from _print.pos
  ; Else: derive from actor screen position
  lda.w SCUMM.dialogY
  bne _ears.useExplicit

  ; Derive from actor: screenX = actor.x - cameraX, screenY = actor.y - 24
  lda.w SCUMM.dialogActor
  and #$00FF
  asl a
  asl a
  asl a
  asl a                                ; *16 = _sizeof_scummActor
  tax
  lda.w SCUMM.actors.1.x,x
  sec
  sbc.w GLOBAL.room.cameraX           ; screen X
  lsr a
  lsr a
  lsr a                                ; /8 = tile column
  sta.w SCUMM.dialogX
  lda.w SCUMM.actors.1.y,x
  sec
  sbc #24                              ; above actor head
  bpl +
  lda #8                               ; clamp to top
+
  lsr a
  lsr a
  lsr a                                ; /8 = tile row
  cmp #17                              ; clamp below verb bar boundary (row 18 = pixel Y 144)
  bcc +
  lda #16
+
  sta.w SCUMM.dialogY
  bra _ears.center

_ears.useExplicit:
  .ACCU 16
  .INDEX 16
  ; dialogX/dialogY set by _print.pos (SCUMM 320x200 coords)
  ; Convert to tile: col = X / 10 (320->32), row = Y / 8
  lda.w SCUMM.dialogX
  ldx #0
_ears.div10:
  .ACCU 16
  .INDEX 16
  cmp #10
  bcc _ears.div10done
  sec
  sbc #10
  inx
  bra _ears.div10
_ears.div10done:
  .ACCU 16
  .INDEX 16
  txa
  sta.w SCUMM.dialogX                 ; tile column (0-31)
  lda.w SCUMM.dialogY
  lsr a
  lsr a
  lsr a
  cmp #17                              ; clamp below verb bar boundary (row 18 = pixel Y 144)
  bcc +
  lda #16
+
  sta.w SCUMM.dialogY                 ; tile row

_ears.center:
  .ACCU 16
  .INDEX 16
  ; --- Center text: start_col = centerCol - (charCount / 2) ---
  lda.w SCUMM.dialogCharCount
  lsr a                                ; count / 2
  sta.w SCUMM.scratch                  ; half width
  lda.w SCUMM.dialogX                 ; center column
  sec
  sbc.w SCUMM.scratch                  ; start_col = center - half
  bpl +
  lda #0                               ; clamp to left edge
+
  cmp #32
  bcc +
  lda #0                               ; if > 31, reset to 0
+
  ; --- Right-edge clamp: ensure start + charCount <= 32 ---
  pha                                    ; save start_col
  clc
  adc.w SCUMM.dialogCharCount           ; start + count
  cmp #33                               ; > 32?
  bcc _ears.noOverflow                   ; fits — use saved start
  ; Overflow: compute new start = max(0, 32 - count)
  pla                                    ; discard saved start
  lda #32
  sec
  sbc.w SCUMM.dialogCharCount           ; 32 - count
  bpl _ears.startReady
  lda #0                               ; text wider than 32: start at 0
  bra _ears.startReady
_ears.noOverflow:
  .ACCU 16
  .INDEX 16
  pla                                    ; restore original start
_ears.startReady:
  .ACCU 16
  .INDEX 16
  sta.w SCUMM.scratch                  ; scratch = current column

  ; --- Compute tilemap base offset for current row ---
  ; offset = (row * 32 + col) * 2
  lda.w SCUMM.dialogY                 ; tile row
  asl a
  asl a
  asl a
  asl a
  asl a                                ; row * 32
  clc
  adc.w SCUMM.scratch                  ; + start column
  asl a                                ; * 2 (word entries)
  tax                                  ; X = tilemap byte offset

  ; --- Render: read chars from bytecode, write tilemap entries ---
  ; Reads until $00 terminator (like skipPrintString). Renders printable chars.
_ears.renderEndTrap:
  .ACCU 16
  .INDEX 16
  jmp _ears.renderEnd                  ; trampoline (scan code pushes renderEnd out of branch range)
_ears.renderCharTrap:
  .ACCU 16
  .INDEX 16
  jmp _ears.renderChar                 ; trampoline (scan code pushes renderChar out of branch range)
_ears.renderLoop:
  .ACCU 16
  .INDEX 16
  lda [tmp],y
  and #$00FF
  beq _ears.renderEndTrap              ; $00 = end of string
  iny
  cmp #$00FF
  beq _ears.renderFF                   ; $FF = escape prefix (CD talkie)
  cmp #$0009
  bcs _ears.renderCharTrap             ; >= $09 = printable
  ; $01-$08: escape, skip 2-byte arg
  iny
  iny
  bra _ears.renderLoop
_ears.renderFF:
  .ACCU 16
  .INDEX 16
  ; $FF escape: read sub-code byte
  lda [tmp],y
  and #$00FF
  iny                                  ; skip sub-code
  ; sub-codes 1, 8: newline; 2, 3: no-op
  cmp #1
  beq _ears.renderNewline
  cmp #2
  beq _ears.renderLoop
  cmp #3
  beq _ears.renderLoop
  cmp #8
  beq _ears.renderNewline
  ; all other sub-codes (incl. $0A talkie): skip 2 arg bytes
  iny
  iny
  bra _ears.renderLoop

_ears.renderNewline:
  .ACCU 16
  .INDEX 16
  ; Advance X to start of next 32-tile tilemap row (64 bytes per row)
  txa
  clc
  adc #$003F                             ; round up...
  and #$FFC0                             ; ...to next 64-byte boundary
  tax
  cpx #1152                              ; verb area starts at row 18 (18*64=$0480, pixel Y 144)
  bcc +                                  ; within gameplay area — continue
  jmp _ears.renderEnd                    ; at/past verb area → stop
+

  ; Per-line centering: scan ahead to count chars in the new line
  phy                                    ; save Y (bytecode position)
  phx                                    ; save X (row_base byte offset)
  lda #0
  sta.w SCUMM.scratch2                   ; line char count = 0
_ears.nlScanLoop:
  .ACCU 16
  .INDEX 16
  lda [tmp],y
  and #$00FF
  beq _ears.nlScanDone
  iny
  cmp #$00FF
  beq _ears.nlScanFF
  cmp #$0009
  bcs _ears.nlScanChar
  iny
  iny
  bra _ears.nlScanLoop
_ears.nlScanFF:
  .ACCU 16
  .INDEX 16
  lda [tmp],y
  and #$00FF
  iny
  cmp #1
  beq _ears.nlScanDone
  cmp #2
  beq _ears.nlScanLoop
  cmp #3
  beq _ears.nlScanLoop
  cmp #8
  beq _ears.nlScanDone
  iny
  iny
  bra _ears.nlScanLoop
_ears.nlScanChar:
  .ACCU 16
  .INDEX 16
  inc.w SCUMM.scratch2
  bra _ears.nlScanLoop
_ears.nlScanDone:
  .ACCU 16
  .INDEX 16
  plx                                    ; restore row_base into X
  ply                                    ; restore bytecode position into Y
  ; Compute start_col = clamp(dialogX - count/2, 0, 32 - count)
  lda.w SCUMM.scratch2                   ; line char count
  lsr a                                  ; count / 2
  sta.w SCUMM.scratch                    ; scratch = half-width
  lda.w SCUMM.dialogX                    ; center column (0-31)
  sec
  sbc.w SCUMM.scratch                    ; start_col = center - half
  bpl +
    lda #0
+
  cmp #32
  bcc +
    lda #0
+
  pha                                    ; save start_col
  clc
  adc.w SCUMM.scratch2                   ; start + count
  cmp #33
  bcc _ears.nlNoOverflow
    pla
    lda #32
    sec
    sbc.w SCUMM.scratch2
    bpl _ears.nlStartOk
    lda #0
    bra _ears.nlStartOk
_ears.nlNoOverflow:
  .ACCU 16
  .INDEX 16
  pla
_ears.nlStartOk:
  .ACCU 16
  .INDEX 16
  asl a                                  ; start_col * 2 = byte offset
  sta.w SCUMM.scratch                    ; save byte offset
  txa                                    ; A = row_base
  clc
  adc.w SCUMM.scratch                    ; A = row_base + start_offset
  tax                                    ; X = new tilemap position
  jmp _ears.renderLoop                   ; bra out of range — use jmp

_ears.renderLoopTrap:
  .ACCU 16
  .INDEX 16
  jmp _ears.renderLoop                 ; trampoline (renderChar branches too far back)
_ears.renderChar:
  .ACCU 16
  .INDEX 16
  ; tile index = char - $20 (ASCII space = tile 0 in font)
  sec
  sbc #$20
  ; tilemap word: priority 1 + palette 7 + tile index
  ora #$3C00
  cpx #DIALOG_TILEMAP_SIZE
  bcs _ears.renderLoopTrap             ; bounds check: skip if past tilemap end
  sta.w SCUMM.dialogTilemap,x
  inx
  inx
  ; Right margin wrap: if column wrapped to 0, indent by 1 tile
  txa
  and #$003F                           ; mod 64 = byte offset within row
  bne _ears.renderLoopTrap             ; not at start of row — continue
  inx                                  ; skip column 0
  inx
  bra _ears.renderLoopTrap

_ears.renderEnd:
  .ACCU 16
  .INDEX 16
  iny                                  ; skip past $00 terminator

  ; --- Default dialogColor to white if not set ---
  lda.w SCUMM.dialogColor
  bne +
    lda #15
    sta.w SCUMM.dialogColor
+
  ; --- Set dialog state ---
  lda #1
  sta.w SCUMM.dialogActive
  ; Timer = char_count * 6 + 60 (min 1 second)
  lda.w SCUMM.dialogCharCount
  asl a                                ; *2
  sta.w SCUMM.scratch
  asl a                                ; *4
  clc
  adc.w SCUMM.scratch                  ; *6
  clc
  adc #60                              ; minimum 1 second
  sta.w SCUMM.dialogTimer
  lda #1
  sta.w SCUMM.dialogDmaPending

  plb
  plx
  plp
  rtl


;-------------------------------------------------------------------
; scummvm.clearDialogTilemap -- fill tilemap with $0000, flag DMA
;-------------------------------------------------------------------
scummvm.clearDialogTilemap:
  php
  phx
  phb
  sep #$20
  lda #$7E
  pha
  plb
  rep #$31

  ldx #0
  lda #0
_cdt.clearLoop:
  .ACCU 16
  .INDEX 16
  sta.w SCUMM.dialogTilemap,x
  inx
  inx
  cpx #DIALOG_TILEMAP_SIZE
  bcc _cdt.clearLoop

  lda #1
  sta.w SCUMM.dialogDmaPending
  ; Re-dirty sentence so it re-renders on BG2 after dialog clears
  lda #1
  sta.w SCUMM.sentenceDirty

  plb
  plx
  plp
  rtl


;-------------------------------------------------------------------
; scummvm.clearVerbTilemap -- fill verb tilemap with $0000, flag DMA
;-------------------------------------------------------------------
scummvm.clearVerbTilemap:
  php
  phx
  phb
  sep #$20
  lda #$7E
  pha
  plb
  rep #$31

  ldx #0
  lda #0
_cvt.clearLoop:
  .ACCU 16
  .INDEX 16
  sta.w SCUMM.verbTilemap,x
  inx
  inx
  cpx #VERB_TILEMAP_SIZE
  bcc _cvt.clearLoop

  lda #1
  sta.w SCUMM.verbTilemapNmiPending

  plb
  plx
  plp
  rtl

.ends


;===================================================================
; Sentence line renderer — superfree
; Renders the current verb/action on BG2 verb tilemap row 0 (Y=144).
; Default "Walk to" when no verb selected.
;===================================================================
.bank 5 slot 0
.base BSL
.section "ScummVMSentenceRenderer" free

scummvm.renderSentenceLine:
  php
  phx
  phy
  phb
  sep #$20
  lda #$7E
  pha
  plb
  rep #$31

  ; Clear row 0 of verb tilemap (32 entries x 2 bytes = 64 bytes)
  ldx #0
  lda #0
  ldy #32
_rsl.clearLoop:
  .ACCU 16
  .INDEX 16
  sta.w SCUMM.verbTilemap,x
  inx
  inx
  dey
  bne _rsl.clearLoop

  ; If sentenceVerb != 0, find verb name from table
  lda.w SCUMM.sentenceVerb
  bne _rsl.findVerb

  ; Default: write "Walk to" from ROM (X=string index, Y=tilemap offset)
  ldx #0
  ldy #2                              ; start at column 1 (byte offset 2)
  lda #7                              ; "Walk to" is 7 chars
  sta.w SCUMM.scratch2

_rsl.defaultLoop:
  .ACCU 16
  .INDEX 16
  lda.w SCUMM.scratch2
  beq _rsl.appendDefault
  dec.w SCUMM.scratch2
  sep #$20
  lda.l _rsl.defaultName,x
  rep #$20
  and #$00FF
  sec
  sbc #$20                            ; ASCII to tile index
  ora #$3C00                          ; priority 1 + palette 7 (white)
  sta.w SCUMM.verbTilemap,y
  inx
  iny
  iny
  bra _rsl.defaultLoop

_rsl.findVerb:
  .ACCU 16
  .INDEX 16
  ; Find verb slot matching sentenceVerb
  ldy #0
  ldx #0

_rsl.findVerbLoop:
  .ACCU 16
  .INDEX 16
  cpy #SCUMM_MAX_VERBS
  bcc _rsl.findVerbContinue
  jmp _rsl.done                       ; not found
_rsl.findVerbContinue:
  .ACCU 16
  .INDEX 16
  lda.w SCUMM.verbs.1.id,x
  and #$00FF
  cmp.w SCUMM.sentenceVerb
  beq _rsl.foundVerb
  txa
  clc
  adc #_sizeof_scummVerb
  tax
  iny
  bra _rsl.findVerbLoop

_rsl.foundVerb:
  .ACCU 16
  .INDEX 16
  ; X = verb struct offset; read name pointer and length
  lda.w SCUMM.verbs.1.namePtr,x
  pha                                 ; save namePtr
  lda.w SCUMM.verbs.1.nameLen,x
  and #$00FF
  sta.w SCUMM.scratch2               ; char count

  ; Write verb name to row 0, starting at column 1
  ply                                 ; Y = namePtr (offset into verbNames)
  ldx #2                              ; start at column 1 (byte offset 2)

_rsl.writeLoop:
  .ACCU 16
  .INDEX 16
  lda.w SCUMM.scratch2
  beq _rsl.appendObj
  dec.w SCUMM.scratch2
  sep #$20
  lda.w SCUMM.verbNames,y
  rep #$20
  and #$00FF
  sec
  sbc #$20                            ; ASCII to tile index
  ora #$3C00                          ; priority 1 + palette 7 (white)
  sta.w SCUMM.verbTilemap,x
  iny
  inx
  inx
  bra _rsl.writeLoop

_rsl.appendDefault:
  .ACCU 16
  .INDEX 16
  tyx                                    ;default loop: Y=tilemap offset → X
_rsl.appendObj:
  .ACCU 16
  .INDEX 16
  ; Check if we have a first noun already selected
  lda.w SCUMM.sentenceObjectA
  bne _rsl.twoNoun

  ; Single noun: show cursorObject on hover (original behavior)
  lda.w SCUMM.cursorObject
  beq _rsl.done
  jsl scummvm.appendObjectName           ;X = tilemap byte offset
  jmp _rsl.done

_rsl.twoNoun:
  .ACCU 16
  .INDEX 16
  ; Show: "verb sentenceObjectA with cursorObject"
  ; Swap cursorObject with sentenceObjectA temporarily
  lda.w SCUMM.cursorObject
  pha                                    ; save real cursorObject
  lda.w SCUMM.sentenceObjectA
  sta.w SCUMM.cursorObject
  jsl scummvm.appendObjectName           ; write sentenceObjectA name
  pla
  sta.w SCUMM.cursorObject               ; restore real cursorObject

  ; Write " with " literal tiles
  lda #$3C00                             ; space tile
  sta.w SCUMM.verbTilemap,x
  inx
  inx
  lda #$3C00 | ($77 - $20)              ; 'w' tile (priority+pal7)
  sta.w SCUMM.verbTilemap,x
  inx
  inx
  lda #$3C00 | ($69 - $20)              ; 'i'
  sta.w SCUMM.verbTilemap,x
  inx
  inx
  lda #$3C00 | ($74 - $20)              ; 't'
  sta.w SCUMM.verbTilemap,x
  inx
  inx
  lda #$3C00 | ($68 - $20)              ; 'h'
  sta.w SCUMM.verbTilemap,x
  inx
  inx
  lda #$3C00                             ; space tile
  sta.w SCUMM.verbTilemap,x
  inx
  inx

  ; Append second noun (cursorObject) if different from sentenceObjectA
  lda.w SCUMM.cursorObject
  beq _rsl.done
  cmp.w SCUMM.sentenceObjectA
  beq _rsl.done                          ; same object, don't repeat
  jsl scummvm.appendObjectName           ; write cursorObject name

_rsl.done:
  .ACCU 16
  .INDEX 16
  stz.w SCUMM.sentenceDirty
  lda #1
  sta.w SCUMM.verbDmaPending

  plb
  ply
  plx
  plp
  rtl

_rsl.defaultName:
  .db "Walk to"

.ends


;===================================================================
; Object hover detection — called per frame from updateCursor
; Sets SCUMM.cursorObject + SCUMM.sentenceDirty on change.
;===================================================================
.bank 5 slot 0
.base BSL
.section "ScummVM object hover" free

scummvm.updateObjectHover:
  rep #$31
  lda.w SCUMM.cursorY
  cmp #144
  bcs _oh.verbArea
  ;room area — check object under cursor
  sta.w SCUMM.scratch                   ;scratch = screenY
  lda.w SCUMM.cursorX                   ;A = screenX
  jsl room.findObject                   ;A = objId (0=none)
  cmp.w SCUMM.cursorObject
  beq _oh.done
  sta.w SCUMM.cursorObject
  lda #1
  sta.w SCUMM.sentenceDirty
  rtl

_oh.verbArea:
  .ACCU 16
  .INDEX 16
  ;check if in inventory row: Y in [184, 192)
  cmp #184
  bcc _oh.verbOnly
  cmp #192
  bcs _oh.verbOnly
  ;inventory row — compute which item slot
  lda.w SCUMM.cursorX
  lsr a
  lsr a
  lsr a
  lsr a
  lsr a
  lsr a                                 ;cursorX / 64 = visible item index
  clc
  adc.w SCUMM.inventoryScroll           ;+ scroll offset = absolute item index
  cmp.w SCUMM.inventoryCount
  bcs _oh.clearObj                      ;beyond inventory → clear
  ;valid item — look up obj_id from list
  asl a                                 ;* 2 = byte offset
  tax
  lda.w SCUMM.inventoryList,x
  beq _oh.clearObj
  cmp.w SCUMM.cursorObject
  beq _oh.done                          ;same object, no change
  sta.w SCUMM.cursorObject
  lda #1
  sta.w SCUMM.sentenceDirty
  rtl

_oh.verbOnly:
  .ACCU 16
  .INDEX 16
  ;verb area (not inventory row) — clear object if any
_oh.clearObj:
  .ACCU 16
  .INDEX 16
  lda.w SCUMM.cursorObject
  beq _oh.done
  stz.w SCUMM.cursorObject
  lda #1
  sta.w SCUMM.sentenceDirty
_oh.done:
  .ACCU 16
  .INDEX 16
  rtl

.ends


;===================================================================
; Append hovered object name to sentence line tilemap
; Input: X = tilemap byte offset (next free position)
; Assumes DBR=$7E (called from sentence renderer context).
;===================================================================
.bank 5 slot 0
.base BSL
.section "ScummVM appendObjectName" free

scummvm.appendObjectName:
  rep #$31

  ;write a space tile
  lda #$3C00                            ;space = tile 0, priority+pal7
  sta.w SCUMM.verbTilemap,x
  inx
  inx

  ;search roomObjTable for matching cursorObject ID
  lda.w SCUMM.cursorObject
  bne +
  rtl                                    ;no cursor object → early return
+
  phx                                   ;save tilemap position
  ldx #0                                ;X = entry byte offset
  stz.b tmp+2                           ;cumulative name byte offset
  ldy.w SCUMM.roomObjCount
  beq _aon.notFound

_aon.search:
  .ACCU 16
  .INDEX 16
  lda.l SCUMM.roomObjTable,x            ;obj_id at +$00
  cmp.w SCUMM.cursorObject
  beq _aon.found
  ;add this entry's name_len to offset
  lda.l SCUMM.roomObjTable+15,x         ;name_len at +$0F
  and #$00FF
  clc
  adc.b tmp+2
  sta.b tmp+2
  ;next entry
  txa
  clc
  adc #16
  tax
  dey
  bne _aon.search

_aon.notFound:
  .ACCU 16
  .INDEX 16
  plx
  ;--- Fallback: search inventory name cache ---
  lda.w SCUMM.invNameCount
  beq _aon.ret
  sta.b tmp+6                           ;search count
  phx                                   ;save tilemap position
  ldx #0                                ;X = name slot * 2

_aon.invSearch:
  .ACCU 16
  .INDEX 16
  lda.w SCUMM.invNameObjIds,x
  cmp.w SCUMM.cursorObject
  beq _aon.invFound
  inx
  inx
  dec.b tmp+6
  bne _aon.invSearch
  plx                                   ;not found in cache either
  rtl

_aon.invFound:
  .ACCU 16
  .INDEX 16
  ;X = name slot * 2; get slot index
  txa
  lsr a                                 ;slot index
  sta.b tmp+2                           ;save slot

  ;get name length
  tax
  lda.w SCUMM.invNameLens,x
  and #$00FF
  beq _aon.invNotFoundPop
  sta.b tmp+4                           ;char count

  ;name data offset = slot * 16
  lda.b tmp+2
  asl a
  asl a
  asl a
  asl a                                 ;* 16
  tax                                   ;X = name data offset
  ply                                   ;Y = tilemap offset (from stack)

_aon.invWriteChar:
  .ACCU 16
  .INDEX 16
  sep #$20
.ACCU 8
  lda.w SCUMM.invNames,x
  rep #$20
.ACCU 16
  and #$00FF
  sec
  sbc #$20                              ;ASCII → tile index
  ora #$3C00                            ;priority + palette 7 (white)
  sta.w SCUMM.verbTilemap,y
  inx
  iny
  iny
  dec.b tmp+4
  bne _aon.invWriteChar

  tyx                                   ;X = updated tilemap position
  rtl

_aon.invNotFoundPop:
  .ACCU 16
  .INDEX 16
  plx
  rtl

_aon.found:
  .ACCU 16
  .INDEX 16
  ;read name_len for this object
  lda.l SCUMM.roomObjTable+15,x
  and #$00FF
  beq _aon.notFound                     ;empty name
  sta.b tmp+4                            ;char count

  ;set up: X = name byte offset, Y = tilemap byte offset
  ldx.b tmp+2
  ply                                    ;Y = tilemap offset (from stack)

_aon.writeChar:
  .ACCU 16
  .INDEX 16
  sep #$20
.ACCU 8
  lda.l SCUMM.roomObjNames,x
  rep #$20
.ACCU 16
  and #$00FF
  sec
  sbc #$20                              ;ASCII → tile index
  ora #$3C00                            ;priority + palette 7 (white)
  sta.w SCUMM.verbTilemap,y
  inx
  iny
  iny
  dec.b tmp+4
  bne _aon.writeChar

  tyx                                    ;X = updated tilemap position
_aon.ret:
  .ACCU 16
  .INDEX 16
  rtl

.ends


;===================================================================
; drawObject state helpers — superfree to avoid dispatch growth
;===================================================================
.bank 5 slot 0
.base BSL
.section "ScummVM drawObjectState" free

;set objectState[SCUMM.scratch] = 1 (show object)
scummvm.drawObjectSetState1:
  rep #$20
  ldx.w SCUMM.scratch

  ;check if transitioning from hidden to visible
  sep #$20
.ACCU 8
  lda.w SCUMM.objectState,x
  bne _dos1.alreadyVisible      ;already visible, just update state
  ;was hidden → becoming visible: apply patch
  lda #1
  sta.w SCUMM.objectState,x
  rep #$20
.ACCU 16
  lda.w SCUMM.scratch           ;obj_id
  jsl room.applyObjectPatch
  rtl

_dos1.alreadyVisible:
.ACCU 8
  lda #1
  sta.w SCUMM.objectState,x
  rep #$20
.ACCU 16
  rtl

;set objectState[SCUMM.scratch] = A (low byte)
scummvm.drawObjectSetStateN:
  rep #$20
  and #$00FF
  sta.b tmp+28                  ;save new state value
  ldx.w SCUMM.scratch

  ;read old state
  sep #$20
.ACCU 8
  lda.w SCUMM.objectState,x
  sta.b tmp+30                  ;old state (byte)

  ;write new state
  lda.b tmp+28
  sta.w SCUMM.objectState,x
  rep #$20
.ACCU 16

  ;check transitions
  sep #$20
.ACCU 8
  lda.b tmp+30                  ;old state
  beq _dosN.wasHidden
  ;was visible
  lda.b tmp+28                  ;new state
  bne _dosN.done                ;visible→visible, no change
  ;visible→hidden: remove patch
  rep #$20
.ACCU 16
  lda.w SCUMM.scratch
  jsl room.removeObjectPatch
  rtl

_dosN.wasHidden:
.ACCU 8
  lda.b tmp+28                  ;new state
  beq _dosN.done                ;hidden→hidden, no change
  ;hidden→visible: apply patch
  rep #$20
.ACCU 16
  lda.w SCUMM.scratch
  jsl room.applyObjectPatch
  rtl

_dosN.done:
.ACCU 8
  rep #$20
.ACCU 16
  rtl

.ends


;===================================================================
; resolveClickTarget — returns walk target for room click
; If cursorObject != 0, returns object walk-to point.
; Otherwise returns cursor room position.
; Output: A = targetX, SCUMM.scratch = targetY
;===================================================================
.bank 5 slot 0
.base BSL
.section "ScummVM resolveClickTarget" free

scummvm.resolveClickTarget:
  rep #$31
  lda.w SCUMM.cursorObject
  beq _rct.cursorPos
  ;object click — look up walk-to point from roomObjTable
  sta.b tmp                            ;tmp = target obj_id
  ldy.w SCUMM.roomObjCount
  beq _rct.cursorPos
  ldx #0
_rct.search:
  .ACCU 16
  .INDEX 16
  lda.l SCUMM.roomObjTable,x
  cmp.b tmp
  beq _rct.found
  txa
  clc
  adc #16
  tax
  dey
  bne _rct.search
  bra _rct.cursorPos                   ;not found, fall back
_rct.found:
  .ACCU 16
  .INDEX 16
  lda.l SCUMM.roomObjTable+12,x       ;walk_y (signed LE16 at +$0C)
  sta.w SCUMM.scratch
  lda.l SCUMM.roomObjTable+10,x       ;walk_x (signed LE16 at +$0A)
  rtl
_rct.cursorPos:
  .ACCU 16
  .INDEX 16
  lda.w SCUMM.cursorX
  clc
  adc.w GLOBAL.room.cameraX
  pha
  lda.w SCUMM.cursorY
  sta.w SCUMM.scratch
  pla
  rtl

.ends


;===================================================================
; lookupObjectWalkTo — find walk-to point for any object ID
; Input: A = object ID
; Output: A = walk_x, SCUMM.scratch = walk_y, carry set if found
;===================================================================
.bank 5 slot 0
.base BSL
.section "ScummVM lookupObjectWalkTo" free

scummvm.lookupObjectWalkTo:
  rep #$31
  sta.b tmp                            ;tmp = target obj_id
  ldy.w SCUMM.roomObjCount
  beq _lowt.fail
  ldx #0
_lowt.search:
  .ACCU 16
  .INDEX 16
  lda.l SCUMM.roomObjTable,x
  cmp.b tmp
  beq _lowt.found
  txa
  clc
  adc #16
  tax
  dey
  bne _lowt.search
_lowt.fail:
  .ACCU 16
  .INDEX 16
  lda #0
  sta.w SCUMM.scratch
  clc                                  ;carry clear = not found
  rtl
_lowt.found:
  .ACCU 16
  .INDEX 16
  lda.l SCUMM.roomObjTable+12,x       ;walk_y
  sta.w SCUMM.scratch
  lda.l SCUMM.roomObjTable+10,x       ;walk_x
  sec                                  ;carry set = found
  rtl

.ends


;===================================================================
; putActorAtObject / walkActorToObject — unified implementation
;===================================================================
.bank 5 slot 0
.base BSL
.section "ScummVM actorAtObj" free

;-------------------------------------------------------------------
; scummvm.actorAtObj_impl — put or walk actor to object's walk-to point
; Input: A = object ID, SCUMM.scratch2 = actor struct offset
;        carry SET = put (teleport), carry CLEAR = walk
;-------------------------------------------------------------------
scummvm.actorAtObj_impl:
  php                                    ;save put/walk flag
  rep #$31
  jsl scummvm.lookupObjectWalkTo         ;A=walk_x, scratch=walk_y, C=found
  bcc _aao.fail

  plp                                    ;restore put/walk flag
  bcc _aao.walk

  ;--- PUT: teleport actor to walk-to point ---
  ldx.w SCUMM.scratch2
  sta.w SCUMM.actors.x,x                ;walk_x → actor X
  lda.w SCUMM.scratch
  sta.w SCUMM.actors.y,x                ;walk_y → actor Y
  rtl

  ;--- WALK: path-find to walk-to point ---
_aao.walk:
  .ACCU 16
  .INDEX 16
  pha                                    ;save walk_x
  lda.w SCUMM.scratch2
  lsr a
  lsr a
  lsr a
  lsr a
  sta.w SCUMM.scratch3                   ;actor index

  ; Store walk targets
  asl a                                  ;word index
  tax
  pla                                    ;walk_x
  sta.w SCUMM.actorTargetX,x
  lda.w SCUMM.scratch                    ;walk_y
  sta.w SCUMM.actorTargetY,x

  ; Set up buildWalkPath params: tmp=startXY, tmp+4=targetXY
  ldx.w SCUMM.scratch2
  lda.w SCUMM.actors.x,x
  sta.b tmp
  lda.w SCUMM.actors.y,x
  sta.b tmp+2
  lda.w SCUMM.scratch3
  asl a
  tax
  lda.w SCUMM.actorTargetX,x
  sta.b tmp+4
  lda.w SCUMM.actorTargetY,x
  sta.b tmp+6
  lda.w SCUMM.scratch3
  jsl scummvm.buildWalkPath_long

  ; Init animation
  lda.w SCUMM.scratch3
  and #$000F
  tax
  .ACCU 16
  lda #COSTUME_WALK_ANIM_SPEED
  sep #$20
  sta.w SCUMM.actorAnimTimer,x
  lda #0
  sta.w SCUMM.actorAnimFrame,x

  ; Set actor.moving = 1
  ldx.w SCUMM.scratch2
  lda #1
  sta.w SCUMM.actors.moving,x
  rep #$20
  rtl

_aao.fail:
  .ACCU 16
  .INDEX 16
  plp                                    ;clean stack
  rtl

.ends


;===================================================================
; Camera system — per-frame camera position update
;===================================================================
.bank 5 slot 0
.base BSL
.section "ScummVM camera" free

;-------------------------------------------------------------------
; scummvm.moveCamera — update camera position per frame
; Called via jsl from play() after updateActors.
; If following an actor, updates cameraDest from actor X.
; Moves camera center toward cameraDest at FAST_X speed.
; Writes GLOBAL.room.cameraX (left edge) for scroll system.
;-------------------------------------------------------------------
scummvm.moveCamera:
  rep #$31

  ; If cameraFollows != 0, update cameraDest from actor X
  lda.w SCUMM.cameraFollows
  and #$00FF
  beq _mc.checkPan

  ; Compute actor X: actors + actorNum*16 + 2
  asl a
  asl a
  asl a
  asl a                              ; * 16
  clc
  adc #2                             ; .x offset
  tax
  lda.w SCUMM.actors,x              ; actor X
  sta.w SCUMM.scratch3

  ; Strip-based trigger zones (ScummVM model)
  ; screenStartStrip = (cameraPosX - 128) / 8
  ; actorStrip = actorX / 8 - screenStartStrip
  ; If actorStrip < leftTrigger(8) or actorStrip > rightTrigger(24), follow
  ldx #SCUMM_VAR_CAMERA_POS_X*2
  lda.w SCUMM.globalVars,x          ; cameraPosX (center)
  sec
  sbc #128                           ; left edge
  bcs +
    lda #0
+
  lsr a
  lsr a
  lsr a                              ; screenStartStrip = leftEdge / 8
  sta.w SCUMM.scratch                ; scratch = screenStartStrip
  lda.w SCUMM.scratch3               ; actorX
  lsr a
  lsr a
  lsr a                              ; actorX / 8
  sec
  sbc.w SCUMM.scratch                ; actorStrip = actorX/8 - screenStartStrip
  cmp #8                             ; leftTrigger = 8 strips (64px from left)
  bcc _mc.follow                     ; actor too far left → follow
  cmp #25                            ; rightTrigger = 24, so > 24 means >= 25
  bcc _mc.checkPan                   ; within safe zone, don't update dest

_mc.follow:
  .ACCU 16
  .INDEX 16
  ; Set cameraDest = actorX
  lda.w SCUMM.scratch3
  sta.w SCUMM.cameraDest

_mc.checkPan:
  .ACCU 16
  .INDEX 16
  ; Clamp cameraDest to [MIN_X, MAX_X]
  ldx #SCUMM_VAR_CAMERA_MIN_X*2
  lda.w SCUMM.cameraDest
  cmp.w SCUMM.globalVars,x          ; VAR_CAMERA_MIN_X
  bcs +
    lda.w SCUMM.globalVars,x
    sta.w SCUMM.cameraDest
+
  ldx #SCUMM_VAR_CAMERA_MAX_X*2
  lda.w SCUMM.cameraDest
  cmp.w SCUMM.globalVars,x          ; VAR_CAMERA_MAX_X
  bcc +
  beq +
    lda.w SCUMM.globalVars,x
    sta.w SCUMM.cameraDest
+

  ; Move cameraPosX toward cameraDest
  ldx #SCUMM_VAR_CAMERA_POS_X*2
  lda.w SCUMM.globalVars,x          ; current camera pos
  cmp.w SCUMM.cameraDest
  beq _mc.updateRoom                ; already at destination
  bcc _mc.moveRight

  ; Move left: step = min(cur - dest, fast_x)
  sec
  sbc.w SCUMM.cameraDest
  sta.w SCUMM.scratch3              ; delta
  ldx #SCUMM_VAR_CAMERA_FAST_X*2
  cmp.w SCUMM.globalVars,x          ; VAR_CAMERA_FAST_X
  bcc +
    lda.w SCUMM.globalVars,x
    sta.w SCUMM.scratch3
+
  ldx #SCUMM_VAR_CAMERA_POS_X*2
  lda.w SCUMM.globalVars,x
  sec
  sbc.w SCUMM.scratch3
  sta.w SCUMM.globalVars,x
  bra _mc.updateRoom

_mc.moveRight:
  .ACCU 16
  .INDEX 16
  ; step = min(dest - cur, fast_x)
  lda.w SCUMM.cameraDest
  ldx #SCUMM_VAR_CAMERA_POS_X*2
  sec
  sbc.w SCUMM.globalVars,x          ; delta = dest - cur
  sta.w SCUMM.scratch3
  ldx #SCUMM_VAR_CAMERA_FAST_X*2
  cmp.w SCUMM.globalVars,x          ; VAR_CAMERA_FAST_X
  bcc +
    lda.w SCUMM.globalVars,x
    sta.w SCUMM.scratch3
+
  ldx #SCUMM_VAR_CAMERA_POS_X*2
  lda.w SCUMM.globalVars,x
  clc
  adc.w SCUMM.scratch3
  sta.w SCUMM.globalVars,x

_mc.updateRoom:
  .ACCU 16
  .INDEX 16
  ; Convert center to left edge: cameraX = cameraPosX - 128
  ldx #SCUMM_VAR_CAMERA_POS_X*2
  lda.w SCUMM.globalVars,x          ; VAR_CAMERA_POS_X
  sec
  sbc #128
  bcs +
    lda #0
+
  sta.w GLOBAL.room.cameraX

  rtl

scummvm.initCameraVars:
  rep #$31
  ;--- Init objectOwner: all objects owned by room ($0F) ---
  lda #$0F0F
  ldx #0
_icv.ownerLoop:
  .ACCU 16
  .INDEX 16
  sta.l SCUMM.objectOwner,x
  inx
  inx
  cpx #SCUMM_MAX_OBJECTS
  bcc _icv.ownerLoop
  ;--- Init objectClass: all zero ---
  lda #0
  ldx #0
_icv.classLoop:
  .ACCU 16
  .INDEX 16
  sta.l SCUMM.objectClass,x
  inx
  inx
  cpx #SCUMM_MAX_OBJECTS * 2
  bcc _icv.classLoop
  ;--- Init render slots: all empty ---
  sep #$20
  ldx #0
  lda #0
_icv.slotLoop:
  .ACCU 16
  .INDEX 16
  sta.w SCUMM.renderSlotActor,x
  sta.w SCUMM.renderSlotCostume,x
  sta.w SCUMM.renderSlotLastPic,x
  sta.w SCUMM.renderSlotDirty,x
  inx
  cpx #SCUMM_MAX_RENDER_SLOTS
  bcc _icv.slotLoop
  rep #$20
  ;--- Camera state init ---
  stz.w SCUMM.cameraFollows
  stz.w SCUMM.cameraDest
  lda #128
  ldx #SCUMM_VAR_CAMERA_POS_X*2
  sta.w SCUMM.globalVars,x
  ldx #SCUMM_VAR_CAMERA_MIN_X*2
  sta.w SCUMM.globalVars,x
  ldx #SCUMM_VAR_CAMERA_MAX_X*2
  sta.w SCUMM.globalVars,x
  lda #4
  ldx #SCUMM_VAR_CAMERA_FAST_X*2
  sta.w SCUMM.globalVars,x
  rtl

scummvm.snapCameraToRoom:
  rep #$31
  lda.w GLOBAL.room.hdr.width_px
  sec
  sbc #128
  bcs +
    lda #128
+
  ldx #SCUMM_VAR_CAMERA_MAX_X*2
  sta.w SCUMM.globalVars,x
  lda #128
  ldx #SCUMM_VAR_CAMERA_MIN_X*2
  sta.w SCUMM.globalVars,x
  lda.w SCUMM.cameraFollows
  and #$00FF
  beq _snap.done
  asl a
  asl a
  asl a
  asl a
  clc
  adc #2
  tax
  lda.w SCUMM.actors,x              ; actor X (e.g. 320)
  ; Clamp to [VAR_CAMERA_MIN_X, VAR_CAMERA_MAX_X]
  ldx #SCUMM_VAR_CAMERA_MIN_X*2
  cmp.w SCUMM.globalVars,x
  bcs +
    lda.w SCUMM.globalVars,x
+
  ldx #SCUMM_VAR_CAMERA_MAX_X*2
  cmp.w SCUMM.globalVars,x
  bcc +
  beq +
    lda.w SCUMM.globalVars,x
+
  ; A = clamped camera center (e.g. 192 for room 38)
  sta.w SCUMM.cameraDest
  ldx #SCUMM_VAR_CAMERA_POS_X*2
  sta.w SCUMM.globalVars,x
  ; cameraX = clamped center - 128 (left edge of viewport)
  sec
  sbc #128
  bcs +
    lda #0
+
  sta.w GLOBAL.room.cameraX
  sta.w GLOBAL.room.cameraXOld
_snap.done:
  .ACCU 16
  .INDEX 16
  rtl

;-------------------------------------------------------------------
; scummvm.setCameraAtImpl — instant camera snap (JSL/RTL)
; Input:  A = target X center position
; Clamps to [MIN_X, MAX_X], writes cameraDest + cameraPosX,
; exits follow mode, computes cameraX/cameraXOld left edge.
;-------------------------------------------------------------------
scummvm.setCameraAtImpl:
  rep #$31

  ; Save old cameraX for snap detection
  lda.w GLOBAL.room.cameraX
  sta.w SCUMM.scratch3

  ; Clamp to [MIN_X, MAX_X]
  ldx #SCUMM_VAR_CAMERA_MIN_X*2
  cmp.w SCUMM.globalVars,x
  bcs +
    lda.w SCUMM.globalVars,x
+
  ldx #SCUMM_VAR_CAMERA_MAX_X*2
  cmp.w SCUMM.globalVars,x
  bcc +
  beq +
    lda.w SCUMM.globalVars,x
+
  ; Write VAR_CAMERA_POS_X and cameraDest
  ldx #SCUMM_VAR_CAMERA_POS_X*2
  sta.w SCUMM.globalVars,x
  sta.w SCUMM.cameraDest
  ; Exit follow mode
  stz.w SCUMM.cameraFollows
  ; cameraX = cameraPosX - 128
  sec
  sbc #128
  bcs +
    lda #0
+
  sta.w GLOBAL.room.cameraX
  sta.w GLOBAL.room.cameraXOld

  ; If snap >= 9px, mark viewport dirty for syncScroll to handle
  sec
  sbc.w SCUMM.scratch3            ; A = new - old (may underflow)
  bcs _setCamAt.posDelta
    lda.w SCUMM.scratch3
    sec
    sbc.w GLOBAL.room.cameraX     ; A = old - new
_setCamAt.posDelta:
  cmp #9
  bcc _setCamAt.noSnap
    inc.w GLOBAL.room.viewportDirty  ; request reload in syncScroll
_setCamAt.noSnap:

  clc
  rtl

.ends

;===================================================================
; scummvm.getVerbEntrypoint_impl — superfree
; Input:  A = object ID, SCUMM.scratch = verb ID
; Output: A = verb entry offset (>0 = handler exists, 0 = none)
;===================================================================
.bank 5 slot 0
.base BSL
.section "scummvm getVerbEntrypoint" free

scummvm.getVerbEntrypoint_impl:
  rep #$31
  ;--- Find the object's index in roomObjTable ---
  sta.w SCUMM.scratch2                ; scratch2 = target obj_id
  lda.w SCUMM.roomObjCount
  beq _gve.notfound
  tay                                  ; Y = remaining count
  ldx #0                              ; X = entry byte offset
_gve.scanObj:
  .ACCU 16
  .INDEX 16
  lda.l SCUMM.roomObjTable,x          ; obj_id at this entry
  cmp.w SCUMM.scratch2
  beq _gve.foundObj
  txa
  clc
  adc #16                             ; next entry (16 bytes each)
  tax
  dey
  bne _gve.scanObj
_gve.notfound:
  .ACCU 16
  .INDEX 16
  lda #0
  rtl

_gve.foundObj:
  .ACCU 16
  .INDEX 16
  ;--- X/16 = object index. Read verb index entry ---
  ; verbIdx = index * 4 (verb_data_off + verb_data_len)
  txa
  lsr a
  lsr a                               ; index * 4 (16/4 = 4)
  tax
  lda.l SCUMM.roomObjVerbIdx+2,x      ; verb_data_len
  beq _gve.notfound                   ; no verb data
  lda.l SCUMM.roomObjVerbIdx,x        ; verb_data_off
  tax                                  ; X = offset into roomObjVerbData

  ;--- Scan verb table: {verb_id:u8, offset:u16}* terminated by 0x00 ---
  lda.w SCUMM.scratch                  ; target verb_id
  and #$00FF
  sta.w SCUMM.scratch3                 ; scratch3 = target verb_id (8-bit in 16-bit reg)
_gve.scanVerb:
  .ACCU 16
  .INDEX 16
  lda.l SCUMM.roomObjVerbData,x       ; read verb_id byte
  and #$00FF
  beq _gve.notfound                   ; 0x00 = end of table
  cmp.w SCUMM.scratch3
  beq _gve.foundVerb
  cmp #$00FF
  beq _gve.foundVerb                   ; 0xFF = catch-all matches any verb
  inx
  inx
  inx                                  ; skip verb_id(1) + offset(2)
  bra _gve.scanVerb

_gve.foundVerb:
  .ACCU 16
  .INDEX 16
  inx                                  ; skip verb_id byte
  lda.l SCUMM.roomObjVerbData,x       ; read offset (LE16)
  sec
  sbc #8                               ; offsets are relative to VERB chunk start
  rtl                                   ; (includes 8-byte chunk header); adjust to data

.ends

;===================================================================
; scummvm.startObjectScript — superfree
; Start executing an object's verb script in a new slot.
; Input:  A = object ID, SCUMM.scratch = entry offset within VERB data
; Output: none
; The object's verb data blob is copied to the script cache, a new
; slot is initialized with pc = entry offset.
;===================================================================
.bank 5 slot 0
.base BSL
.section "scummvm startObjectScript" free

scummvm.startObjectScript:
  rep #$31
  sta.w SCUMM.scratch2                ; scratch2 = obj_id

  ;--- Find object index in roomObjTable ---
  lda.w SCUMM.roomObjCount
  beq _sos.bail
  tay
  ldx #0
_sos.scanObj:
  .ACCU 16
  .INDEX 16
  lda.l SCUMM.roomObjTable,x
  cmp.w SCUMM.scratch2
  beq _sos.foundObj
  txa
  clc
  adc #16
  tax
  dey
  bne _sos.scanObj
_sos.bail:
  .ACCU 16
  .INDEX 16
  rtl

_sos.foundObj:
  .ACCU 16
  .INDEX 16
  ;--- Read verb index: index = X/16, verbIdx offset = index*4 ---
  ; X = obj entry byte offset (index * 16)
  ; We need index * 4 for verb idx table
  txa
  lsr a
  lsr a                               ; X/16 * 4 = X/4
  tax
  lda.l SCUMM.roomObjVerbIdx+2,x      ; verb_data_len
  beq _sos.bail
  sta.w SCUMM.scratch3                 ; scratch3 = verb_data_len
  lda.l SCUMM.roomObjVerbIdx,x        ; verb_data_off
  tax                                  ; X = source offset in roomObjVerbData

  ;--- Check cache space ---
  lda.w SCUMM.cacheWritePtr
  clc
  adc.w SCUMM.scratch3                 ; cacheWritePtr + verb_data_len
  cmp #SCUMM_CACHE_SIZE
  bcc _sos.cacheOk
  rtl                                  ; cache full, bail
_sos.cacheOk:
  .ACCU 16
  .INDEX 16

  ;--- Copy verb data blob to script cache ($7F:6400+) ---
  ; X = source offset in roomObjVerbData, scratch3 = byte count
  lda.w SCUMM.cacheWritePtr
  sta.w SCUMM.scratch2                 ; scratch2 = cachePtr (start of cached blob)
  phy                                  ; save caller's Y
  ldy.w SCUMM.scratch3                 ; Y = bytes remaining
_sos.copy:
  .ACCU 16
  .INDEX 16
  sep #$20
.ACCU 8
  lda.l SCUMM.roomObjVerbData,x       ; read from $7E WRAM
  phx                                  ; save source index
  ldx.w SCUMM.cacheWritePtr
  sta.l SCUMM_CACHE_WRAM,x            ; write to $7F cache
  inx
  stx.w SCUMM.cacheWritePtr           ; 16-bit store (X flag still clear)
  plx                                  ; restore source index
  rep #$20
.ACCU 16
  inx
  dey
  bne _sos.copy
  ply                                  ; restore caller's Y

  ;--- Find a dead script slot ---
  phx                                  ; save (unused but balance)
  ldx #0
  ldy #0
_sos.findSlot:
  .ACCU 16
  .INDEX 16
  lda.w SCUMM.slots.status,x
  and #$00FF
  cmp #SCUMM_SLOT_DEAD
  beq _sos.gotSlot
  txa
  clc
  adc #_sizeof_scummSlot
  tax
  iny
  cpy #SCUMM_MAX_SLOTS
  bcc _sos.findSlot
  plx
  rtl                                  ; no free slot

_sos.gotSlot:
  .ACCU 16
  .INDEX 16
  pla                                  ; discard saved X (preserve X = slot offset)
  ;--- Initialize the slot ---
  ; X = slot byte offset
  sep #$20
.ACCU 8
  lda #0                               ; script "number" = 0 for object scripts
  sta.w SCUMM.slots.number,x
  lda #SCUMM_SLOT_RUNNING
  sta.w SCUMM.slots.status,x
  lda #SCUMM_WHERE_ROOM
  sta.w SCUMM.slots.where,x
  lda #0
  sta.w SCUMM.slots.freezeCount,x
  sta.w SCUMM.slots.cutsceneOverride,x
  rep #$20
.ACCU 16
  lda.w SCUMM.scratch2                 ; cachePtr
  sta.w SCUMM.slots.cachePtr,x
  lda.w SCUMM.scratch3                 ; cacheLen (= verb_data_len)
  sta.w SCUMM.slots.cacheLen,x
  lda.w SCUMM.scratch                  ; entry offset (pc start)
  sta.w SCUMM.slots.pc,x
  lda #0
  sta.w SCUMM.slots.delay,x

  ;--- Zero local variables ---
  phx
  ldy #0
_sos.zeroLocals:
  .ACCU 16
  .INDEX 16
  sta.w SCUMM.slots.localVars,x
  inx
  inx
  iny
  cpy #SCUMM_MAX_LOCALS
  bcc _sos.zeroLocals
  plx

  rtl

.ends


;===================================================================
; rebuildInventory — scan objectOwner for ego (actor 1), rebuild list
; Sets inventoryDirty + verbDirty. JSL/RTL.
;===================================================================
.bank 5 slot 0
.base BSL
.section "ScummVM rebuildInventory" free

scummvm.rebuildInventory:
  phb
  sep #$20
  lda #$7E
  pha
  plb
  rep #$31

  ; Clear inventoryList (32 slots x 2B = 64 bytes)
  ldx #0
  lda #0
-
  sta.w SCUMM.inventoryList,x
  inx
  inx
  cpx #INV_MAX_ITEMS * 2
  bcc -

  ; Scan objectOwner[0..1023] for owner == 1
  ldx #0                              ; X = object index
  ldy #0                              ; Y = inventory slot byte offset

_rbi.scan:
  .ACCU 16
  .INDEX 16
  lda.w SCUMM.objectOwner,x
  and #$00FF
  cmp #1
  bne _rbi.next
  ; Found an ego-owned item — store obj_id
  cpy #INV_MAX_ITEMS * 2              ; cap at 32 items
  bcs _rbi.next
  txa                                  ; A = obj_id (== object index)
  sta.w SCUMM.inventoryList,y
  iny
  iny
_rbi.next:
  .ACCU 16
  .INDEX 16
  inx
  cpx #SCUMM_MAX_OBJECTS
  bcc _rbi.scan

  ; Store count (byte offset / 2)
  tya
  lsr a
  sta.w SCUMM.inventoryCount

  ; Clamp scroll
  lda.w SCUMM.inventoryScroll
  cmp.w SCUMM.inventoryCount
  bcc +
  stz.w SCUMM.inventoryScroll
+

  ; Set dirty flags
  lda #1
  sta.w SCUMM.inventoryDirty
  sta.w SCUMM.verbDirty               ; trigger full verb+inventory re-render

  plb
  rtl

.ends


;===================================================================
; cacheInventoryName — cache object name from current room data
; Input: A = obj_id. Searches roomObjTable for matching object,
; copies name into invNameCache. JSL/RTL.
;===================================================================
.bank 5 slot 0
.base BSL
.section "ScummVM cacheInventoryName" free

scummvm.cacheInventoryName:
  phb
  phx
  phy
  pha                                    ; save A (16-bit) — must match pla width
  sep #$20
  lda #$7E
  pha
  plb
  rep #$31
  pla                                    ; A = obj_id (full 16-bit)
  sta.w SCUMM.scratch                  ; scratch = obj_id

  ; Check if already cached
  ldx #0
  lda.w SCUMM.invNameCount
  beq _cin.searchRoom
  sta.w SCUMM.scratch2                 ; search count

_cin.checkExisting:
  .ACCU 16
  .INDEX 16
  lda.w SCUMM.invNameObjIds,x
  cmp.w SCUMM.scratch
  beq _cin.alreadyCached               ; already in cache, skip
  inx
  inx
  dec.w SCUMM.scratch2
  bne _cin.checkExisting

_cin.searchRoom:
  .ACCU 16
  .INDEX 16
  ; Search roomObjTable for matching obj_id
  ldx #0                              ; X = entry byte offset
  stz.w SCUMM.scratch3                ; cumulative name byte offset
  ldy.w SCUMM.roomObjCount
  beq _cin.notFound

_cin.roomSearch:
  .ACCU 16
  .INDEX 16
  lda.l SCUMM.roomObjTable,x          ; obj_id at +$00
  cmp.w SCUMM.scratch
  beq _cin.roomFound
  ; Accumulate name offset
  lda.l SCUMM.roomObjTable+15,x       ; name_len at +$0F
  and #$00FF
  clc
  adc.w SCUMM.scratch3
  sta.w SCUMM.scratch3
  ; Next entry
  txa
  clc
  adc #16
  tax
  dey
  bne _cin.roomSearch

_cin.notFound:
  .ACCU 16
  .INDEX 16
_cin.alreadyCached:
  .ACCU 16
  .INDEX 16
  ply
  plx
  plb
  rtl

_cin.roomFound:
  .ACCU 16
  .INDEX 16
  ; Get name_len for this object
  lda.l SCUMM.roomObjTable+15,x
  and #$00FF
  beq _cin.notFound
  cmp #INV_NAME_MAX_LEN + 1
  bcc +
  lda #INV_NAME_MAX_LEN                ; clamp to 16 chars
+
  sta.w SCUMM.scratch2                 ; char count

  ; Allocate a cache slot
  lda.w SCUMM.invNameCount
  cmp #INV_MAX_ITEMS
  bcs _cin.notFound                    ; cache full
  asl a                                ; slot * 2 for objId array
  tax
  lda.w SCUMM.scratch
  sta.w SCUMM.invNameObjIds,x          ; store obj_id

  ; Store name length
  lda.w SCUMM.invNameCount
  tax
  lda.w SCUMM.scratch2
  sep #$20
.ACCU 8
  sta.w SCUMM.invNameLens,x
  rep #$20
.ACCU 16

  ; Compute name data destination: slot * 16
  lda.w SCUMM.invNameCount
  asl a
  asl a
  asl a
  asl a                                ; * 16
  tay                                  ; Y = dest offset in invNames

  ; Copy name chars from roomObjNames
  ldx.w SCUMM.scratch3                 ; X = source offset in roomObjNames
  lda.w SCUMM.scratch2                 ; char count
  sta.w SCUMM.scratch3                 ; reuse scratch3 as counter

_cin.copyLoop:
  .ACCU 16
  .INDEX 16
  sep #$20
.ACCU 8
  lda.l SCUMM.roomObjNames,x
  sta.w SCUMM.invNames,y
  rep #$20
.ACCU 16
  inx
  iny
  dec.w SCUMM.scratch3
  bne _cin.copyLoop

  ; Increment cache count
  inc.w SCUMM.invNameCount

  ply
  plx
  plb
  rtl

.ends


;===================================================================
; findInventory_impl — find Nth object owned by actor
; Input: A = owner actor, SCUMM.scratch = index (1-based)
; Output: A = obj_id (0 if not found). JSL/RTL.
;===================================================================
.bank 5 slot 0
.base BSL
.section "ScummVM findInventory impl" free

scummvm.findInventory_impl:
  phb
  phx
  phy
  sep #$20
  pha
  lda #$7E
  pha
  plb
  rep #$31
  pla
  and #$00FF                           ; A = owner
  sta.w SCUMM.scratch2                 ; scratch2 = target owner

  lda.w SCUMM.scratch
  and #$00FF                           ; index (1-based)
  beq _fi.zero                         ; index 0 = invalid
  sta.w SCUMM.scratch3                 ; scratch3 = remaining count

  ldx #0                              ; X = object index
_fi.scan:
  .ACCU 16
  .INDEX 16
  lda.w SCUMM.objectOwner,x
  and #$00FF
  cmp.w SCUMM.scratch2
  bne _fi.next
  ; Found a match — decrement counter
  dec.w SCUMM.scratch3
  bne _fi.next
  ; This is the Nth item — return obj_id
  txa                                  ; A = obj_id
  ply
  plx
  plb
  rtl

_fi.next:
  .ACCU 16
  .INDEX 16
  inx
  cpx #SCUMM_MAX_OBJECTS
  bcc _fi.scan

_fi.zero:
  .ACCU 16
  .INDEX 16
  lda #0
  ply
  plx
  plb
  rtl

.ends


;===================================================================
; getInventoryCount_impl — count objects owned by actor
; Input: A = owner actor
; Output: A = count. JSL/RTL.
;===================================================================
.bank 5 slot 0
.base BSL
.section "ScummVM getInventoryCount impl" free

scummvm.getInventoryCount_impl:
  phb
  phx
  phy
  sep #$20
  pha
  lda #$7E
  pha
  plb
  rep #$31
  pla
  and #$00FF                           ; A = owner
  sta.w SCUMM.scratch2                 ; target owner
  ldy #0                              ; Y = count
  ldx #0                              ; X = object index

_gic.scan:
  .ACCU 16
  .INDEX 16
  lda.w SCUMM.objectOwner,x
  and #$00FF
  cmp.w SCUMM.scratch2
  bne _gic.next
  iny
_gic.next:
  .ACCU 16
  .INDEX 16
  inx
  cpx #SCUMM_MAX_OBJECTS
  bcc _gic.scan

  tya                                  ; A = count
  ply
  plx
  plb
  rtl

.ends

;===================================================================
; saveRestoreVerbs implementation — superfree (bank 5)
; Stack on entry (after jsl):
;   8,s = begin_verb, 6,s = end_verb, 4,s = mode (unused)
; SCUMM.scratch = sub-opcode ($01=save, $02=restore, $03=delete)
;===================================================================
.bank 5 slot 0
.base BSL
.section "ScummVM saveRestoreVerbs" free

saveRestoreVerbs_impl:
  .ACCU 16
  .INDEX 16
  php
  rep #$31
  phb
  lda #$007E
  pha
  plb
  plb                                    ; DBR=$7E for WRAM access

  ; Load params from stack (adjusted +4 for php+phb)
  lda 12,s                              ; begin_verb
  and #$00FF
  sta.w SCUMM.scratch2                  ; begin_verb
  lda 10,s                              ; end_verb
  and #$00FF
  sta.w SCUMM.scratch3                  ; end_verb

  ; Dispatch on sub-opcode low 3 bits
  lda.w SCUMM.scratch
  and #$00FF
  cmp #$01
  beq _srv.save
  cmp #$02
  bne +
  jmp _srv.restore
+
  cmp #$03
  bne +
  jmp _srv.delete
+
  jmp _srv.done                         ; unknown sub-op

_srv.save:
  .ACCU 16
  .INDEX 16
  ldx #0                                ; X = verb slot offset
_srv.saveLoop:
  .ACCU 16
  .INDEX 16
  cpx #_sizeof_scummVerb * SCUMM_MAX_VERBS
  bcc _srv.saveCheck
  jmp _srv.done
_srv.saveCheck:
  .ACCU 16
  .INDEX 16
  sep #$20
  lda.w SCUMM.verbs.1.id,x
  rep #$20
  and #$00FF
  beq _srv.saveNext                     ; empty slot, skip
  cmp.w SCUMM.scratch2                  ; < begin_verb?
  bcc _srv.saveNext
  cmp.w SCUMM.scratch3                  ; > end_verb?
  beq +
  bcs _srv.saveNext
+
  .ACCU 16
  ; Copy 16 bytes: verbs[x] -> verbSaveSlots[x]
  phx
  ldy #0
_srv.saveCopy:
  .ACCU 16
  .INDEX 16
  lda.w SCUMM.verbs.1,x
  sta.w SCUMM.verbSaveSlots,x
  inx
  inx
  iny
  iny
  cpy #_sizeof_scummVerb
  bcc _srv.saveCopy
  plx
_srv.saveNext:
  .ACCU 16
  .INDEX 16
  txa
  clc
  adc #_sizeof_scummVerb
  tax
  bra _srv.saveLoop

_srv.restore:
  .ACCU 16
  .INDEX 16
  ldx #0
_srv.restoreLoop:
  .ACCU 16
  .INDEX 16
  cpx #_sizeof_scummVerb * SCUMM_MAX_VERBS
  bcs _srv.restoreDone
  sep #$20
  lda.w SCUMM.verbSaveSlots,x           ; check saved slot id
  rep #$20
  and #$00FF
  beq _srv.restoreNext                  ; empty saved slot, skip
  cmp.w SCUMM.scratch2                  ; < begin_verb?
  bcc _srv.restoreNext
  cmp.w SCUMM.scratch3                  ; > end_verb?
  beq +
  bcs _srv.restoreNext
+
  .ACCU 16
  ; Copy 16 bytes: verbSaveSlots[x] -> verbs[x]
  phx
  ldy #0
_srv.restoreCopy:
  .ACCU 16
  .INDEX 16
  lda.w SCUMM.verbSaveSlots,x
  sta.w SCUMM.verbs.1,x
  inx
  inx
  iny
  iny
  cpy #_sizeof_scummVerb
  bcc _srv.restoreCopy
  plx
_srv.restoreNext:
  .ACCU 16
  .INDEX 16
  txa
  clc
  adc #_sizeof_scummVerb
  tax
  bra _srv.restoreLoop
_srv.restoreDone:
  .ACCU 16
  .INDEX 16
  lda #1
  sta.w SCUMM.verbDirty
  jmp _srv.done

_srv.delete:
  .ACCU 16
  .INDEX 16
  ldx #0
_srv.deleteLoop:
  .ACCU 16
  .INDEX 16
  cpx #_sizeof_scummVerb * SCUMM_MAX_VERBS
  bcs _srv.deleteDone
  sep #$20
  lda.w SCUMM.verbs.1.id,x
  rep #$20
  and #$00FF
  beq _srv.deleteNext                   ; already empty, skip
  cmp.w SCUMM.scratch2                  ; < begin_verb?
  bcc _srv.deleteNext
  cmp.w SCUMM.scratch3                  ; > end_verb?
  beq +
  bcs _srv.deleteNext
+
  .ACCU 16
  sep #$20
  stz.w SCUMM.verbs.1.id,x             ; zero the verb id
  rep #$20
_srv.deleteNext:
  .ACCU 16
  .INDEX 16
  txa
  clc
  adc #_sizeof_scummVerb
  tax
  bra _srv.deleteLoop
_srv.deleteDone:
  .ACCU 16
  .INDEX 16
  lda #1
  sta.w SCUMM.verbDirty

_srv.done:
  .ACCU 16
  .INDEX 16
  plb
  plp
  rtl

.ends


;===================================================================
; getStringWidth_impl — measure pixel width of a SCUMM string slot
; Input: A = string slot ID (0-15, already clamped)
; Output: A = pixel width (16-bit). JSL/RTL.
;===================================================================
.section "ScummVM getStringWidth impl" superfree

scummvm.getStringWidth_impl:
  phb
  phx
  phy
  and #$000F                         ; clamp slot ID 0-15 (A is 16-bit on entry)
  pha                                ; save slot ID (2 bytes, 16-bit)
  sep #$20
  .ACCU 8
  lda #$7E
  pha
  plb                                ; DBR = $7E for WRAM access
  rep #$31
  .ACCU 16
  .INDEX 16
  pla                                ; restore slot ID (2 bytes)

  ; compute slot address: SCUMM.stringTable + (slotID * 128)
  xba                                ; A = slotID << 8
  lsr a                              ; A = slotID << 7 = slotID * 128
  clc
  adc #SCUMM.stringTable & $FFFF     ; 16-bit offset within bank $7E
  tax                                ; X = pointer into string slot

  ldy #1                             ; Y = width accumulator (init 1 per ScummVM v5)

_gsw.loop:
  .ACCU 16
  .INDEX 16
  lda.w $0000,x                      ; read byte (16-bit load, use low byte)
  and #$00FF
  beq _gsw.done                      ; null terminator -> done

  cmp #$00FF
  beq _gsw.escape
  cmp #$00FE
  beq _gsw.escape

  ; printable character: add 8 pixels
  tya
  clc
  adc #8
  tay
  inx
  bra _gsw.loop

_gsw.escape:
  .ACCU 16
  .INDEX 16
  inx                                ; skip $FF/$FE byte
  lda.w $0000,x                      ; read escape code byte
  and #$00FF
  inx                                ; skip code byte

  ; codes 1, 2, 3, 9: stop iteration
  cmp #1
  beq _gsw.done
  cmp #2
  beq _gsw.done
  cmp #3
  beq _gsw.done
  cmp #9
  beq _gsw.done

  ; codes 10, 21, 12, 13, 14, 8: skip 2 more bytes
  cmp #10
  beq _gsw.skip2
  cmp #21
  beq _gsw.skip2
  cmp #12
  beq _gsw.skip2
  cmp #13
  beq _gsw.skip2
  cmp #14
  beq _gsw.skip2
  cmp #8
  beq _gsw.skip2

  ; other codes: no extra bytes, continue
  bra _gsw.loop

_gsw.skip2:
  .ACCU 16
  inx
  inx                                ; skip 2 parameter bytes
  bra _gsw.loop

_gsw.done:
  .ACCU 16
  .INDEX 16
  tya                                ; A = width
  ply
  plx
  plb
  rtl

.ends


;===================================================================
; getClosestObjActor_impl — find nearest actor/object to reference
; Input: A = reference actor/object ID (16-bit)
; Output: A = closest actor/object ID (or $00FF if none). JSL/RTL.
;===================================================================
.section "ScummVM getClosestObjActor impl" superfree

; Stack frame layout (after prologue):
;   sp+1  = closestObj (word)
;   sp+3  = closestDist (word)
;   sp+5  = rangeMin (word)
;   sp+7  = loopCounter (word)
;   sp+9  = refY (word)
;   sp+11 = refX (word)
.define _gcoa.refX      11
.define _gcoa.refY       9
.define _gcoa.counter    7
.define _gcoa.rangeMin   5
.define _gcoa.closeDist  3
.define _gcoa.closeObj   1

scummvm.getClosestObjActor_impl:
  phb
  pha                                ; save ref ID (16-bit)
  sep #$20
  .ACCU 8
  lda #$7E
  pha
  plb                                ; DBR = $7E for WRAM access
  rep #$31
  .ACCU 16
  .INDEX 16
  pla                                ; A = ref actor/object ID

  ; if ref >= 13, simplified: return $FF (object distance not implemented)
  cmp #13
  bcc +
  jmp _gcoa.failReturn
+

  ; ref is an actor: get its position
  ; actor struct = SCUMM.actors + (id * 16)
  and #$00FF
  asl a
  asl a
  asl a
  asl a                              ; A = id * 16
  tax
  ; check ref actor is in current room
  lda.w SCUMM.actors.1.room,x
  and #$00FF
  cmp.w SCUMM.currentRoom
  beq +
  jmp _gcoa.failReturn               ; ref not in room -> return $FF
+

  ; build stack frame: refX, refY, counter, rangeMin, closestDist, closestObj
  lda.w SCUMM.actors.1.x,x
  pha                                ; sp+11 = refX
  lda.w SCUMM.actors.1.y,x
  pha                                ; sp+9 = refY

  ; read VAR_ACTOR_RANGE_MAX (var 16) = globalVars[16], byte offset 32
  ldx #32
  lda.w SCUMM.globalVars,x
  and #$00FF
  pha                                ; sp+7 = loop counter (starts at MAX)

  ; read VAR_ACTOR_RANGE_MIN (var 15) = globalVars[15], byte offset 30
  ldx #30
  lda.w SCUMM.globalVars,x
  and #$00FF
  pha                                ; sp+5 = rangeMin

  lda #$00FF
  pha                                ; sp+3 = closestDist (init $FF)
  pha                                ; sp+1 = closestObj (init $FF)

_gcoa.loop:
  .ACCU 16
  .INDEX 16
  lda _gcoa.counter,s                ; A = current obj ID
  and #$00FF
  beq _gcoa.next                     ; skip actor 0
  cmp #13
  bcs _gcoa.next                     ; skip objects (id >= 13)

  ; get actor struct: A * 16
  asl a
  asl a
  asl a
  asl a
  tax

  ; check actor is in current room
  lda.w SCUMM.actors.1.room,x
  and #$00FF
  cmp.w SCUMM.currentRoom
  bne _gcoa.next                     ; not in room -> skip

  ; compute Chebyshev distance: max(abs(x1-x2), abs(y1-y2))
  ; dx = abs(actorX - refX)
  lda.w SCUMM.actors.1.x,x
  sec
  sbc _gcoa.refX,s
  bpl +
  eor #$FFFF
  inc a
+
  sta.w SCUMM.scratch                ; scratch = abs(dx)

  ; dy = abs(actorY - refY)
  lda.w SCUMM.actors.1.y,x
  sec
  sbc _gcoa.refY,s
  bpl +
  eor #$FFFF
  inc a
+
  ; A = abs(dy), scratch = abs(dx)
  cmp.w SCUMM.scratch
  bcs +                              ; dy >= dx -> keep dy
  lda.w SCUMM.scratch                ; else use dx
+
  ; A = distance; clamp to $FF if > $FF
  cmp #$0100
  bcc _gcoa.gotDist
  lda #$00FF
_gcoa.gotDist:
  .ACCU 16
  ; compare with closestDist
  cmp _gcoa.closeDist,s
  beq _gcoa.next                     ; equal -> don't replace
  bcs _gcoa.next                     ; this >= closest -> don't replace
  ; this actor is closer
  sta _gcoa.closeDist,s              ; update closest distance
  lda _gcoa.counter,s
  sta _gcoa.closeObj,s               ; update closest object

_gcoa.next:
  .ACCU 16
  .INDEX 16
  lda _gcoa.counter,s
  dec a
  sta _gcoa.counter,s
  cmp _gcoa.rangeMin,s
  bcs _gcoa.loop                     ; >= min -> continue

  ; done: retrieve closestObj
  lda _gcoa.closeObj,s
  ; tear down stack frame (6 words = 12 bytes)
  tay                                ; save result in Y
  tsc
  clc
  adc #12
  tcs                                ; SP += 12 (discard frame)
  tya                                ; A = result
  bra _gcoa.return

_gcoa.failReturn:
  .ACCU 16
  lda #$00FF

_gcoa.return:
  .ACCU 16
  .INDEX 16
  plb
  rtl

.undefine _gcoa.refX
.undefine _gcoa.refY
.undefine _gcoa.counter
.undefine _gcoa.rangeMin
.undefine _gcoa.closeDist
.undefine _gcoa.closeObj

.ends


;===================================================================
; darkenPalette_impl — scale RGB from CGRAM shadow, write to CGRAM
; Params in BWRAM_PALETTE_SCRATCH: +0=redScale, +2=greenScale,
;   +4=blueScale (0-255 each), +6=startColor, +8=endColor
;===================================================================
.bank 0 slot 0
.section "ScummVM darkenPalette impl" superfree
.base BSL

scummvm.darkenPalette_impl:
  php
  rep #$31
  .ACCU 16
  .INDEX 16

  ; Set CGRAM write address to startColor
  lda.l BWRAM_PALETTE_SCRATCH+6     ; startColor
  sep #$20
  .ACCU 8
  sta.l $2121                       ; CGADD
  rep #$20
  .ACCU 16

  ; X = byte offset into shadow = startColor * 2
  lda.l BWRAM_PALETTE_SCRATCH+6
  asl a
  tax

  ; Calculate loop count = (endColor - startColor + 1)
  lda.l BWRAM_PALETTE_SCRATCH+8     ; endColor
  sec
  sbc.l BWRAM_PALETTE_SCRATCH+6     ; - startColor
  inc a                             ; + 1
  tay                               ; Y = remaining count
  bne +
  jmp _darken.done
+
  bpl _darken.loop
  jmp _darken.done

_darken.loop:

  ; Read BGR555 word from shadow
  lda.l BWRAM_CGRAM_SHADOW,x
  pha                               ; save original word

  ; --- Extract and scale R (bits 0-4) ---
  and #$001F
  ; result = (channel * scale + 128) >> 8
  sep #$20
  .ACCU 8
  sta.l BWRAM_PALETTE_SCRATCH+10    ; temp: R channel (low byte only)
  rep #$20
  .ACCU 16
  lda.l BWRAM_PALETTE_SCRATCH+10
  and #$00FF
  pha                               ; save R on stack
  lda.l BWRAM_PALETTE_SCRATCH       ; redScale
  and #$00FF
  sta.l BWRAM_PALETTE_SCRATCH+12    ; temp: scale
  pla                               ; A = R
  ; A * scale: 16-bit multiply via shift-add
  ; Use software multiply: result = A * scratch+12
  jsr _darken.multiply              ; A = (channel * scale + 128) >> 8
  sta.l BWRAM_PALETTE_SCRATCH+14    ; scaled R

  ; --- Extract and scale G (bits 5-9) ---
  pla                               ; restore original BGR555
  pha                               ; keep it for B
  lsr a
  lsr a
  lsr a
  lsr a
  lsr a
  and #$001F
  pha
  lda.l BWRAM_PALETTE_SCRATCH+2     ; greenScale
  and #$00FF
  sta.l BWRAM_PALETTE_SCRATCH+12
  pla
  jsr _darken.multiply
  asl a
  asl a
  asl a
  asl a
  asl a
  ora.l BWRAM_PALETTE_SCRATCH+14
  sta.l BWRAM_PALETTE_SCRATCH+14    ; R | (G << 5)

  ; --- Extract and scale B (bits 10-14) ---
  pla                               ; restore original BGR555
  xba
  lsr a
  lsr a
  and #$001F
  pha
  lda.l BWRAM_PALETTE_SCRATCH+4     ; blueScale
  and #$00FF
  sta.l BWRAM_PALETTE_SCRATCH+12
  pla
  jsr _darken.multiply
  ; shift B into bits 10-14
  asl a
  asl a
  asl a
  asl a
  asl a
  asl a
  asl a
  asl a
  asl a
  asl a
  ora.l BWRAM_PALETTE_SCRATCH+14    ; R | (G << 5) | (B << 10)

  ; Write to CGRAM (auto-increments)
  sep #$20
  .ACCU 8
  sta.l $2122                       ; CGDATA low byte
  xba
  sta.l $2122                       ; CGDATA high byte
  rep #$20
  .ACCU 16

  inx
  inx
  dey
  beq _darken.done
  jmp _darken.loop

_darken.done:
  plp
  rtl

; Software multiply helper: A = (A * scratch+12 + 128) >> 8
; Input: A = channel (0-31), scratch+12 = scale (0-255)
; Output: A = scaled value (0-31)
; Uses simple add-loop: channel is max 31, so at most 31 additions.
_darken.multiply:
  .ACCU 16
  and #$001F
  beq _darken.mulDone               ; channel=0 -> result=0
  tay                               ; Y = channel (loop counter)
  lda #0                            ; accumulator
_darken.mulAdd:
  clc
  adc.l BWRAM_PALETTE_SCRATCH+12    ; += scale
  dey
  bne _darken.mulAdd
  ; A = channel * scale. Apply (+ 128) >> 8
  clc
  adc #128
  xba                               ; >> 8
  and #$00FF
  cmp #32
  bcc _darken.mulDone
  lda #31
_darken.mulDone:
  rts

.ends


;===================================================================
; setPalColor_impl — convert VGA RGB to BGR555, write shadow + CGRAM
; Params in BWRAM_PALETTE_SCRATCH: +0=r, +2=g, +4=b (VGA 0-63),
;   +6=palette index
;===================================================================
.bank 0 slot 0
.section "ScummVM setPalColor impl" superfree
.base BSL

scummvm.setPalColor_impl:
  php
  rep #$31
  .ACCU 16
  .INDEX 16

  ; Convert VGA (0-63) to SNES (0-31): snes_channel = vga >> 1
  lda.l BWRAM_PALETTE_SCRATCH       ; r
  lsr a
  and #$001F
  sta.l BWRAM_PALETTE_SCRATCH+10    ; SNES R

  lda.l BWRAM_PALETTE_SCRATCH+2     ; g
  lsr a
  and #$001F
  asl a
  asl a
  asl a
  asl a
  asl a
  ora.l BWRAM_PALETTE_SCRATCH+10
  sta.l BWRAM_PALETTE_SCRATCH+10    ; R | (G << 5)

  lda.l BWRAM_PALETTE_SCRATCH+4     ; b
  lsr a
  and #$001F
  asl a
  asl a
  asl a
  asl a
  asl a
  asl a
  asl a
  asl a
  asl a
  asl a
  ora.l BWRAM_PALETTE_SCRATCH+10    ; R | (G << 5) | (B << 10)
  pha                               ; save BGR555 word

  ; Write to BWRAM_CGRAM_SHADOW at index*2
  lda.l BWRAM_PALETTE_SCRATCH+6     ; palette index
  asl a
  tax
  pla                               ; BGR555 word
  sta.l BWRAM_CGRAM_SHADOW,x        ; update shadow

  ; Write to CGRAM
  sep #$20
  .ACCU 8
  lda.l BWRAM_PALETTE_SCRATCH+6
  sta.l $2121                       ; CGADD = index
  rep #$20
  .ACCU 16
  lda.l BWRAM_CGRAM_SHADOW,x        ; re-read BGR555
  sep #$20
  .ACCU 8
  sta.l $2122                       ; CGDATA low
  xba
  sta.l $2122                       ; CGDATA high
  rep #$20
  .ACCU 16

  plp
  rtl

.ends


;===================================================================
; runInputScript — start VAR_VERB_SCRIPT with clickArea/verb/button args
;
; Called from bank 0 via JSL.  Reads VAR(7) = verb script number,
; fills argBuffer[0..2], calls startScriptSlot_long, copies args.
;
; Input (pre-filled by caller):
;   SCUMM.argBuffer+0 = clickArea (word)
;   SCUMM.argBuffer+2 = verb/code (word)
;   SCUMM.argBuffer+4 = button code (word)
;   SCUMM.argCount = 6
;===================================================================
.section "ScummVM runInputScript" superfree
.ACCU 16
.INDEX 16

scummvm.runInputScript_impl:
  rep #$31
  .ACCU 16
  .INDEX 16

  ; Read VAR_VERB_SCRIPT (globalVar[7])
  ldx #7*2
  lda.w SCUMM.globalVars,x
  and #$00FF
  beq _ris.done                       ; no verb script configured

  ; A = script number; argBuffer already filled by caller
  jsl scummvm.startScriptSlot_long
  bcc _ris.done                       ; slot creation failed

  ; X = new slot byte offset; copy 3 args (6 bytes) to localVars
  ldy #0
_ris.copyArgs:
  .ACCU 16
  .INDEX 16
  cpy.w SCUMM.argCount
  bcs _ris.done
  lda.w SCUMM.argBuffer,y
  sta.w SCUMM.slots.localVars,x
  inx
  inx
  iny
  iny
  bra _ris.copyArgs

_ris.done:
  .ACCU 16
  .INDEX 16
  rtl

.ends


;===================================================================
; Room 0 clear: zero room state + wipe BG1 VRAM tilemap
;===================================================================
.section "scummvm clearRoom0 impl" superfree
.base BSL

scummvm.clearRoom0:
  .ACCU 16
  .INDEX 16

  ; Replicate the 6 original stz operations (16-bit A context)
  stz.w SCUMM.currentRoom
  ldx #4*2                              ; VAR_ROOM
  stz.w SCUMM.globalVars,x
  stz.w SCUMM.roomEncdLen
  stz.w SCUMM.roomExcdLen
  stz.w SCUMM.roomObjCount

  ; Disable NMI + IRQ to prevent VRAM address corruption during writes
  sei
  sep #$20
  lda #0
  sta.l NMITIMEN                        ; disable NMI (non-maskable, sei alone won't block it)

  ; Enter force blank for safe VRAM access
  lda #INIDSP_FORCE_BLANK
  sta.l INIDSP

  ; Set VMAIN: increment on high byte write, step +1
  lda #VMAIN_INCREMENT_MODE
  sta.l VMAIN

  ; Set VRAM address to BG1 tilemap base ($3800 word addr = $7000 byte addr)
  rep #$20
  lda #$3800
  sta.l VMADDL

  ; Zero $800 words (64x32 tilemap = $1000 bytes)
  ; Must use 8-bit writes: 16-bit sta to VMDATAL spills into VMDATAH,
  ; causing double auto-increment
  sep #$20
  lda #0
  ldy.w #$0800
- sta.l VMDATAL
  sta.l VMDATAH
  dey
  bne -

  ; DMA dialog font to VRAM — room 0 fast path skips room.load,
  ; so processRoomChange's loadDialogFont JSL never fires
  jsl scummvm.loadDialogFont
  sep #$20          ; loadDialogFont returns 16-bit, restore 8-bit for NMI write

  ; Restore NMI + auto-joypad read
  lda #$81
  sta.l NMITIMEN
  cli

  rep #$20
  .ACCU 16
  rtl

.ends


;===================================================================
; Dialog font DMA — called from processRoomChange after room.load
; Force blank is guaranteed active by the caller.
;===================================================================
.section "scummvm loadDialogFont impl" superfree
.base BSL

scummvm.loadDialogFont:
  ; Just set the NMI pending flag — actual DMA happens in VBlank
  sep #$20
  lda #1
  sta.w SCUMM.dialogFontNmiPending
  rep #$20
  .ACCU 16
  rtl

.ends


