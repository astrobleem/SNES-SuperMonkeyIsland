;
; SCUMM v5 Bytecode Interpreter for SNES
;
; OOP class that runs MI1's SCUMM scripts. One object manages all
; 25 SCUMM script slots. play() runs the scheduler once per frame.
;
; Bytecode fetch: [dp:tmp],y where tmp holds 24-bit pointer into
; $7F script cache, Y is the SCUMM PC offset within the script.
;
; Dispatch: 256-entry jsr (table,x) jump table. Handler returns
; with carry clear = continue, carry set = yield.
;

.include "src/object/scummvm/scummvm.h"

.section "scummvm class"

;===================================================================
; METHOD: init
; Read MSU-1 script section header, zero all state, start script 1
;===================================================================
  METHOD init
  rep #$31

  ;--- Zero all WRAM state ---
  ;zero script slots (25 * 64 = 1600 bytes)
  ldx #0
  lda #0
_init.zeroSlots:
  sta.w SCUMM.slots,x
  inx
  inx
  cpx #_sizeof_scummSlot * SCUMM_MAX_SLOTS
  bcc _init.zeroSlots

  ;zero global variables (800 * 2 = 1600 bytes)
  ldx #0
_init.zeroGlobals:
  sta.w SCUMM.globalVars,x
  inx
  inx
  cpx #SCUMM_MAX_GLOBALS * 2
  bcc _init.zeroGlobals

  ;zero bit variables (256 bytes)
  ldx #0
_init.zeroBits:
  sta.w SCUMM.bitVars,x
  inx
  inx
  cpx #256
  bcc _init.zeroBits

  ;zero VM state
  stz.w SCUMM.running
  stz.w SCUMM.currentSlot
  stz.w SCUMM.currentSlotPtr
  stz.w SCUMM.currentOpcode
  stz.w SCUMM.resultVar
  stz.w SCUMM.scratch
  stz.w SCUMM.scratch2
  stz.w SCUMM.cacheWritePtr
  stz.w SCUMM.cutsceneNest
  stz.w SCUMM.currentRoom
  stz.w SCUMM.newRoom
  stz.w SCUMM.bgInitDone
  stz.w SCUMM.roomEncdPtr
  stz.w SCUMM.roomEncdLen
  stz.w SCUMM.roomExcdPtr
  stz.w SCUMM.roomExcdLen
  stz.w SCUMM.roomLscrCount

  ;zero LSCR table (56 * 4 = 224 bytes)
  ldx #0
  lda #0
_init.zeroLscr:
  sta.w SCUMM.roomLscrTable,x
  inx
  inx
  cpx #_sizeof_lscrEntry * SCUMM_LSCR_MAX
  bcc _init.zeroLscr

  ;zero script cache in $7F
  ldx #0
  lda #0
_init.zeroCache:
  sta.l SCUMM_CACHE_WRAM,x
  inx
  inx
  cpx #SCUMM_CACHE_SIZE
  bcc _init.zeroCache

  ;--- Read script section offset from MSU-1 header ---
  ; MSU header at offset $0024 has 32-bit script section offset
  lda.w #SCUMM_MSU_SCRIPT_HDR_OFFSET
  ldx #0
  jsr room.msu1Seek

  ; Read LE32 into scriptSectionLo/Hi using XBA word-read pattern
  sep #$20
  lda.l MSU_DATA
  xba
  lda.l MSU_DATA
  xba
  rep #$20
  sta.w SCUMM.scriptSectionLo
  sep #$20
  lda.l MSU_DATA
  xba
  lda.l MSU_DATA
  xba
  rep #$20
  sta.w SCUMM.scriptSectionHi

  ; Check that script section exists
  lda.w SCUMM.scriptSectionLo
  ora.w SCUMM.scriptSectionHi
  bne +
    TRIGGER_ERROR E_ScummVmBadOpcode
+

  ;--- Seek to script section and read 32-byte header ---
  lda.w SCUMM.scriptSectionLo
  ldx.w SCUMM.scriptSectionHi
  jsr room.msu1Seek

  ; Skip magic (4 bytes) + version (1) + reserved (1) = 6 bytes
  sep #$20
  lda.l MSU_DATA
  lda.l MSU_DATA
  lda.l MSU_DATA
  lda.l MSU_DATA
  lda.l MSU_DATA
  lda.l MSU_DATA
  rep #$20

  ; Read global_slots (LE16) -- XBA word-read
  sep #$20
  lda.l MSU_DATA
  xba
  lda.l MSU_DATA
  xba
  rep #$20
  sta.w SCUMM.globalSlots

  ; Read room_slots (LE16) -- XBA word-read
  sep #$20
  lda.l MSU_DATA
  xba
  lda.l MSU_DATA
  xba
  rep #$20
  sta.w SCUMM.roomSlots

  ; Skip 6 reserved bytes (bytes 10-15)
  sep #$20
  lda.l MSU_DATA
  lda.l MSU_DATA
  lda.l MSU_DATA
  lda.l MSU_DATA
  lda.l MSU_DATA
  lda.l MSU_DATA
  rep #$20

  ; Read global_index_offset (LE32, bytes 16-19) -- XBA word-read
  sep #$20
  lda.l MSU_DATA
  xba
  lda.l MSU_DATA
  xba
  rep #$20
  sta.w SCUMM.globalIndexLo
  sep #$20
  lda.l MSU_DATA
  xba
  lda.l MSU_DATA
  xba
  rep #$20
  sta.w SCUMM.globalIndexHi

  ; Read room_index_offset (LE32, bytes 20-23) -- XBA word-read
  sep #$20
  lda.l MSU_DATA
  xba
  lda.l MSU_DATA
  xba
  rep #$20
  sta.w SCUMM.roomIndexLo
  sep #$20
  lda.l MSU_DATA
  xba
  lda.l MSU_DATA
  xba
  rep #$20
  sta.w SCUMM.roomIndexHi

  ;--- Set SCUMM v5 system variables (from ScummVM resetScummVars) ---
  ; Use indexed addressing: ldx #var*2 / lda #val / sta.w globalVars,x
  ; (wla-dx ramsection + constant = 24-bit → linker error without index)
  lda #1
  ldx #1*2
  sta.w SCUMM.globalVars,x          ; VAR(1)  = VAR_EGO = 1 (Guybrush)
  lda #13
  ldx #8*2
  sta.w SCUMM.globalVars,x          ; VAR(8)  = VAR_NUM_ACTOR = 13
  lda #1
  ldx #15*2
  sta.w SCUMM.globalVars,x          ; VAR(15) = VAR_ACTOR_RANGE_MIN = 1
  lda #12
  ldx #16*2
  sta.w SCUMM.globalVars,x          ; VAR(16) = VAR_ACTOR_RANGE_MAX = 12
  lda #1400
  ldx #40*2
  sta.w SCUMM.globalVars,x          ; VAR(40) = VAR_HEAPSPACE = 1400
  lda #3
  ldx #46*2
  sta.w SCUMM.globalVars,x          ; VAR(46) = VAR_SOUNDCARD = 3 (SB)
  lda #19
  ldx #47*2
  sta.w SCUMM.globalVars,x          ; VAR(47) = VAR_VIDEOMODE = 19 (VGA)
  lda #1
  ldx #49*2
  sta.w SCUMM.globalVars,x          ; VAR(49) = VAR_FIXEDDISK = 1

  ;--- Set starting room (triggers room load on first play frame) ---
  ; MI1 starting room = 1; currentRoom already 0 from zero pass
  lda #1
  sta.w SCUMM.newRoom

  ;--- Start MI1 boot script (script 1) ---
  lda #1
  jsr _scummvm.startScriptSlot

  ;--- Mark VM as running ---
  lda #1
  sta.w SCUMM.running

  rts


;===================================================================
; METHOD: play -- per-frame SCUMM scheduler
; Iterates all 25 slots, runs RUNNING slots until they yield.
;===================================================================
  METHOD play
  rep #$31

  lda.w SCUMM.running
  beq _play.done

  ; Check for pending room change
  lda.w SCUMM.newRoom
  cmp.w SCUMM.currentRoom
  beq _play.noRoomChange
  jsr _scummvm.processRoomChange
_play.noRoomChange:

  ; Iterate slots 0..24
  stz.w SCUMM.currentSlot
  stz.w SCUMM.currentSlotPtr

_play.slotLoop:
  ldx.w SCUMM.currentSlotPtr

  ; Check status == RUNNING
  lda.w SCUMM.slots.status,x
  and #$00FF
  cmp #SCUMM_SLOT_RUNNING
  bne _play.nextSlot

  ; Check freezeCount == 0
  lda.w SCUMM.slots.freezeCount,x
  and #$00FF
  bne _play.nextSlot

  ; Check delay > 0
  lda.w SCUMM.slots.delay,x
  beq _play.runSlot

  ; Decrement delay
  dec a
  sta.w SCUMM.slots.delay,x
  bra _play.nextSlot

_play.runSlot:
  jsr _scummvm.executeSlot

_play.nextSlot:
  ; Advance to next slot
  lda.w SCUMM.currentSlotPtr
  clc
  adc #_sizeof_scummSlot
  sta.w SCUMM.currentSlotPtr

  lda.w SCUMM.currentSlot
  inc a
  sta.w SCUMM.currentSlot
  cmp #SCUMM_MAX_SLOTS
  bcc _play.slotLoop

_play.done:
  rts


;-------------------------------------------------------------------
; _scummvm.processRoomChange -- load new room background
; Called when SCUMM.newRoom != SCUMM.currentRoom
;-------------------------------------------------------------------
_scummvm.processRoomChange:
  rep #$31

  ; Set up PPU for BG1 room display (once)
  lda.w SCUMM.bgInitDone
  bne _prc.bgReady

  sep #$20
  ; Mode 1, BG1 tilemap at $7000 (word $3800), 64 tiles wide
  lda.b #$39                        ; $38 = tilemap base $3800, +1 = 64-wide
  sta.w BG1TilemapVram
  ; Tile data at VRAM $0000 (BG1 uses low nibble of BG12NBA)
  lda.b #$00
  sta.w BGTilesVram12
  ; Enable BG1 on main screen
  lda.w MainScreen
  ora.b #T_BG1_ENABLE
  sta.w MainScreen
  ; Set mode 1
  lda.b #BGMODE_MODE_1
  sta.w ScreenMode
  rep #$20

  lda #1
  sta.w SCUMM.bgInitDone

_prc.bgReady:
  ; Load room via Phase 0 room loader
  lda.w SCUMM.newRoom
  jsr room.load
  bcc _prc.failed

  ; Kill old room/local script slots
  jsr _scummvm.killRoomScripts

  ; Flush cache (global scripts reload on demand)
  stz.w SCUMM.cacheWritePtr

  ; Load room scripts (ENCD/EXCD/LSCR) from MSU-1
  lda.w SCUMM.newRoom
  jsr _scummvm.loadRoomScripts
  bcc _prc.noEncd

  ; Auto-start ENCD if present
  lda.w SCUMM.roomEncdLen
  beq _prc.noEncd
  jsr _scummvm.startEncdSlot
_prc.noEncd:

  ; Update current room + SCUMM variable
  lda.w SCUMM.newRoom
  sta.w SCUMM.currentRoom
  ldx #4*2                          ; VAR(4) = VAR_ROOM
  sta.w SCUMM.globalVars,x

  ; Fade up brightness
  sep #$20
  lda.b #$0F
  sta.w ScreenBrightness
  rep #$20

_prc.failed:
  rts


;===================================================================
; METHOD: kill
;===================================================================
  METHOD kill
  rep #$31
  stz.w SCUMM.running
  rts


;===================================================================
; _scummvm.executeSlot -- run opcodes for current slot until yield
;
; Sets up [tmp] pointing into $7F cache and Y = slot.pc,
; then loops: fetch opcode, dispatch via jsr (table,x).
; Handler returns carry set to yield, carry clear to continue.
;===================================================================
_scummvm.executeSlot:
  rep #$31

  ; Set up tmp (ZP) as 24-bit pointer to script bytecode
  ; tmp+0,1 = SCUMM_CACHE_BASE + slot.cachePtr (low 16)
  ; tmp+2   = $7F
  ldx.w SCUMM.currentSlotPtr
  lda.w SCUMM.slots.cachePtr,x
  clc
  adc #SCUMM_CACHE_BASE
  sta.b tmp
  sep #$20
  lda #$7F
  sta.b tmp+2
  rep #$20

  ; Y = slot.pc
  ldx.w SCUMM.currentSlotPtr
  ldy.w SCUMM.slots.pc,x

_scummvm.fetchLoop:
  ; Read opcode byte (16-bit load, mask to 8-bit)
  lda [tmp],y
  and #$00FF
  sta.w SCUMM.currentOpcode
  iny                       ; advance PC past opcode byte

  ; Dispatch: opcode * 2 for word-indexed table
  asl a
  tax
  jsr (_scummvm.dispatchTable,x)
  bcc _scummvm.fetchLoop    ; carry clear = keep going

  ; Carry set = yield. Save Y back to slot.pc
  ldx.w SCUMM.currentSlotPtr
  tya
  sta.w SCUMM.slots.pc,x
  rts


;===================================================================
; Parameter Decoder Helpers
;
; These read parameters from the bytecode stream.
; Y = SCUMM PC (advanced as bytes are consumed).
; [tmp] = bytecode pointer.
;===================================================================

;-------------------------------------------------------------------
; _scummvm.fetchByte -- read next byte, zero-extend to 16-bit
; Returns: A = byte value, Y advanced by 1
;-------------------------------------------------------------------
_scummvm.fetchByte:
  lda [tmp],y
  and #$00FF
  iny
  rts

;-------------------------------------------------------------------
; _scummvm.fetchWord -- read next 16-bit LE word
; Returns: A = word value, Y advanced by 2
;-------------------------------------------------------------------
_scummvm.fetchWord:
  lda [tmp],y
  iny
  iny
  rts

;-------------------------------------------------------------------
; _scummvm.getVarOrDirectWord -- decode p16 parameter
; Input: A = flag bitmask to test against currentOpcode
; If flag SET in opcode: FETCH_WORD -> readVariable (var reference)
; If flag CLEAR: FETCH_WORD (literal value)
; Returns: A = resolved value
;-------------------------------------------------------------------
_scummvm.getVarOrDirectWord:
  and.w SCUMM.currentOpcode   ; test flag bit against opcode
  beq +
    ; Flag set: word is a variable reference
    jsr _scummvm.fetchWord
    jmp _scummvm.readVariable
+
  ; Flag clear: word is literal
  jsr _scummvm.fetchWord
  rts

;-------------------------------------------------------------------
; _scummvm.getVarOrDirectByte -- decode p8 parameter
; Input: A = flag bitmask to test against currentOpcode
; If flag SET: FETCH_WORD -> readVariable (2-byte var ref)
; If flag CLEAR: FETCH_BYTE (1-byte literal)
; Returns: A = resolved value
;-------------------------------------------------------------------
_scummvm.getVarOrDirectByte:
  and.w SCUMM.currentOpcode   ; test flag bit against opcode
  beq +
    ; Flag set: read variable reference (2 bytes)
    jsr _scummvm.fetchWord
    jmp _scummvm.readVariable
+
  ; Flag clear: literal byte
  jsr _scummvm.fetchByte
  rts

;-------------------------------------------------------------------
; _scummvm.getResultPos -- read result variable position
; Reads 2-byte variable reference, stores in SCUMM.resultVar
;-------------------------------------------------------------------
_scummvm.getResultPos:
  jsr _scummvm.fetchWord
  sta.w SCUMM.resultVar
  rts


;-------------------------------------------------------------------
; _scummvm.skipWordVararg -- skip getWordVararg argument list
; SCUMM v5 format: { sub_opcode_byte, word_arg } ... 0xFF
; Each non-0xFF byte is followed by a 2-byte word (var ref or literal).
; Preserves A on stack (caller typically has script number pushed).
;-------------------------------------------------------------------
_scummvm.skipWordVararg:
-
  jsr _scummvm.fetchByte
  cmp #$00FF
  beq +
  jsr _scummvm.fetchWord          ; skip the 2-byte argument
  bra -
+
  rts


;===================================================================
; Variable System
;===================================================================

;-------------------------------------------------------------------
; _scummvm.readVariable -- read a SCUMM variable
; Input: A = raw variable encoding (16-bit)
; Returns: A = variable value (16-bit)
;-------------------------------------------------------------------
_scummvm.readVariable:
  sta.w SCUMM.scratch
  and #SCUMM_VAR_TYPE_MASK
  beq _readVar.global

  cmp #SCUMM_VAR_LOCAL_MASK
  beq _readVar.local

  ; Bit variable ($8000-$BFFF)
  lda.w SCUMM.scratch
  and #SCUMM_VAR_INDEX_MASK
  pha
  lsr a
  lsr a
  lsr a
  tax
  pla
  and #$0007
  pha
  lda #1
  sta.w SCUMM.scratch2
  pla
  beq _readBit.test
_readBit.shift:
  asl.w SCUMM.scratch2
  dec a
  bne _readBit.shift
_readBit.test:
  lda.w SCUMM.bitVars,x
  and #$00FF
  and.w SCUMM.scratch2
  beq +
    lda #1
+
  rts

_readVar.global:
  lda.w SCUMM.scratch
  and #SCUMM_VAR_INDEX_MASK
  asl a
  tax
  lda.w SCUMM.globalVars,x
  rts

_readVar.local:
  lda.w SCUMM.scratch
  and #SCUMM_VAR_INDEX_MASK
  asl a
  clc
  adc.w SCUMM.currentSlotPtr
  tax
  lda.w SCUMM.slots.localVars,x
  rts


;-------------------------------------------------------------------
; _scummvm.writeVariable -- write a SCUMM variable
; Input: A = value to write
;        SCUMM.resultVar = target variable encoding
;-------------------------------------------------------------------
_scummvm.writeVariable:
  sta.w SCUMM.scratch2
  lda.w SCUMM.resultVar
  and #SCUMM_VAR_TYPE_MASK
  beq _writeVar.global

  cmp #SCUMM_VAR_LOCAL_MASK
  beq _writeVar.local

  ; Bit variable
  lda.w SCUMM.resultVar
  and #SCUMM_VAR_INDEX_MASK
  pha
  lsr a
  lsr a
  lsr a
  tax
  pla
  and #$0007
  pha
  lda #1
  sta.w SCUMM.scratch
  pla
  beq _writeBit.apply
_writeBit.shift:
  asl.w SCUMM.scratch
  dec a
  bne _writeBit.shift
_writeBit.apply:
  lda.w SCUMM.scratch2
  beq _writeBit.clear
    sep #$20
    lda.w SCUMM.bitVars,x
    ora.w SCUMM.scratch
    sta.w SCUMM.bitVars,x
    rep #$20
    rts
_writeBit.clear:
    sep #$20
    lda.w SCUMM.scratch
    eor #$FF
    and.w SCUMM.bitVars,x
    sta.w SCUMM.bitVars,x
    rep #$20
    rts

_writeVar.global:
  lda.w SCUMM.resultVar
  and #SCUMM_VAR_INDEX_MASK
  asl a
  tax
  lda.w SCUMM.scratch2
  sta.w SCUMM.globalVars,x
  rts

_writeVar.local:
  lda.w SCUMM.resultVar
  and #SCUMM_VAR_INDEX_MASK
  asl a
  clc
  adc.w SCUMM.currentSlotPtr
  tax
  lda.w SCUMM.scratch2
  sta.w SCUMM.slots.localVars,x
  rts


;===================================================================
; Script Loader -- MSU-1 -> $7F Cache
;===================================================================

;-------------------------------------------------------------------
; _scummvm.copyMsuToCache -- copy bytes from MSU-1 into $7F cache
; Input: A = byte count to copy
; Assumes: MSU-1 data port is already seeked to correct position
; Uses cacheWritePtr as destination offset (updated on return)
; Output: A = cachePtr where data was written, X = byte count
; Clobbers: SCUMM.scratch, SCUMM.scratch2
;-------------------------------------------------------------------
_scummvm.copyMsuToCache:
  sta.w SCUMM.scratch           ; scratch = byte count

  ; Save starting cacheWritePtr (= destination offset)
  lda.w SCUMM.cacheWritePtr
  sta.w SCUMM.scratch2          ; scratch2 = cachePtr result

  ; X = destination offset into $7F bank
  ldx.w SCUMM.cacheWritePtr

  ; Copy loop: read MSU_DATA byte-by-byte into $7F cache
  phy
  ldy.w SCUMM.scratch           ; Y = remaining count
  beq _copyMsu.done
_copyMsu.loop:
  sep #$20
  lda.l MSU_DATA
  sta.l SCUMM_CACHE_WRAM,x
  rep #$20
  inx
  dey
  bne _copyMsu.loop
_copyMsu.done:
  ply

  ; Update cacheWritePtr
  lda.w SCUMM.cacheWritePtr
  clc
  adc.w SCUMM.scratch
  sta.w SCUMM.cacheWritePtr

  ; Return: A = cachePtr, X = byte count
  lda.w SCUMM.scratch2
  ldx.w SCUMM.scratch
  rts


;-------------------------------------------------------------------
; _scummvm.loadGlobalScript -- load a global script into cache
; Input: A = script number (0-based)
; Output: A = cachePtr (offset within cache), X = size
;-------------------------------------------------------------------
_scummvm.loadGlobalScript:
  sta.w SCUMM.scratch

  ; Compute index entry MSU offset: globalIndexOffset + scriptNum * 8
  asl a
  asl a
  asl a
  clc
  adc.w SCUMM.globalIndexLo
  sta.w SCUMM.scratch2
  lda #0
  adc.w SCUMM.globalIndexHi
  tax
  lda.w SCUMM.scratch2
  jsr room.msu1Seek

  ; Read 8-byte index entry: offset32 + size32
  sep #$20
  lda.l MSU_DATA
  xba
  lda.l MSU_DATA
  xba
  rep #$20
  pha                        ;push offset_lo
  sep #$20
  lda.l MSU_DATA
  xba
  lda.l MSU_DATA
  xba
  rep #$20
  pha                        ;push offset_hi
  sep #$20
  lda.l MSU_DATA
  xba
  lda.l MSU_DATA
  xba
  rep #$20
  pha                        ;push size_lo
  sep #$20
  lda.l MSU_DATA
  lda.l MSU_DATA
  rep #$20

  ; Stack: [size_lo] [offset_hi] [offset_lo]
  ; Check for null entry (offset == 0)
  lda 5,s
  ora 3,s
  bne _loadGlobal.exists

  ; Script doesn't exist
  pla
  pla
  pla
  lda #0
  tax
  rts

_loadGlobal.exists:
  lda 1,s
  sta.w SCUMM.scratch

  ; Check cache space
  lda.w SCUMM.cacheWritePtr
  clc
  adc.w SCUMM.scratch
  cmp #SCUMM_CACHE_SIZE
  bcc _loadGlobal.cacheOk

  ; Cache full -- reset
  stz.w SCUMM.cacheWritePtr

_loadGlobal.cacheOk:
  ; Seek to script data
  lda 3,s
  tax                 ;X = offset_hi (high 16 bits)
  lda 5,s             ;A = offset_lo (low 16 bits)
  jsr room.msu1Seek

  ; Copy bytecode from MSU-1 into cache via helper
  lda.w SCUMM.scratch
  jsr _scummvm.copyMsuToCache
  ; A = cachePtr, X = byte count

  ; Clean up stack (size_lo, offset_hi, offset_lo)
  sta.w SCUMM.scratch2
  pla
  pla
  pla

  lda.w SCUMM.scratch2
  ldx.w SCUMM.scratch
  rts


;-------------------------------------------------------------------
; _scummvm.startScriptSlot -- find dead slot, load script, init it
; Input: A = script number to start
;-------------------------------------------------------------------
_scummvm.startScriptSlot:
  sta.w SCUMM.scratch

  ; Find a dead slot
  ldx #0
  ldy #0
_startScript.findSlot:
  lda.w SCUMM.slots.status,x
  and #$00FF
  cmp #SCUMM_SLOT_DEAD
  beq _startScript.foundSlot
  txa
  clc
  adc #_sizeof_scummSlot
  tax
  iny
  cpy #SCUMM_MAX_SLOTS
  bcc _startScript.findSlot

  ; No free slot
  rts

_startScript.foundSlot:
  phx                             ; save slot offset

  ; Check if LSCR (script number >= 200)
  lda.w SCUMM.scratch
  cmp #SCUMM_LSCR_BASE
  bcs _startScript.local

  ;--- Global script path ---
  lda.w SCUMM.scratch
  pha                           ;push script number

  ; Load the script into cache
  phy
  jsr _scummvm.loadGlobalScript
  ply

  ; Check if script was found
  cpx #0
  bne _startScript.globalInit

  pla                           ;discard saved script number
  plx
  rts

_startScript.globalInit:
  ; A = cachePtr, X = size (from loadGlobalScript)
  sta.w SCUMM.scratch2          ; scratch2 = cachePtr
  stx.w SCUMM.scratch           ; scratch = cacheLen
  pla                           ;A = saved script number
  plx                           ;X = slot offset
  ldy #SCUMM_WHERE_GLOBAL
  bra _startScript.initSlot

  ;--- Local (LSCR) script path ---
_startScript.local:
  ; SCUMM.scratch = script number (>= 200)
  lda.w SCUMM.scratch
  pha                           ;push script number (for initSlot)
  sec
  sbc #SCUMM_LSCR_BASE          ; table index (0-55)
  asl a
  asl a                          ; * 4 = byte offset into lscrEntry table
  tax
  lda.w SCUMM.roomLscrTable.cacheLen,x
  beq _startScript.localNone     ; cacheLen == 0 → not loaded, bail
  sta.w SCUMM.scratch            ; scratch = cacheLen
  lda.w SCUMM.roomLscrTable.cachePtr,x
  sta.w SCUMM.scratch2           ; scratch2 = cachePtr

  pla                            ;A = script number
  plx                            ;X = slot offset (from foundSlot push)
  ldy #SCUMM_WHERE_LOCAL
  bra _startScript.initSlot

_startScript.localNone:
  pla                            ; discard script number
  plx                            ; discard slot offset
  rts

  ;--- Common slot initialization ---
  ; A = script number, X = slot byte offset, Y = WHERE value
  ; SCUMM.scratch2 = cachePtr, SCUMM.scratch = cacheLen
_startScript.initSlot:
  sep #$20
  sta.w SCUMM.slots.number,x
  lda #SCUMM_SLOT_RUNNING
  sta.w SCUMM.slots.status,x
  tya
  sta.w SCUMM.slots.where,x
  lda #0
  sta.w SCUMM.slots.freezeCount,x
  sta.w SCUMM.slots.cutsceneOverride,x
  rep #$20

  lda.w SCUMM.scratch2
  sta.w SCUMM.slots.cachePtr,x
  lda.w SCUMM.scratch
  sta.w SCUMM.slots.cacheLen,x

  lda #0
  sta.w SCUMM.slots.pc,x
  sta.w SCUMM.slots.delay,x

  ; Zero local variables
  phx
  ldy #0
_startScript.zeroLocals:
  sta.w SCUMM.slots.localVars,x
  inx
  inx
  iny
  cpy #SCUMM_MAX_LOCALS
  bcc _startScript.zeroLocals
  plx

  rts


;-------------------------------------------------------------------
; _scummvm.killRoomScripts -- kill all slots with where != GLOBAL
; Preserves Y (SCUMM PC)
;-------------------------------------------------------------------
_scummvm.killRoomScripts:
  phx
  phy
  ldx #0
  ldy #0
_killRoom.loop:
  lda.w SCUMM.slots.status,x
  and #$00FF
  cmp #SCUMM_SLOT_DEAD
  beq _killRoom.next
  lda.w SCUMM.slots.where,x
  and #$00FF
  beq _killRoom.next             ; where == 0 (GLOBAL) → keep
  sep #$20
  lda #SCUMM_SLOT_DEAD
  sta.w SCUMM.slots.status,x
  rep #$20
_killRoom.next:
  txa
  clc
  adc #_sizeof_scummSlot
  tax
  iny
  cpy #SCUMM_MAX_SLOTS
  bcc _killRoom.loop
  ply
  plx
  rts


;-------------------------------------------------------------------
; _scummvm.loadRoomScripts -- load ENCD/EXCD/LSCR from MSU-1
; Input: A = room number
; Output: carry set = scripts loaded, carry clear = none
; Clobbers: A, X, scratch/scratch2
;-------------------------------------------------------------------
_scummvm.loadRoomScripts:
  rep #$31
  sta.w SCUMM.scratch

  ;--- Zero LSCR table + ENCD/EXCD pointers ---
  stz.w SCUMM.roomEncdPtr
  stz.w SCUMM.roomEncdLen
  stz.w SCUMM.roomExcdPtr
  stz.w SCUMM.roomExcdLen
  stz.w SCUMM.roomLscrCount
  phx
  ldx #0
  lda #0
_loadRoom.zeroTable:
  sta.w SCUMM.roomLscrTable,x
  inx
  inx
  cpx #_sizeof_lscrEntry * SCUMM_LSCR_MAX
  bcc _loadRoom.zeroTable
  plx

  ;--- Seek to room index entry: roomIndexOffset + room * 8 ---
  lda.w SCUMM.scratch
  asl a
  asl a
  asl a                          ; room * 8
  clc
  adc.w SCUMM.roomIndexLo
  sta.w SCUMM.scratch2
  lda #0
  adc.w SCUMM.roomIndexHi
  tax
  lda.w SCUMM.scratch2
  phy
  jsr room.msu1Seek
  ply

  ;--- Read 8-byte index entry: offset32 + size32 ---
  sep #$20
  lda.l MSU_DATA
  xba
  lda.l MSU_DATA
  xba
  rep #$20
  pha                            ;push offset_lo
  sep #$20
  lda.l MSU_DATA
  xba
  lda.l MSU_DATA
  xba
  rep #$20
  pha                            ;push offset_hi
  ; Read size32 (discard — we parse the block header instead)
  sep #$20
  lda.l MSU_DATA
  lda.l MSU_DATA
  lda.l MSU_DATA
  lda.l MSU_DATA
  rep #$20

  ; Stack: [offset_hi] [offset_lo]
  ; Check for null entry (offset == 0)
  lda 3,s
  ora 1,s
  bne _loadRoom.exists

  ; No scripts for this room
  pla
  pla
  clc
  rts

_loadRoom.exists:
  ;--- Seek to room script block ---
  lda 1,s                        ;offset_hi
  tax
  lda 3,s                        ;offset_lo
  phy
  jsr room.msu1Seek
  ply
  pla                            ;discard offset_hi
  pla                            ;discard offset_lo

  ;--- Read block header ---
  ; encd_size (LE16)
  sep #$20
  lda.l MSU_DATA
  xba
  lda.l MSU_DATA
  xba
  rep #$20
  sta.w SCUMM.roomEncdLen

  ; excd_size (LE16)
  sep #$20
  lda.l MSU_DATA
  xba
  lda.l MSU_DATA
  xba
  rep #$20
  sta.w SCUMM.roomExcdLen

  ; lscr_count (u8) + reserved (u8)
  sep #$20
  lda.l MSU_DATA
  rep #$20
  and #$00FF
  sta.w SCUMM.roomLscrCount
  sep #$20
  lda.l MSU_DATA                 ;drain reserved byte
  rep #$20

  ;--- Read per-LSCR header entries ---
  ; For each LSCR: number(u8) + size(LE16) → store in table
  lda.w SCUMM.roomLscrCount
  beq _loadRoom.copyEncd
  pha                            ;push remaining count
_loadRoom.lscrHdr:
  ; Read lscr_number (u8)
  sep #$20
  lda.l MSU_DATA
  rep #$20
  and #$00FF
  sec
  sbc #SCUMM_LSCR_BASE           ; table index (0-55)
  asl a
  asl a                           ; * 4 byte offset
  tax

  ; Read lscr_size (LE16)
  sep #$20
  lda.l MSU_DATA
  xba
  lda.l MSU_DATA
  xba
  rep #$20
  sta.w SCUMM.roomLscrTable.cacheLen,x

  lda 1,s
  dec a
  sta 1,s
  bne _loadRoom.lscrHdr
  pla                            ;discard count

_loadRoom.copyEncd:
  ;--- Copy ENCD from MSU → cache ---
  lda.w SCUMM.roomEncdLen
  beq _loadRoom.copyExcd
  lda.w SCUMM.cacheWritePtr
  sta.w SCUMM.roomEncdPtr
  lda.w SCUMM.roomEncdLen
  jsr _scummvm.copyMsuToCache

_loadRoom.copyExcd:
  ;--- Copy EXCD from MSU → cache ---
  lda.w SCUMM.roomExcdLen
  beq _loadRoom.copyLscr
  lda.w SCUMM.cacheWritePtr
  sta.w SCUMM.roomExcdPtr
  lda.w SCUMM.roomExcdLen
  jsr _scummvm.copyMsuToCache

_loadRoom.copyLscr:
  ;--- Copy LSCR bytecodes from MSU → cache ---
  ; LSCRs are stored in number-ascending order in MSU, matching table iteration
  phx
  ldx #0
_loadRoom.lscrLoop:
  cpx #_sizeof_lscrEntry * SCUMM_LSCR_MAX
  bcs _loadRoom.lscrDone
  lda.w SCUMM.roomLscrTable.cacheLen,x
  beq _loadRoom.lscrNext          ; no entry at this index
  ; Save table offset, copy this LSCR
  phx
  lda.w SCUMM.cacheWritePtr
  sta.w SCUMM.scratch2            ; save cachePtr for this entry
  lda.w SCUMM.roomLscrTable.cacheLen,x
  jsr _scummvm.copyMsuToCache
  ; Write cachePtr back into the table
  plx
  lda.w SCUMM.scratch2
  sta.w SCUMM.roomLscrTable.cachePtr,x
_loadRoom.lscrNext:
  inx
  inx
  inx
  inx                              ; next lscrEntry (4 bytes)
  bra _loadRoom.lscrLoop
_loadRoom.lscrDone:
  plx

  sec                              ; success
  rts


;-------------------------------------------------------------------
; _scummvm.startEncdSlot -- start ENCD script in a new slot
; Uses roomEncdPtr/roomEncdLen. Finds dead slot, inits as ROOM.
;-------------------------------------------------------------------
_scummvm.startEncdSlot:
  rep #$31

  ; Find a dead slot
  ldx #0
  ldy #0
_startEncd.findSlot:
  lda.w SCUMM.slots.status,x
  and #$00FF
  cmp #SCUMM_SLOT_DEAD
  beq _startEncd.found
  txa
  clc
  adc #_sizeof_scummSlot
  tax
  iny
  cpy #SCUMM_MAX_SLOTS
  bcc _startEncd.findSlot
  rts                              ; no free slot

_startEncd.found:
  ; X = slot byte offset
  ; Set up SCUMM.scratch2 = cachePtr, SCUMM.scratch = cacheLen
  lda.w SCUMM.roomEncdPtr
  sta.w SCUMM.scratch2
  lda.w SCUMM.roomEncdLen
  sta.w SCUMM.scratch
  ; A = 0 (ENCD script number), Y = WHERE_ROOM
  lda #0
  ldy #SCUMM_WHERE_ROOM
  jmp _startScript.initSlot


;-------------------------------------------------------------------
; _scummvm.findSlotByNumber -- find slot running script N
; Input: A = script number
; Output: X = slot byte offset, carry set if found
;-------------------------------------------------------------------
_scummvm.findSlotByNumber:
  sta.w SCUMM.scratch
  ldx #0
  ldy #0
_findSlot.loop:
  lda.w SCUMM.slots.status,x
  and #$00FF
  cmp #SCUMM_SLOT_DEAD
  beq _findSlot.next
  lda.w SCUMM.slots.number,x
  and #$00FF
  cmp.w SCUMM.scratch
  beq _findSlot.found
_findSlot.next:
  txa
  clc
  adc #_sizeof_scummSlot
  tax
  iny
  cpy #SCUMM_MAX_SLOTS
  bcc _findSlot.loop
  clc
  rts
_findSlot.found:
  sec
  rts


;===================================================================
; 256-Entry Dispatch Table
;===================================================================
.include "src/object/scummvm/scummvm_dispatch_table.inc"


;===================================================================
; Opcode Handlers
;
; Register conventions:
;   Y = SCUMM PC (bytecode offset). Advance as bytes consumed.
;   A = scratch. SCUMM.currentOpcode has original byte.
;   X = scratch (not preserved).
;   [tmp] = 24-bit bytecode ptr. Do NOT clobber.
;   Carry on return: clear=continue, set=yield.
;   All handlers assume rep #$31 (16-bit A/X/Y).
;===================================================================

;-------------------------------------------------------------------
; op_stub -- unimplemented opcode, fatal error
;-------------------------------------------------------------------
op_stub:
  ldx.w SCUMM.currentSlotPtr
  tya
  sta.w SCUMM.slots.pc,x
  TRIGGER_ERROR E_ScummVmBadOpcode


;-------------------------------------------------------------------
; Tier 1 -- Boot critical opcodes
;-------------------------------------------------------------------

; stopObjectCode ($00, $A0)
op_stopObjectCode:
  ldx.w SCUMM.currentSlotPtr
  sep #$20
  lda #SCUMM_SLOT_DEAD
  sta.w SCUMM.slots.status,x
  rep #$20
  sec
  rts

; breakHere ($80)
op_breakHere:
  sec
  rts

; jumpRelative ($18) -- 2-byte signed relative offset
op_jumpRelative:
  jsr _scummvm.fetchWord    ; A = signed relative offset, Y past word
  sta.w SCUMM.scratch
  tya
  clc
  adc.w SCUMM.scratch       ; Y' = Y + offset
  tay
  clc
  rts

; move ($1A, $9A)
op_move:
  jsr _scummvm.getResultPos
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord
  jsr _scummvm.writeVariable
  clc
  rts

; startScript ($0A, $2A, $4A, $6A, $8A, $AA, $CA, $EA)
op_startScript:
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte
  pha
  jsr _scummvm.skipWordVararg
  pla
  phy                           ; save SCUMM PC (startScriptSlot clobbers Y)
  jsr _scummvm.startScriptSlot
  ply                           ; restore SCUMM PC
  clc
  rts

; stopScript ($62, $E2)
op_stopScript:
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte
  and #$00FF
  beq _stopScript.self
  phy                           ; save SCUMM PC (findSlotByNumber clobbers Y)
  jsr _scummvm.findSlotByNumber
  ply                           ; restore SCUMM PC
  bcc _stopScript.done
  sep #$20
  lda #SCUMM_SLOT_DEAD
  sta.w SCUMM.slots.status,x
  rep #$20
_stopScript.done:
  clc
  rts
_stopScript.self:
  ldx.w SCUMM.currentSlotPtr
  sep #$20
  lda #SCUMM_SLOT_DEAD
  sta.w SCUMM.slots.status,x
  rep #$20
  sec
  rts


;-------------------------------------------------------------------
; Tier 2 -- Conditional branches
;-------------------------------------------------------------------

; SCUMM v5 conditional convention (from ScummVM source):
;   if (condition TRUE) jumpRelative();      // Y += signed offset
;   else ignoreScriptWord();                 // skip 2 bytes (already consumed)
; Jump targets are signed relative offsets from the byte AFTER the target word.

; Helper: apply relative jump from SCUMM.scratch2 to Y
_scummvm.takeRelJump:
  tya
  clc
  adc.w SCUMM.scratch2
  tay
  rts

; isEqual ($48, $C8) -- if var == value, jump
op_isEqual:
  jsr _scummvm.getResultPos
  lda.w SCUMM.resultVar
  jsr _scummvm.readVariable
  pha
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord
  sta.w SCUMM.scratch
  jsr _scummvm.fetchWord
  sta.w SCUMM.scratch2
  pla
  cmp.w SCUMM.scratch
  bne +
    jsr _scummvm.takeRelJump
+
  clc
  rts

; isNotEqual ($08, $88) -- if var != value, jump
op_isNotEqual:
  jsr _scummvm.getResultPos
  lda.w SCUMM.resultVar
  jsr _scummvm.readVariable
  pha
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord
  sta.w SCUMM.scratch
  jsr _scummvm.fetchWord
  sta.w SCUMM.scratch2
  pla
  cmp.w SCUMM.scratch
  beq +
    jsr _scummvm.takeRelJump
+
  clc
  rts

; notEqualZero ($A8) -- if var != 0, jump
op_notEqualZero:
  jsr _scummvm.fetchWord
  jsr _scummvm.readVariable
  pha
  jsr _scummvm.fetchWord
  sta.w SCUMM.scratch2
  pla
  cmp #0
  beq +
    jsr _scummvm.takeRelJump
+
  clc
  rts

; equalZero ($28) -- if var == 0, jump
op_equalZero:
  jsr _scummvm.fetchWord
  jsr _scummvm.readVariable
  pha
  jsr _scummvm.fetchWord
  sta.w SCUMM.scratch2
  pla
  cmp #0
  bne +
    jsr _scummvm.takeRelJump
+
  clc
  rts

; isGreater ($78, $F8) -- if var > value, jump
op_isGreater:
  jsr _scummvm.getResultPos
  lda.w SCUMM.resultVar
  jsr _scummvm.readVariable
  pha
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord
  sta.w SCUMM.scratch
  jsr _scummvm.fetchWord
  sta.w SCUMM.scratch2
  pla
  cmp.w SCUMM.scratch
  beq +                    ; equal -> not greater -> skip
  bcc +                    ; less -> not greater -> skip
    jsr _scummvm.takeRelJump  ; greater -> jump
+
  clc
  rts

; isLess ($44, $C4) -- if var < value, jump
op_isLess:
  jsr _scummvm.getResultPos
  lda.w SCUMM.resultVar
  jsr _scummvm.readVariable
  pha
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord
  sta.w SCUMM.scratch
  jsr _scummvm.fetchWord
  sta.w SCUMM.scratch2
  pla
  cmp.w SCUMM.scratch
  bcs +                    ; carry set -> >= -> skip
    jsr _scummvm.takeRelJump  ; carry clear -> less -> jump
+
  clc
  rts

; isLessEqual ($38, $B8) -- if var <= value, jump
op_isLessEqual:
  jsr _scummvm.getResultPos
  lda.w SCUMM.resultVar
  jsr _scummvm.readVariable
  pha
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord
  sta.w SCUMM.scratch
  jsr _scummvm.fetchWord
  sta.w SCUMM.scratch2
  pla
  cmp.w SCUMM.scratch
  beq _isLessEqual.jump    ; equal -> <= -> jump
  bcs +                    ; greater -> skip
_isLessEqual.jump:
    jsr _scummvm.takeRelJump
+
  clc
  rts

; isGreaterEqual ($04, $84) -- if var >= value, jump
op_isGreaterEqual:
  jsr _scummvm.getResultPos
  lda.w SCUMM.resultVar
  jsr _scummvm.readVariable
  pha
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord
  sta.w SCUMM.scratch
  jsr _scummvm.fetchWord
  sta.w SCUMM.scratch2
  pla
  cmp.w SCUMM.scratch
  bcc +                    ; carry clear -> less -> skip
    jsr _scummvm.takeRelJump  ; carry set -> >= -> jump
+
  clc
  rts


;-------------------------------------------------------------------
; Tier 3 -- Arithmetic opcodes
;-------------------------------------------------------------------

; add ($5A, $DA)
op_add:
  jsr _scummvm.getResultPos
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord
  pha
  lda.w SCUMM.resultVar
  jsr _scummvm.readVariable
  clc
  adc 1,s
  sta.w SCUMM.scratch
  pla
  lda.w SCUMM.scratch
  jsr _scummvm.writeVariable
  clc
  rts

; subtract ($3A, $BA)
op_subtract:
  jsr _scummvm.getResultPos
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord
  pha
  lda.w SCUMM.resultVar
  jsr _scummvm.readVariable
  sec
  sbc 1,s
  sta.w SCUMM.scratch
  pla
  lda.w SCUMM.scratch
  jsr _scummvm.writeVariable
  clc
  rts

; increment ($46)
op_increment:
  jsr _scummvm.getResultPos
  lda.w SCUMM.resultVar
  jsr _scummvm.readVariable
  inc a
  jsr _scummvm.writeVariable
  clc
  rts

; decrement ($C6)
op_decrement:
  jsr _scummvm.getResultPos
  lda.w SCUMM.resultVar
  jsr _scummvm.readVariable
  dec a
  jsr _scummvm.writeVariable
  clc
  rts


;-------------------------------------------------------------------
; Misc opcodes for boot path
;-------------------------------------------------------------------

; setVarRange ($26, $A6)
op_setVarRange:
  jsr _scummvm.getResultPos
  jsr _scummvm.fetchByte
  sta.w SCUMM.scratch

  lda.w SCUMM.currentOpcode
  and #SCUMM_FLAG_BIT5
  bne _setVarRange.wordMode

_setVarRange.byteMode:
  lda.w SCUMM.scratch
  beq _setVarRange.done
_setVarRange.byteLoop:
  jsr _scummvm.fetchByte
  jsr _scummvm.writeVariable
  lda.w SCUMM.resultVar
  inc a
  sta.w SCUMM.resultVar
  lda.w SCUMM.scratch
  dec a
  sta.w SCUMM.scratch
  bne _setVarRange.byteLoop
  bra _setVarRange.done

_setVarRange.wordMode:
  lda.w SCUMM.scratch
  beq _setVarRange.done
_setVarRange.wordLoop:
  jsr _scummvm.fetchWord
  jsr _scummvm.writeVariable
  lda.w SCUMM.resultVar
  inc a
  sta.w SCUMM.resultVar
  lda.w SCUMM.scratch
  dec a
  sta.w SCUMM.scratch
  bne _setVarRange.wordLoop

_setVarRange.done:
  clc
  rts

; delay ($2E) -- 3-byte LE delay value
op_delay:
  jsr _scummvm.fetchByte
  sta.w SCUMM.scratch
  jsr _scummvm.fetchByte
  xba
  ora.w SCUMM.scratch
  ldx.w SCUMM.currentSlotPtr
  sta.w SCUMM.slots.delay,x
  jsr _scummvm.fetchByte
  sec
  rts

; delayVariable ($2B)
op_delayVariable:
  jsr _scummvm.fetchWord
  jsr _scummvm.readVariable
  ldx.w SCUMM.currentSlotPtr
  sta.w SCUMM.slots.delay,x
  sec
  rts

; dummy ($A7)
op_dummy:
  clc
  rts

; cutscene ($40) -- read arg list, increment nest level
op_cutscene:
_cutscene.skipArgs:
  jsr _scummvm.fetchByte
  cmp #$00FF
  bne _cutscene.skipArgs
  lda.w SCUMM.cutsceneNest
  inc a
  sta.w SCUMM.cutsceneNest
  ldx.w SCUMM.currentSlotPtr
  sep #$20
  lda.w SCUMM.slots.cutsceneOverride,x
  inc a
  sta.w SCUMM.slots.cutsceneOverride,x
  rep #$20
  clc
  rts

; endCutscene ($C0)
op_endCutscene:
  lda.w SCUMM.cutsceneNest
  beq +
  dec a
  sta.w SCUMM.cutsceneNest
+
  ldx.w SCUMM.currentSlotPtr
  lda.w SCUMM.slots.cutsceneOverride,x
  and #$00FF
  beq +
  dec a
  sep #$20
  sta.w SCUMM.slots.cutsceneOverride,x
  rep #$20
+
  clc
  rts

; override ($58)
op_override:
  jsr _scummvm.fetchWord
  clc
  rts

; freezeScripts ($60, $E0)
op_freezeScripts:
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte
  sta.w SCUMM.scratch
  ldx #0
  ldy #0
_freeze.loop:
  cpx.w SCUMM.currentSlotPtr
  beq _freeze.next
  lda.w SCUMM.slots.status,x
  and #$00FF
  cmp #SCUMM_SLOT_RUNNING
  bne _freeze.next

  lda.w SCUMM.scratch
  beq _freeze.unfreeze
  lda.w SCUMM.slots.freezeCount,x
  and #$00FF
  inc a
  sep #$20
  sta.w SCUMM.slots.freezeCount,x
  rep #$20
  bra _freeze.next
_freeze.unfreeze:
  lda.w SCUMM.slots.freezeCount,x
  and #$00FF
  beq _freeze.next
  dec a
  sep #$20
  sta.w SCUMM.slots.freezeCount,x
  rep #$20

_freeze.next:
  txa
  clc
  adc #_sizeof_scummSlot
  tax
  iny
  cpy #SCUMM_MAX_SLOTS
  bcc _freeze.loop
  clc
  rts

; stopObjectScript ($6E, $EE)
op_stopObjectScript:
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord
  clc
  rts

; isScriptRunning ($68, $E8)
op_isScriptRunning:
  jsr _scummvm.getResultPos
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte
  phy                           ; save SCUMM PC (findSlotByNumber clobbers Y)
  jsr _scummvm.findSlotByNumber
  ply                           ; restore SCUMM PC
  bcs +
    lda #0
    bra _isScriptRunning.write
+
    lda #1
_isScriptRunning.write:
  jsr _scummvm.writeVariable
  clc
  rts

; debug ($6B, $EB)
op_debug:
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord
  clc
  rts

; and ($17, $97)
op_and:
  jsr _scummvm.getResultPos
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord
  pha
  lda.w SCUMM.resultVar
  jsr _scummvm.readVariable
  and 1,s
  sta.w SCUMM.scratch
  pla
  lda.w SCUMM.scratch
  jsr _scummvm.writeVariable
  clc
  rts

; or ($57, $D7)
op_or:
  jsr _scummvm.getResultPos
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord
  pha
  lda.w SCUMM.resultVar
  jsr _scummvm.readVariable
  ora 1,s
  sta.w SCUMM.scratch
  pla
  lda.w SCUMM.scratch
  jsr _scummvm.writeVariable
  clc
  rts

; expression ($AC) -- stack-based expression evaluator
op_expression:
  jsr _scummvm.getResultPos
_expression.loop:
  jsr _scummvm.fetchByte
  cmp #$FF
  beq _expression.end
  sta.w SCUMM.scratch

  lda.w SCUMM.scratch
  and #$001F
  cmp #$06
  beq _expression.number
  cmp #$01
  beq _expression.add
  cmp #$02
  beq _expression.sub
  cmp #$03
  beq _expression.mul
  cmp #$04
  beq _expression.div
  cmp #$05
  beq _expression.end
  bra _expression.loop

_expression.number:
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord
  pha
  bra _expression.loop

_expression.add:
  pla
  sta.w SCUMM.scratch2
  pla
  clc
  adc.w SCUMM.scratch2
  pha
  bra _expression.loop

_expression.sub:
  pla
  sta.w SCUMM.scratch2
  pla
  sec
  sbc.w SCUMM.scratch2
  pha
  bra _expression.loop

_expression.mul:
  ; Placeholder: pop both, push product (just do 0 for now)
  pla
  sta.w SCUMM.scratch2
  pla
  pha
  bra _expression.loop

_expression.div:
  pla
  sta.w SCUMM.scratch2
  pla
  ldx.w SCUMM.scratch2
  beq _expression.divZero
  pha
  bra _expression.loop
_expression.divZero:
  lda #0
  pha
  bra _expression.loop

_expression.end:
  pla
  jsr _scummvm.writeVariable
  clc
  rts

; chainScript ($42, $C2)
op_chainScript:
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte
  pha
  jsr _scummvm.skipWordVararg
  ldx.w SCUMM.currentSlotPtr
  sep #$20
  lda #SCUMM_SLOT_DEAD
  sta.w SCUMM.slots.status,x
  rep #$20
  pla
  phy                           ; save Y (startScriptSlot clobbers Y)
  jsr _scummvm.startScriptSlot
  ply                           ; restore Y
  sec
  rts

; cursorCommand ($2C) -- subop-based, consume parameters
op_cursorCommand:
  jsr _scummvm.fetchWord
  and #$001F
  cmp #$0A
  beq _cursor.twoArgs
  cmp #$0B
  beq _cursor.twoArgs
  cmp #$0C
  beq _cursor.oneArg
  cmp #$0D
  beq _cursor.oneArg
  cmp #$0E
  beq _cursor.argList
  ; Default: no args
  clc
  rts
_cursor.twoArgs:
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte
  lda #SCUMM_FLAG_BIT6
  jsr _scummvm.getVarOrDirectByte
  clc
  rts
_cursor.oneArg:
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte
  clc
  rts
_cursor.argList:
  jsr _scummvm.fetchByte
  cmp #$00FF
  bne _cursor.argList
  clc
  rts

; systemOps ($98)
op_systemOps:
  jsr _scummvm.fetchByte
  clc
  rts

;-------------------------------------------------------------------
; Actor / resource stubs -- consume params correctly, no-op for now
;-------------------------------------------------------------------

; resourceRoutines ($0C, $8C) -- resource preload/cache management
; Sub-opcode byte controls flag bits, not the main opcode.
; All are no-ops for MSU-1 on-demand loading; just skip params.
op_resourceRoutines:
  jsr _scummvm.fetchByte     ; read sub-opcode byte
  sta.w SCUMM.scratch        ; save full sub-opcode

  and #$003F                 ; mask to get key
  cmp #$11
  beq _resRoutines.done      ; clearHeap: no params
  cmp #$14
  beq _resRoutines.flObject  ; loadFlObject: p8 + p16

  ; Default: one p8 parameter (flag = bit 7 of sub-opcode)
  lda.w SCUMM.scratch
  and #$0080
  beq _resRoutines.lit
  jsr _scummvm.fetchWord     ; var ref: 2 bytes
  bra _resRoutines.done
_resRoutines.lit:
  jsr _scummvm.fetchByte     ; literal: 1 byte
  bra _resRoutines.done

_resRoutines.flObject:
  ; loadFlObject: p8[7] room + p16 object
  lda.w SCUMM.scratch
  and #$0080
  beq _resRoutines.flLit
  jsr _scummvm.fetchWord     ; room as var ref
  bra +
_resRoutines.flLit:
  jsr _scummvm.fetchByte     ; room as literal
+
  jsr _scummvm.fetchWord     ; object ID (always p16)

_resRoutines.done:
  clc
  rts

; putActorInRoom ($2D, $6D, $AD, $ED)
; Params: p8[7]=actor, p8[6]=room
; No-op for now (actors not implemented)
op_putActorInRoom:
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte    ; actor
  lda #SCUMM_FLAG_BIT6
  jsr _scummvm.getVarOrDirectByte    ; room
  clc
  rts

; getActorMoving ($56, $D6)
; Params: result + p8[7]=actor
; Always returns 0 (not moving) since actors aren't implemented yet
op_getActorMoving:
  jsr _scummvm.getResultPos
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte
  lda #0
  jsr _scummvm.writeVariable
  clc
  rts

; getObjectState ($0F, $8F) -- result + p16, return 0
op_getObjectState:
  jsr _scummvm.getResultPos
  jsr _scummvm.fetchWord             ; object ID (always p16)
  lda #0
  jsr _scummvm.writeVariable
  clc
  rts

; getObjectOwner ($10, $90) -- result + p16, return 0
op_getObjectOwner:
  jsr _scummvm.getResultPos
  jsr _scummvm.fetchWord             ; object ID
  lda #0
  jsr _scummvm.writeVariable
  clc
  rts

; setState ($07, $47, $87, $C7) -- p16 + p8[7], no-op
op_setState:
  jsr _scummvm.fetchWord             ; object ID
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte    ; state
  clc
  rts

; putActor ($01, $21, $41, $61, $81, $A1, $C1, $E1) -- p8[7] + p16 + p16, no-op
op_putActor:
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte    ; actor
  jsr _scummvm.fetchWord             ; x
  jsr _scummvm.fetchWord             ; y
  clc
  rts

; getActorRoom ($03, $83) -- result + p8[7], return 0
op_getActorRoom:
  jsr _scummvm.getResultPos
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte    ; actor
  lda #0
  jsr _scummvm.writeVariable
  clc
  rts

; panCameraTo ($12, $92) -- p16[7] (always 2 bytes), no-op
op_panCameraTo:
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord
  clc
  rts

; setCameraAt ($32, $B2) -- p16[7] (always 2 bytes), no-op
op_setCameraAt:
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord
  clc
  rts

; lights ($70, $F0) -- p8[7] + byte + byte, no-op
op_lights:
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte    ; luminance
  jsr _scummvm.fetchByte             ; color1
  jsr _scummvm.fetchByte             ; color2
  clc
  rts

; loadRoom ($72, $F2) -- p8[7], no-op for now
op_loadRoom:
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte    ; room number
  and #$00FF
  sta.w SCUMM.newRoom                ; request room change (processed in play loop)
  clc
  rts

; setOwnerOf ($29, $69, $A9, $E9) -- p16[7] + p8[6], no-op
op_setOwnerOf:
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord    ; object
  lda #SCUMM_FLAG_BIT6
  jsr _scummvm.getVarOrDirectByte    ; owner
  clc
  rts

; getActorX ($43, $C3) -- result + p16[7], return 0
op_getActorX:
  jsr _scummvm.getResultPos
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord    ; actor
  lda #0
  jsr _scummvm.writeVariable
  clc
  rts

; getActorY ($23, $A3) -- result + p16[7], return 0
op_getActorY:
  jsr _scummvm.getResultPos
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectWord    ; actor
  lda #0
  jsr _scummvm.writeVariable
  clc
  rts

; actorOps ($13, $93) -- p8[7] + sub-opcode sequence terminated by $FF
; Complex: skip sub-opcodes based on their parameter sizes
op_actorOps:
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte    ; actor
_actorOps.subLoop:
  jsr _scummvm.fetchByte
  cmp #$FF
  bne _actorOps.dispatch
  jmp _actorOps.done
_actorOps.dispatch:
  sta.w SCUMM.scratch
  and #$001F                         ; sub-opcode key
  ; No-param sub-ops: $08, $0A, $12, $14, $15
  cmp #$08
  beq _actorOps.sub_none
  cmp #$0A
  beq _actorOps.sub_none
  cmp #$12
  beq _actorOps.sub_none
  cmp #$14
  beq _actorOps.sub_none
  cmp #$15
  beq _actorOps.sub_none
  ; p16 sub-op: $09
  cmp #$09
  beq _actorOps.sub_p16
  ; String sub-op: $0D
  cmp #$0D
  beq _actorOps.sub_string
  ; 2-param sub-ops (p8[7]+p8[6]): $02, $05, $07, $0B, $11, $17
  cmp #$02
  beq _actorOps.sub_2param
  cmp #$05
  beq _actorOps.sub_2param
  cmp #$07
  beq _actorOps.sub_2param
  cmp #$0B
  beq _actorOps.sub_2param
  cmp #$11
  beq _actorOps.sub_2param
  cmp #$17
  beq _actorOps.sub_2param
  ; Everything else: 1-param p8[7]
  ; ($00, $01, $03, $04, $06, $0C, $0E, $10, $13, $16, + unknown)
  ; Fall through to sub_1param

_actorOps.sub_1param:
  lda.w SCUMM.scratch
  and #$0080
  beq +
  jsr _scummvm.fetchWord
  jmp _actorOps.subLoop
+
  jsr _scummvm.fetchByte
  jmp _actorOps.subLoop

_actorOps.sub_none:
  jmp _actorOps.subLoop

_actorOps.sub_2param:
  lda.w SCUMM.scratch
  and #$0080
  beq +
  jsr _scummvm.fetchWord
  bra ++
+
  jsr _scummvm.fetchByte
++
  lda.w SCUMM.scratch
  and #$0040
  beq +
  jsr _scummvm.fetchWord
  jmp _actorOps.subLoop
+
  jsr _scummvm.fetchByte
  jmp _actorOps.subLoop

_actorOps.sub_p16:
  jsr _scummvm.fetchWord
  jmp _actorOps.subLoop

_actorOps.sub_string:
  jsr _scummvm.fetchByte
  cmp #0
  bne _actorOps.sub_string
  jmp _actorOps.subLoop

_actorOps.done:
  clc
  rts

;===================================================================
; Batch stub opcodes — consume params correctly, no-op behavior
; These allow ENCD and LSCR scripts to run without crashing.
;===================================================================

;-------------------------------------------------------------------
; Sound stubs
;-------------------------------------------------------------------

; stopSound ($3C, $BC) -- p8[7], no-op
op_stopSound:
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte
  clc
  rts

; startSound ($1C, $9C) -- p8[7], no-op
op_startSound:
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte
  clc
  rts

; startMusic ($02, $82) -- p8[7], no-op
op_startMusic:
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte
  clc
  rts

; stopMusic ($20) -- no params, no-op
op_stopMusic:
  clc
  rts

; isSoundRunning ($7C, $FC) -- result + p8[7], always return 0
op_isSoundRunning:
  jsr _scummvm.getResultPos
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte
  lda #0
  jsr _scummvm.writeVariable
  clc
  rts

; soundKludge ($4C, $CC) -- vararg list, skip all
op_soundKludge:
-
  jsr _scummvm.fetchByte
  cmp #$00FF
  beq +
  jsr _scummvm.fetchWord
  bra -
+
  clc
  rts


;-------------------------------------------------------------------
; setClass ($5D, $DD) -- p16 object + vararg class list, no-op
;-------------------------------------------------------------------
op_setClass:
  jsr _scummvm.fetchWord             ; object ID (always p16)
  ; Vararg: {aux_byte, word_value}* terminated by $FF
-
  jsr _scummvm.fetchByte
  cmp #$00FF
  beq +
  jsr _scummvm.fetchWord             ; class word arg
  bra -
+
  clc
  rts


;-------------------------------------------------------------------
; matrixOps ($30, $B0) -- sub-opcode with box params, no-op
;-------------------------------------------------------------------
op_matrixOps:
  jsr _scummvm.fetchByte             ; sub-opcode byte
  sta.w SCUMM.scratch
  and #$001F                         ; key
  cmp #$04
  beq _matrixOps.done                ; createBoxMatrix: no params
  cmp #$01
  beq _matrixOps.twoP8
  cmp #$02
  beq _matrixOps.twoP8
  cmp #$03
  beq _matrixOps.twoP8
  ; Unknown sub-op: no params
  bra _matrixOps.done

_matrixOps.twoP8:
  ; box: p8[bit7 of sub], val: p8[bit6 of sub]
  lda.w SCUMM.scratch
  and #$0080
  beq +
  jsr _scummvm.fetchWord             ; var ref
  bra ++
+
  jsr _scummvm.fetchByte             ; literal
++
  lda.w SCUMM.scratch
  and #$0040
  beq +
  jsr _scummvm.fetchWord
  bra _matrixOps.done
+
  jsr _scummvm.fetchByte

_matrixOps.done:
  clc
  rts


;-------------------------------------------------------------------
; roomOps ($33, $B3) -- sub-opcode with variable params, no-op
; Only sub-opcodes actually used by MI1 need full param decode.
;-------------------------------------------------------------------
op_roomOps:
  jsr _scummvm.fetchByte             ; sub-opcode byte
  sta.w SCUMM.scratch
  and #$001F

  cmp #$01
  beq _roomOps.scroll                ; scroll: 2x p16
  cmp #$03
  beq _roomOps.setScreen             ; setScreen: 2x p16
  cmp #$04
  beq _roomOps.palColor              ; setPalColor: 3x p16 + p8[7]
  cmp #$05
  beq _roomOps.shake                 ; shake: 1x p8[7]
  cmp #$07
  beq _roomOps.scale                 ; roomScale v5: complex
  cmp #$08
  bne +
  jmp _roomOps.scaleSimple           ; roomScale simple: 3x p8
+
  cmp #$0A
  bne +
  jmp _roomOps.scroll                ; roomScroll (alias): 2x p16
+
  cmp #$0B
  bne +
  jmp _roomOps.intensity             ; rgbRoomIntensity: 3x p16 + aux + 2x p8
+
  cmp #$0C
  bne +
  jmp _roomOps.intensity             ; roomShadow (same format)
+
  ; Default: no params
  clc
  rts

_roomOps.scroll:
  ; minX/maxX or b/h: 2x p16
  jsr _scummvm.fetchWord
  jsr _scummvm.fetchWord
  clc
  rts

_roomOps.setScreen:
  jsr _scummvm.fetchWord
  jsr _scummvm.fetchWord
  clc
  rts

_roomOps.palColor:
  ; r, g, b: 3x p16, index: p8[bit7 of sub]
  jsr _scummvm.fetchWord
  jsr _scummvm.fetchWord
  jsr _scummvm.fetchWord
  lda.w SCUMM.scratch
  and #$0080
  beq +
  jsr _scummvm.fetchWord
  clc
  rts
+
  jsr _scummvm.fetchByte
  clc
  rts

_roomOps.shake:
  lda.w SCUMM.scratch
  and #$0080
  beq +
  jsr _scummvm.fetchWord
  clc
  rts
+
  jsr _scummvm.fetchByte
  clc
  rts

_roomOps.scale:
  ; scale1: p8[7], y1: p8[6]
  lda.w SCUMM.scratch
  and #$0080
  beq +
  jsr _scummvm.fetchWord
  bra ++
+
  jsr _scummvm.fetchByte
++
  lda.w SCUMM.scratch
  and #$0040
  beq +
  jsr _scummvm.fetchWord
  bra ++
+
  jsr _scummvm.fetchByte
++
  ; aux1 byte, then p8[7], p8[6]
  jsr _scummvm.fetchByte
  sta.w SCUMM.scratch
  lda.w SCUMM.scratch
  and #$0080
  beq +
  jsr _scummvm.fetchWord
  bra ++
+
  jsr _scummvm.fetchByte
++
  lda.w SCUMM.scratch
  and #$0040
  beq +
  jsr _scummvm.fetchWord
  bra ++
+
  jsr _scummvm.fetchByte
++
  ; aux2 byte, then p8[7]
  jsr _scummvm.fetchByte
  sta.w SCUMM.scratch
  lda.w SCUMM.scratch
  and #$0080
  beq +
  jsr _scummvm.fetchWord
  clc
  rts
+
  jsr _scummvm.fetchByte
  clc
  rts

_roomOps.scaleSimple:
  ; scale: p8[7], startcolor: p8[6], endcolor: p8[5]
  lda.w SCUMM.scratch
  and #$0080
  beq +
  jsr _scummvm.fetchWord
  bra ++
+
  jsr _scummvm.fetchByte
++
  lda.w SCUMM.scratch
  and #$0040
  beq +
  jsr _scummvm.fetchWord
  bra ++
+
  jsr _scummvm.fetchByte
++
  lda.w SCUMM.scratch
  and #$0020
  beq +
  jsr _scummvm.fetchWord
  clc
  rts
+
  jsr _scummvm.fetchByte
  clc
  rts

_roomOps.intensity:
  ; r, g, b: 3x p16
  jsr _scummvm.fetchWord
  jsr _scummvm.fetchWord
  jsr _scummvm.fetchWord
  ; aux byte, then startcolor: p8[7], endcolor: p8[6]
  jsr _scummvm.fetchByte
  sta.w SCUMM.scratch
  lda.w SCUMM.scratch
  and #$0080
  beq +
  jsr _scummvm.fetchWord
  bra ++
+
  jsr _scummvm.fetchByte
++
  lda.w SCUMM.scratch
  and #$0040
  beq +
  jsr _scummvm.fetchWord
  clc
  rts
+
  jsr _scummvm.fetchByte
  clc
  rts


;-------------------------------------------------------------------
; loadRoomWithEgo ($24, $64, $A4, $E4) -- p16 + p8[6] + word + word
; Sets newRoom and yields (no-op for actor placement)
;-------------------------------------------------------------------
op_loadRoomWithEgo:
  jsr _scummvm.fetchWord             ; object (always p16)
  lda #SCUMM_FLAG_BIT6
  jsr _scummvm.getVarOrDirectByte    ; room number
  and #$00FF
  sta.w SCUMM.newRoom                ; request room change
  jsr _scummvm.fetchWord             ; x (consumed, ignored)
  jsr _scummvm.fetchWord             ; y (consumed, ignored)
  clc
  rts


;-------------------------------------------------------------------
; Actor stubs — consume params, no-op
;-------------------------------------------------------------------

; animateActor ($11, $51, $91, $D1) -- p8[7] + p8[6], no-op
op_animateActor:
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte    ; actor
  lda #SCUMM_FLAG_BIT6
  jsr _scummvm.getVarOrDirectByte    ; frame
  clc
  rts

; faceActor ($09, $49, $89, $C9) -- p8[7] + p16[6], no-op
op_faceActor:
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte    ; actor
  lda #SCUMM_FLAG_BIT6
  jsr _scummvm.getVarOrDirectWord    ; direction (p16)
  clc
  rts

; walkActorToActor ($0D, $4D, $8D, $CD) -- p8[7] + p8[6] + byte, no-op
op_walkActorToActor:
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte    ; actor
  lda #SCUMM_FLAG_BIT6
  jsr _scummvm.getVarOrDirectByte    ; target actor
  jsr _scummvm.fetchByte             ; options byte
  clc
  rts

; walkActorTo ($1E, $3E, $5E, $7E, $9E, $BE, $DE, $FE) -- p8[7] + p16[6] + p16[5], no-op
op_walkActorTo:
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte    ; actor
  lda #SCUMM_FLAG_BIT6
  jsr _scummvm.getVarOrDirectWord    ; x
  lda #SCUMM_FLAG_BIT5
  jsr _scummvm.getVarOrDirectWord    ; y
  clc
  rts

; isActorInBox ($1F, $5F, $9F, $DF) -- p8[7] + p8[6] + jump, return false
op_isActorInBox:
  lda #SCUMM_FLAG_BIT7
  jsr _scummvm.getVarOrDirectByte    ; actor
  lda #SCUMM_FLAG_BIT6
  jsr _scummvm.getVarOrDirectByte    ; box
  jsr _scummvm.fetchWord             ; jump offset (skip — always false)
  clc
  rts


;-------------------------------------------------------------------
; wait ($AE) -- sub-opcode with conditional waits, stub as no-op
; Each wait variant would normally yield until condition met.
; Stub: consume params and continue (don't actually wait).
;-------------------------------------------------------------------
op_wait:
  jsr _scummvm.fetchByte             ; sub-opcode byte
  sta.w SCUMM.scratch
  and #$001F

  cmp #$01
  beq _wait.forActor                 ; waitForActor: p8[7] + word

  ; waitForMessage ($02), waitForCamera ($03), waitForSentence ($04):
  ; No additional params. Stub: just continue.
  clc
  rts

_wait.forActor:
  lda.w SCUMM.scratch
  and #$0080
  beq +
  jsr _scummvm.fetchWord             ; actor as var ref
  bra ++
+
  jsr _scummvm.fetchByte             ; actor as literal
++
  jsr _scummvm.fetchWord             ; jump offset (consumed, ignored)
  clc
  rts


;-------------------------------------------------------------------
; drawObject ($05, $25, $45, $65, $85, $A5, $C5, $E5)
; p16 object + sub-opcode + sub params, no-op
;-------------------------------------------------------------------
op_drawObject:
  jsr _scummvm.fetchWord             ; object ID (always p16)
  jsr _scummvm.fetchByte             ; sub-opcode byte
  and #$001F
  cmp #$01
  beq _drawObj.setXY
  cmp #$02
  beq _drawObj.setState
  ; $1F or default: no extra params
  clc
  rts

_drawObj.setXY:
  jsr _scummvm.fetchWord             ; xpos
  jsr _scummvm.fetchWord             ; ypos
  clc
  rts

_drawObj.setState:
  jsr _scummvm.fetchWord             ; state
  clc
  rts


  CLASS ScummVM

.ends
